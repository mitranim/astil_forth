{
  "selector": "source.astil_forth",
  "cmd": ["astil", "$file"],

  // Uncomment if you like sticky error messages.
  // "file_regex": "position:[\t ]+(...*?):(\\d+):(\\d+)",

  "variants": [
    {
      "name": "lang.af",
      "cmd": ["astil", "lang.af", "$file"],
    },
    {
      "name": "trace",
      "cmd": ["astil", "--trace=true", "$file"],
    },
    {
      "name": "stack-cc",
      "cmd": ["astil_s", "$file"],
    },
  ]
}
