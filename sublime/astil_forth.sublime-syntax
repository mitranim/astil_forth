%YAML 1.2
---
version: 2
scope: source.astil_forth
file_extensions: [af, f]

variables:
  eol: (?:\n|$)
  comment_line_begin: (?:\\+)
  comment_block_begin: \(
  comment_block_end: \)
  md_heading: (?:\s*((#+)\s+.*?)(?={{eol}}))
  delim: \(\)\[\]\{\}
  num_begin: '{{word_begin}}'
  num_end: '{{word_end}}'
  int_bin: '[0-1][0-1_]*'
  int_oct: '[0-7][0-7_]*'
  int_dec: '[0-9][0-9_]*'
  int_hex: '[0-9a-f][0-9a-f_]*'
  exponent: 'e[+-]?'
  mod: \# # Conventional modifier prefix for custom control words.
  tick: \'
  word_begin: '(?<=^|\s)'
  word_end: '(?=\s|$)'
  word: '(?:\S+)'
  param: '[^\s"{{tick}}]+'
  parens_param: '(?:[^\s()]+)'
  braces_param: '(?:[^\s{}]+)'
  brace_params_pre: (?:stack)
  declarator: '[^\s"{{tick}}{{delim}}]+'
  keyword: |-
    (?x:
      ret|recur|
      if|ifz|then|else|elif|elifz|switch|case|do|end|
      loop|for|while|leave|cont|
      throw|throwf|throw[_]{{word}}|{{word}}[_]throw|
      try|try[_]{{word}}|{{word}}[_]try|
      assert|abort|unreachable|fatal|quit|exit
    )

contexts:
  prototype:
    - include: comment-match

  main:
    - include: number-match
    - include: string-match
    - include: semi-match
    - include: colon-match
    - include: braces-params-match
    - include: declaring-word-match
    - include: parsing-word-match
    - include: delimited-word-match
    - include: modified-word-match
    - include: constant-match
    - include: keyword-match
    - include: any-word-match

  comment-match:
    - include: comment-line-match
    - include: comment-block-match
    - include: parens-params-match

  comment-line-match:
    - match: '{{word_begin}}{{comment_line_begin}}{{word_end}}'
      scope: punctuation.definition.comment.astil_forth
      push: [comment-line-pop, comment-heading-pop]

  comment-line-pop:
    - meta_scope: comment.line.astil_forth
    - meta_include_prototype: false
    - match: '{{eol}}'
      pop: 1

  # Also see `parens-params-match`.
  comment-block-match:
    - match: '{{word_begin}}{{comment_block_begin}}{{word_end}}(?={{eol}})'
      scope: punctuation.definition.comment.begin.astil_forth
      push: [comment-block-pop, comment-heading-pop]

  comment-block-pop:
    - meta_scope: comment.block.astil_forth
    - meta_include_prototype: false
    - match: '{{comment_block_end}}'
      scope: punctuation.definition.comment.end.astil_forth
      pop: 1
    - include: comment-heading

  comment-heading-pop:
    - match: '{{md_heading}}'
      captures:
        1: entity.name.section.astil_forth markup.heading.astil_forth
        2: punctuation.definition.heading.begin.astil_forth
      pop: 1
    - include: now-pop

  comment-heading:
    - match: '{{md_heading}}'
      captures:
        1: entity.name.section.astil_forth markup.heading.astil_forth
        2: punctuation.definition.heading.begin.astil_forth

  number-match:
    - include: number-bin
    - include: number-oct
    - include: number-dec
    - include: number-hex

  number-bin:
    - match: '{{num_begin}}(?i)([+-])?(0b){{int_bin}}(?:(\.){{int_bin}})?(?:({{exponent}}){{int_bin}})?{{num_end}}'
      scope: constant.numeric.binary.astil_forth
      captures:
        1: keyword.operator.arithmetic.astil_forth
        2: punctuation.definition.numeric.binary.astil_forth
        3: punctuation.separator.numeric.binary.astil_forth
        4: punctuation.separator.exponent.astil_forth

  number-oct:
    - match: '{{num_begin}}(?i)([+-])?(0o)(?:{{int_oct}}(?:(\.){{int_oct}})?)?(?:({{exponent}}){{int_oct}})?{{num_end}}'
      scope: constant.numeric.octal.astil_forth
      captures:
        1: keyword.operator.arithmetic.astil_forth
        2: punctuation.definition.numeric.octal.astil_forth
        3: punctuation.separator.numeric.octal.astil_forth
        4: punctuation.separator.exponent.astil_forth

  number-dec:
    - match: '{{num_begin}}(?i)([+-])?{{int_dec}}(?:(\.){{int_dec}})?(?:({{exponent}}){{int_dec}})?{{num_end}}'
      scope: constant.numeric.astil_forth
      captures:
        1: keyword.operator.arithmetic.astil_forth
        2: punctuation.separator.numeric.astil_forth
        3: punctuation.separator.exponent.astil_forth

  number-hex:
    - match: '{{num_begin}}(?i)([+-])?(0x)(?:{{int_hex}}(?:(\.){{int_hex}})?)?{{num_end}}'
      scope: constant.numeric.hexadecimal.astil_forth
      captures:
        1: keyword.operator.arithmetic.astil_forth
        2: punctuation.definition.numeric.hexadecimal.astil_forth
        3: punctuation.separator.numeric.hexadecimal.astil_forth

  string-match:
    - include: string-double-match
    - include: string-backtick-match

  # Scopes any construct like:
  #
  #   <beg>"   <string content>"<end>
  #   <beg>""  <string content>""<end>
  #   <beg>""" <string content>"""<end>
  string-double-match:
    - include: string-double-keyword-match
    - include: string-double-other-match

  string-double-keyword-match:
    - match: '{{word_begin}}({{mod}})([^\s"]*)("+){{word_end}}(?:\s)'
      captures:
        1: storage.modifier.astil_forth
        2: variable.function.astil_forth
        3: punctuation.definition.string.begin.astil_forth
      push: string-pop
    - match: '{{word_begin}}({{mod}})?({{keyword}})("+){{word_end}}(?:\s)'
      captures:
        1: storage.modifier.astil_forth
        2: variable.function.astil_forth
        3: punctuation.definition.string.begin.astil_forth
      push: string-pop

  string-double-other-match:
    - match: '{{word_begin}}({{mod}})?([^\s"]*)("+){{word_end}}(?:\s)'
      captures:
        1: storage.modifier.astil_forth
        2: variable.other.astil_forth
        3: punctuation.definition.string.begin.astil_forth
      push: string-pop

  # Scopes any construct like:
  #
  #   <beg>`   <string content>`<end>
  #   <beg>``  <string content>``<end>
  #   <beg>``` <string content>```<end>
  string-backtick-match:
    - match: '{{word_begin}}({{mod}})?([^\s`]*)(`+){{word_end}}(?:\s)'
      captures:
        1: storage.modifier.astil_forth
        2: variable.other.astil_forth
        3: punctuation.definition.string.begin.astil_forth
      push: string-pop

  string-pop:
    - meta_content_scope: string.quoted.astil_forth
    - meta_include_prototype: false
    - match: (\3)(\S*)
      captures:
        1: punctuation.definition.string.end.astil_forth
        2: variable.other.astil_forth
      pop: 1
    # - include: str-escape-match

  # str-escape-match:
  #   - match: \\(?:.|\n)
  #     scope: constant.character.escape.mox

  semi-match:
    - match: '{{word_begin}};{{word_end}}'
      scope: punctuation.terminator.astil_forth

  # Somewhat deprecated. TODO consider removing all "colon" stuff.
  colon-match:
    - match: '{{word_begin}}:+{{word_end}}'
      scope: keyword.declaration.function.astil_forth
      push: [colon-meta-pop, colon-body-pop, colon-params-pop, colon-name-pop]

  colon-name-pop:
    - meta_include_prototype: false
    - meta_scope: meta.declaration.astil_forth
    - match: '{{word_begin}}{{word}}{{word_end}}'
      scope: entity.name.function.astil_forth
      pop: 1
    # When typing new definitions, this prevents an opening colon
    # from "declaring" an unrelated word on a subsequent line.
    - match: '{{eol}}'
      pop: 3

  colon-params-pop:
    - meta_include_prototype: false
    - include: comment-line-match
    - include: params-match
    - include: nonblank-pop

  colon-body-pop:
    - match: '{{word_begin}};{{word_end}}'
      scope: punctuation.terminator.astil_forth
      pop: 1
    - include: main

  # The meta scope makes it so that `expand_selection {"to": "scope"}`
  # can select the entire colon definition. Unfortunately we're unable
  # to use this trick for `fun: name end` definitions because we can't
  # special-case all openers which are terminated by `end`.
  colon-meta-pop:
    - meta_scope: meta.colon.astil_forth
    - match: ''
      pop: 1

  params-match:
    - include: parens-params-match
    - include: braces-params-match

  parens-params-match:
    - match: '{{word_begin}}\({{word_end}}'
      scope: punctuation.section.parens.begin.astil_forth
      push: parens-params-inner-pop

  parens-params-inner-pop:
    - meta_scope: markup.raw.astil_forth meta.parens.astil_forth
    - include: parens-end-pop
    - include: parens-special-match
    - include: parens-param-match
    - include: nonblank-pop

  parens-special-match:
    - match: '{{word_begin}}{{word}}(:){{word_end}}'
      scope: storage.modifier.astil_forth
      captures:
        1: punctuation.separator.astil_forth
    - match: '{{word_begin}}(?:--|->){{word_end}}'
      scope: punctuation.separator.astil_forth

  parens-param-match:
    - match: '{{parens_param}}'
      scope: variable.other.astil_forth

  parens-end-pop:
    - match: \)
      scope: punctuation.section.parens.end.astil_forth
      pop: 1

  braces-params-match:
    - match: '{{word_begin}}(?:{{brace_params_pre}})?(\{){{word_end}}'
      captures:
        1: punctuation.section.braces.begin.astil_forth
      push: braces-params-inner-pop

  braces-params-inner-pop:
    - include: braces-end-pop
    - match: '{{word_begin}}(?:--|->){{word_end}}'
      scope: punctuation.separator.astil_forth
      set: braces-params-output-pop
    - match: '{{word_begin}}{{braces_param}}{{word_end}}'
      scope: variable.parameter.astil_forth
    - include: nonblank-pop

  braces-params-output-pop:
    - match: '{{word_begin}}(?:--|->){{word_end}}'
      scope: punctuation.separator.astil_forth
    - match: '{{word_begin}}err{{word_end}}(?=\s+})'
      scope: variable.parameter.astil_forth storage.modifier.astil_forth
    - match: '{{word_begin}}{{braces_param}}{{word_end}}'
      scope: variable.parameter.astil_forth
    - include: nonblank-pop

  braces-end-pop:
    - match: \}
      scope: punctuation.section.braces.end.astil_forth
      pop: 1

  # Convention for word-declaring words.
  declaring-word-match:
    - match: '{{word_begin}}({{mod}})?({{declarator}})(:){{word_end}}\s+({{word}}){{word_end}}'
      scope: meta.declaration.astil_forth
      captures:
        1: storage.modifier.astil_forth
        2: keyword.declaration.astil_forth
        3: storage.modifier.astil_forth
        4: variable.declaration.astil_forth

  # Support the convention where immediate words with a trailing apostrophe are
  # expected to read the very next word in the source text, and do something
  # with it. We scope the next word as a string to clarify its semantic role.
  parsing-word-match:
    - include: parsing-word-bracketed-ticked-match
    - include: parsing-word-ticked-match

  parsing-word-bracketed-ticked-match:
    - match: '{{word_begin}}(\[+)[^\s"]*?({{tick}}+)(\]+){{word_end}}'
      scope: variable.function.astil_forth
      captures:
        1: storage.modifier.astil_forth
        2: storage.modifier.astil_forth
        3: storage.modifier.astil_forth
      push: parse-word-pop

  parsing-word-ticked-match:
    - match: '{{word_begin}}({{mod}})?[^\s{{tick}}"]*?({{tick}}+){{word_end}}'
      scope: variable.function.astil_forth
      captures:
        1: storage.modifier.astil_forth
        2: storage.modifier.astil_forth
      push: parse-word-pop

  parse-word-pop:
    - meta_include_prototype: false
    - match: '{{eol}}'
      pop: 1
    - match: '{{word_begin}}{{word}}{{word_end}}'
      scope: string.other.astil_forth
      pop: 1

  delimited-word-match:
    - include: bracketed-word-match
    - match: '{{word_begin}}([{{delim}}]+)([^\s{{delim}}]*){{word_end}}'
      captures:
        1: punctuation.section.astil_forth
        2: variable.other.astil_forth
    - match: '{{word_begin}}([{{delim}}]*)([^\s{{delim}}]*?)([{{delim}}]+){{word_end}}'
      captures:
        1: punctuation.section.astil_forth
        2: variable.other.astil_forth
        3: punctuation.section.astil_forth

  # Support the common convention of `[bracketed]` words.
  bracketed-word-match:
    - match: '{{word_begin}}(\[+)\S*(\]+){{word_end}}'
      scope: variable.function.astil_forth
      captures:
        1: storage.modifier.astil_forth
        2: storage.modifier.astil_forth

  modified-word-match:
    - match: '{{word_begin}}({{mod}})\S+{{word_end}}'
      scope: variable.function.astil_forth
      captures:
        1: storage.modifier.astil_forth

  constant-match:
    - match: '{{word_begin}}(?:nil|true|false){{word_end}}'
      scope: constant.language.boolean.astil_forth

  keyword-match:
    - match: '{{word_begin}}{{keyword}}{{word_end}}'
      scope: variable.function.astil_forth

  any-word-match:
    - match: '{{word_begin}}{{word}}{{word_end}}'
      scope: variable.other.astil_forth

  now-pop:
    - match: ''
      pop: 1

  nonblank-pop:
    - match: (?=\S)
      pop: 1

  eol-pop:
    - match: '{{eol}}'
      pop: 1
