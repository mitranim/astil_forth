import' std:lang.af

fun: reverse { str len }
  str           { floor }
  str len + dec { ceil }

  loop
    floor ceil < while
    floor @b { low }
    ceil  @b { high }
    high  floor !b
    low   ceil  !b
    ++:   floor
    --:   ceil
  end
end

fun: main
  s" 0123456789abcdef" { str len }
  str log lf
  str len reverse
  str log lf
end

main
\ fedcba9876543210
