use' lang.af

fun: reverse { str len }
  str           { low }
  str len + dec { high }

  loop
    low high < while
    low @b { tmp }
    high @b low !b
    tmp high !b
    inc: low
    dec: high
  end
end

fun: main
  s" 0123456789abcdef" { str len }
  str log lf
  str len reverse
  str log lf
end

main
\ fedcba9876543210
