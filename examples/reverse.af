use' lang.af

fun: reverse { str len }
  str            { low }
  str len + .dec { high }

  loop
    low high < .while
    low @b high @b low !b high !b
    inc: low
    dec: high
  end
end

fun: run
  s" 0123456789abcdef" { str len }
  str .log .lf
  str len .reverse
  str .log .lf
end

.run
\ fedcba9876543210
