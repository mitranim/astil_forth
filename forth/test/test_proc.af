use' ../proc.af

fun: .proc_run_capture_with_mem { argv mem cap -- buf len exit sig err top }
  alloca' Ctx { ctx }
  mem cap ctx .ctx_init
  ctx .with_ctx argv .proc_run_capture end
  ctx .Ctx_top @
end

fun: .test_proc_wait { argv -- Err }
  " false" argv !cellz
  argv nil .proc_spawn .try { pid }
  pid .pid_wait .try { exit sig }
  assert= exit 1 end .try
  assert= sig 0 end .try

  argv nil .proc_spawn .try { pid }
  pid .pid_wait_ok { err }
  err " exited with code 1" .assert_str_has .try

  " sleep" " 10" argv !cellz
  argv nil .proc_spawn .try { pid }
  assert= pid SIGTERM .kill .cint_to_cell 0 end .try
  pid .pid_wait .try { exit sig }
  assert= exit 0 end .try
  assert= sig SIGTERM end .try
end

fun: .test_proc_stdin { argv -- Err }
  " grep" " -qx" " hello" argv !cellz
  argv .proc_spawn_stdin .try { pid fd_write }

  fd_write s" hello\n" .fd_write_all { write_err }
  fd_write .close { -- }
  pid .pid_wait_ok { wait_err }

  write_err wait_err .coalesce .try
end

fun: .test_proc_stdin_early_close { argv -- Err }
  1 20 .lsl { len }
  len 1 .ctx_alloc .try { buf }
  buf len 0x55 .memfill

  " false" argv !cellz
  argv buf len .proc_run_with_stdin_ok { err }
  EPIPE .strerror { exp }
  err exp .assert_str_has
end

fun: .test_proc_capture { argv -- Err }
  " echo" " out" argv !cellz
  argv .proc_run_capture .try { buf len exit sig }
  assert buf len s" out\n" str= end .try
  assert= exit 0 end .try
  assert= sig 0 end .try

  " cat" " /definitely/missing/astil-test-file" argv !cellz
  argv .proc_run_capture .try { buf _len exit sig }
  buf " /definitely/missing/astil-test-file" .assert_str_has .try
  assert exit <>0 end .try
  assert= sig 0 end .try

  argv .proc_run_capture_ok { buf _len err }
  buf " /definitely/missing/astil-test-file" .assert_str_has .try
  err " exited with code" .assert_str_has .try

  " /definitely/missing/astil-test-command" argv !cellz
  argv .proc_run_capture { buf len exit sig err }
  assert= len 0 end .try
  assert= buf @b 0 end .try
  assert= exit 0 end .try
  assert= sig 0 end .try
  err " unable to spawn" .assert_str_has .try
end

fun: .test_proc_capture_capacity { argv -- Err }
  8 .alloca { capture_mem }

  " false" argv !cellz
  capture_mem 8 0x55 .memfill
  argv capture_mem 8 .proc_run_capture_with_mem { buf len exit sig err top }
  err .try

  assert= buf capture_mem end .try
  assert= len 0 end .try
  assert= buf @b 0 end .try
  assert= top capture_mem 1 + end .try
  assert= exit 1 end .try
  assert= sig 0 end .try

  " echo" " 012345" argv !cellz
  capture_mem 8 0x55 .memfill
  argv capture_mem 8 .proc_run_capture_with_mem { buf len exit sig err top }
  err .try

  assert= buf capture_mem end .try
  assert= len 7 end .try
  assert buf len s" 012345\n" str= end .try
  assert= buf len + @b 0 end .try
  assert= top capture_mem 8 + end .try
  assert= exit 0 end .try
  assert= sig 0 end .try

  " echo" " 0123456789abcdef" argv !cellz
  capture_mem 8 0x55 .memfill
  argv capture_mem 8 .proc_run_capture_with_mem { buf len exit sig err top }

  err " unable to capture subprocess output: context out of space"
  .assert_str_eq .try

  assert= buf capture_mem end .try
  assert= len 7 end .try
  assert buf len s" 0123456" str= end .try
  assert= buf len + @b 0 end .try
  assert= top capture_mem 8 + end .try
  assert= exit 0 end .try
  assert= sig 0 end .try
end

fun: .test_proc_closes_unselected_fdes { argv -- Err }
  .fd_pipe .try { fd_read fd_write }

  \ `.fd_pipe` leaves its endpoints inheritable on Darwin. Spawn policy, not a
  \ descriptor-local `FD_CLOEXEC` flag, must keep this one out of the child.
  assert= fd_read F_GETFD 0 .fcntl_int .cint_to_cell 0 end .try
  fd_write s" inherited\n" .fd_write_all .try
  fd_write .close { -- }

  32 .alloca { path }
  path 32 " /dev/fd/%zd" fd_read .str_prnf .try { _ }
  " cat" path argv !cellz

  argv .proc_run_capture { _buf _len exit sig err }
  fd_read .close { -- }
  err .try
  assert exit <>0 end .try
  assert= sig 0 end .try
end

fun: .test_proc { -- err }
  4 .cells .alloca { argv }
  argv .test_proc_wait
  argv .test_proc_stdin
  argv .test_proc_stdin_early_close
  argv .test_proc_capture
  argv .test_proc_capture_capacity
  argv .test_proc_closes_unselected_fdes
end

fun: .main { -- exit }
  .with_main_ctx .test_proc end { err }
  err .then " [test] [proc] [aot] error: %s\n" err .elogf 1 else 0 end
end

\ Run once in interpreter/JIT mode; `.main` covers AOT executable.
.test_proc

" [test] [proc] [jit] ok\n" .elog
