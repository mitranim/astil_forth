  assert= 20 const_fold_gt_lhs_imm_fun 0 end
  assert= 19 const_fold_lt_rhs_imm_fun 1 end
  assert= 20 const_fold_lt_rhs_imm_fun 0 end
  assert= 21 const_fold_lt_lhs_imm_fun 1 end
  assert= 20 const_fold_lt_lhs_imm_fun 0 end
  assert= 20 const_fold_le_rhs_imm_fun 1 end
  assert= 21 const_fold_le_rhs_imm_fun 0 end
  assert= 20 const_fold_le_lhs_imm_fun 1 end
  assert= 19 const_fold_le_lhs_imm_fun 0 end
  assert= 20 const_fold_ge_rhs_imm_fun 1 end
  assert= 19 const_fold_ge_rhs_imm_fun 0 end
