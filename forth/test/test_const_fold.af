test_const_fold_unary_large_imm

fun: const_fold_fallback_0_1_1_2_fun { val -- out0 out1 }
  val inc
  val =0
end

fun: test_const_fold_fallback_0_1_1_2 { -- err }
  41 const_fold_fallback_0_1_1_2_fun { out0 out1 }
  assert= out0 42 end
  assert= out1 0 end
  0  const_fold_fallback_0_1_1_2_fun { out2 out3 }
  assert= out2 1 end
  assert= out3 1 end
end
test_const_fold_fallback_0_1_1_2

