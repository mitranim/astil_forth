fun: .const_fold_multi_zero_cmp_fun { -- out0 out1 out2 out3 out4 out5 }
  0 =0
  1 <>0
  -1 <0
  1 >0
  0 <=0
  0 >=0
end

fun: .test_const_fold_zero_cmp { -- err }
  .const_fold_multi_zero_cmp_fun { out0 out1 out2 out3 out4 out5 }
  assert= out0 1 end
  assert= out1 1 end
  assert= out2 1 end
  assert= out3 1 end
  assert= out4 1 end
  assert= out5 1 end
  ifz .has_interp .then .ret end

  .cf_want_clear
  0 1 .cf_want_load
  1 1 .cf_want_load
  2 1 .cf_want_load
  3 1 .cf_want_load
  4 1 .cf_want_load
  5 1 .cf_want_load
  .cf_want_ret
  xt' .const_fold_multi_zero_cmp_fun .cf_want_word
end
.test_const_fold_zero_cmp

fun: .const_fold_bit_shift_fun { -- out0 out1 out2 out3 out4 out5 }
  0b1010 0b1100 .or
  0b1010 0b1100 .and
  0b1010 0b1100 .xor
  3 4 .lsl
  64 3 .lsr
  -64 2 .asr
end

fun: .const_fold_lsl_imm_fun { val -- out } val 3 .lsl end
fun: .const_fold_lsr_imm_fun { val -- out } val 3 .lsr end
fun: .const_fold_asr_imm_fun { val -- out } val 2 .asr end
fun: .const_fold_or_rhs_imm_fun { val -- out } val 0xff .or end
fun: .const_fold_and_rhs_imm_fun { val -- out } val 0xff .and end
fun: .const_fold_xor_rhs_imm_fun { val -- out } val 0xff .xor end
fun: .const_fold_is_aligned_rhs_imm_fun { val -- out } val 8 .is_aligned_to end
fun: .const_fold_align_down_rhs_imm_fun { val -- out } val 16 .align_down end
fun: .const_fold_align_up_rhs_imm_fun { val -- out } val 16 .align_up end
fun: .const_fold_bits_trunc_rhs_imm_fun { val -- out } val 8 .bits_trunc end
fun: .const_fold_bit_mask_get_rhs_imm_fun { val -- out } val 0b111111110000 .bit_mask_get end

fun: .test_const_fold_bit_shift { -- err }
  .const_fold_bit_shift_fun { out0 out1 out2 out3 out4 out5 }
  assert= out0 14 end
  assert= out1 8 end
  assert= out2 6 end
  assert= out3 48 end
  assert= out4 8 end
  assert= out5 -16 end
  ifz .has_interp .then .ret end

  .cf_want_clear
  0 14 .cf_want_load
  1 8 .cf_want_load
  2 6 .cf_want_load
  3 48 .cf_want_load
  4 8 .cf_want_load
  5 -16 .cf_want_load
  .cf_want_ret
  xt' .const_fold_bit_shift_fun .cf_want_word

  0 0 3 .asm_lsl_imm xt' .const_fold_lsl_imm_fun .cf_want_word1
  0 0 3 .asm_lsr_imm xt' .const_fold_lsr_imm_fun .cf_want_word1
  0 0 2 .asm_asr_imm xt' .const_fold_asr_imm_fun .cf_want_word1

  0 0 0xff .asm_orr_imm xt' .const_fold_or_rhs_imm_fun .cf_want_word1
  0 0 0xff .asm_and_imm xt' .const_fold_and_rhs_imm_fun .cf_want_word1
  0 0 0xff .asm_eor_imm xt' .const_fold_xor_rhs_imm_fun .cf_want_word1

  0 7 .asm_tst_imm { instr0 }
  0 ASM_EQ .asm_cset { instr1 }
  instr0 instr1 xt' .const_fold_is_aligned_rhs_imm_fun .cf_want_word2

  0 0 -16 .asm_and_imm xt' .const_fold_align_down_rhs_imm_fun .cf_want_word1
  0 0 15 .asm_add_imm { instr0 }
  0 0 -16 .asm_and_imm { instr1 }
  instr0 instr1 xt' .const_fold_align_up_rhs_imm_fun .cf_want_word2
  0 0 0xff .asm_and_imm xt' .const_fold_bits_trunc_rhs_imm_fun .cf_want_word1
  0 0 0b111111110000 .asm_and_imm { instr0 }
  0 0 4 .asm_lsr_imm { instr1 }
  instr0 instr1 xt' .const_fold_bit_mask_get_rhs_imm_fun .cf_want_word2
end
.test_const_fold_bit_shift

fun: .test_const_fold_bit_mask_errors { -- Err }
  use' ./fail/test_const_fold_bit_mask_get_bad.af
  " invalid bit mask: expected nonzero contiguous mask" .assert_str_has .try
end
.test_const_fold_bit_mask_errors

fun: .test_const_fold_redundant_arith_errors { -- Err }
  use' ./fail/test_const_fold_redundant_logical.af
  " redundant arithmetic" .assert_str_has .try

  use' ./fail/test_const_fold_redundant_addsub.af
  " redundant arithmetic" .assert_str_has .try

  use' ./fail/test_const_fold_redundant_shift.af
  " redundant arithmetic" .assert_str_has .try

  use' ./fail/test_const_fold_redundant_const_shift.af
  " redundant arithmetic" .assert_str_has .try

  use' ./fail/test_const_fold_redundant_mul_zero.af
  " redundant arithmetic" .assert_str_has .try

  use' ./fail/test_const_fold_redundant_div_one.af
  " redundant arithmetic: division by 1" .assert_str_has .try

  use' ./fail/test_const_fold_redundant_udiv_one.af
  " redundant arithmetic: division by 1" .assert_str_has .try

  use' ./fail/test_const_fold_redundant_mod_one.af
  " redundant arithmetic: modulo by 1" .assert_str_has .try

  use' ./fail/test_const_fold_redundant_umod_one.af
  " redundant arithmetic: modulo by 1" .assert_str_has .try

  use' ./fail/test_const_fold_redundant_divmod_one.af
  " redundant arithmetic: division by 1" .assert_str_has .try

  use' ./fail/test_const_fold_redundant_udivmod_one.af
  " redundant arithmetic: division by 1" .assert_str_has .try

  use' ./fail/test_const_fold_div_zero.af
  " redundant arithmetic: division by 0 -> 0" .assert_str_has .try

  use' ./fail/test_const_fold_udiv_zero.af
  " redundant arithmetic: division by 0 -> 0" .assert_str_has .try

  use' ./fail/test_const_fold_mod_zero.af
  " redundant arithmetic: modulo by 0 -> dividend" .assert_str_has .try

  use' ./fail/test_const_fold_umod_zero.af
  " redundant arithmetic: modulo by 0 -> dividend" .assert_str_has .try

  use' ./fail/test_const_fold_divmod_zero.af
  " redundant arithmetic: div by 0 -> quo 0, rem dividend" .assert_str_has .try

  use' ./fail/test_const_fold_udivmod_zero.af
  " redundant arithmetic: div by 0 -> quo 0, rem dividend" .assert_str_has .try

  use' ./fail/test_const_fold_rhs_div_zero.af
  " redundant arithmetic: division by 0 -> 0" .assert_str_has .try

  use' ./fail/test_const_fold_rhs_udiv_zero.af
  " redundant arithmetic: division by 0 -> 0" .assert_str_has .try

  use' ./fail/test_const_fold_rhs_mod_zero.af
  " redundant arithmetic: modulo by 0 -> dividend" .assert_str_has .try

  use' ./fail/test_const_fold_rhs_umod_zero.af
  " redundant arithmetic: modulo by 0 -> dividend" .assert_str_has .try

  use' ./fail/test_const_fold_rhs_divmod_zero.af
  " redundant arithmetic: div by 0 -> quo 0, rem dividend" .assert_str_has .try

  use' ./fail/test_const_fold_rhs_udivmod_zero.af
  " redundant arithmetic: div by 0 -> quo 0, rem dividend" .assert_str_has .try

  use' ./fail/test_const_fold_redundant_align_down.af
  " redundant arithmetic" .assert_str_has .try

  use' ./fail/test_const_fold_redundant_align_up.af
  " redundant arithmetic" .assert_str_has .try

  use' ./fail/test_const_fold_redundant_is_aligned.af
  " redundant arithmetic" .assert_str_has .try

  use' ./fail/test_const_fold_redundant_bits_trunc.af
  " redundant arithmetic" .assert_str_has .try

  use' ./fail/test_const_fold_redundant_bits_clear.af
  " redundant arithmetic" .assert_str_has .try

  use' ./fail/test_const_fold_redundant_bit_mask_get.af
  " redundant arithmetic" .assert_str_has .try
end
.test_const_fold_redundant_arith_errors

fun: .test_const_fold_assert_static_errors { -- Err }
  use' ./fail/test_assert_static_fail.af
  " assertion failed: 10 20 =" .assert_str_has .try

  use' ./fail/test_assert_static_fail_after_drop_with_err.af
  " assertion failed: 123 234 =" .assert_str_has .try
end
.test_const_fold_assert_static_errors

fun: .const_fold_div_mod_fun { -- out0 out1 out2 out3 out4 }
  29 5 /
  29 5 u/
  29 5 .mod
  29 5 /mod
end

fun: .const_fold_udiv_mod_fun { -- out0 out1 out2 out3 }
  -1 -2 u/
  -1 -2 .umod
  -1 -2 u/mod
end

fun: .const_fold_mul_pow2_rhs_imm_fun { val -- out } val -8 * end
fun: .const_fold_udiv_pow2_rhs_imm_fun { val -- out } val 8 u/ end
fun: .const_fold_umod_pow2_rhs_imm_fun { val -- out } val 8 .umod end

fun: .test_const_fold_div_mod { -- err }
  .const_fold_div_mod_fun { out0 out1 out2 out3 out4 }
  assert= out0 5 end
  assert= out1 5 end
  assert= out2 4 end
  assert= out3 4 end
  assert= out4 5 end
  .const_fold_udiv_mod_fun { out5 out6 out7 out8 }
  assert= out5 1 end
  assert= out6 1 end
  assert= out7 1 end
  assert= out8 1 end

  ifz .has_interp .then .ret end

  .cf_want_clear
  0 5 .cf_want_load
  1 5 .cf_want_load
  2 4 .cf_want_load
  3 4 .cf_want_load
  4 5 .cf_want_load
  .cf_want_ret
  xt' .const_fold_div_mod_fun .cf_want_word

  .cf_want_clear
  0 1 .cf_want_load
  1 1 .cf_want_load
  2 1 .cf_want_load
  3 1 .cf_want_load
  .cf_want_ret
  xt' .const_fold_udiv_mod_fun .cf_want_word

  0 0 3 .asm_lsl_imm { instr0 }
  0 .asm_neg { instr1 }
  instr0 instr1 xt' .const_fold_mul_pow2_rhs_imm_fun .cf_want_word2

  0 0 3 .asm_lsr_imm xt' .const_fold_udiv_pow2_rhs_imm_fun .cf_want_word1
  0 0 7 .asm_and_imm xt' .const_fold_umod_pow2_rhs_imm_fun .cf_want_word1
end
.test_const_fold_div_mod

fun: .const_fold_compare2_fun { -- out0 out1 out2 out3 out4 out5 out6 out7 }
  7 3 .min
  7 3 .max
  7 7 =
  7 3 <>
  7 3 >
  3 7 <
  3 7 <=
  7 7 >=
end

