end
.test_const_fold_derived


fun: .const_fold_low_bits_fun { -- out } 5 .low_bits end
fun: .const_fold_bits_trunc_fun { -- out } 0b10110101 4 .bits_trunc end
fun: .const_fold_bits_clear_fun { -- out } 0b11110011 0b00110000 .bits_clear end
fun: .const_fold_bits_clear_imm_fun { val -- out } val 0xff .bits_clear end
fun: .const_fold_bit_mask_get_fun { -- out }
  0b1001000110100 0b111111110000 .bit_mask_get
end

fun: .test_const_fold_bits { -- err }
  ifz .has_interp .then .ret end

  31 xt' .const_fold_low_bits_fun .cf_want_load_word
  5 xt' .const_fold_bits_trunc_fun .cf_want_load_word
  0b11000011 xt' .const_fold_bits_clear_fun .cf_want_load_word
  0b100011 xt' .const_fold_bit_mask_get_fun .cf_want_load_word

  0 0 0xff .asm_bic_imm xt' .const_fold_bits_clear_imm_fun .cf_want_word1
end
.test_const_fold_bits

fun: .const_fold_cint_to_cell_fun { -- out0 out1 }
  -1 .cint_to_cell
  123 .cint_to_cell
end

fun: .test_const_fold_cint_to_cell { -- err }
  .const_fold_cint_to_cell_fun { out0 out1 }
  assert= out0 -1 end
  assert= out1 123 end
  ifz .has_interp .then .ret end

  .cf_want_clear
  0 -1 .cf_want_load
  1 123 .cf_want_load
  .cf_want_ret
  xt' .const_fold_cint_to_cell_fun .cf_want_word
end
.test_const_fold_cint_to_cell

