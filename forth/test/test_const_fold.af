  1 4 asm_mov_reg cf_expect_instr
  0 1 5 asm_add_imm cf_expect_instr
  2 0 asm_mov_reg cf_expect_instr
  1 2 3 asm_sub_imm cf_expect_instr
  2 4096 cf_expect_load
  3 1 asm_mov_reg cf_expect_instr
  2 3 2 asm_add_reg cf_expect_instr
  cf_expect_ret
  xt' const_fold_loc_step_fun cf_expect_word

  cf_expect_clear
  0 7 cf_expect_load
  2 0 asm_mov_reg cf_expect_instr
  1 2 asm_mov_reg cf_expect_instr
  0 1 3 asm_lsl_imm cf_expect_instr
  0 asm_neg cf_expect_instr
  cf_expect_ret
  xt' loc_mul_pow2_fun cf_expect_word

  0 1 3 asm_lsr_imm 80 xt' loc_udiv_pow2_fun cf_expect_load_lhs_imm1
  0 1 7 asm_and_imm -1 xt' loc_umod_pow2_fun cf_expect_load_lhs_imm1

  0 0 1 asm_add_imm { instr0 }
  0 0 1 asm_sub_imm { instr1 }
  instr0 instr1 xt' loc_inc_dec_inline_fun cf_expect_word2
  0 0 asm_mvn xt' loc_invert_fun cf_expect_word1
  0 asm_neg xt' loc_negate_fun cf_expect_word1

  0 asm_cmp_zero { instr0 }
  0 0 0 ASM_PL asm_csneg { instr1 }
  instr0 instr1 xt' loc_abs_fun cf_expect_word2

  0 0 asm_clz xt' loc_bit_clz_fun cf_expect_word1
  0 0 asm_rbit { instr0 }
  0 0 asm_clz { instr1 }
  instr0 instr1 xt' loc_bit_ctz_fun cf_expect_word2

  cf_expect_clear
  0 0 asm_clz cf_expect_instr
  1 64 cf_expect_load
  0 1 0 asm_sub_reg cf_expect_instr
  cf_expect_ret
  xt' loc_bit_len_fun cf_expect_word

  0 0 asm_sign_extend_32 xt' loc_int_to_cell_fun cf_expect_word1
  0 0 3 asm_lsl_imm      xt' loc_cells_fun       cf_expect_word1
  0 0 3 asm_asr_imm      xt' loc_div_cells_fun   cf_expect_word1
  0 0 CELL asm_add_imm   xt' loc_add_cell_fun    cf_expect_word1
  0 0 CELL asm_sub_imm   xt' loc_sub_cell_fun    cf_expect_word1
  0 0 1 asm_and_imm      xt' loc_odd_fun         cf_expect_word1

  cf_expect_clear
  1 1 cf_expect_load
  1 1 0 asm_lsl_reg cf_expect_instr
  0 1 1 asm_sub_imm cf_expect_instr
  cf_expect_ret
  xt' loc_low_bits_fun cf_expect_word
end
test_const_fold_loc_step

fun: const_fold_low_bits_fun { -- out } 5 low_bits end
fun: const_fold_bits_trunc_fun { -- out } 0b10110101 4 bits_trunc end
fun: const_fold_bits_clear_fun { -- out } 0b11110011 0b00110000 bits_clear end
fun: const_fold_bits_clear_imm_fun { val -- out } val 0xff bits_clear end

fun: low_bits_instr_fun { len -- out } len low_bits end
fun: bits_trunc_instr_fun { imm len -- out } imm len bits_trunc end
fun: bits_clear_instr_fun { imm mask -- out } imm mask bits_clear end

fun: test_const_fold_bits { -- err }
  assert= const_fold_low_bits_fun 31 end
  assert= const_fold_bits_trunc_fun 5 end
  assert= const_fold_bits_clear_fun 0b11000011 end
  assert= 0x1234 const_fold_bits_clear_imm_fun 0x1200 end
  assert= 5 low_bits_instr_fun 31 end
  assert= 0b10110101 4 bits_trunc_instr_fun 5 end
  assert= 0b11110011 0b00110000 bits_clear_instr_fun 0b11000011 end
  ifz has_interp then ret end

  31         xt' const_fold_low_bits_fun   cf_expect_load_word
  5          xt' const_fold_bits_trunc_fun cf_expect_load_word
  0b11000011 xt' const_fold_bits_clear_fun cf_expect_load_word

  0 0 0xff asm_bic_imm xt' const_fold_bits_clear_imm_fun cf_expect_word1

  cf_expect_clear
  1 1 cf_expect_load
  1 1 0 asm_lsl_reg cf_expect_instr
  0 1 1 asm_sub_imm cf_expect_instr
  cf_expect_ret
  xt' low_bits_instr_fun cf_expect_word

  cf_expect_clear
  2 1 cf_expect_load
  2 2 1 asm_lsl_reg cf_expect_instr
  2 2 1 asm_sub_imm cf_expect_instr
  0 0 2 asm_and_reg cf_expect_instr
  asm_nop cf_expect_instr
  cf_expect_ret
  xt' bits_trunc_instr_fun cf_expect_word

  0 0 1 asm_bic { instr0 }
  asm_nop { instr1 }
  instr0 instr1 xt' bits_clear_instr_fun cf_expect_word2
end
test_const_fold_bits

fun: const_fold_int_to_cell_fun { -- out0 out1 }
  -1 int_to_cell
  123 int_to_cell
end

fun: test_const_fold_int_to_cell { -- err }
  const_fold_int_to_cell_fun { out0 out1 }
  assert= out0 -1 end
  assert= out1 123 end
  ifz has_interp then ret end

  cf_expect_clear
  0 -1  cf_expect_load
  1 123 cf_expect_load
  cf_expect_ret
  xt' const_fold_int_to_cell_fun cf_expect_word
end
test_const_fold_int_to_cell

