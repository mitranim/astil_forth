use' ../lang.af

\ This file should contain tests for CF-specific optimizations.
\ It shouldn't bother testing semantic-only arithmetic results;
\ those should be covered in `./test.af`. It should not bother
\ testing pessimizations either; no locking down poor codegen.

128 mem: CF_WANT_INSTRS
0 var: CF_WANT_LEN

fun: .cf_want_clear 0 CF_WANT_LEN ! end

fun: .cf_want_instr { instr }
  CF_WANT_LEN @ { ind }
  instr CF_WANT_INSTRS ind 4 * + !32
  ind .inc CF_WANT_LEN !
end

fun: .cf_want_word { XT -- err }
  CF_WANT_LEN @ { exp_len }
  XT .Sym_union .Sym_norm_spans { spans }
  spans .Sym_instrs_ret @u32 .inc spans .Sym_instrs_prologue @u32 - { act_len }
  if exp_len act_len <> .then
    XT .Sym_name .Sym_word_buf { name }
    XT .Sym_name .Sym_word_len @u32 { name_len }
    " [test] `%.*s` instruction length mismatch: expected %zd, actual %zd"
    name_len name exp_len act_len .strf .throw
  end

  0 { ind }
  loop
    ind exp_len < .while
    CF_WANT_INSTRS ind 4 * + @u32 { exp }
    XT .sym_instr ind 4 * + @u32 { act }
    if exp act <> .then
      XT .Sym_name .Sym_word_buf { name }
      XT .Sym_name .Sym_word_len @u32 { name_len }
      " [test] `%.*s` instruction mismatch at %zd: expected 0x%zx, actual 0x%zx"
      name_len name ind exp act .strf .throw
    end
    inc: ind
  end
end

fun: .cf_imm_lane { imm hw -- lane }
  imm hw 16 * .lsr 0xffff .and
end

fun: .cf_base_hw { bits -- hw }
  if bits 0 .cf_imm_lane .then 0 .ret end
  if bits 1 .cf_imm_lane .then 1 .ret end
  if bits 2 .cf_imm_lane .then 2 .ret end
  if bits 3 .cf_imm_lane .then 3 .ret end
  0
end

fun: .cf_want_movk_if { reg neg base_hw hw bits }
  bits hw .cf_imm_lane { lane }
  if hw base_hw <> .then
    if lane .then
      if neg .then lane .invert 0xffff .and else lane end { imm16 }
      reg 0b11 hw imm16 .asm_mov_wide .cf_want_instr
    end
  end
end

fun: .cf_want_load { reg imm }
  imm <0 { neg }
  if neg .then imm .invert else imm end { bits }
  if neg .then 0b00 else 0b10 end { opc }

  bits .cf_base_hw { hw }
  bits hw .cf_imm_lane { imm16 }
  reg opc hw imm16 .asm_mov_wide .cf_want_instr

  reg neg hw 0 bits .cf_want_movk_if
  reg neg hw 1 bits .cf_want_movk_if
  reg neg hw 2 bits .cf_want_movk_if
  reg neg hw 3 bits .cf_want_movk_if
end

fun: .cf_want_ret asm_ret .cf_want_instr end

fun: .cf_want_load_word { imm XT -- err }
  .cf_want_clear
  0 imm .cf_want_load
  .cf_want_ret
  XT .cf_want_word
end

fun: .cf_want_word1 { instr XT -- err }
  .cf_want_clear
  instr .cf_want_instr
  .cf_want_ret
  XT .cf_want_word
end

fun: .cf_want_word2 { instr0 instr1 XT -- err }
  .cf_want_clear
  instr0 .cf_want_instr
  instr1 .cf_want_instr
  .cf_want_ret
  XT .cf_want_word
end

fun: .const_fold_arith_fun { -- val } 10 20 30 40 + - * end

fun: .test_const_fold_arith { -- err }
  assert= .const_fold_arith_fun -500 end
  ifz .has_interp .then .ret end

  -500 xt' .const_fold_arith_fun .cf_want_load_word
end
.test_const_fold_arith

fun: .const_fold_large_imm_fun { -- out0 out1 out2 }
  1 0x123456789 +
  0x123456789 1 +
  0x123456789 0x987654321 +
end

fun: .test_const_fold_large_imm { -- err }
  .const_fold_large_imm_fun { out0 out1 out2 }
  assert= out0 0x12345678a end
  assert= out1 0x12345678a end
  assert= out2 0xaaaaaaaaa end
  ifz .has_interp .then .ret end

  .cf_want_clear
  0 0x12345678a .cf_want_load
  1 0x12345678a .cf_want_load
  2 0xaaaaaaaaa .cf_want_load
  .cf_want_ret
  xt' .const_fold_large_imm_fun .cf_want_word
end
.test_const_fold_large_imm

fun: .const_fold_ugly_imm_fun { -- out0 out1 }
  0x123456789abcdef0
  0 0x123456789abc -
end

fun: .test_const_fold_ugly_imm { -- err }
  .const_fold_ugly_imm_fun { out0 out1 }
  assert= out0 0x123456789abcdef0 end
  assert= out1 0 0x123456789abc - end
  ifz .has_interp .then .ret end

  .cf_want_clear
  0 0x123456789abcdef0 .cf_want_load
  1 0 0x123456789abc - .cf_want_load
  .cf_want_ret
  xt' .const_fold_ugly_imm_fun .cf_want_word
end
.test_const_fold_ugly_imm

fun: .const_fold_negative_lane_imm_fun { -- out }
  0 0x100020003 -
end

fun: .test_const_fold_negative_lane_imm { -- err }
  assert= .const_fold_negative_lane_imm_fun 0 0x100020003 - end
  ifz .has_interp .then .ret end

  .cf_want_clear
  0 0x100020003 - { imm }
  0 imm .cf_want_load
  .cf_want_ret
  xt' .const_fold_negative_lane_imm_fun .cf_want_word
end
.test_const_fold_negative_lane_imm

fun: .const_fold_multi_out_fun { -- out0 out1 out2 out3 out4 out5 out6 }
  41 .inc
  43 .dec
  42 .negate
  0 .invert
  -42 .abs
  0 .bit_len
  255 .bit_len
end

fun: .test_const_fold_unary { -- err }
  .const_fold_multi_out_fun { out0 out1 out2 out3 out4 out5 out6 }
  assert= out0 42 end
  assert= out1 42 end
  assert= out2 -42 end
  assert= out3 -1 end
  assert= out4 42 end
  assert= out5 0 end
  assert= out6 8 end
  ifz .has_interp .then .ret end

  .cf_want_clear
  0 42 .cf_want_load
  1 42 .cf_want_load
  2 -42 .cf_want_load
  3 -1 .cf_want_load
  4 42 .cf_want_load
  5 0 .cf_want_load
  6 8 .cf_want_load
  .cf_want_ret
  xt' .const_fold_multi_out_fun .cf_want_word
end
.test_const_fold_unary

fun: .const_fold_pow2_ceil_fun { -- out0 out1 out2 out3 }
  0 .pow2_ceil
  1 .pow2_ceil
  4096 .pow2_ceil
  4097 .pow2_ceil
end

fun: .test_const_fold_pow2_ceil { -- err }
  .const_fold_pow2_ceil_fun { out0 out1 out2 out3 }
