fun: const_fold_multi_out_fun { -- out0 out1 out2 out3 out4 out5 out6 }
  41  inc
  43  dec
  42  negate
  0   invert
  -42 abs
  0   bit_len
  255 bit_len
end

fun: test_const_fold_unary { -- err }
  const_fold_multi_out_fun { out0 out1 out2 out3 out4 out5 out6 }
  assert= out0 42 end
  assert= out1 42 end
  assert= out2 -42 end
  assert= out3 -1 end
  assert= out4 42 end
  assert= out5 0 end
  assert= out6 8 end
  ifz has_interp then ret end

  cf_expect_clear
  0 42  cf_expect_load
  1 42  cf_expect_load
  2 -42 cf_expect_load
  3 -1  cf_expect_load
  4 42  cf_expect_load
  5 0   cf_expect_load
  6 8   cf_expect_load
  cf_expect_ret
  xt' const_fold_multi_out_fun cf_expect_word
end
test_const_fold_unary

