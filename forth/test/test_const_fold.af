fun: const_fold_bit_shift_fun { -- out0 out1 out2 out3 out4 out5 }
  0b1010 0b1100 or
  0b1010 0b1100 and
  0b1010 0b1100 xor
  3 4 lsl
  64 3 lsr
  -64 2 asr
end

fun: const_fold_lsl_imm_fun { val -- out } val 3 lsl end
fun: const_fold_lsr_imm_fun { val -- out } val 3 lsr end
fun: const_fold_asr_imm_fun { val -- out } val 2 asr end
fun: const_fold_or_rhs_imm_fun { val -- out } val 0xff or end
fun: const_fold_or_lhs_imm_fun { val -- out } 0xff val or end
fun: const_fold_and_rhs_imm_fun { val -- out } val 0xff and end
fun: const_fold_and_lhs_imm_fun { val -- out } 0xff val and end
fun: const_fold_and_bad_imm_fun { val -- out } val 0 and end
fun: const_fold_xor_rhs_imm_fun { val -- out } val 0xff xor end
fun: const_fold_xor_lhs_imm_fun { val -- out } 0xff val xor end
fun: const_fold_is_aligned_rhs_imm_fun { val -- out } val 8 is_aligned_to end
fun: const_fold_align_down_rhs_imm_fun { val -- out } val 16 align_down end
fun: const_fold_align_up_rhs_imm_fun { val -- out } val 16 align_up end
fun: const_fold_bits_trunc_rhs_imm_fun { val -- out } val 8 bits_trunc end
fun: const_fold_bit_mask_get_rhs_imm_fun { val -- out } val 0b111111110000 bit_mask_get end

fun: test_const_fold_bit_shift { -- err }
  const_fold_bit_shift_fun { out0 out1 out2 out3 out4 out5 }
  assert= out0 14 end
  assert= out1 8 end
  assert= out2 6 end
  assert= out3 48 end
  assert= out4 8 end
  assert= out5 -16 end
  assert= 6 const_fold_lsl_imm_fun 48 end
  assert= 64 const_fold_lsr_imm_fun 8 end
  assert= -64 const_fold_asr_imm_fun -16 end
  assert= 0x1234 const_fold_or_rhs_imm_fun 0x12ff end
  assert= 0x1234 const_fold_or_lhs_imm_fun 0x12ff end
  assert= 0x1234 const_fold_and_rhs_imm_fun 0x34 end
  assert= 0x1234 const_fold_and_lhs_imm_fun 0x34 end
  assert= 0x1234 const_fold_and_bad_imm_fun 0 end
  assert= 0x1234 const_fold_xor_rhs_imm_fun 0x12cb end
  assert= 0x1234 const_fold_xor_lhs_imm_fun 0x12cb end
  assert= 0x1238 const_fold_is_aligned_rhs_imm_fun true end
  assert= 0x1234 const_fold_is_aligned_rhs_imm_fun false end
  assert= 0x1234 const_fold_align_down_rhs_imm_fun 0x1230 end
  assert= 0x1234 const_fold_align_up_rhs_imm_fun 0x1240 end
  assert= 0x1234 const_fold_bits_trunc_rhs_imm_fun 0x34 end
  assert=
    0b1001000110100 const_fold_bit_mask_get_rhs_imm_fun
    0b100011
  end
  ifz has_interp then ret end

  cf_expect_clear
  0 14  cf_expect_load
  1 8   cf_expect_load
  2 6   cf_expect_load
  3 48  cf_expect_load
  4 8   cf_expect_load
  5 -16 cf_expect_load
  cf_expect_ret
  xt' const_fold_bit_shift_fun cf_expect_word

  0 0 3 asm_lsl_imm xt' const_fold_lsl_imm_fun cf_expect_word1
  0 0 3 asm_lsr_imm xt' const_fold_lsr_imm_fun cf_expect_word1
  0 0 2 asm_asr_imm xt' const_fold_asr_imm_fun cf_expect_word1

  0 0 0xff asm_orr_imm xt' const_fold_or_rhs_imm_fun  cf_expect_word1
  0 1 0xff asm_orr_imm xt' const_fold_or_lhs_imm_fun  cf_expect_lhs_imm1
  0 0 0xff asm_and_imm xt' const_fold_and_rhs_imm_fun cf_expect_word1
  0 1 0xff asm_and_imm xt' const_fold_and_lhs_imm_fun cf_expect_lhs_imm1
  0 0 0xff asm_eor_imm xt' const_fold_xor_rhs_imm_fun cf_expect_word1
  0 1 0xff asm_eor_imm xt' const_fold_xor_lhs_imm_fun cf_expect_lhs_imm1

  0 7 asm_tst_imm { instr0 }
  0 ASM_EQ asm_cset { instr1 }
  instr0 instr1 xt' const_fold_is_aligned_rhs_imm_fun cf_expect_word2

  0 0 -16 asm_and_imm xt' const_fold_align_down_rhs_imm_fun cf_expect_word1
  0 0 15  asm_add_imm { instr0 }
  0 0 -16 asm_and_imm { instr1 }
  instr0 instr1 xt' const_fold_align_up_rhs_imm_fun cf_expect_word2
  0 0 0xff asm_and_imm xt' const_fold_bits_trunc_rhs_imm_fun cf_expect_word1
  0 0 0b111111110000 asm_and_imm { instr0 }
  0 0 4              asm_lsr_imm { instr1 }
  instr0 instr1 xt' const_fold_bit_mask_get_rhs_imm_fun cf_expect_word2
end
test_const_fold_bit_shift

fun: const_fold_bit_mask_get_fun { -- out }
  0b1001000110100 0b111111110000 bit_mask_get
end

fun: const_fold_bit_mask_set_fun { -- out }
  0b10101011 0b1001000110100 0b111111110000 bit_mask_set
end

fun: test_const_fold_bit_mask_get_set { -- err }
  assert= const_fold_bit_mask_get_fun 0b100011 end
  assert= const_fold_bit_mask_set_fun 0b1101010110100 end
  ifz has_interp then ret end

  0b100011 xt' const_fold_bit_mask_get_fun cf_expect_load_word

  cf_expect_clear
  0 0b10101011      cf_expect_load
  1 0b1001000110100 cf_expect_load
  2 0b111111110000  cf_expect_load
  1 1 2 asm_bic     cf_expect_instr
  3 2   asm_rbit    cf_expect_instr
  3 3   asm_clz     cf_expect_instr
  0 0 3 asm_lsl_reg cf_expect_instr
  0 0 2 asm_and_reg cf_expect_instr
  0 0 1 asm_orr_reg cf_expect_instr
  cf_expect_ret
  xt' const_fold_bit_mask_set_fun cf_expect_word
end
test_const_fold_bit_mask_get_set

fun: test_const_fold_bit_mask_errors { -- err } [ false try_all ]
  use' ./fail/test_const_fold_bit_mask_get_bad.af
  " invalid bit mask: expected nonzero contiguous mask" assert_str_has try
end
test_const_fold_bit_mask_errors

fun: const_fold_div_mod_fun { -- out0 out1 out2 out3 out4 }
  29 5 /
  29 5 u/
  29 5 mod
  29 5 /mod
end

fun: const_fold_div_zero_fun { -- out0 out1 out2 out3 }
  29 0 /
  29 0 mod
  29 0 /mod
end

fun: const_fold_udiv_mod_fun { -- out0 out1 out2 out3 }
  -1 -2 u/
  -1 -2 umod
  -1 -2 u/mod
end

fun: const_fold_mul_pow2_rhs_imm_fun { val -- out } val -8 * end
fun: const_fold_mul_pow2_lhs_imm_fun { val -- out } 8 val * end
fun: const_fold_udiv_pow2_rhs_imm_fun { val -- out } val 8 u/ end
fun: const_fold_umod_pow2_rhs_imm_fun { val -- out } val 8 umod end

fun: test_const_fold_div_mod { -- err }
  const_fold_div_mod_fun { out0 out1 out2 out3 out4 }
  assert= out0 5 end
  assert= out1 5 end
  assert= out2 4 end
  assert= out3 4 end
  assert= out4 5 end
  const_fold_div_zero_fun { out5 out6 out7 out8 }
  assert= out5 0 end
  assert= out6 29 end
  assert= out7 29 end
  assert= out8 0 end
  const_fold_udiv_mod_fun { out9 out10 out11 out12 }
  assert= out9 1 end
  assert= out10 1 end
  assert= out11 1 end
  assert= out12 1 end
  assert= 7 const_fold_mul_pow2_rhs_imm_fun -56 end
  assert= 7 const_fold_mul_pow2_lhs_imm_fun 56 end
  assert= 64 const_fold_udiv_pow2_rhs_imm_fun 8 end
  assert= 31 const_fold_umod_pow2_rhs_imm_fun 7 end

  ifz has_interp then ret end

  cf_expect_clear
  0 5  cf_expect_load
  1 5  cf_expect_load
  2 4  cf_expect_load
  3 4  cf_expect_load
  4 5  cf_expect_load
  cf_expect_ret
  xt' const_fold_div_mod_fun cf_expect_word

  cf_expect_clear
  0 0  cf_expect_load
  1 29 cf_expect_load
  2 29 cf_expect_load
  3 0  cf_expect_load
  cf_expect_ret
  xt' const_fold_div_zero_fun cf_expect_word

  cf_expect_clear
  0 1 cf_expect_load
  1 1 cf_expect_load
  2 1 cf_expect_load
  3 1 cf_expect_load
  cf_expect_ret
  xt' const_fold_udiv_mod_fun cf_expect_word

  0 0 3 asm_lsl_imm { instr0 }
  0 asm_neg { instr1 }
  instr0 instr1 xt' const_fold_mul_pow2_rhs_imm_fun cf_expect_word2

  0 1 3 asm_lsl_imm xt' const_fold_mul_pow2_lhs_imm_fun cf_expect_lhs_imm1

  0 0 3 asm_lsr_imm xt' const_fold_udiv_pow2_rhs_imm_fun cf_expect_word1
  0 0 7 asm_and_imm xt' const_fold_umod_pow2_rhs_imm_fun cf_expect_word1
end
test_const_fold_div_mod

