use' ../lang.af

true try_all

128 mem: CF_EXPECT_INSTRS
0   var: CF_EXPECT_LEN

fun: cf_expect_clear 0 CF_EXPECT_LEN ! end

fun: cf_expect_instr { instr }
  CF_EXPECT_LEN @ { ind }
  instr CF_EXPECT_INSTRS ind 4 * + !32
  ind inc CF_EXPECT_LEN !
end

fun: cf_sym_instr_len { XT -- len }
  XT Sym_union Sym_norm_spans { spans }
  spans Sym_instrs_ret @u32 inc
  spans Sym_instrs_prologue @u32 -
end

fun: cf_actual_instr { XT ind -- instr }
  XT sym_instr ind 4 * + @u32
end

fun: cf_expect_word { XT -- err }
  CF_EXPECT_LEN @ { exp_len }
  XT cf_sym_instr_len { act_len }
  if exp_len act_len <> then
    " [test] instruction length mismatch: expected %zd, actual %zd" exp_len act_len errf throw
  end

  0 { ind }
  loop
    ind exp_len < while
    CF_EXPECT_INSTRS ind 4 * + @u32 { exp }
    XT ind cf_actual_instr          { act }
    if exp act <> then
      " [test] instruction mismatch at %zd: expected 0x%zx, actual 0x%zx" ind exp act errf throw
    end
    inc: ind
  end
end

fun: cf_imm_lane { imm hw -- lane }
  imm hw 16 * lsr 0xffff and
end

fun: cf_base_hw { bits -- hw }
  if bits 0 cf_imm_lane then 0 ret end
  if bits 1 cf_imm_lane then 1 ret end
  if bits 2 cf_imm_lane then 2 ret end
  if bits 3 cf_imm_lane then 3 ret end
  0
end

fun: cf_expect_movk_if { reg neg base_hw hw bits }
  bits hw cf_imm_lane { lane }
  if hw base_hw <> then
    if lane then
      if neg then lane invert 0xffff and else lane end { imm16 }
      reg 0b11 hw imm16 asm_mov_wide cf_expect_instr
    end
  end
end

fun: cf_expect_load { reg imm }
  imm <0 { neg }
  if neg then imm invert else imm end { bits }
  if neg then 0b00 else 0b10 end     { opc }

  bits cf_base_hw { hw }
  bits hw cf_imm_lane { imm16 }
  reg opc hw imm16 asm_mov_wide cf_expect_instr

  reg neg hw 0 bits cf_expect_movk_if
  reg neg hw 1 bits cf_expect_movk_if
  reg neg hw 2 bits cf_expect_movk_if
  reg neg hw 3 bits cf_expect_movk_if
end

fun: cf_expect_ret asm_ret cf_expect_instr end

fun: cf_expect_load_word { imm XT -- err }
  cf_expect_clear
  0 imm cf_expect_load
  cf_expect_ret
  XT cf_expect_word
end

fun: cf_expect_word1 { instr XT -- err }
  cf_expect_clear
  instr cf_expect_instr
  cf_expect_ret
  XT cf_expect_word
end

fun: cf_expect_word2 { instr0 instr1 XT -- err }
  cf_expect_clear
  instr0 cf_expect_instr
  instr1 cf_expect_instr
  cf_expect_ret
  XT cf_expect_word
end

fun: cf_expect_lhs_imm1 { instr XT -- err }
  cf_expect_clear
  2 0 asm_mov_reg cf_expect_instr
  1 2 asm_mov_reg cf_expect_instr
  instr cf_expect_instr
  cf_expect_ret
  XT cf_expect_word
end

fun: cf_expect_load_lhs_imm1 { instr imm XT -- err }
  cf_expect_clear
  0 imm cf_expect_load
  2 0 asm_mov_reg cf_expect_instr
  1 2 asm_mov_reg cf_expect_instr
  instr cf_expect_instr
  cf_expect_ret
  XT cf_expect_word
end

fun_comp: cf_expect_top_not_foldable { -- err }
  1 nil comp_args_min
  comp_args_get dec { reg }
  reg comp_arg { val }
  val cf_arg_foldable_imm { imm ok }
  if ok then
    " [test] expected non-foldable top reg; got immediate %zd" imm errf throw
  end
end

fun_comp: cf_expect_reg_no_local { reg -- err }
  reg comp_arg { val }
  val Interp_comp_arg_loc_field Interp_comp_arg_loc_loc @ { loc }
  if loc then
    " [test] expected no local in reg %zd" reg errf throw
  end
end

fun: cf_expect_sym_clobbers_reg { XT reg -- err }
  XT Sym_clobber @ { clobber }
  clobber 1 reg lsl and { has_clobber }
  ifz has_clobber then
    " [test] expected clobber for reg %zd" reg errf throw
  end
end

fun_comp: cf_expect_top_foldable { exp -- err }
  1 nil comp_args_min
  comp_args_get dec { reg }
  reg comp_arg { val }
  val cf_arg_foldable_imm { imm ok }
  ifz ok then " [test] expected foldable top reg" throw end
  if imm exp <> then
    " [test] expected top immediate %zd; got %zd" exp imm errf throw
  end
end

fun: const_fold_arith_fun { -- val } 10 20 30 40 + - * end

fun: test_const_fold_arith { -- err }
  assert= const_fold_arith_fun -500 end
  ifz has_interp then ret end

  -500 xt' const_fold_arith_fun cf_expect_load_word
end
test_const_fold_arith

