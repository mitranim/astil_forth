fun: .const_fold_gt_rhs_imm_fun { val -- out } val 20 > end
fun: .const_fold_lt_rhs_imm_fun { val -- out } val 20 < end
fun: .const_fold_le_rhs_imm_fun { val -- out } val 20 <= end
fun: .const_fold_ge_rhs_imm_fun { val -- out } val 20 >= end
fun: .const_fold_ugt_rhs_imm_fun { val -- out } val 20 u> end
fun: .const_fold_ult_rhs_imm_fun { val -- out } val 20 u< end
fun: .const_fold_ule_rhs_imm_fun { val -- out } val 20 u<= end
fun: .const_fold_uge_rhs_imm_fun { val -- out } val 20 u>= end

fun: .cf_want_cmp_rhs_imm { XT cond -- err }
  0 20 .asm_cmp_imm { instr0 }
  0 cond .asm_cset { instr1 }
  instr0 instr1 XT .cf_want_word2
end

fun: .test_const_fold_compare2 { -- err }
  .const_fold_compare2_fun { out0 out1 out2 out3 out4 out5 out6 out7 }
  assert= out0 3 end
  assert= out1 7 end
  assert= out2 1 end
  assert= out3 1 end
  assert= out4 1 end
  assert= out5 1 end
  assert= out6 1 end
  assert= out7 1 end
  ifz .has_interp .then .ret end

  .cf_want_clear
  0 3 .cf_want_load
  1 7 .cf_want_load
  2 1 .cf_want_load
  3 1 .cf_want_load
  4 1 .cf_want_load
  5 1 .cf_want_load
  6 1 .cf_want_load
  7 1 .cf_want_load
  .cf_want_ret
  xt' .const_fold_compare2_fun .cf_want_word

  xt' .const_fold_eq_rhs_imm_fun ASM_EQ .cf_want_cmp_rhs_imm
  xt' .const_fold_ne_rhs_imm_fun ASM_NE .cf_want_cmp_rhs_imm
  xt' .const_fold_gt_rhs_imm_fun ASM_GT .cf_want_cmp_rhs_imm
  xt' .const_fold_lt_rhs_imm_fun ASM_LT .cf_want_cmp_rhs_imm
  xt' .const_fold_le_rhs_imm_fun ASM_LE .cf_want_cmp_rhs_imm
  xt' .const_fold_ge_rhs_imm_fun ASM_GE .cf_want_cmp_rhs_imm
  xt' .const_fold_ugt_rhs_imm_fun ASM_HI .cf_want_cmp_rhs_imm
  xt' .const_fold_ult_rhs_imm_fun ASM_LO .cf_want_cmp_rhs_imm
  xt' .const_fold_ule_rhs_imm_fun ASM_LS .cf_want_cmp_rhs_imm
  xt' .const_fold_uge_rhs_imm_fun ASM_HS .cf_want_cmp_rhs_imm
end
.test_const_fold_compare2

