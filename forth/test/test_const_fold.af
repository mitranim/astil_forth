fun_comp: cf_expect_reg_no_fix { reg -- err }
  reg comp_arg Interp_comp_arg_loc_field Interp_comp_arg_loc_fix @ { fix }
  if fix then " [test] expected no fixup in reg %zd" reg errf throw end
end

fun_comp: cf_expect_reg_fix { reg -- err }
  reg comp_arg Interp_comp_arg_loc_field Interp_comp_arg_loc_fix @ { fix }
  ifz fix then " [test] expected fixup in reg %zd" reg errf throw end
end

fun: const_fold_local_fix_reassign_fun { -- out }
  41 { old }
  [ comp_barrier ] old
  [ 0 cf_expect_reg_fix ]
  [ s` new` comp_local 0 swap comp_assign_local_from_reg ]
  [ 0 cf_expect_reg_no_fix ]
  { -- }
  new inc
end

fun: test_const_fold_local_fix_reassign { -- err }
  assert= const_fold_local_fix_reassign_fun 42 end
end
test_const_fold_local_fix_reassign

