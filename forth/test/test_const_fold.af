  .cf_want_clear
  0 1 .cf_want_load
  1 1 .cf_want_load
  2 4096 .cf_want_load
  3 8192 .cf_want_load
  .cf_want_ret
  xt' .const_fold_pow2_ceil_fun .cf_want_word
end
.test_const_fold_pow2_ceil

