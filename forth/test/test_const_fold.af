  assert= 21 const_fold_ge_lhs_imm_fun 0 end
  assert= 21 const_fold_ugt_rhs_imm_fun 1 end
  assert= 20 const_fold_ugt_rhs_imm_fun 0 end
  assert= 19 const_fold_ugt_lhs_imm_fun 1 end
  assert= 20 const_fold_ugt_lhs_imm_fun 0 end
  assert= 19 const_fold_ult_rhs_imm_fun 1 end
  assert= 20 const_fold_ult_rhs_imm_fun 0 end
  assert= 21 const_fold_ult_lhs_imm_fun 1 end
  assert= 20 const_fold_ult_lhs_imm_fun 0 end
  assert= 20 const_fold_ule_rhs_imm_fun 1 end
  assert= 21 const_fold_ule_rhs_imm_fun 0 end
