fun: .test_escaped_literals { -- err }
  s" one\ntwo" { str len }
  assert= len 7 end
  assert= str 3 + @b LF end
  assert= str len + @b 0 end

  " tab\there" { cstr }
  assert= cstr .strlen 8 end
  assert= cstr 3 + @b TAB end

  s` one\`two\"three` { tick_str tick_len }
  assert= tick_len 13 end
  assert= tick_str 3 + @b 96 end
  assert= tick_str 7 + @b 34 end

  rs" one\ntwo" { raw_str raw_len }
  assert= raw_len 8 end
  assert= raw_str 3 + @b 92 end
  assert= raw_str 4 + @b char' n end

  r` tab\there` { raw_cstr }
  assert= raw_cstr .strlen 9 end
  assert= raw_cstr 3 + @b 92 end

  ` line\nbreak` { tick_cstr }
  assert= tick_cstr 4 + @b LF end

  rs` raw\ntext` { raw_tick_str raw_tick_len }
  assert= raw_tick_len 9 end
  assert= raw_tick_str 3 + @b 92 end
end
.test_escaped_literals

