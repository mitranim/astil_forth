fun: .test_strf_into { -- err }
  32 .alloca { out }

  out 32 " codes: %zd " 10 .strf_into { buf cap }
  assert= buf out 10 + end
  assert= cap 22 end

  buf cap " %zd" 20 .strf_into { buf cap }
  assert= buf out 12 + end
  assert= cap 20 end
  out " codes: 10 20" .assert_str_eq

  4 .alloca { trunc }
  trunc 4 " abcdef" .strf_into { buf cap }
  assert= buf trunc 3 + end
  assert= cap 1 end
  trunc " abc" .assert_str_eq

  out 0 " ignored" .strf_into { buf cap }
  assert= buf out end
  assert= cap 0 end

  4 .alloca .strf_into_infallible { buf cap }
  assert= cap 1 end
  buf 3 - " abc" .assert_str_eq
end
.test_strf_into

fun: .test_errf_exact_fill { -- err }
  alloca' Ctx { ctx }
  2 .alloca { buf }
  buf 2 ctx .ctx_init
  context { prev_ctx }

  ctx .with_ctx
    " A" .errf { out }
  end

  assert= context prev_ctx end
  out " A" .assert_str_eq
end
.test_errf_exact_fill

fun: .test_errf_out_of_space { -- err }
  alloca' Ctx { ctx }
  nil 0 ctx .ctx_init

