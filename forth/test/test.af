fun: .test_comptime_stack_arith { -- err }
  assert= 234 123 - 111 end
  assert= 234 123 + 357 end
  assert= 234 123 * 28782 end
  assert= 10 20 + 30 40 - * -300 end
  assert= 10 20 + 100 30 - * 2100 end
  assert= 24 4 / 64 8 u/ + 14 end
  assert= 29 5 .mod 20 6 .mod + 6 end
  assert= 29 5 /mod 20 6 /mod + + + 14 end
  assert= 1 4 .lsl 128 3 .lsr + 32 end
  assert= -128 2 .asr 0xff .and 224 end
  assert= 0b1010 0b1100 .or 0b0110 .xor 0b1000 end
  assert= 10 20 < 30 5 > + 2 end
  assert= 20 30 + =0 false end
  assert= 10 20 30 + <>0 + 11 end
  assert= -123 .abs 10 20 .min 30 40 .max + + 173 end
  assert= 255 .bit_len 256 .bit_len + 17 end
end
.test_comptime_stack_arith

