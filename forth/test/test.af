0 var: TEST_PARAMS_PUSH_VOID_VAL
fun: test_params_push_sum { left right -> sum } + end
fun: test_params_push_sum3 { one two three -> sum } + + end
fun: test_params_push_void { val -> } TEST_PARAMS_PUSH_VOID_VAL ! end

fun: test_params_push { -- err }
  10 test_params_push_void
  assert= 10 20 test_params_push_sum 30 end
  assert= 10 20 30 test_params_push_sum3 60 end
  assert= TEST_PARAMS_PUSH_VOID_VAL @ 10 end
