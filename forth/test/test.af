fun: test_conditionals { -- err }
  \ Must fail to compile: bare `if then end`
  \ doesn't support outputs.
  \ if false then 10 end

  T{ if false then 10 else 20 end <T> 20 }T
  T{ if true  then 10 else 20 end <T> 10 }T

  T{ ifz false then 10 else 20 end <T> 10 }T
  T{ ifz true  then 10 else 20 end <T> 20 }T

  T{
    if false then 10 elif true then 20 else 30 end
  <T>
    20
  }T

  T{
    if false then 10 elifz false then 20 else 30 end
  <T>
    20
  }T

  T{
    10 { loc }
    if false then 20 else 30 end { out }
    loc out
  <T>
    10 30
  }T

  T{ -1 { val } if false then 10 { val } end val <T> -1 }T
  T{ -1 { val } if true  then 10 { val } end val <T> 10 }T

  T{ if false then 10 else 20 end <T> 20 }T
  T{ if true  then 10 else 20 end <T> 10 }T

  T{ -1 { val } ifz false then 10 { val } end val <T> 10 }T
  T{ -1 { val } ifz true  then 10 { val } end val <T> -1 }T

  T{ ifz false then 10 else 20 end <T> 10 }T
  T{ ifz true  then 10 else 20 end <T> 20 }T

  T{
    -1 { val }
    if false then 10 { val } elif false then 20 { val } end val
  <T>
    -1
  }T

  T{
    if false then 10 elif false then 20 else 30 end
  <T>
    30
  }T

  T{
    -1 { val }
    if false then 10 { val } elif true then 20 { val } end val
  <T>
    20
  }T

  T{
    if false then 10 elif true then 20 else 30 end
  <T>
    20
  }T

  T{
    -1 { val }
    if true then 10 { val } elif false then 20 { val } end val
  <T>
    10
  }T

  T{
    if true then 10 elif false then 20 else 30 end
  <T>
    10
  }T

  T{
    -1 { val }
    if false then 10 { val } elifz false then 20 { val } end val
  <T>
    20
  }T

  T{
    if false then 10 elifz false then 20 else 30 end
  <T>
    20
  }T

  T{
    -1 { val }
    if false then 10 { val } elifz true then 20 { val } end val
  <T>
    -1
  }T

  T{
    if false then 10 elifz true then 20 else 30 end
  <T>
    30
  }T

  T{
    -1 { val }
    if true then 10 { val } elifz false then 20 { val } end val
  <T>
    10
  }T

  T{
    if true then 10 elifz false then 20 else 30 end
  <T>
    10
  }T

  T{
    -1 { val }
    if false then
      10 { val }
    else
      if true then
        20 { val }
      end
    end
    val
  <T>
    20
  }T

end
test_conditionals

fun: cond_input_if { val flag -- out } val flag if then end end
fun: cond_input_ifn { val flag -- out } val flag ifz then end end
fun: cond_input_if_else { val flag -- out } val flag if then else end end

fun: cond_input_elif { val flag0 flag1 -- out }
  val flag0 if then
  elif flag1 then
  else
  end
end

fun: cond_input_elifn { val flag0 flag1 -- out }
  val flag0 if then
  elifz flag1 then
  else
  end
end

fun: cond_input_elif_diff { flag0 flag1 -- out0 out1 }
  20 flag0 if then drop 10 11
  elif flag1 then 30
  else 40
  end
end

fun: cond_input_elif_diff_no_else { flag0 flag1 -- out }
  20 flag0 if then drop 10
  elif flag1 then
  end
end

fun: cond_input_max { A B C D E F G flag -- A B C D E F G }
  A B C D E F G flag if then end
end

fun: test_cond_input_arity { -- err }
  T{ 123 false cond_input_if <T> 123 }T
  T{ 123 true  cond_input_if <T> 123 }T

  T{ 234 false cond_input_ifn <T> 234 }T
  T{ 234 true  cond_input_ifn <T> 234 }T

  T{ 345 false cond_input_if_else <T> 345 }T
  T{ 345 true  cond_input_if_else <T> 345 }T

  T{ 456 false false cond_input_elif <T> 456 }T
  T{ 456 false true  cond_input_elif <T> 456 }T
  T{ 456 true  false cond_input_elif <T> 456 }T

  T{ 567 false false cond_input_elifn <T> 567 }T
  T{ 567 false true  cond_input_elifn <T> 567 }T
  T{ 567 true  false cond_input_elifn <T> 567 }T

  T{ false false cond_input_elif_diff <T> 20 40 }T
  T{ false true  cond_input_elif_diff <T> 20 30 }T
  T{ true  false cond_input_elif_diff <T> 10 11 }T

  T{ false false cond_input_elif_diff_no_else <T> 20 }T
  T{ false true  cond_input_elif_diff_no_else <T> 20 }T
  T{ true  false cond_input_elif_diff_no_else <T> 10 }T

  T{ 0 1 2 3 4 5 6 false cond_input_max <T> 0 1 2 3 4 5 6 }T
  T{ 0 1 2 3 4 5 6 true  cond_input_max <T> 0 1 2 3 4 5 6 }T
end
test_cond_input_arity

fun: recursive_fun { val -- val }
  if val 13 <= then val ret end
  val dec recur
end

fun: test_recursion { -- err }
  T{ 123 recursive_fun <T> 13 }T
end
test_recursion

fun: recur_reg_clobber_fun { val -- out }
  -1 -2   { -- }            \ Unconditionally clobber x0 x1.
  ifz val then 0 ret end
  val val { _ignored saved } \ `_ignored` = x0, `saved` = x1, `val` = none
  0 recur { -- }            \ Must relocate `saved`.
  saved inc
end

fun: test_recur_reg_clobber { -- err }
  T{ 10 recur_reg_clobber_fun <T> 11 }T
end
test_recur_reg_clobber

