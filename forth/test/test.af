fun: test_asm_append_imm_to_reg { -- err }
  32 alloca { buf }

  assert= 0 0 buf asm_append_imm_to_reg buf 4 + end
  assert= buf @u32 0b1_10_100101_00_0000000000000000_00000 end \ movz x0, #0

  assert= 0 -1 buf asm_append_imm_to_reg buf 4 + end
  assert= buf @u32 0b1_00_100101_00_0000000000000000_00000 end \ movn x0, #0

  assert= 3 0x1234_5678_9abc_def0 buf asm_append_imm_to_reg buf 16 + end
  assert= buf @u32 0b1_10_100101_00_1101111011110000_00011 end \ movz x3, #0xdef0
  assert= buf 4 + @u32 0b1_11_100101_01_1001101010111100_00011 end \ movk x3, #0x9abc, lsl #16
  assert= buf 8 + @u32 0b1_11_100101_10_0101011001111000_00011 end \ movk x3, #0x5678, lsl #32
  assert= buf 12 + @u32 0b1_11_100101_11_0001001000110100_00011 end \ movk x3, #0x1234, lsl #48

  assert= 3 -305419896 buf asm_append_imm_to_reg buf 8 + end
  assert= buf @u32 0b1_00_100101_00_0101011001110111_00011 end \ movn x3, #0x5677
  assert= buf 4 + @u32 0b1_11_100101_01_1110110111001011_00011 end \ movk x3, #0xedcb, lsl #16
end
test_asm_append_imm_to_reg

