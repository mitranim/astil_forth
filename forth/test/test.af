fun: .test_loop_manual_countdown { -- err }
  \ Should terminate right away.
  -12 { ind } loop dec: ind ind >=0 .while end
  -1 { ind } loop dec: ind ind >=0 .while end
  0 { ind } loop dec: ind ind >=0 .while end

  assert=
    0 12 { val ind }
    loop dec: ind ind >=0 .while inc: val end
    val
    12
  end

  assert=
    0 12 { val ind }
    loop dec: ind ind >=0 .while inc: val leave end
    val
    1
  end

  assert=
    0 12 { val ind }
    loop dec: ind ind >=0 .while leave inc: val end
    val
    0
  end

  assert=
    0 12 { val ind }
    loop
      dec: ind
      ind >=0 .while
      val 5 > .then leave end
      inc: val
    end
    val
    6
  end

  assert=
    0 12 { val ind }
    loop
      dec: ind
      ind >=0 .while
      val 6 < .while
      inc: val
    end
    val
    6
  end

  assert=
    0 12 { val ind }
    loop
      dec: ind
      ind >=0 .while
      val 5 < .while
      val 8 < .while
      inc: val
    end
    val
    5
  end

  assert=
    0 12 { val ind }
    loop
      dec: ind
      ind >=0 .while
      val 8 < .while
      val 5 < .while
      inc: val
    end
    val
    5
  end
end
.test_loop_manual_countdown

fun: .test_loop_manual_counting { -- err }
  0 0 { acc ind }
  loop
    ind 12 < .while
    ind +: acc
    inc: ind
  end
  assert= acc 66 end
  assert= ind 12 end

  0 { acc }
  8 { ind }
  loop
    ind 2 - { ind }
    0 ind <= .while
    ind +: acc
  end
  assert= acc 12 end
  assert= ind -2 end
end
.test_loop_manual_counting

