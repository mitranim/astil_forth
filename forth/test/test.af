  use' ./fail/test_call_missing_dot_comp.af
  " undefined word `logf`: use `.logf`"
  .assert_str_has .try

  use' ./fail/test_call_extra_dot_local.af
  " undefined word `.val`: use `val`"
  .assert_str_has .try

  use' ./fail/test_local_name_leading_dot.af
  " invalid local name `.val`: local names must be ident-like"
  .assert_str_has .try

  use' ./fail/test_local_assignment_leading_dot.af
  " invalid local name `.tmp`: local names must be ident-like"
  .assert_str_has .try

  use' ./fail/test_local_name_numeric.af
  " invalid local name `1val`: local names must be ident-like"
  .assert_str_has .try

  use' ./fail/test_local_assignment_numeric.af
  " invalid local name `1tmp`: local names must be ident-like"
  .assert_str_has .try

  use' ./fail/test_local_name_non_ident.af
  " invalid local name `val-name`: local names must be ident-like"
  .assert_str_has .try

  use' ./fail/test_local_assignment_non_ident.af
  " invalid local name `tmp.name`: local names must be ident-like"
  .assert_str_has .try

  use' ./fail/test_call_extra_dot_value.af
  " undefined word `.TEST_VALUE`: use `TEST_VALUE`"
  .assert_str_has .try

  use' ./fail/test_call_missing_dot_control.af
  " undefined word `try`: use `.try`"
  .assert_str_has .try

  use' ./fail/test_call_extra_dot.af
  " undefined word `.u/`: use `u/`"
  .assert_str_has .try

  use' ./fail/test_value_name_non_ident.af
  " invalid declaration `BAD-VALUE`; use an ident-like name or remove `.plain_call`"
  .assert_str_has .try

  use' ./fail/test_call_undefined.af
  " undefined word `.MISSING_WORD`"
  .assert_str_has .try

  use' ./fail/test_declaration_ident.af
  " invalid declaration `bad_name`; use `.bad_name`"
  .assert_str_has .try

  use' ./fail/test_declaration_numeric.af
  " invalid declaration `1bad_name`; use `.1bad_name`"
  .assert_str_has .try

  use' ./fail/test_declaration_signed_numeric.af
  " invalid declaration `+1bad_name`; use `.+1bad_name`"
  .assert_str_has .try

  use' ./fail/test_extern_declaration_precedes_redefinition.af
  " invalid declaration `bad_name`; use `.bad_name`"
  .assert_str_has .try

end
.test_call_name_failures

