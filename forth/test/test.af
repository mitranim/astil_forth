fun: test_alloca_align { -- err }
  systack_ptr { SP }
  1 alloca { adr0 }
  2 alloca { adr1 }
  4 alloca { adr2 }
  8 alloca { adr3 }
  16 alloca { adr4 }
  32 alloca { adr5 }

  \ Compiler ensures natural alignment up to 16.
  assert= adr1 2 mod 0 end
  assert= adr2 4 mod 0 end
  assert= adr3 8 mod 0 end
  assert= adr4 16 mod 0 end
  assert= adr5 16 mod 0 end

  assert= adr0 SP 16 - end
  assert= adr1 SP 32 - end
  assert= adr2 SP 48 - end
  assert= adr3 SP 64 - end
  assert= adr4 SP 80 - end
  assert= adr5 SP 112 - end
end
test_alloca_align

