fun: test_loop_leave { -- err }
  T{ -1 { val } loop            leave abort             end val <T> -1 }T
  T{ -1 { val } loop 10 { val } leave abort             end val <T> 10 }T
  T{ -1 { val } loop 10 { val } leave abort leave abort end val <T> 10 }T
end
test_loop_leave

fun: test_loop_nested { -- err }
  T{
    -1 { one }
    -2 { two }
    -3 { three }
    loop
      10 { one }
      loop
        20 { two }
        leave
      end
      30 { three }
      leave
    end
    one two three
  <T>
    10 20 30
  }T
end
test_loop_nested

fun: test_loop_while { -- err }
  T{
    -1 { val }
    loop false while 10 { val } end
    val
  <T>
    -1
  }T

  T{
    -1 { val }
    loop 10 { val } false while 20 { val } end
    val
  <T>
    10
  }T

  T{
    -1 { val }
    loop 10 { val } false while 20 { val } true while end
    val
  <T>
    10
  }T

  T{
    -1 { val }
    loop 10 { val } true while 20 { val } false while end
    val
  <T>
    20
  }T

  T{
    12 { val }
    loop
      val 5 > while
      dec: val
    end
    val
  <T>
    5
  }T

  T{
    12 { val }
    loop
      val 5 > while
      val 7 > while
      dec: val
    end
    val
  <T>
    7
  }T

  T{
    12 { val }
    loop
      dec: val
      val while
      val while
      val while
    end
    val
  <T>
    0
  }T
end
test_loop_while

fun: test_loop_while_leave { -- err }
