  10 ptr .Typ_field0 !
  assert= ptr .Typ_field0 @ 10 end

  assert= ptr .Typ_field1 @ 0 end
  20 ptr .Typ_field1 !
  assert= ptr .Typ_field1 @ 20 end

  assert= ptr .Typ_field0 @ 10 end
  30 ptr .Typ_field0 !
  assert= ptr .Typ_field0 @ 30 end

  assert= ptr .Typ_field1 @ 20 end
  40 ptr .Typ_field1 !
  assert= ptr .Typ_field1 @ 40 end
end
.test_struct_fields_load_store

