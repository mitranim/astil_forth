  T{ two <T> 234 }T

  T{ 123 test_explicit_err_3_fun { one two err } <T>              }T
  T{ one two err                                 <T> 246 -123 nil }T
  T{ 123 test_explicit_err_3_fun                 <T> 246 -123 nil }T
end
test_explicit_err_3

fun: test_explicit_err_4_fun { one two -- three four err }
  ifz one then test_throw end
  one two + { three }
