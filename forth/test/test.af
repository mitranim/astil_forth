use' ../lang.af
use' ../testing.af
use' ../arena.af

\ We test both JIT-compiled and AOT-compiled modes.
\ For AOT, every test must be called in `main_run`.

true try_all

T{       <T>       }T
T{ 10    <T> 10    }T
T{ 10 20 <T> 10 20 }T

fun: test_test { -- err }
  T{       <T>       }T
  T{ 10    <T> 10    }T
  T{ 10 20 <T> 10 20 }T
end
test_test

fun: test_empty_comment { -- err }
  \ `\` immediately followed by newline: this used to skip the NEXT line.
  \
  10 20 30
  { one two three }
  T{ one two three <T> 10 20 30 }T
end
test_empty_comment

