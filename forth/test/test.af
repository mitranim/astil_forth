fun: .test_bit_masks { -- err }
  assert= 5 .low_bits 31 end
  assert= 0x1238 8 .is_aligned_to 1 end
  assert= 0x1234 8 .is_aligned_to 0 end
  assert= 0x1234 16 .align_down 0x1230 end
  assert= 0x1234 16 .align_up 0x1240 end
  assert= 0x1234 8 .bits_trunc 0x34 end
  assert= 0b1001000110100 0b111111110000 .bit_mask_get 0b100011 end
  assert= 0b1001000110100 0b11110000 .bits_clear 0b1001000000100 end
  assert=
    0b10101011 0b1001000110100 0b111111110000 .bit_mask_set
    0b1101010110100
  end
  assert=
    0b0 0b1001000110100 0b111111110000 .bit_mask_set
    0b1000000000100
  end
  99 0b10101011 0b1001000110100 0b111111110000 .bit_mask_set { val mask }
  assert= val 99 end
  assert= mask 0b1101010110100 end
end
.test_bit_masks

fun: .test_local_mutators { -- err }
  10 { val } 7 +: val assert= val 17 end
  7 { val } 3 *: val assert= val 21 end
  0b110101 { val } 0b101010 and: val assert= val 0b100000 end
  0b110101 { val } 0b001010 or: val assert= val 0b111111 end
  0b110101 { val } 0b101010 xor: val assert= val 0b011111 end

  -100 { val } 6 min: val assert= val -100 end
  -1 { val } 10 umin: val assert= val 10 end
  81 { val } -10 max: val assert= val 81 end
  -1 { val } 10 umax: val assert= val -1 end
  42 { val } 99 fallback: val assert= val 99 end
  7 { val } 7 =: val assert= val 1 end
  7 { val } 8 <>: val assert= val 1 end

  41 { val } inc: val assert= val 42 end dec: val assert= val 41 end
  42 { val } negate: val assert= val -42 end
  -42 { val } abs: val assert= val 42 end
  0b101010 { val } invert: val assert= val 0b101010 .invert end
  60 { val } bit_clz: val assert= val 58 end
  40 { val } bit_ctz: val assert= val 3 end
  40 { val } bit_len: val assert= val 6 end
  4097 { val } pow2_ceil: val assert= val 8192 end
  0xffffffff { val } cint_to_cell: val assert= val -1 end
  7 { val } cells: val assert= val 56 end
  56 { val } /cells: val assert= val 7 end
  100 { val } +cell: val assert= val 108 end
  100 { val } -cell: val assert= val 92 end
  101 { val } odd: val assert= val 1 end
  5 { val } low_bits: val assert= val 31 end

  0 { val } =0: val assert= val 1 end
  7 { val } <>0: val assert= val 1 end
  -7 { val } <0: val assert= val 1 end
  7 { val } >0: val assert= val 1 end
  0 { val } <=0: val assert= val 1 end
  0 { val } >=0: val assert= val 1 end

  0b100000000001 { val }
  0b0110 0b11110000 bit_mask_set: val
  assert= val 0b100001100001 end
end
.test_local_mutators

fun: .test_asm_new_bits { -- err }
  assert= 2 3 4 .asm_bic 0b10001010001001000000000001100010 end
  assert= 2 3 .asm_rbit 0b11011010110000000000000001100010 end
  assert= 2 3 .asm_clz 0b11011010110000000001000001100010 end
  assert= 2 3 .asm_ctz 0b11011010110000000001100001100010 end
  1 .asm_logical_imm_enc { N immr imms }
  assert= N 1 end
  assert= immr 0 end
  assert= imms 0 end
  0xff .asm_logical_imm_enc { N immr imms }
  assert= N 1 end
  assert= immr 0 end
  assert= imms 7 end
  0x00ff_00ff_00ff_00ff .asm_logical_imm_enc { N immr imms }
  assert= N 0 end
  assert= immr 0 end
  assert= imms 39 end
  0x8000_0000_0000_0000 .asm_logical_imm_enc { N immr imms }
  assert= N 1 end
  assert= immr 1 end
  assert= imms 0 end
  0 .asm_logical_imm_enc_err { err }
  err " unable to encode logical immediate: 0 is reserved" .assert_str_eq
  -1 .asm_logical_imm_enc_err { err }
  err " unable to encode logical immediate: all ones is reserved" .assert_str_eq
  0x1234_5678_9abc_def0 .asm_logical_imm_enc_err { err }
  err " unable to encode logical immediate: value is not a repeated bitmask" .assert_str_eq
  assert= 0 0 1 .asm_and_imm 0b1_00_100100_1_000000_000000_00000_00000 end
  assert= 0 0 1 .asm_orr_imm 0b1_01_100100_1_000000_000000_00000_00000 end
  assert= 0 0 1 .asm_eor_imm 0b1_10_100100_1_000000_000000_00000_00000 end
  0 0 -2 .asm_and_imm { bic_exp }
  assert= 0 0 1 .asm_bic_imm bic_exp end
  0 0 0 .asm_and_imm_err { _instr err }
  err " unable to encode logical immediate: 0 is reserved" .assert_str_eq
end
.test_asm_new_bits

