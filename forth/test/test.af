  spans .Sym_instrs_ret @u32 .inc
  spans .Sym_instrs_prologue @u32 -
end

fun: .test_actual_instr { XT ind -- instr }
  XT .xt_instr ind 4 * + @u32
end

fun: .test_word_instr_count { XT instr -- count }
  XT .test_sym_instr_len { len }
  0 { count }
  0 { ind }
  loop
    ind len < .while
    XT ind .test_actual_instr instr = .then inc: count end
    inc: ind
  end
  count
end

fun: .test_word_has_branch_cond { XT cond -- bool }
  \ Matches `b.<cond>` while ignoring the PC-relative offset.
  0b11111111_0000000000000000000_1_0000 { mask }
  0b01010100_0000000000000000000_0_0000 { match }

  XT .test_sym_instr_len { len }
  0 { ind }
  loop
    ind len < .while
    XT ind .test_actual_instr { instr }
    instr mask .and match = instr 0xf .and cond = .and .then true .ret end
    inc: ind
  end
  false
end

fun: .test_word_has_cset { XT -- bool }
  XT .test_sym_instr_len { len }
  0 { ind }
  loop
    ind len < .while
    XT ind .test_actual_instr .asm_cset_decode { _reg _cond ok }
    ok .then true .ret end
    inc: ind
  end
  false
end

fun: .test_word_has_cbnz { XT -- bool }
  XT .test_sym_instr_len { len }
  0 { ind }
  loop
    ind len < .while
    XT ind .test_actual_instr 24 .lsr 0xff .and 0xb5 = .then
      true .ret
    end
    inc: ind
  end
  false
end

