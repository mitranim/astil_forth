fun: test_loop_leave { -- err }
  assert=
    -1 { val } loop leave abort end val
    -1
  end
  assert=
    -1 { val } loop 10 { val } leave abort end val
    10
  end
  assert=
    -1 { val } loop 10 { val } leave abort leave abort end val
    10
  end
end
test_loop_leave

fun: test_loop_nested { -- err }
  -1 { one }
  -2 { two }
  -3 { three }
  loop
    10 { one }
    loop
      20 { two }
      leave
    end
    30 { three }
    leave
  end
  assert= one 10 end
  assert= two 20 end
  assert= three 30 end
end
test_loop_nested

fun: test_sym_instr_len { XT -- len }
  XT Sym_union Sym_norm_spans { spans }
  spans Sym_instrs_ret @u32 inc
  spans Sym_instrs_prologue @u32 -
end

fun: test_actual_instr { XT ind -- instr }
  XT sym_instr ind 4 * + @u32
end

fun: test_word_instr_count { XT instr -- count }
  XT test_sym_instr_len { len }
  0 { count }
  0 { ind }
  loop
    ind len < while
    if XT ind test_actual_instr instr = then inc: count end
    inc: ind
  end
  count
end

fun: test_word_has_branch_cond { XT cond -- bool }
  \ Matches `b.<cond>` while ignoring the PC-relative offset.
  0b11111111_0000000000000000000_1_0000 { mask }
  0b01010100_0000000000000000000_0_0000 { match }

  XT test_sym_instr_len { len }
  0 { ind }
  loop
    ind len < while
    XT ind test_actual_instr { instr }
    instr mask and match = instr 0xf and cond = and if then true ret end
    inc: ind
  end
  false
end

fun: test_word_has_cset { XT -- bool }
  XT test_sym_instr_len { len }
  0 { ind }
  loop
    ind len < while
    XT ind test_actual_instr asm_cset_decode { _reg _cond ok }
    ok if then true ret end
    inc: ind
  end
  false
end

fun: test_while_cset_branch_fusion_fun { val -- out }
  0 { out }
  loop
    val 0 >= while
    inc: out
    dec: val
  end
  out
end

fun: test_while_cset_branch_fusion { -- err }
  assert= 3 test_while_cset_branch_fusion_fun 4 end
  assert= -1 test_while_cset_branch_fusion_fun 0 end
  assert xt' test_while_cset_branch_fusion_fun ASM_LT test_word_has_branch_cond end
