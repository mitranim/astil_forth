fun: .test_conditionals { -- err }
  \ Must fail to compile: conditional without `else`
  \ can't change stack arity.
  \ false .then 10 end

  assert= false .then 10 else 20 end 20 end
  assert= true .then 10 else 20 end 10 end

  assert= false =0 .then 10 else 20 end 10 end
  assert= true =0 .then 10 else 20 end 20 end

  assert=
    false .then 10 elif true .then 20 else 30 end
    20
  end

  assert=
    false .then 10 elif false =0 .then 20 else 30 end
    20
  end

  10 { loc }
  false .then 20 else 30 end { out }
  assert= loc 10 end
  assert= out 30 end

  assert= -1 { val } false .then 10 { val } end val -1 end
  assert= -1 { val } true .then 10 { val } end val 10 end

  assert= false .then 10 else 20 end 20 end
  assert= true .then 10 else 20 end 10 end

  assert= -1 { val } false =0 .then 10 { val } end val 10 end
  assert= -1 { val } true =0 .then 10 { val } end val -1 end

  assert= false =0 .then 10 else 20 end 10 end
  assert= true =0 .then 10 else 20 end 20 end

  assert=
    -1 { val }
    false .then 10 { val } elif false .then 20 { val } end val
    -1
  end

  assert=
    false .then 10 elif false .then 20 else 30 end
    30
  end

  assert=
    -1 { val }
    false .then 10 { val } elif true .then 20 { val } end val
    20
  end

  assert=
    false .then 10 elif true .then 20 else 30 end
    20
  end

  assert=
    -1 { val }
    true .then 10 { val } elif false .then 20 { val } end val
    10
  end

  assert=
    true .then 10 elif false .then 20 else 30 end
    10
  end

  assert=
    -1 { val }
    false .then 10 { val } elif false =0 .then 20 { val } end val
    20
  end

  assert=
    false .then 10 elif false =0 .then 20 else 30 end
    20
  end

  assert=
    -1 { val }
    false .then 10 { val } elif true =0 .then 20 { val } end val
    -1
  end

  assert=
    false .then 10 elif true =0 .then 20 else 30 end
    30
  end

  assert=
    -1 { val }
    true .then 10 { val } elif false =0 .then 20 { val } end val
    10
  end

  assert=
    true .then 10 elif false =0 .then 20 else 30 end
    10
  end

  assert=
    -1 { val }
    false .then
      10 { val }
    else
      true .then
        20 { val }
      end
    end
    val
    20
  end

end
.test_conditionals

0 var: TEST_COND_PRED_HITS

fun: .test_cond_pred { bool -- bool }
  TEST_COND_PRED_HITS @ .inc TEST_COND_PRED_HITS !
  bool
end

fun: .test_cond_skip_pred { pred0 -- val }
  0 TEST_COND_PRED_HITS !
  pred0 .then 10
  elif false .test_cond_pred .then 20
  else 30
  end
end

fun: .test_cond_skip_predicates { -- err }
  assert= true .test_cond_skip_pred 10 end
  assert= TEST_COND_PRED_HITS @ 0 end
  assert= false .test_cond_skip_pred 30 end
  assert= TEST_COND_PRED_HITS @ 1 end
end
.test_cond_skip_predicates

fun: .test_control_meta { -- err }
  3 16 .asm_cbz { cbz_instr }
  3 16 .asm_cbnz { cbnz_instr }
  16 ASM_EQ .asm_branch_cond { cond_instr }

  assert=
    3 16 ASM_BRANCH_TYPE_CBZ nil .asm_cond_branch
    cbz_instr
  end
  assert=
    3 16 ASM_BRANCH_TYPE_CBNZ nil .asm_cond_branch
    cbnz_instr
  end
  assert=
    3 16 ASM_BRANCH_TYPE_COND ASM_EQ .asm_cond_branch
    cond_instr
  end

  3 nil CONT_MASK_INP_LEN .bit_mask_set { meta }
  0 meta CONT_MASK_OUT_LEN .bit_mask_set
  CONT_MASK_HAS_OUT .or { meta }
  assert= meta CONT_MASK_INP_LEN .bit_mask_get 3 end
  assert= meta CONT_MASK_OUT_LEN .bit_mask_get 0 end
  assert meta CONT_MASK_HAS_OUT .and end

  interp_instrs { instr_adr }
  instr_adr .instr_off meta .cont_meta_instr_off_set { meta }
  assert= meta .cont_meta_instr_adr instr_adr end

  assert= CONT_MASK_INSTR_OFF .bit_ctz 32 end
  assert= CONT_MASK_INSTR_OFF 32 .low_bits .and 0 end
  assert=
    CONT_MASK_INP_LEN
    CONT_MASK_OUT_LEN .or
    CONT_MASK_HAS_OUT .or
    CONT_MASK_BRANCH_TYPE .or
    CONT_MASK_INSTR_INFO .or
    32 .low_bits
  end
end
.test_control_meta

fun: .cond_input_if { val flag -- out } val flag .then end end
fun: .cond_input_ifn { val flag -- out } val flag =0 .then end end
fun: .cond_input_if_else { val flag -- out } val flag .then else end end

fun: .cond_input_elif { val flag0 flag1 -- out }
  val flag0 .then
  elif flag1 .then
  else
  end
end

fun: .cond_input_elifn { val flag0 flag1 -- out }
  val flag0 .then
  elif flag1 =0 .then
  else
  end
end

fun: .cond_input_elif_diff { flag0 flag1 -- out0 out1 }
  flag0 .then 10 11
  elif flag1 .then 20 30
  else 20 40
  end
end

fun: .cond_input_elif_diff_no_else { flag0 flag1 -- out }
  flag0 .then 10
  elif flag1 .then 20
  else 20
  end
end

fun: .cond_input_max { A B C D E F G flag -- A B C D E F G }
  A B C D E F G flag .then end
end

fun: .test_cond_input_arity { -- err }
  assert= 123 false .cond_input_if 123 end
  assert= 123 true .cond_input_if 123 end

  assert= 234 false .cond_input_ifn 234 end
  assert= 234 true .cond_input_ifn 234 end

  assert= 345 false .cond_input_if_else 345 end
  assert= 345 true .cond_input_if_else 345 end

  assert= 456 false false .cond_input_elif 456 end
  assert= 456 false true .cond_input_elif 456 end
  assert= 456 true false .cond_input_elif 456 end

  assert= 567 false false .cond_input_elifn 567 end
  assert= 567 false true .cond_input_elifn 567 end
  assert= 567 true false .cond_input_elifn 567 end

  false false .cond_input_elif_diff { val0 val1 }
  assert= val0 20 end
  assert= val1 40 end
  false true .cond_input_elif_diff { val2 val3 }
  assert= val2 20 end
  assert= val3 30 end
  true false .cond_input_elif_diff { val4 val5 }
  assert= val4 10 end
  assert= val5 11 end

  assert= false false .cond_input_elif_diff_no_else 20 end
  assert= false true .cond_input_elif_diff_no_else 20 end
  assert= true false .cond_input_elif_diff_no_else 10 end

  0 1 2 3 4 5 6 false .cond_input_max { val6 val7 val8 val9 val10 val11 val12 }
  assert= val6 0 end
  assert= val7 1 end
  assert= val8 2 end
  assert= val9 3 end
  assert= val10 4 end
  assert= val11 5 end
  assert= val12 6 end
  0 1 2 3 4 5 6 true .cond_input_max { val13 val14 val15 val16 val17 val18 val19 }
  assert= val13 0 end
  assert= val14 1 end
  assert= val15 2 end
  assert= val16 3 end
  assert= val17 4 end
  assert= val18 5 end
  assert= val19 6 end
end
.test_cond_input_arity

