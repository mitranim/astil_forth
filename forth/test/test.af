fun: test_loop_manual_countdown { -- err }
  \ Should terminate right away.
  T{ -12 { ind } loop dec: ind ind >=0 while end <T> }T
  T{ -1  { ind } loop dec: ind ind >=0 while end <T> }T
  T{ 0   { ind } loop dec: ind ind >=0 while end <T> }T

  T{
    0 12 { val ind }
    loop dec: ind ind >=0 while inc: val end
    val
  <T> 12 }T

  T{
    0 12 { val ind }
    loop dec: ind ind >=0 while inc: val leave end
    val
  <T> 1 }T

  T{
    0 12 { val ind }
    loop dec: ind ind >=0 while leave inc: val end
    val
  <T> 0 }T

  T{
    0 12 { val ind }
    loop
      dec: ind
      ind >=0 while
      if val 5 > then leave end
      inc: val
    end
    val
  <T>
    6
  }T

  T{
    0 12 { val ind }
    loop
      dec: ind
      ind >=0 while
      val 6 < while
      inc: val
    end
    val
  <T>
    6
  }T

  T{
    0 12 { val ind }
    loop
      dec: ind
      ind >=0 while
      val 5 < while
      val 8 < while
      inc: val
    end
    val
  <T>
    5
  }T

  T{
    0 12 { val ind }
    loop
      dec: ind
      ind >=0 while
      val 8 < while
      val 5 < while
      inc: val
    end
    val
  <T>
    5
  }T
end
test_loop_manual_countdown

fun: test_loop_manual_counting { -- err }
  T{
    0 0 { acc ind }
    loop
      ind 12 < while
      ind +: acc
      inc: ind
    end
    acc ind
  <T>
    66 12
  }T

  T{
    0 { acc }
    8 { ind }
    loop
      2 -: ind
      0 ind <= while
      ind +: acc
    end
    acc ind
  <T>
    12 -2
  }T
end
