fun: test_arena_unprot { adr -- err } adr ARENA_PAGE_MIN mem_unprot end

fun: test_arena_alloc { -- err }
  alloca' Arena { arn }
  arn arena_init

  assert= arn test_stack_len_bytes 0 end
  assert= arn Arena_low @ nil end

  1 arn arena_alloc { adr0 }
  arn Arena_low @ { page0 }

  assert= page0 test_stack_cap_bytes ARENA_PAGE_MIN end
  assert= page0 test_stack_len_bytes 1 end
  assert= arn test_stack_len_bytes size' Stack end

  7 arn arena_alloc { adr1 }

  assert= arn Arena_low @ page0 end
  assert= adr1 adr0 - FUND_ALIGN end
  assert= page0 test_stack_len_bytes FUND_ALIGN 7 + end
  assert= arn test_stack_len_bytes size' Stack end

  ARENA_PAGE_MIN arn arena_alloc { adr2 }
  arn Arena_low @ { page1 }

  assert<> page1 page0 end
  assert= page1 test_stack_cap_bytes ARENA_PAGE_MIN end
  assert= page1 test_stack_len_bytes ARENA_PAGE_MIN end
  assert= adr2 page1 Stack_floor @ end
  assert= arn test_stack_len_bytes size' Stack 2 * end

  arn arena_deinit
end
test_arena_alloc

fun: test_arena_trunc { -- err }
  alloca' Arena { arn }
  arn arena_init

  7 arn arena_alloc { _adr0 }
  arn Arena_low @ { page0 }
  page0 Stack_floor @ { floor0 }

  ARENA_PAGE_MIN arn arena_alloc { _adr1 }
  arn Arena_low @ { page1 }

  assert= arn test_stack_len_bytes size' Stack 2 * end
  assert= page0 test_stack_len_bytes 7 end
  assert= page1 test_stack_len_bytes ARENA_PAGE_MIN end

  arn arena_trunc

  assert= arn test_stack_len_bytes size' Stack 2 * end
  assert= arn Arena_low @ page0 end
  assert= page0 test_stack_len_bytes 0 end
  assert= page1 test_stack_len_bytes 0 end

  11 arn arena_alloc { adr2 }

  assert= adr2 floor0 end
  assert= arn Arena_low @ page0 end
  assert= arn test_stack_len_bytes size' Stack 2 * end

  arn arena_deinit
end
test_arena_trunc

fun: test_arena_deinit { -- err }
  alloca' Arena { arn }
  arn arena_init

  128 arn arena_alloc { _adr0 }
  ARENA_PAGE_MIN arn arena_alloc { adr1 }

  arn arena_deinit

  assert= arn test_stack_len_bytes 0 end
  assert= arn Arena_low @ nil end

  adr1 test_arena_unprot catch { err }
  assert err <>0 end
  err " unable to mprotect" assert_str_has
end
test_arena_deinit

fun: test_arena_errors { -- err }
  alloca' Arena { arn }
  arn arena_init

  0 arn arena_alloc catch { _adr err }
  assert err <>0 end
  err " unable to allocate: size is zero" assert_str_has

  nil arena_trunc
  nil arena_deinit
  arn arena_deinit
end
test_arena_errors

