fun: test_loop_while { -- err }
  assert=
    -1 { val }
    loop false while 10 { val } end
    val
    -1
  end

  assert=
    -1 { val }
    loop 10 { val } false while 20 { val } end
    val
    10
  end

  assert=
    -1 { val }
    loop 10 { val } false while 20 { val } true while end
    val
    10
  end

  assert=
    -1 { val }
    loop 10 { val } true while 20 { val } false while end
    val
    20
  end

  assert=
    12 { val }
    loop
      val 5 > while
      dec: val
    end
    val
    5
  end

  assert=
    12 { val }
    loop
      val 5 > while
      val 7 > while
      dec: val
    end
    val
    7
  end

  assert=
    12 { val }
    loop
      dec: val
      val while
      val while
      val while
    end
    val
    0
  end
end
test_loop_while

