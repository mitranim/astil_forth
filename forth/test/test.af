fun: .test_thread_custom_ctx { -- err }
  alloca' Stack { mem }

  PAGE_SIZE Test_req_ctx mem .stack_init_ctx { ctx }
  123 ctx .Test_req_ctx_val !

  instr' .test_thread_custom_ctx_child nil ctx .thread_spawn_ctx { thread }
  thread .thread_join { out }

  assert= out 123 end
  mem .stack_deinit
end
.test_thread_custom_ctx

\ Our `.try` pops the top argument, tests it for being nil/zero, and returns it
\ in the current function's error register if non-zero. By accident, we also
\ allow to "push" more arguments afterwards. Works exactly like a stack.
fun: .test_try_multiple { -- err }
  nil .try
  nil nil .try .try
  nil .try nil .try
  assert= 10 nil .try 10 end
  assert= 20 nil nil .try .try 20 end
  20 nil nil .try nil .try { val0 err0 }
  assert= val0 20 end
  assert= err0 nil end
  10 20 nil .try { val1 val2 }
  assert= val1 10 end
  assert= val2 20 end
  10 20 nil nil .try .try { val3 val4 }
  assert= val3 10 end
  assert= val4 20 end
  10 20 nil .try nil .try { val5 val6 }
  assert= val5 10 end
  assert= val6 20 end
  10 20 nil .try nil .try nil { val7 val8 err1 }
  assert= val7 10 end
  assert= val8 20 end
  assert= err1 nil end
end
.test_try_multiple

fun: .test_errf_wrap { -- err }
  " one" .errf { err0 }
  " two: %s" err0 .errf { err1 }

  \ err0 .logf " \n" .log
  \ err1 .logf " \n" .log

  err0 " one" .assert_str_eq
  err1 " two: one" .assert_str_eq

  " three: %s" err1 .errf { err2 }

  assert<> err0 err2 end
  assert<> err0 err1 end

  err2 " three: two: one" .assert_str_eq

  " four: %zd: %s" 123 err2 .errf { err3 }

  assert<> err3 err0 end
  assert<> err3 err1 end
  assert<> err3 err2 end

  err3 " four: 123: three: two: one" .assert_str_eq
end
.test_errf_wrap

