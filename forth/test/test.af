fun: .test_load_store_typed { -- err }
  CELL .alloca { ptr }

  0 ptr !
  0x1234 ptr !8
  assert= ptr @u8 0x34 end
  assert= ptr @s8 0x34 end
  assert= ptr @ 0x34 end

  0 ptr !
  0xff ptr !8
  assert= ptr @u8 0xff end
  assert= ptr @s8 -1 end

  0 ptr !
  0x12345 ptr !16
  assert= ptr @u16 0x2345 end
  assert= ptr @s16 0x2345 end
  assert= ptr @ 0x2345 end

  0 ptr !
  0x8001 ptr !16
  assert= ptr @u16 0x8001 end
  assert= ptr @s16 -32767 end

  0 ptr !
  0x123456789 ptr !32
  assert= ptr @u32 0x23456789 end
  assert= ptr @s32 0x23456789 end
  assert= ptr @cuint 0x23456789 end
  assert= ptr @cint 0x23456789 end
  assert= ptr @ 0x23456789 end

  0 ptr !
  0x80000001 ptr !32
  assert= ptr @u32 0x80000001 end
  assert= ptr @s32 -2147483647 end
  assert= ptr @cuint 0x80000001 end
  assert= ptr @cint -2147483647 end

  0x123456789abcdef0 ptr !
  assert= ptr @ 0x123456789abcdef0 end
  assert= ptr @culong 0x123456789abcdef0 end

  0 0x100 - ptr !clong
  assert= ptr @clong 0 0x100 - end
  assert= ptr @culong 0 0x100 - end
end
.test_load_store_typed

fun: .test_load_store_exec { -- err }
  CELL .alloca { ptr }

  0x123456789abcdef0 ptr call' !
  assert= ptr call' @ 0x123456789abcdef0 end

  0 ptr call' !
  0x1234 ptr call' !b
  assert= ptr call' @b 0x34 end

  0 ptr call' !
  0xff ptr call' !8
  assert= ptr call' @u8 0xff end
  assert= ptr call' @s8 -1 end

  0 ptr call' !
  0x8001 ptr call' !16
  assert= ptr call' @u16 0x8001 end
  assert= ptr call' @s16 -32767 end

  0 ptr call' !
  0x80000001 ptr call' !32
  assert= ptr call' @u32 0x80000001 end
  assert= ptr call' @s32 -2147483647 end

  0 ptr call' !
  0x80000001 ptr call' !cint
  assert= ptr call' @cint -2147483647 end

  0 ptr call' !
  0x80000001 ptr call' !cuint
  assert= ptr call' @cuint 0x80000001 end

  0 0x100 - ptr call' !clong
  assert= ptr call' @clong 0 0x100 - end

  0x123456789abcdef0 ptr call' !culong
  assert= ptr call' @culong 0x123456789abcdef0 end
end
.test_load_store_exec

