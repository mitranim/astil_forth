  T{ -1  0  1 u<any   <T> false }T
  T{ -1  0  1 u>=any  <T> true  }T
  T{  0 -1  1 u>=any  <T> false }T
  T{ -1  0  1 u>any   <T> true  }T
  T{  0 -1  1 u>any   <T> false }T
  T{  0 -1  1 u<=any  <T> true  }T
  T{ -1  0  1 u<=any  <T> false }T
  T{ -1  0  1 u<none  <T> true  }T
  T{  0 -1  1 u<none  <T> false }T
  T{  0 -1  1 u>=none <T> true  }T
  T{ -1  0  1 u>=none <T> false }T
