  T{  5  4  3 <=any  <T> false }T
  T{ -5 -6 -7 <none  <T> true  }T
  T{ -5 -4 -7 <none  <T> false }T
  T{ -5 -4 -3 >=none <T> true  }T
  T{ -5 -6 -3 >=none <T> false }T
  T{  5  6  7 >none  <T> true  }T
  T{  5  4  7 >none  <T> false }T
  T{  5  4  3 <=none <T> true  }T
  T{  5  6  3 <=none <T> false }T

