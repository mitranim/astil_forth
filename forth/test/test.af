  size1 .alloca { adr1 }

  assert= SP adr0 - size0 end
  assert= adr0 adr1 - size1 end

  adr0 @ { -- } \ Should not segfault.
  adr1 @ { -- } \ Should not segfault.
end
32 64 .test_alloca_dynamic

