fun: .test_unsigned_compare { -- err }
  assert= 0 0 u< 0 end
  assert= 0 1 u< 1 end
  assert= -1 0 u< 0 end
  assert= 0 -1 u< 1 end
  assert= -1 0 u> 1 end
  assert= 0 -1 u> 0 end
  assert= 0 -1 u<= 1 end
  assert= -1 0 u<= 0 end
  assert= -1 0 u>= 1 end
  assert= 0 -1 u>= 0 end

  assert= -1 0 10 .within 0 end
  assert= 0 0 10 .within 1 end
  assert= 5 0 10 .within 1 end
  assert= 10 0 10 .within 0 end
  assert= -5 -10 0 .within 1 end
  assert= -1 0 10 .uwithin 0 end
  assert= 0 0 10 .uwithin 1 end
  assert= 5 0 10 .uwithin 1 end
  assert= 10 0 10 .uwithin 0 end
end
.test_unsigned_compare

fun: .test_compare_many { -- err }
  \ Keep these direct. The multi-check words below lower directly to compare
  \ and conditional-compare instructions; binding their outputs through locals
  \ would add local read/write behavior to the assertion path.
  assert= 10 10 20 =any true end
  assert= 10 20 10 =any true end
  assert= 10 11 20 =any false end
  assert= 10 11 20 =none true end
  assert= 10 10 20 =none false end

  assert= -5 -4 -3 <any true end
  assert= -5 -6 -7 <any false end
  assert= -5 -6 -7 >=any true end
  assert= -5 -4 -3 >=any false end
  assert= 5 4 3 >any true end
  assert= 5 6 7 >any false end
  assert= 5 6 7 <=any true end
  assert= 5 4 3 <=any false end
  assert= -5 -6 -7 <none true end
  assert= -5 -4 -7 <none false end
  assert= -5 -4 -3 >=none true end
  assert= -5 -6 -3 >=none false end
  assert= 5 6 7 >none true end
  assert= 5 4 7 >none false end
  assert= 5 4 3 <=none true end
  assert= 5 6 3 <=none false end

  assert= 0 -1 1 u<any true end
  assert= -1 0 1 u<any false end
  assert= -1 0 1 u>=any true end
  assert= 0 -1 1 u>=any false end
  assert= -1 0 1 u>any true end
  assert= 0 -1 1 u>any false end
  assert= 0 -1 1 u<=any true end
  assert= -1 0 1 u<=any false end
  assert= -1 0 1 u<none true end
  assert= 0 -1 1 u<none false end
  assert= 0 -1 1 u>=none true end
  assert= -1 0 1 u>=none false end
  assert= 0 -1 1 u>none true end
  assert= -1 0 1 u>none false end
  assert= -1 0 1 u<=none true end
  assert= 0 -1 1 u<=none false end
end
.test_compare_many

