  assert= val7 20 end
  30 { one } one one { val8 val9 }
  assert= val8 30 end
  assert= val9 30 end
  40 { one -- } one one { val10 val11 }
  assert= val10 40 end
  assert= val11 40 end
  10 20 { one two } one two { val12 val13 }
  assert= val12 10 end
  assert= val13 20 end
  10 20 { one two }
  10 20 { one two -- }
  30 40 { one two } one { val14 }
  assert= val14 30 end
  50 60 { one two -- } one { val15 }
  assert= val15 50 end
  10 20 { one two } two { val16 }
  assert= val16 20 end
  30 40 { one two } one two { val17 val18 }
  assert= val17 30 end
  assert= val18 40 end
  50 60 { one two } two one { val19 val20 }
  assert= val19 60 end
  assert= val20 50 end
  10 20 { one two } two one one { val21 val22 val23 }
  assert= val21 20 end
  assert= val22 10 end
  assert= val23 10 end
  30 40 { one two } two one two { val24 val25 val26 }
  assert= val24 40 end
  assert= val25 30 end
  assert= val26 40 end
  10 20 { one two } one two one { val27 val28 val29 }
  assert= val27 10 end
  assert= val28 20 end
  assert= val29 10 end
  30 40 { one two } one one two { val30 val31 val32 }
  assert= val30 30 end
  assert= val31 30 end
  assert= val32 40 end
