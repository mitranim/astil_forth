fun: .test_indirect_forward_eq { act exp -- err }
  act exp = .then .ret end
  " indirect forward call mismatch: actual=%zd expected=%zd" act exp .errf .throw
end

fun: .test_indirect_clobber { -- err }
  \ Fails as 467 if indirect trampoline clobbers are not reported to callers.
  0 0 0 0 100 23 .test_indirect_clobber_caller 123 .test_indirect_forward_eq
end
.test_indirect_clobber

fun: .test_indirect_forward { -- err }
  " abc" .test_indirect_forward_caller { char }
  char char' a .test_indirect_forward_eq

  .test_indirect_forward_caller_0 100 .test_indirect_forward_eq
  10 20 .test_indirect_forward_caller_2 30 .test_indirect_forward_eq
  1 2 3 .test_indirect_forward_caller_3 6 .test_indirect_forward_eq
  1 2 3 4 .test_indirect_forward_caller_4 10 .test_indirect_forward_eq
  1 2 3 4 5 .test_indirect_forward_caller_5 15 .test_indirect_forward_eq
  1 2 3 4 5 6 .test_indirect_forward_caller_6 21 .test_indirect_forward_eq
  1 2 3 4 5 6 7 .test_indirect_forward_caller_7 28 .test_indirect_forward_eq
  1 2 3 4 5 6 7 8 .test_indirect_forward_caller_8 36 .test_indirect_forward_eq

  .test_indirect_forward_caller_out2 { a b }
  a 11 .test_indirect_forward_eq
  b 22 .test_indirect_forward_eq

  .test_indirect_forward_caller_out7 { a b c d e f g }
  a 0 .test_indirect_forward_eq
  b 1 .test_indirect_forward_eq
  c 2 .test_indirect_forward_eq
  d 3 .test_indirect_forward_eq
  e 4 .test_indirect_forward_eq
  f 5 .test_indirect_forward_eq
  g 6 .test_indirect_forward_eq

  .test_indirect_forward_caller_out8 { a0 b0 c0 d0 e0 f0 g0 h0 }
  a0 0 .test_indirect_forward_eq
  b0 1 .test_indirect_forward_eq
  c0 2 .test_indirect_forward_eq
  d0 3 .test_indirect_forward_eq
  e0 4 .test_indirect_forward_eq
  f0 5 .test_indirect_forward_eq
  g0 6 .test_indirect_forward_eq
  h0 7 .test_indirect_forward_eq
end
.test_indirect_forward

fun: .recur_fun_with_err { val -- out err }
  val =0 .then 100 .ret end
  val 3 = .then 0 " some_error" .ret end
  val .dec .recur
