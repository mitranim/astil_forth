use' ../lang.af
use' ../arena.af
use' ../time.af

\ We test both JIT-compiled and AOT-compiled modes.
\ For AOT, every test must be called in `main_run`.

true try_all

fun: test_test { -- err }
  assert= 10 10 end
  10 20 { one two }
  assert= one 10 end
  assert= two 20 end
end
test_test

fun: test_empty_comment { -- err }
  \ `\` immediately followed by newline: this used to skip the NEXT line.
  \
  10 20 30
  { one two three }
  assert= one 10 end
  assert= two 20 end
  assert= three 30 end
end
test_empty_comment

fun: test_locals { -- err }
