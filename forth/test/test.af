.test_explicit_err_4_fun_throwing

fun: .test_explicit_err_4 { -- Err }
  0 13 .test_explicit_err_4_fun { one two err }
  err " test_err" .assert_str_eq .try

  13 25 .test_explicit_err_4_fun { one two err }
  assert= one 38 end .try
  assert= two 12 end .try
  assert= err nil end .try
  13 25 .test_explicit_err_4_fun { one2 two2 err2 }
  assert= one2 38 end .try
  assert= two2 12 end .try
  assert= err2 nil end .try

  13 0 .test_explicit_err_4_fun { one two err }
  assert= one 13 end .try
  assert= two -13 end .try
  assert= err nil end .try
  13 0 .test_explicit_err_4_fun { one3 two3 err3 }
  assert= one3 13 end .try
  assert= two3 -13 end .try
  assert= err3 nil end
end
.test_explicit_err_4

