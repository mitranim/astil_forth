  assert= xt' .test_ctx_top_set_codegen_fun store .test_word_instr_count 1 end

  0 ASM_REG_CTX 1 .asm_load_off { load }
  0 ASM_REG_CTX 1 .asm_store_off { store }
  assert= xt' .test_ctx_top_roundtrip_codegen_fun load .test_word_instr_count 1 end
  assert= xt' .test_ctx_top_roundtrip_codegen_fun store .test_word_instr_count 1 end
end
