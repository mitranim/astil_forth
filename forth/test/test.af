  assert " one" .strdup " two" .ccompare <0 end
  assert " two" .strdup " one" .ccompare >0 end
  assert= " one" .strdup " two" cstr< true end
  assert= " two" .strdup " one" cstr< false end
  assert= " one" .strdup " one" cstr< false end
end
.test_cstr_less

