test_params_push

\ Stack operations are tested early because they're used by conditionals and
\ loops, which makes testing kinda cyclic.
fun: test_stack_len_bytes { stack -- len }
  stack Stack_top @ stack Stack_floor @ -
end

fun: test_stack_cap_bytes { stack -- len }
  stack Stack_ceil @ stack Stack_floor @ -
end

fun: test_stack_len_cells { stack -- len } stack test_stack_len_bytes /cells end
fun: test_stack_cap_cells { stack -- len } stack test_stack_cap_bytes /cells end

fun: test_stack_primitives { -- err }
  assert= size' Stack 40 end

  alloca' Stack { stk }
  stk size' Stack memzero

  assert= stk test_stack_len_cells 0 end
  assert= stk test_stack_cap_cells 0 end

  32 stk stack_init

  assert= stk test_stack_len_cells 0 end
  assert= stk test_stack_cap_cells 2048 end \ Adjusted to mem page size.

  10 stk >s
  assert= stk test_stack_len_cells 1 end
  assert= stk s> 10 end
  assert= stk test_stack_len_cells 0 end

  20 stk >s
  30 stk >s
  assert= stk test_stack_len_cells 2 end
  assert= stk Stack_top @ -cell @ 30 end
  assert= stk Stack_top @ -cell -cell @ 20 end
  assert= stk s> 30 end
  assert= stk test_stack_len_cells 1 end
  assert= stk s> 20 end
  assert= stk test_stack_len_cells 0 end

  stk stack_deinit
end
test_stack_primitives

fun: test_to_stack_sequence { -- err }
  alloca' Stack { stk }
  32 stk stack_init

  assert= stk test_stack_len_cells 0 end

  10 stk >s
  assert= stk test_stack_len_cells 1 end
  assert= stk s> 10 end
  assert= stk test_stack_len_cells 0 end

  666 stk >s
  assert= stk test_stack_len_cells 1 end
  assert= stk s> 666 end
  assert= stk test_stack_len_cells 0 end

  20 stk >s 30 stk >s
  assert= stk test_stack_len_cells 2 end
  assert= stk s> 30 end
  assert= stk test_stack_len_cells 1 end
  assert= stk s> 20 end
  assert= stk test_stack_len_cells 0 end

  40 stk >s 50 stk >s 60 stk >s
  assert= stk test_stack_len_cells 3 end
  assert= stk s> 60 end
  assert= stk test_stack_len_cells 2 end
  assert= stk s> 50 end
  assert= stk test_stack_len_cells 1 end
  assert= stk s> 40 end
  assert= stk test_stack_len_cells 0 end

  stk stack_deinit
end
test_to_stack_sequence

fun: test_stack_braces { -- err }
  alloca' Stack { stk }
  32 stk stack_init

  assert= stk test_stack_len_cells 0 end
  stk stack{ }
  assert= stk test_stack_len_cells 0 end

  10 stk >s
  assert= stk test_stack_len_cells 1 end
  stk stack{ one }
  assert= stk test_stack_len_cells 0 end
  assert= one 10 end

  10 stk >s 20 stk >s
  assert= stk test_stack_len_cells 2 end
  stk stack{ one two }
  assert= stk test_stack_len_cells 0 end
  assert= one 10 end
  assert= two 20 end

  10 stk >s 20 stk >s 30 stk >s
  assert= stk test_stack_len_cells 3 end
  stk stack{ one two three }
  assert= stk test_stack_len_cells 0 end
  assert= one 10 end
  assert= two 20 end
  assert= three 30 end

  stk stack_deinit
end
test_stack_braces

fun: bang_with_more_inputs { val adr _x2 _x3 _x4 } val adr ! end

fun: bang_with_outputs { val adr next -- x0 x1 x2 } val adr ! next next next end

fun: test_conditionals { -- err }
  \ Must fail to compile: bare `if then end`
  \ doesn't support outputs.
  \ if false then 10 end

  assert= if false then 10 else 20 end 20 end
  assert= if true then 10 else 20 end 10 end

  assert= ifz false then 10 else 20 end 10 end
  assert= ifz true then 10 else 20 end 20 end

  assert=
    if false then 10 elif true then 20 else 30 end
    20
  end

  assert=
    if false then 10 elifz false then 20 else 30 end
    20
  end

  10 { loc }
  if false then 20 else 30 end { out }
  assert= loc 10 end
  assert= out 30 end

  assert= -1 { val } if false then 10 { val } end val -1 end
  assert= -1 { val } if true then 10 { val } end val 10 end

  assert= if false then 10 else 20 end 20 end
  assert= if true then 10 else 20 end 10 end

  assert= -1 { val } ifz false then 10 { val } end val 10 end
  assert= -1 { val } ifz true then 10 { val } end val -1 end

  assert= ifz false then 10 else 20 end 10 end
  assert= ifz true then 10 else 20 end 20 end

  assert=
    -1 { val }
    if false then 10 { val } elif false then 20 { val } end val
    -1
  end

  assert=
    if false then 10 elif false then 20 else 30 end
    30
  end

  assert=
    -1 { val }
    if false then 10 { val } elif true then 20 { val } end val
    20
  end

  assert=
    if false then 10 elif true then 20 else 30 end
    20
  end

  assert=
    -1 { val }
    if true then 10 { val } elif false then 20 { val } end val
    10
  end

  assert=
    if true then 10 elif false then 20 else 30 end
    10
  end

  assert=
    -1 { val }
    if false then 10 { val } elifz false then 20 { val } end val
    20
  end

  assert=
    if false then 10 elifz false then 20 else 30 end
    20
  end

  assert=
    -1 { val }
    if false then 10 { val } elifz true then 20 { val } end val
    -1
  end

  assert=
    if false then 10 elifz true then 20 else 30 end
    30
  end

  assert=
    -1 { val }
    if true then 10 { val } elifz false then 20 { val } end val
    10
  end

  assert=
    if true then 10 elifz false then 20 else 30 end
    10
  end

  assert=
    -1 { val }
    if false then
      10 { val }
    else
      if true then
        20 { val }
      end
    end
    val
    20
  end

end
test_conditionals

fun: cond_input_if { val flag -- out } val flag if then end end
fun: cond_input_ifn { val flag -- out } val flag ifz then end end
fun: cond_input_if_else { val flag -- out } val flag if then else end end

fun: cond_input_elif { val flag0 flag1 -- out }
  val flag0 if then
  elif flag1 then
  else
  end
end

fun: cond_input_elifn { val flag0 flag1 -- out }
  val flag0 if then
  elifz flag1 then
  else
  end
end

fun: cond_input_elif_diff { flag0 flag1 -- out0 out1 }
  if flag0 then 10 11
  elif flag1 then 20 30
  else 20 40
  end
end

fun: cond_input_elif_diff_no_else { flag0 flag1 -- out }
  if flag0 then 10
  elif flag1 then 20
  else 20
  end
end

fun: cond_input_max { A B C D E F G flag -- A B C D E F G }
  A B C D E F G flag if then end
end

fun: test_cond_input_arity { -- err }
  assert= 123 false cond_input_if 123 end
  assert= 123 true cond_input_if 123 end

  assert= 234 false cond_input_ifn 234 end
  assert= 234 true cond_input_ifn 234 end

  assert= 345 false cond_input_if_else 345 end
  assert= 345 true cond_input_if_else 345 end

  assert= 456 false false cond_input_elif 456 end
  assert= 456 false true cond_input_elif 456 end
  assert= 456 true false cond_input_elif 456 end

  assert= 567 false false cond_input_elifn 567 end
  assert= 567 false true cond_input_elifn 567 end
  assert= 567 true false cond_input_elifn 567 end

  false false cond_input_elif_diff { val0 val1 }
  assert= val0 20 end
  assert= val1 40 end
  false true cond_input_elif_diff { val2 val3 }
  assert= val2 20 end
  assert= val3 30 end
  true false cond_input_elif_diff { val4 val5 }
  assert= val4 10 end
  assert= val5 11 end

  assert= false false cond_input_elif_diff_no_else 20 end
  assert= false true cond_input_elif_diff_no_else 20 end
  assert= true false cond_input_elif_diff_no_else 10 end

  0 1 2 3 4 5 6 false cond_input_max { val6 val7 val8 val9 val10 val11 val12 }
  assert= val6 0 end
  assert= val7 1 end
  assert= val8 2 end
  assert= val9 3 end
  assert= val10 4 end
  assert= val11 5 end
  assert= val12 6 end
  0 1 2 3 4 5 6 true cond_input_max { val13 val14 val15 val16 val17 val18 val19 }
  assert= val13 0 end
  assert= val14 1 end
  assert= val15 2 end
  assert= val16 3 end
  assert= val17 4 end
  assert= val18 5 end
  assert= val19 6 end
end
test_cond_input_arity

fun: recursive_fun { val -- val }
  if val 13 <= then val ret end
  val dec recur
end

fun: test_recursion { -- err }
  assert= 123 recursive_fun 13 end
end
test_recursion

fun: recursive_fib_fun { ind -- out }
  if ind 1 <= then 1 ret end
  ind 1 - recur { prev }
  ind 2 - recur
  prev +
end

fun: test_recursive_saved_local { -- err }
  assert= 10 recursive_fib_fun 89 end
end
test_recursive_saved_local

fun: recur_reg_clobber_fun { val -- out }
  -1 -2 { -- } \ Unconditionally clobber x0 x1.
  ifz val then 0 ret end
  val val { _ignored saved } \ `_ignored` = x0, `saved` = x1, `val` = none
  0 recur { -- } \ Must relocate `saved`.
  saved inc
end

fun: test_recur_reg_clobber { -- err }
  assert= 10 recur_reg_clobber_fun 11 end
end
test_recur_reg_clobber

