fun: recur_fun_with_err { val -- out err }
  ifz val then 100 ret end
  if val 3 = then 0 " some_error" ret end
  val dec recur
end

fun: recur_catch_fun { val -- out err }
  ifz val then 100 ret end
  if val 3 = then 0 " some_error" ret end
  val dec recur catch
end

fun: test_recur_with_err { -- err }
  2 recur_fun_with_err catch { out err }
  assert= out 100 end
  assert= err nil end
  4 recur_fun_with_err catch { -- err }
  err " some_error" assert_str_eq

  2 recur_catch_fun catch { out err }
  assert= out 100 end
  assert= err nil end
  4 recur_catch_fun catch { -- err }
  err " some_error" assert_str_eq
end
test_recur_with_err

