fun: .test_ctx_top_codegen { -- err }
  context .Ctx_top @ { top }
  99 .test_ctx_top_get_codegen_fun { keep act }
  assert= keep 99 end
  assert= act top end
  assert= 99 top .test_ctx_top_set_codegen_fun 99 end

