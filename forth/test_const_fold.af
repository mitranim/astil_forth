test_const_fold_int_to_cell

fun: const_fold_unary_large_imm_fun { -- out0 out1 }
  0x123456789 inc
  0x123456789 =0
end

fun: test_const_fold_unary_large_imm { -- err }
  T{ const_fold_unary_large_imm_fun <T> 0x12345678a 0 }T
end
test_const_fold_unary_large_imm

fun: const_fold_fallback_0_1_1_2_fun { val -- out0 out1 }
  val inc
  val =0
end

fun: test_const_fold_fallback_0_1_1_2 { -- err }
  T{ 41 const_fold_fallback_0_1_1_2_fun <T> 42 0 }T
  T{ 0  const_fold_fallback_0_1_1_2_fun <T> 1  1 }T
end
test_const_fold_fallback_0_1_1_2

\ For AOT testing.
fun: test_const_fold_all { -- err }
  test_const_fold_arith
  test_const_fold_fallback_0_1
  test_const_fold_large_imm
  test_const_fold_unary
  test_const_fold_zero_cmp
  test_const_fold_bit_shift
  test_const_fold_div_mod
  test_const_fold_compare2
  test_const_fold_ucompare2
  test_const_fold_derived
  test_const_fold_int_to_cell
  test_const_fold_unary_large_imm
  test_const_fold_fallback_0_1_1_2
end

" [test] [cf] ok" log lf
