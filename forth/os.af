struct: Sigaction
  Adr 1 field: .Sigaction_handler
  U32 1 field: .Sigaction_mask
  S32 1 field: .Sigaction_flags
end

struct: Siginfo
  S32  1 field: .Siginfo_signo
  S32  1 field: .Siginfo_errno
  S32  1 field: .Siginfo_code
  S32  1 field: .Siginfo_pid
  U32  1 field: .Siginfo_uid
  S32  1 field: .Siginfo_status
  Adr  1 field: .Siginfo_addr
  Cell 1 field: .Siginfo_value
  S64  1 field: .Siginfo_band
  U64  7 field: .Siginfo_pad
end

struct: Sigstack
  Adr  1 field: .Sigstack_sp
  U64  1 field: .Sigstack_size
  S32  1 field: .Sigstack_flags
end

