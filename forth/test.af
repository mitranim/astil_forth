\ Load/store is used internally by testing utils. The test is kinda cyclic.
: test_load_store
  has_interp if
    T{ VAR @ <T> 123 }T
  else
    T{ VAR @ <T> 345 }T \ Preserved in AOT from this test.
  end

  T{ 234 VAR ! <T>     }T
  T{ VAR @     <T> 234 }T
  T{ 345 VAR ! <T>     }T
  T{ VAR @     <T> 345 }T
;
test_load_store

