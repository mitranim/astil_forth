fun: test_loop_countdown { -- err }
  0 { len }

  T{
    8 0 1
    -loop: ind
      inc: len
    end
    len ind
  <T>
    8 -1
  }T

  0 { len }
  T{ 8 0 2 -loop: ind inc: len end len ind <T> 4 -2 }T

  0 { len }
  T{ 8 0 3 -loop: ind inc: len end len ind <T> 2 -1 }T

  0 { len }
  T{ 8 0 4 -loop: ind inc: len end len ind <T> 2 -4 }T

  0 { len }
  T{ 8 0 5 -loop: ind inc: len end len ind <T> 1 -2 }T

  0 { len }
  T{ 8 0 6 -loop: ind inc: len end len ind <T> 1 -4 }T

  0 { len }
  T{ 8 0 7 -loop: ind inc: len end len ind <T> 1 -6 }T

  0 { len }
  T{ 8 0 8 -loop: ind inc: len end len ind <T> 1 -8 }T

  \ Out of range from the start.
  0 { len }
  T{ 8 0 9 -loop: ind inc: len end len ind <T> 0 -1 }T

  \ Out of range from the start.
  0 { len }
  T{ 8 0 10 -loop: ind inc: len end len ind <T> 0 -2 }T
  nil
end
test_loop_countdown

\ When the loop terminates, the "ind" local holds an out-of-range value.
\ If the value is out of range at the start, it should remain unchanged.
fun: test_loop_countup { -- err }
  0 { len }

  T{
    8 0 1
    +loop: ind
      inc: len
    end
    len ind
  <T>
    8 8
  }T

  0 { len }
  T{ 8 0 2 +loop: ind inc: len end len ind <T> 4 8 }T

  0 { len }
  T{ 8 0 3 +loop: ind inc: len end len ind <T> 3 9 }T

  0 { len }
  T{ 8 0 4 +loop: ind inc: len end len ind <T> 2 8 }T

  0 { len }
  T{ 8 0 5 +loop: ind inc: len end len ind <T> 2 10 }T

  0 { len }
  T{ 8 0 6 +loop: ind inc: len end len ind <T> 2 12 }T

  0 { len }
  T{ 8 0 7 +loop: ind inc: len end len ind <T> 2 14 }T

  0 { len }
  T{ 8 0 8 +loop: ind inc: len end len ind <T> 1 8 }T

  0 { len }
  T{ 8 0 9 +loop: ind inc: len end len ind <T> 1 9 }T

  \ Out of range from the start.
  0 { len }
  T{ 8 8 1 +loop: ind inc: len end len ind <T> 0 8 }T

  \ Out of range from the start.
  0 { len }
  T{ 8 9 1 +loop: ind inc: len end len ind <T> 0 9 }T
  nil
end
test_loop_countup

