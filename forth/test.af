  T{  0    123 = <T> 0 }T
  T{  123  0   = <T> 0 }T
  T{ -123  0   = <T> 0 }T
  T{ -123  123 = <T> 0 }T
  T{  123 -123 = <T> 0 }T
  T{ -123 -123 = <T> 1 }T
  T{  123  123 = <T> 1 }T
;
test_equal

