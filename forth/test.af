fun: test_catch_2_cond { one two -- three four err }
  one <>0 { ok0 }
  two <>0 { ok1 }

  ok0 ok1 and if
    one two + { three }
    two one - { four  }
    three four nil ret
  end

  test_throw
  unreachable
  nil nil nil
end

fun: test_catch_2 { -- err }
