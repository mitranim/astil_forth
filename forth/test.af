\ Our "try" is atypical compared to verbs: instead of consuming all outputs,
\ it "pops" only the last one, assuming it to be error or nil. By accident,
\ we also allow to "push" subsequent arguments. Works exactly like a stack.
fun: test_try_multiple { -- err }
  T{ nil try <T> }T
  T{ nil nil try try <T> }T
  T{ nil try nil try <T> }T
  T{ 10 nil try <T> 10 }T
  T{ 20 nil nil try try <T> 20 }T
  T{ 20 nil nil try nil try <T> 20 nil }T
  T{ 10 20 nil try <T> 10 20 }T
  T{ 10 20 nil nil try try <T> 10 20 }T
  T{ 10 20 nil try nil try <T> 10 20 }T
  T{ 10 20 nil try nil try nil <T> 10 20 nil }T
  nil
end
test_try_multiple

fun: test_wrapf { -- err }
  nil  " one"          wrapf { err0 }
  err0 " two: %s" err0 wrapf { err1 }

  \ err0 logf lf
  \ err1 logf lf

  err0 " one"      T_str_eq
  err1 " two: one" T_str_eq

  err1 " three: %s" err1 wrapf { err2 }

  \ `wrapf` rotates two string buffers.
  T{ err0 err2 = <T> true  }T
  T{ err0 err1 = <T> false }T

  err2 " three: two: one" T_str_eq

  err2 " four: %zd: %s" 123 err2 wrapf { err3 }

  T{ err3 err0 = <T> false }T
  T{ err3 err1 = <T> true  }T
  T{ err3 err2 = <T> false }T

  err3 " four: 123: three: two: one" T_str_eq

  nil
end
test_wrapf

