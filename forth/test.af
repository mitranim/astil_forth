fun: test_arena_unprot { adr -- err } adr ARENA_PAGE_MIN mem_unprot nil end

fun: test_arena_alloc { -- err }
  alloca' Arena { arn }
  arn arena_init

  T{ arn stack_len_bytes <T> 0   }T
  T{ arn Arena_low @     <T> nil }T

  1 arn arena_alloc { adr0 }
  arn Arena_low @ { page0 }

  T{ page0 stack_cap_bytes <T> ARENA_PAGE_MIN }T
  T{ page0 stack_len_bytes <T> 1              }T
  T{ arn   stack_len_bytes <T> size' Stack    }T

  7 arn arena_alloc { adr1 }

  T{ arn Arena_low @       <T> page0          }T
  T{ adr1 adr0 -           <T> FUND_ALIGN     }T
  T{ page0 stack_len_bytes <T> FUND_ALIGN 7 + }T
  T{ arn stack_len_bytes   <T> size' Stack    }T

  ARENA_PAGE_MIN arn arena_alloc { adr2 }
  arn Arena_low @ { page1 }

  T{ page1 page0 <>        <T> true                }T
  T{ page1 stack_cap_bytes <T> ARENA_PAGE_MIN      }T
  T{ page1 stack_len_bytes <T> ARENA_PAGE_MIN      }T
  T{ adr2                  <T> page1 Stack_floor @ }T
  T{ arn stack_len_bytes   <T> size' Stack 2 *     }T

  arn arena_deinit
  nil
end
test_arena_alloc

fun: test_arena_trunc { -- err }
  alloca' Arena { arn }
  arn arena_init

  7 arn arena_alloc { adr0 }
  arn Arena_low @ { page0 }
  page0 Stack_floor @ { floor0 }

  ARENA_PAGE_MIN arn arena_alloc { adr1 }
  arn Arena_low @ { page1 }

  T{ arn stack_len_bytes   <T> size' Stack 2 * }T
  T{ page0 stack_len_bytes <T> 7               }T
  T{ page1 stack_len_bytes <T> ARENA_PAGE_MIN  }T

  arn arena_trunc

  T{ arn stack_len_bytes   <T> size' Stack 2 * }T
  T{ arn Arena_low @       <T> page0           }T
  T{ page0 stack_len_bytes <T> 0               }T
  T{ page1 stack_len_bytes <T> 0               }T

  11 arn arena_alloc { adr2 }

  T{ adr2                <T> floor0          }T
  T{ arn Arena_low @     <T> page0           }T
  T{ arn stack_len_bytes <T> size' Stack 2 * }T

  arn arena_deinit
  nil
end
test_arena_trunc

fun: test_arena_deinit { -- err }
  alloca' Arena { arn }
  arn arena_init

  128 arn arena_alloc { adr0 }
  ARENA_PAGE_MIN arn arena_alloc { adr1 }

  arn arena_deinit

  T{ arn stack_len_bytes <T> 0   }T
  T{ arn Arena_low @     <T> nil }T

  adr1 catch' test_arena_unprot { err }
  T{ err <>0 <T> true }T
  err " unable to mprotect" T_err_contains
  nil
end
test_arena_deinit

fun: test_arena_errors { -- err }
