import' ./lang.af
import' ./testing.af
import' ./arena.af

\ We test both JIT-compiled and AOT-compiled modes.
\ For AOT, every test must be called in `main_run`.

true try_all

T{       <T>       }T
T{ 10    <T> 10    }T
T{ 10 20 <T> 10 20 }T

fun: test_test { -- err }
  T{       <T>       }T
  T{ 10    <T> 10    }T
  T{ 10 20 <T> 10 20 }T
  nil
end
test_test

