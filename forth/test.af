fun: test_stack_braces { -- err }
  alloca' Stack { stk }
  32 stk stack_init

  T{ stk stack_len_cells <T> 0 }T
  stk stack{ }
  T{ stk stack_len_cells <T> 0 }T

  10 stk >>s
  T{ stk stack_len_cells <T> 1 }T
  stk stack{ one }
  T{ stk stack_len_cells one <T> 0 10 }T

  10 20 stk >>s
  T{ stk stack_len_cells <T> 2 }T
  stk stack{ one two }
  T{ stk stack_len_cells one two <T> 0 10 20 }T

  10 20 30 stk >>s
  T{ stk stack_len_cells <T> 3 }T
  stk stack{ one two three }
  T{ stk stack_len_cells one two three <T> 0 10 20 30 }T

  stk stack_deinit
  nil
end
