    len inc { len }
    cont
    leave
  end
  T{ len <T> 7 }T
;
test_cont_for

\ Should terminate.
: test_cont_for_countup
  12 0 +for: ind cont end
  T{ ind <T> 12 }T
;
test_cont_for_countup

: test_cont_loop_countdown
