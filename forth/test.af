\ In top-level interpretation, `./testing.af` inspects the default Forth stack
\ to compare expected with provided values. All of below should be equivalent.
T{ 10          <T> 10 }T
T{ 10 STACK >s <T> 10 }T
T{ 10 STACK s> <T> 10 }T

\ Stack operations are tested early because they're used by conditionals,
\ loops, and testing utils themselves, which makes testing kinda cycling.
fun: test_stack_primitives { -- err }
  T{ size' Stack <T> 40 }T

  alloca' Stack { stk }
  stk size' Stack erase

  T{ stk stack_len_cells <T> 0 }T
  T{ stk stack_cap_cells <T> 0 }T

  32 stk stack_init

  T{ stk stack_len_cells <T> 0    }T
  T{ stk stack_cap_cells <T> 2048 }T \ Adjusted to mem page size.

  10 stk >s
  T{ stk stack_len_cells <T> 1  }T
  T{ stk s>              <T> 10 }T
  T{ stk stack_len_cells <T> 0  }T

  20 stk >s
  30 stk >s
  T{ stk stack_len_cells <T> 2  }T
  T{ stk s>              <T> 30 }T
  T{ stk stack_len_cells <T> 1  }T
  T{ stk s>              <T> 20 }T
  T{ stk stack_len_cells <T> 0  }T

  stk stack_deinit
  nil
end
test_stack_primitives

