end
test_recursion

fun: recur_err_non_try_fun { val -- out err } [ false try_all ]
  val ifn 100 nil ret end
  val 3 = if 0 " recur_err_non_try" ret end
  val dec recur
end

fun: recur_err_manual_try_fun { val -- out err } [ false try_all ]
  val ifn 100 nil ret end
  val 3 = if 0 " recur_err_manual" ret end
  val dec recur try { out }
  out nil
end

fun: recur_err_auto_try_fun { val -- out err } [ true try_all ]
  val ifn 100 nil ret end
  val 3 = if 0 " recur_err_auto" ret end
  val dec recur { out }
  out nil
end

fun: test_recur_with_err { -- err }
  [ false try_all ]

  T{ 2 recur_err_non_try_fun { out0 err0 } <T>         }T
  T{ out0 err0                             <T> 100 nil }T
  T{ 4 recur_err_non_try_fun { out1 err1 } <T>         }T
  err1 " recur_err_non_try" T_str_eq try

  [ true try_all ]

  T{ 2 catch' recur_err_manual_try_fun               <T> 100 nil }T
  T{ 4 catch' recur_err_manual_try_fun { out2 err2 } <T>         }T
  err2 " recur_err_manual" T_str_eq

  T{ 2 catch' recur_err_auto_try_fun <T> 100 nil }T

  [ false try_all ]

  T{ 4 recur_err_auto_try_fun { out3 err3 } err3 <>0 <T> true }T

  [ true try_all ]

  4 catch' recur_err_auto_try_fun { out4 err4 }
  err4 " recur_err_auto" T_str_eq

  nil
end
test_recur_with_err

