fun: test_loop_until { -- err }
  \ Loops indefinitely. How to test?
  \ loop false until

  T{ loop             true  until <T> }T
  T{ loop leave       true  until <T> }T
  T{ loop leave       false until <T> }T
  T{ loop leave leave false until <T> }T

  T{ -1 { val } loop      10 { val } val     until val <T> 10 }T
  T{ 0  { val } loop val inc { val } val     until val <T> 1  }T
  T{ 0  { val } loop val dec { val } val     until val <T> -1 }T
  T{ 12 { val } loop val dec { val } val 6 < until val <T> 5  }T

  T{
    12 { val }
    loop
      val dec { val }
      val 5 > while
      val 9 <
    until
    val
  <T>
    8
  }T

  T{
    12 { val }
    loop
      val dec { val }
      val 9 > while
      val 5 <
    until
    val
  <T>
    9
  }T
  nil
end
test_loop_until

fun: test_loop_for { -- err }
  \ Should terminate right away.
  T{ -12 for end <T> }T
  T{ -1  for end <T> }T
  T{ 0   for end <T> }T

  T{ 0 { val } 12 for       val inc { val }       end val <T> 12 }T
  T{ 0 { val } 12 for       val inc { val } leave end val <T> 1  }T
  T{ 0 { val } 12 for leave val inc { val }       end val <T> 0  }T

  T{
    0 { val }
    12 for
      val 5 > if leave end
      val inc { val }
    end
    val
  <T>
    6
  }T

  T{
    0 { val }
    12 for
      val 6 < while
      val inc { val }
    end
    val
  <T>
    6
  }T

  T{
    0 { val }
    12 for
      val 5 < while
      val 8 < while
      val inc { val }
    end
    val
  <T>
    5
  }T

  T{
    0 { val }
    12 for
      val 8 < while
      val 5 < while
      val inc { val }
    end
    val
  <T>
    5
  }T
  nil
end
test_loop_for

\ A countdown loop walks the range [floor,ceil), in the backwards direction.
\ We retain the index local after the loop with an out-of-range value, which
\ is always -1 in this case.
fun: test_loop_for_countdown { -- err }
  T{ -12 -for: ind end <T> }T
  T{ -1  -for: ind end <T> }T
  T{ 0   -for: ind end <T> }T

  T{ 666 { ind } 12 -for: ind                       end ind <T> -1 }T
  T{ 666 { ind } 12 -for: ind             leave     end ind <T> 11 }T
  T{ 666 { ind } 12 -for: ind ind 5 <= if leave end end ind <T> 5  }T
  T{ 666 { ind } 12 -for: ind ind 5 >     while     end ind <T> 5  }T

  T{
    666 { ind }
    12 -for: ind
      ind 7 > while
      ind 5 > while
    end
    ind
  <T>
    7
  }T

  T{
    666 { ind }
    12 -for: ind
      ind 5 > while
      ind 7 > while
    end
    ind
  <T>
    7
  }T
  nil
