\ ## More memory stuff

\ Some `libc` functions return -1 as 32-bit `0xffff_ffff`, while some others,
\ like `stat`, return 64-bit `0xffff_ffff_ffff_ffff`, sometimes straight from
\ the kernel. Since there's no way to know this generically, we must always
\ sign-extend `int` before testing for -1.
\
\ Should NOT be used for addresses returned by the `mmap`.
\ Its error sentinel is 64-bit -1. The returned address
\ may accidentally have the `int32` sign bit set.
fun: is_err_flag { int -- bool } int int_to_cell -1 = end

6 1 extern: mmap     ( adr size pflag mflag fdes off -- adr )
2 1 extern: munmap   ( adr size )
3 1 extern: mprotect ( adr size pflag -- err )

16384 let: PAGE_SIZE

0 let: PROT_NONE
1 let: PROT_READ
2 let: PROT_WRITE
3 let: PROT_RW
4 let: PROT_EXEC
5 let: PROT_RE

2    let: MAP_PRIVATE
4096 let: MAP_ANON
4098 let: MAP_DEFAULT

fun: mem_map { size pflag -- addr err }
  0 size pflag MAP_DEFAULT -1 0 mmap { addr }
  if addr -1 = then " unable to mmap" throw end
  addr
end

fun: mem_unmap { addr size -- err }
  addr size munmap
  if is_err_flag then " unable to munmap" throw end
end

fun: mem_prot { addr size pflag -- err }
  addr size pflag mprotect
  if is_err_flag then " unable to mprotect" throw end
end

fun: mem_unprot { addr size -- err } addr size PROT_RW mem_prot end

\ ## Stacks continued

\ Initializes a stack with guards. Note: the memory is acquired from the OS
\ and is NOT managed by the compiler. When used for global variables, their
\ state is not preserved in AOT compilation.
\
\ This is the preferred way to acquire memory pages from the OS.
\ Size is counted in bytes; to allocate cells, use `size cells`.
fun: stack_init { size stack -- err }
  size PAGE_SIZE align_up   { size }
  PAGE_SIZE 1 lsl size +    { bytelen } \ + space for 2 guards
  bytelen PROT_NONE mem_map { cellar }
  cellar PAGE_SIZE +        { floor }
  floor size +              { ceil }
  floor size mem_unprot

  bytelen stack Stack_bytelen !
  cellar  stack Stack_cellar  !
  floor   stack Stack_floor   !
  floor   stack Stack_top     !
  ceil    stack Stack_ceil    !
end

fun: stack_deinit { stack -- err }
  ifz stack then ret end

  stack Stack_bytelen @ { bytelen }
  stack Stack_cellar  @ { cellar }

  if cellar then cellar bytelen mem_unmap end

  nil stack Stack_bytelen !
  nil stack Stack_cellar  !
  nil stack Stack_floor   !
  nil stack Stack_top     !
  nil stack Stack_ceil    !
end

\ Redefine to skip nil stack.
fun: stack_trunc { stack } [ redefine ]
  ifz stack then ret end
  stack stack_trunc
end

fun: stack_repr { stack }
  ifz stack then " [debug] stack is nil" elog elf ret end

  " [debug] stack           " elog stack                 debug_arg
  " [debug] Stack_bytelen @ " elog stack Stack_bytelen @ debug_arg
  " [debug] Stack_cellar  @ " elog stack Stack_cellar  @ debug_arg
  " [debug] Stack_floor   @ " elog stack Stack_floor   @ debug_arg
  " [debug] Stack_top     @ " elog stack Stack_top     @ debug_arg
  " [debug] Stack_ceil    @ " elog stack Stack_ceil    @ debug_arg
end

\ For JIT use only. TODO: AOT compatibility.
fun: stack: { size -- err } ( C: "name" -- ) ( E: -- stack )
  size' Stack malloc { adr }
  size adr stack_init
  adr execute' let:
end

\ ## Loops
\
\ Unlike other Forth systems, we implement termination of arbitrary
\ control structures with a generic `end`. This works for all loops
\ and eliminates the need to remember many different terminators.
\
\ Our solution isn't complicated, either. We simply push functions
\ with their arguments to the control stack and pop the latest one
\ with `end`. Each function pops its arguments and does something,
\ then pops the next function in the chain. The cascade terminates
\ when encountering a function which doesn't pop a preceding one.
\
\ In every counting loop with a named index, such as `+for: ind`,
\ when the loop terminates normally, not with `leave` or `while`,
\ the index local is still in scope, with an out-of-range value.

\ Control stack for auxiliary loop constructs like
\ `leave` and `while` which push their frames here.
\
\ TODO: since we never unmap this memory, this is a known leak
\ in the theoretical case of repeatedly discarding and initing
\ interpreter and language state in an outer C program. How to
\ cleanup?
1024 cells stack: LOOP_AUX

\ Position of the topmost loop frame on the control stack.
\ Each loop pushes at least the following frame:
\
\   prev_loop_ind loop_frame_pop loop_beg …extra… loop_pop
\                                ^
\                                LOOP_IND points here
\
\ `loop_beg` holds the instruction address of loop start.
\ It's used to compile jump-to-start in `end` and `cont`.
\ Many loops also push extra stuff before the "pop" word.
\
\ In stack signatures below, `prev_loop_ind loop_frame_pop`
\ is often shortened to `<loop_prev>`.
0 var: LOOP_IND

fun: loop_frame_adr { -- adr err }
  LOOP_IND @ { frame }
  ifz frame then " missing loop frame" throw end
  frame STACK stack_cell_at
end

fun: loop_frame_pop { prev_loop_ind -- err } ( LOOP_AUX: …aux… -- )
  0 nil comp_barrier
  LOOP_AUX s> execute \ Pop all auxiliaries until a terminating `nop`.
  prev_loop_ind LOOP_IND !
end

fun: loop_frame_init ( C: -- <loop_prev> ) ( LOOP_AUX: -- nop )
  \ Stash prev loop info; replace it, making this the topmost loop frame.
  LOOP_IND @            STACK >s
  xt' loop_frame_pop    STACK >s
  STACK stack_len_cells LOOP_IND !

  \ Terminator for `loop_frame_pop`.
  xt' nop LOOP_AUX >s
end

fun: loop_back { adr -- err }
  0 nil comp_barrier
  adr off_from_pc asm_branch comp_instr \ b <beg>
end

\ Pops the "base" loop frame described in comment for `LOOP_IND`.
\ Loops which push larger frames simply pop-off extra data first.
fun: loop_base_pop { loop_beg -- err }
  ( LOOP_AUX: …aux… -- ) ( C: <loop_prev> -- )
  0 nil comp_barrier
  loop_beg loop_back \ b <beg>
  execute'' end      \ Run `loop_frame_pop`.
end

fun_comp: loop { -- loop_beg loop_pop err } ( C: -- <loop_prev> )
  0 nil comp_barrier
  loop_frame_init
  here_write xt' loop_base_pop
end

fun: leave_pop { -- err }
  0 nil comp_barrier
  LOOP_AUX s> patch_branch_forward
  LOOP_AUX s> execute
end

\ Breaks out of any loop.
fun_comp: leave { -- err } ( LOOP_AUX: -- leave_adr leave_pop )
  0 nil comp_barrier
  reserve_here  LOOP_AUX >s
  xt' leave_pop LOOP_AUX >s
end

fun: while_pop { -- err }
  LOOP_AUX s> { adr }
  LOOP_AUX s> { prev }
  prev adr if_pop_void
end

\ Breaks out of any loop.
fun_comp: while { -- err } ( LOOP_AUX: -- while_adr while_pop )
  1 " when calling `while`" comp_args_valid 0 comp_args_set
  0 nil comp_barrier
  reserve_here  LOOP_AUX >s
  xt' while_pop LOOP_AUX >s
end

\ Goes back to loop start.
fun_comp: cont { -- err } loop_frame_adr @ loop_back end \ b <beg>

\ Like regular Forth `until`, but usable with any loop.
\ Alternative loop terminator; replaces `end`. Example:
\
\   loop false until
fun_comp: until { fun -- err }
  1 " when calling `until`" comp_args_valid 0 comp_args_set
  0 nil comp_barrier
  0 8 asm_cmp_branch_not_zero comp_instr \ cbnz x0, 8
  fun execute
end

fun: loop_pop_with_cond { loop_beg cond_adr asm_cond -- err }
  ( LOOP_AUX: …aux… -- )
  ( C: <loop_prev> -- )

  \ `b <beg>` and other effects.
  loop_beg loop_base_pop

  \ Retropatch `b.<cond> <end>`.
  cond_adr off_to_pc asm_cond asm_branch_cond cond_adr !32
end

fun: for_loop_countdown_init { cur -- loop_beg cond_adr asm_cond loop_pop err }
  ( C: -- <loop_prev> )
  ( E: ceil -- )
  ( LOOP_AUX: -- nop )

  loop_frame_init
  0 cur             comp_local_set \ mov <cur>, x0 | str x0, [FP, <cur>]
  0 nil comp_barrier               \ Clobber / relocate locals.
  here_write { loop_beg }          \ `end` jumps here.
  0 cur             comp_local_get \ mov x0, <cur> | ldr x0, [FP, <cur>]
  0 0 1 asm_sub_imm comp_instr     \ sub x0, x0, 1
  0 cur             comp_local_set \ mov <cur>, x0 | str x0, [FP, <cur>]
  0 nil comp_barrier               \ Tell compiler to commit "local set".
  0 asm_cmp_zero    comp_instr     \ cmp x0, 0
  here_write { cond_adr } reserve_instr \ b.lt <end>

  loop_beg cond_adr ASM_LT xt' loop_pop_with_cond \ stop on <
end

\ A count-down-by-one loop with the range `[0,ceil)`.
\ Analogue of the non-standard `for … next` loop.
\ Usage; ceiling must be positive:
\
\   123
\   for
\     " looping" log lf
\   end
\
\ Anton Ertl circa 1994:
\
\ > This is the preferred loop of native code compiler writers
\   who are too lazy to optimize `?do` loops properly.
fun_comp: for { -- loop_beg cond_adr asm_cond loop_pop err }
  ( C: -- <loop_prev> )
  ( E: ceil -- )
  ( LOOP_AUX: -- nop )
  1 " when calling `for`" comp_args_valid 0 comp_args_set
  comp_local_anon for_loop_countdown_init
end

\ Like `for` but requires a local name to make the index
\ accessible. Usage; ceiling must be positive:
\
\   123
\   -for: ind
\     ind .
\   end
fun_comp: -for: { -- loop_beg cond_adr asm_cond loop_pop err }
  ( C: "name" -- <loop_prev> )
  ( E: ceil -- )
  ( LOOP_AUX: -- nop )
  1 " when calling `-for:`" comp_args_valid 0 comp_args_set
  read_word comp_local_named for_loop_countdown_init
end

\ Count-up loop with the range `[floor,ceil)`. Usage:
\
\   ceil floor +for: ind       end
\   123  45    +for: ind ind . end
fun_comp: +for: { -- loop_beg cond_adr asm_cond loop_pop err }
  ( C: "name" -- <loop_prev> )
  ( E: ceil floor -- )

  2 " when calling `+for:`" comp_args_valid 0 comp_args_set

  loop_frame_init
  comp_local_anon            { lim } \ ceil  = limit
  read_word comp_local_named { cur } \ floor = cursor

  0 lim             comp_local_set \ mov <lim>, x0, | str x0, [FP, <lim>]
  1 cur             comp_local_set \ mov <cur>, x1, | str x1, [FP, <cur>]
  0 nil comp_barrier               \ Clobber / relocate locals.
  20 asm_branch     comp_instr     \ b <cmp>
  here_write { loop_beg }          \ `end` jumps here.
  0 lim             comp_local_get \ mov x0, <lim> | ldr x0, [FP, <lim>]
  1 cur             comp_local_get \ mov x1, <cur> | ldr x1, [FP, <cur>]
  1 1 1 asm_add_imm comp_instr     \ add x1, x1, 1
  1 cur             comp_local_set \ mov <cur>, x1 | str x1, [FP, <cur>]
  0 nil comp_barrier               \ Tell compiler to commit "local set".
  0 1 asm_cmp_reg   comp_instr     \ cmp x0, x1
  here_write { cond_adr } reserve_instr \ b.le <end>

  loop_beg cond_adr ASM_LE xt' loop_pop_with_cond \ stop on <=
end

\ Like in `+for:` and `+loop:`, the range is `[floor,ceil)`.
fun_comp: -loop: { -- loop_beg cond_adr asm_cond loop_pop err }
  ( C: "name" -- <loop_prev> )
  ( E: ceil floor step -- )
  ( LOOP_AUX: -- nop )

  3 " when calling `-loop:`" comp_args_valid 0 comp_args_set

  loop_frame_init
  read_word comp_local_named { cur } \ ceil  = cursor
  comp_local_anon            { lim } \ floor = limit
  comp_local_anon            { step }

  0 cur             comp_local_set \ mov <cur>,  x0 | str x0, [FP, <cur>]
  1 lim             comp_local_set \ mov <lim>,  x1 | str x1, [FP, <lim>]
  2 step            comp_local_set \ mov <step>, x2 | str x2, [FP, <step>]
  0 nil comp_barrier               \ Clobber / relocate locals.
  here_write { loop_beg }          \ `end` jumps here.
  0 cur             comp_local_get \ mov x0, <cur>  | ldr x0, [FP, <cur>]
  1 lim             comp_local_get \ mov x1, <lim>  | ldr x1, [FP, <lim>]
  2 step            comp_local_get \ mov x2, <step> | ldr x2, [FP, <step>]
  0 0 2 asm_sub_reg comp_instr     \ sub x0, x0, x2
  0 cur             comp_local_set \ mov <cur>, x0 | str x0, [FP, <cur>]
  0 nil comp_barrier               \ Tell compiler to commit "local set".
  0 1   asm_cmp_reg comp_instr     \ cmp <cur>, <lim>
  here_write { cond_adr } reserve_instr \ b.lt <end>

  loop_beg cond_adr ASM_LT xt' loop_pop_with_cond \ stop on <
end

\ Similar to the standard `?do ... +loop`, but terminated with an `end`
\ like all our loops. Takes a name to make the index accessible. Usage:
\
\   ceil floor step +loop: ind       end
\   123  23    3    +loop: ind ind . end
\
\ When the loop ends, the index local is still in scope,
\ holding a value which is out of range. For example, then
\ `ceil floor step` is `7 3 2`, the loop iterates twice,
\ with indexes `3` and `5`, and the index outside is `8`.
fun_comp: +loop: { -- loop_beg cond_adr loc_step loop_pop err }
  ( C: "name" -- <loop_prev> )
  ( E: ceil floor step -- )

  3 " when calling `+loop:`" comp_args_valid 0 comp_args_set

  loop_frame_init
  comp_local_anon            { lim } \ ceil  = limit
  read_word comp_local_named { cur } \ floor = cursor
  comp_local_anon            { step }

  0 lim             comp_local_set \ mov <lim>, x0, | str x0, [FP, <lim>]
  1 cur             comp_local_set \ mov <cur>, x1, | str x1, [FP, <cur>]
  2 step            comp_local_set \ mov <step>, x2 | str x2, [FP, <step>]
  0 nil comp_barrier               \ Clobber / relocate locals.
  24 asm_branch     comp_instr     \ b <cmp>
  here_write { loop_beg }          \ `end` jumps here.
  0 lim             comp_local_get \ mov x0, <lim>  | ldr x0, [FP, <lim>]
  1 cur             comp_local_get \ mov x1, <cur>  | ldr x1, [FP, <cur>]
  2 step            comp_local_get \ mov x2, <step> | ldr x2, [FP, <step>]
  1 1 2 asm_add_reg comp_instr     \ add x1, x1, x2
  1 cur             comp_local_set \ mov <cur>, x1  | str x1, [FP, <cur>]
  0 nil comp_barrier               \ Tell compiler to commit "local set".
  0 1 asm_cmp_reg   comp_instr     \ cmp x0, x1
  here_write { cond_adr } reserve_instr \ b.le <end>

  loop_beg cond_adr ASM_LE xt' loop_pop_with_cond \ stop on <=
end

\ ## String comparison continued

\ `strncmp` doesn't like null string pointers.
fun: compare { str0 len0 str1 len1 -- direction }
  ifz   str0 str1 or then 0
  elifz str0         then -1
  elifz str1         then +1
  else  str0 str1 len0 len1 max strncmp
  end
end

\ `strcmp` doesn't like null string pointers.
fun: ccompare { cstr0 cstr1 -- cmp }
  ifz   cstr0 cstr1 or then 0
  elifz cstr0          then -1
  elifz cstr1          then +1
  else  cstr0 cstr1 strcmp
  end
end

fun: str=   { str0 len0 str1 len1 -- bool } str0 len0 str1 len1 compare =0  end
fun: str<   { str0 len0 str1 len1 -- bool } str0 len0 str1 len1 compare <0  end
fun: str<>  { str0 len0 str1 len1 -- bool } str0 len0 str1 len1 compare <>0 end
fun: cstr=  { cstr0 cstr1 -- bool } cstr0 cstr1 ccompare =0  end
fun: cstr<  { cstr0 cstr1 -- bool } cstr0 cstr1 ccompare <0  end
fun: cstr<> { cstr0 cstr1 -- bool } cstr0 cstr1 ccompare <>0 end

\ ## Vargs and formatting

4096    let: ERR_CAP
ERR_CAP mem: ERR_BUF_0
ERR_CAP mem: ERR_BUF_1

\ Short for "compile variadic arguments begin". Assumes the Apple Arm64 ABI
\ where vargs always use the systack. Modifies the SP, which must be later
\ restored with `comp_va_end`. Doesn't clobber any registers.
\
\ We always store pairs and modify the SP by 16, because Arm64 requires the SP
\ to be aligned to 16 when accessing memory. When length is odd, we also store
\ an unused junk value from an unused register, which is fine.
\
\ `floor` is the count of non-vargs preceding vargs.
\ The layout is always `( …non-vargs… …vargs… )`.
\ `diff` must be passed to `comp_va_end`.
fun: comp_va_beg { floor -- diff err }
  comp_args_get           { ceil }
  ceil floor - 2 align_up { diff }
  diff floor +            { ceil }

  ceil floor 2
  -loop: ind
    ind     { Xd }
    ind inc { Xt }
    Xd Xt ASM_REG_SP -16 asm_store_pair_pre comp_instr \ stp Xd, Xt, [sp, -16]!
  end

  floor comp_args_set
  diff
end

\ Short for "compile variadic arguments end".
fun: comp_va_end { len -- err }
  if len then
    len cells 16 align_up { off }
    ASM_REG_SP ASM_REG_SP off asm_add_imm comp_instr \ add sp, sp, <off>
  end
end

\ Sets up variadic arguments following the C ABI. Usage example:
\
\   fun: some_word
\     10 20 30 vargs{ " numbers: %zd %zd %zd" printf }vargs lf
\   end
\
\ Caution: vargs can only be used in direct calls to variadic functions.
\ Indirect calls DO NOT WORK, because stack pointer is changed by calls.
fun_comp: vargs{ { -- len err } ( E: <systack_push> ) 0   comp_va_beg end
fun_comp: }vargs { len -- err } ( E: <systack_pop> )  len comp_va_end end

\ Prepends `pre_len` args to current args. Inputs are passed on the control
\ stack. EVERY input MUST be an execution token from `WORDLIST_COMP`.
fun: comp_args_prepend { pre_len -- err } ( …pre… -- )
  ifz pre_len then ret end

  comp_args_get      { post_len }
  post_len pre_len + { arg_len }

  if arg_len ASM_ARG_LEN_MAX > then
    " in `comp_args_prepend`: too many total args" throw
  end

  arg_len pre_len +for: reg reg comp_clobber end

  post_len -for: reg_src
    reg_src pre_len + { reg_out }
    reg_out reg_src asm_mov_reg comp_instr \ mov <out>, <src>
  end

  pre_len -for: reg
    reg comp_args_set
    STACK s> execute
  end

  arg_len comp_args_set
end

fun_comp: logf { -- err } ( E: fmt …vargs… -- )
  1 comp_va_beg { len }
  compile' printf
  len comp_va_end
  0 comp_args_set
end

fun_comp: elogf { -- err } ( E: fmt …vargs… -- )
  1 comp_va_beg { len }

  xt'' stderr STACK >s
  1 comp_args_prepend
  execute'' systack_ptr
  compile' vfprintf

  len comp_va_end
  0 comp_args_set
end

\ ## Error formatting

fun_comp: errf { -- err } ( E: fmt …vargs… -- err )
  1 comp_va_beg { len }

  xt'' ERR_BUF_0 STACK >s
  xt'' ERR_CAP   STACK >s
  2 comp_args_prepend

  execute'' systack_ptr
  compile' vsnprintf

  len comp_va_end
  0 comp_args_set
  execute'' ERR_BUF_0
end

fun: wrapf_args { err fmt -- buf cap fmt }
  if err ERR_BUF_0 = then ERR_BUF_1 ERR_CAP fmt ret end
  ERR_BUF_0 ERR_CAP fmt
end

\ Wraps a prior error with an additional message.
\ The prior error must always be provided as the
\ first argument before the format, and should
\ usually ALSO be provided in the format vargs.
\ Usage example:
\
\   err " unable to blah (error code: %zd): %s" code err wrapf throw
\
\ Passing the error as the first argument allows us
\ to rotate error format buffers. You can create an
\ error with `errf` and wrap it repeatedly.
fun_comp: wrapf { -- err } ( C: err fmt …vargs… -- str )
  comp_local_anon { buf }
  2 comp_va_beg   { len }

  compile' wrapf_args
  0 buf comp_local_set
  compile' snprintf

  len comp_va_end
  0 buf comp_local_get
end

fun: fatal { err } " fatal: %s" err elogf elf abort end

\ ## OS error stuff
\
\ Also see `./errno.af`.

0 1 extern: __error
1 1 extern: strerror

\ We'd like to treat `errno` as a noun. It would have been convenient then
\ `errno` was a regular global variable, like `__stdinp`. Unfortunately,
\ on MacOS, it's implemented as a macro which calls an external function
\ which returns `x0` while clobbering `x8` and `x9` on the tested system
\ at the time of writing; the ABI is subject to change. Because of this,
\ we have to treat `errno` as a verb, which sometimes requires user code
\ to save its output into a local before using the value as an argument.
\ We could work around this by hardcoding the knowledge of the clobbers,
\ but that would make this system even less portable than it already is.
fun: errno { -- code } __error @s32 end

\ `code` comes from from `errno`, `ferror`, Posix functions, etc.
\ See `is_err_flag` earlier in this file for detecting -1 error codes.
fun: os_err { code ctx -- err_str }
  code strerror { msg }
  if msg then
    " %s; code: %zd; msg: %s" ctx code msg errf ret
  end
  " %s; code: %zd" ctx code errf
end

\ Shortcut for calling `libc` functions which return
\ `-1` and set `errno` on failure. Usage:
\
\   0 1 extern: some_fun
\   some_fun " unable to do X" os_err? try
fun: os_err? { int ctx -- err_str }
  if int is_err_flag then errno ctx os_err else nil end
end

\ Like `os_err?`, but for Posix functions which directly
\ return an `errno` code on failure, and zero on success.
fun: posix_err? { code ctx -- err_str }
  if code then code ctx os_err else nil end
end

\ ## Formatting continued

\ For functions like `snprintf` which return length or error sentinel.
\ Assumes length has already been sign-extended from `Cint`.
fun: validate_format_len { len -- len err }
  if len >=0 then len ret end

  errno { code }
  code strerror { msg }
  if msg then
    " unable to format string; code: %d; msg: %s" code msg errf throw
  else
    " unable to format string; code: %s" code errf throw
  end

  nil
end

\ Formats into a given buffer, with null-termination. Usage:
\
\   BUF CAP " codes: %zd %zd %zd" 10 20 30 str_prnf
fun_comp: str_prnf { -- err } ( E: buf cap fmt …vargs… -- len|err )
  3 comp_va_beg { len }
  compile' snprintf
  len comp_va_end
  compile' int_to_cell
  compile' validate_format_len
end

\ Like `str_prnf`, but returns the given buffer,
\ instead of formatted length or error sentinel.
fun_comp: strf { -- err } ( E: buf cap fmt …vargs… -- buf )
  comp_local_anon { loc }
  0 loc comp_local_set
  execute'' str_prnf
  0 loc comp_local_get
end

fun_comp: fmtf { -- err } ( E: file fmt …vargs… )
  2 comp_va_beg { len }
  compile' fprintf
  len comp_va_end
  compile' int_to_cell
  compile' validate_format_len
  0 comp_args_set
end

\ ## Stack manipulation continued

\ ldur <top>, [<stk>, STACK_OFF_TOP]
\ ...
\   str  <arg>, [<top>], 8
\   str  <arg>, [<top>], 8
\   str  <arg>, [<top>], 8
\ ...
\ stur <top>, [<stk>, STACK_OFF_TOP]
\
\ Should usually be followed with `0 comp_args_set`.
fun: comp_args_to_stack { len stk_reg top_reg -- err } ( E: …args… -- )
  ifz len then ret end

  top_reg stk_reg asm_stack_top_load comp_instr \ ldur <top>, [<stk>, STACK_OFF_TOP]

  comp_args_get 0 +for: arg_reg
    arg_reg top_reg 8 asm_store_post comp_instr \ str <arg>, [<top>], 8
  end

  top_reg stk_reg asm_stack_top_store comp_instr \ stur <top>, [<stk>, STACK_OFF_TOP]
end

\ Variadic alternative to `>s`:
\
\   10 20 30 some_stack >>s
\
\ TODO drop: too error-prone.
fun_comp: >>s { -- err } ( E: …args… stack -- )
  comp_args_get { arg_len }

  ifz arg_len then
    " unable to use `>>s`: at least 1 argument is required (stack address)"
    throw
  end

  arg_len dec { len }
  len comp_args_set
  ifz len then ret end

  if arg_len ASM_ARG_LEN_MAX >= then
    " unable to use `>>s`: not enough scratch registers" throw
  end

  len     { stk_reg }
  arg_len { top_reg }
  top_reg comp_clobber
  len stk_reg top_reg comp_args_to_stack
  0 comp_args_set
end

\ Variadic assignment of locals from the stack:
\
\   10 20 30 some_stack >>s
\   some_stack stack{ ten twenty thirty }
fun_comp: stack{ { -- err } ( E: stack -- )
  comp_args_get { len }

  if len 1 <> then
    " unable to use `stack{`: exactly one argument is required (stack address)"
    throw
  end

  0 { locs }

  loop
    read_word { str len }

    if s" }"  str len str= then leave end

    if s" --" str len str= then
      " unsupported `--` in `stack{`" throw
    end

    str len comp_local_named STACK >s
    locs inc { locs }
  end

  0 comp_args_set
  ifz locs then ret end

  0 { stk_reg }
  1 { top_reg }
  2 { val_reg }

  top_reg comp_clobber
  val_reg comp_clobber

  top_reg stk_reg asm_stack_top_load comp_instr \ ldur <top>, [<stk>, STACK_OFF_TOP]

  locs for
    STACK s> { loc }
    val_reg top_reg -8 asm_load_pre comp_instr     \ ldr <val>, [<top>, -8]!
    val_reg loc                     comp_local_set \ mov <loc>, x0 | str x0, [FP, <loc>]
    val_reg comp_clobber
  end

  top_reg stk_reg asm_stack_top_store comp_instr \ stur <top>, [<stk>, STACK_OFF_TOP]
end

\ ## Stack printing

fun: log_int  { num } " %zd" num logf end
fun: log_cell { num } " %zd 0x%zx" num num logf end
fun: .        { num } num log_cell lf end

fun: stack_log_cells { stack }
  stack stack_len_cells { len }

  ifz len then
    " stack is empty" log lf
    ret
  end

  if len <0 then
    " stack length is negative: %zd" len logf lf
    ret
  end

  " stack <%zd>:" len logf lf

  len 0 +for: ind
    space space
    ind stack stack_cell_at @ log_cell
    "  <%zd>" ind logf
    lf
  end
end

fun: .s STACK stack_log_cells end
fun: .sc .s STACK stack_trunc end

\ ## Dictionary introspection

fun: wordlist_log { dict list_num list_name }
  dict Interp_dict_len @u32 { len }

  ifz len then
    " %s: empty" list_name logf lf
    ret
  end

  " %s (%zd):" list_name len logf

  dict Interp_dict_cap  @u32 { cap }
  dict Interp_dict_keys @    { keys }
  dict Interp_dict_bits @    { bitsets }
  8 cells                    { bitset_size }

  \ See C `dict_has` (with some indirections):
  \
  \   bits[ind / HASH_TABLE_BITS_CAP] & ((Uint)1 << (ind % HASH_TABLE_BITS_CAP))
  cap 0 +for: ind
    ind bitset_size / cells { bitset_off }
    bitsets bitset_off + @  { bitset }
    ind bitset_size mod     { bit_ind }
    1 bit_ind lsl           { bit_mask }
    bitset bit_mask and     { live }

    ifz live then cont end

    ind cells { off }
    keys off + @ { key }
    space key log
  end

  lf
end

\ "words" is magically recommended by compiler in REPL.
fun: words
  interp Interp_dict_exec WORDLIST_EXEC " WORDLIST_EXEC" wordlist_log
  interp Interp_dict_comp WORDLIST_COMP " WORDLIST_COMP" wordlist_log
end

\ ## Indirect functions
\
\ Support for indirect functions, analogous to the standard `defer`,
\ which can be used to emulate forward declarations, at the cost of
\ dispatch overhead. Intended mainly for mutual recursion.
\
\ Usage example:
\
\   1 1 false indirect: SOME_FUNC some_func
\
\   fun: some_func { inp -- out } [ redefine ] inp end
\
\   SOME_FUNC indirect_to' some_func

struct: Indir_decl
  Cell 1 field: Indir_decl_off \ Could be `S32`, but needs changes elsewhere.
  Adr  1 field: Indir_decl_instr
  U8   1 field: Indir_decl_inp
  U8   1 field: Indir_decl_out
  U8   1 field: Indir_decl_has_err
end

fun: indirect: { inp out has_err -- err } ( C: "var_name" "fun_name" -- )
  nil size' Indir_decl alloc_data { decl }

  inp     decl Indir_decl_inp     !b
  out     decl Indir_decl_out     !b
  has_err decl Indir_decl_has_err !b

  read_word { str len }
  str len decl init_data_word

  read_word define_fun
    inp out has_err comp_signature_set
    comp_clobber_volatile

    ASM_REG_SCRATCH { R_off } \ Holds offsets.
    R_off inc       { R_adr } \ Holds address of `br <implementation>` instruction.

    decl R_off      comp_page_load \ adrp x8, @page ; ldr x8, @pageoff
    R_adr 8 asm_adr comp_instr     \ adr x9, offsetof `br`

    R_off R_off R_adr asm_add_reg  comp_instr \ add x8, x8, x9
    here_exec decl Indir_decl_instr !
    R_off  asm_branch_to_reg       comp_instr \ br <implementation>
    123    asm_brk                 comp_instr \ brk 123 -- unreachable

    out comp_args_set
  semicolon

  [ false comp_only ]
end

\ This would be a 1-liner without signature checks and error messages.
fun: indirect_to { decl xt_to -- err }
  decl Indir_decl_inp @b { decl_inp }
  xt_to Sym_inp_len     @b { sym_inp }
  xt_to sym_name           { name }

  if decl_inp sym_inp <> then
    " unable to indirect to `%s`: input count: %zd <> %zd"
    name decl_inp sym_inp errf throw
  end

  decl Indir_decl_out @b { decl_out }
  xt_to Sym_out_len     @b { sym_out }

  if decl_out sym_out <> then
    " unable to indirect to `%s`: output count: %zd <> %zd"
    name decl_out sym_out errf throw
  end

  decl Indir_decl_has_err @b { decl_has_err }
  xt_to Sym_has_err       @b { sym_has_err }

  if decl_has_err sym_has_err <> then
    " unable to indirect to `%s`: has_err: %zd <> %zd"
    name decl_has_err sym_has_err errf throw
  end

  decl Indir_decl_instr @ { instr_adr }
  xt_to sym_instr instr_adr - decl Indir_decl_off !
end

fun: indirect_to' { decl -- err } ( C: "name" -- )
  WORDLIST_EXEC next_word { XT }
  decl XT indirect_to
end

\ ## Misc

\ blr x0
fun: execute_raw { fun } [ 0 asm_branch_link_reg comp_instr ] end

\ Takes any amount of args where the last arg is assumed to be a raw
\ instruction address, known in C as "function pointer". Invokes the
\ function with the preceding args. Assumes no outputs or errors.
\
\ TODO: tell the compiler about the call. We want the compiler
\ to emit prologue and epilogue, track clobbers, and so on.
\
\ TODO: verify that clobbering works properly.
fun_comp: execute_raw { -- err } ( C: …args… fun -- ) ( E: …args… fun -- )
  comp_args_get { len }

  ifz len then
    " unable to compile `execute_raw`: at least 1 argument is required" throw
  end

  if len ASM_PARAM_LEN_MAX inc > then
    " unable to compile `execute_raw`: %zd param registers available, %zd arguments provided"
    ASM_PARAM_LEN_MAX len dec errf throw
  end

  comp_clobber_volatile
  0 comp_args_set

  \ The frame record is a workaround for "leaf" functions using `execute_raw`.
  \
  \   stp x29, x30, [sp, #-16]!
  \   blr <fun>
  \   ldp x29, x30, [sp], #16
  ASM_REG_FP ASM_REG_LR ASM_REG_SP -16 asm_store_pair_pre comp_instr
  len dec asm_branch_link_reg comp_instr
  ASM_REG_FP ASM_REG_LR ASM_REG_SP 16 asm_load_pair_post comp_instr
end

\ For compiling words which modify a local by applying the given function.
fun: comp_loc_mut { fun name -- err } ( C: "name" -- ) ( E: -- )
  read_word comp_local_named { loc }

  if comp_args_get then
    " arity mismatch in `%s`: expected no arguments" name errf throw
  end

  0 loc comp_local_get \ mov x0, <loc> | ldr x0, [FP, <loc>]
  1     comp_args_set
  fun   comp_call      \ blr <fun>
  0 loc comp_local_set \ mov <loc>, x0 | str x0, [FP, <loc>]
  0     comp_args_set
end

\ Increment a local: `inc: some_val`.
fun_comp: inc: { -- err } ( C: "name" -- ) ( E: -- )
  xt' inc " inc:" comp_loc_mut
end

\ Decrement a local: `inc: some_val`.
fun_comp: dec: { -- err } ( C: "name" -- ) ( E: -- )
  xt' dec " dec:" comp_loc_mut
end

\ Comptime analogue of top-level `import'`.
fun_comp: import' { -- err } read_word comp_str compile' import end

\ For internal use below. Each `ccmp` runs only if previous test didn't pass;
\ otherwise it sets condition flags to our `nzcv` fallback. The final `cset`
\ sets the final bool based on resulting flags.
fun: comp_cmp_many { name cond_each nzcv cond_end -- err }
  ( E: val …preds… -- bool )

  comp_args_get { len }

  if len 3 < then
    " `%s` requires at least 3 inputs: value to test, and predicates" name errf throw
  end

  0 1 asm_cmp_reg comp_instr \ cmp x0, x1

  len 2 +for: pred
    \ ccmp x0, xN, <nzcv>, <cond>
    0 pred nzcv cond_each asm_ccmp_reg comp_instr
  end

  0 comp_clobber
  0 cond_end asm_cset comp_instr \ cset x0, <cond>
  1 comp_args_set
end

0b1000 let: ASM_NZCV_N
0b0100 let: ASM_NZCV_Z
0b0010 let: ASM_NZCV_C
0b0001 let: ASM_NZCV_V
0b0100 let: ASM_NZCV_EQ_OK \ Z=1
0b0000 let: ASM_NZCV_NE_OK \ Z=0
0b0000 let: ASM_NZCV_LO_OK \ C=0
0b0010 let: ASM_NZCV_HS_OK \ C=1
0b0010 let: ASM_NZCV_HI_OK \ C=1 Z=0
0b0000 let: ASM_NZCV_LS_OK \ C=0 -> LS true
0b1000 let: ASM_NZCV_LT_OK \ N=1 V=0
0b0000 let: ASM_NZCV_GE_OK \ N=0 V=0
0b0000 let: ASM_NZCV_GT_OK \ Z=0 N=V=0
0b0100 let: ASM_NZCV_LE_OK \ Z=1

false try_all
fun_comp: =any    { -- err } " =any"    ASM_NE ASM_NZCV_EQ_OK ASM_EQ comp_cmp_many end
fun_comp: =none   { -- err } " =none"   ASM_NE ASM_NZCV_EQ_OK ASM_NE comp_cmp_many end
fun_comp: u<any   { -- err } " u<any"   ASM_HS ASM_NZCV_LO_OK ASM_LO comp_cmp_many end
fun_comp: u>=any  { -- err } " u>=any"  ASM_LO ASM_NZCV_HS_OK ASM_HS comp_cmp_many end
fun_comp: u>any   { -- err } " u>any"   ASM_LS ASM_NZCV_HI_OK ASM_HI comp_cmp_many end
fun_comp: u<=any  { -- err } " u<=any"  ASM_HI ASM_NZCV_LS_OK ASM_LS comp_cmp_many end
fun_comp: u<none  { -- err } " u<none"  ASM_HS ASM_NZCV_LO_OK ASM_HS comp_cmp_many end
fun_comp: u>=none { -- err } " u>=none" ASM_LO ASM_NZCV_HS_OK ASM_LO comp_cmp_many end
fun_comp: u>none  { -- err } " u>none"  ASM_LS ASM_NZCV_HI_OK ASM_LS comp_cmp_many end
fun_comp: u<=none { -- err } " u<=none" ASM_HI ASM_NZCV_LS_OK ASM_HI comp_cmp_many end
fun_comp: <any    { -- err } " <any"    ASM_GE ASM_NZCV_LT_OK ASM_LT comp_cmp_many end
fun_comp: >=any   { -- err } " >=any"   ASM_LT ASM_NZCV_GE_OK ASM_GE comp_cmp_many end
fun_comp: >any    { -- err } " >any"    ASM_LE ASM_NZCV_GT_OK ASM_GT comp_cmp_many end
fun_comp: <=any   { -- err } " <=any"   ASM_GT ASM_NZCV_LE_OK ASM_LE comp_cmp_many end
fun_comp: <none   { -- err } " <none"   ASM_GE ASM_NZCV_LT_OK ASM_GE comp_cmp_many end
fun_comp: >=none  { -- err } " >=none"  ASM_LT ASM_NZCV_GE_OK ASM_LT comp_cmp_many end
fun_comp: >none   { -- err } " >none"   ASM_LE ASM_NZCV_GT_OK ASM_LE comp_cmp_many end
fun_comp: <=none  { -- err } " <=none"  ASM_GT ASM_NZCV_LE_OK ASM_GT comp_cmp_many end
true try_all

fun: is_whitespace { char -- bool } char LF CR TAB VTAB SPACE =any end

fun: assert_cond { cond ctx -- err }
  if cond then ret end
  " assertion failed: %s" ctx errf
end

fun: assert_pop { beg -- err }
  1 " when compiling `assert`" comp_args_valid
  interp Interp_module @ Interp_module_reader { read }
  read Interp_reader_src @ read Interp_reader_pos @u32 + { ceil }

  ceil 3 - { ceil }
  ceil dec @b is_whitespace =0 { fail }
  s" end" ceil 3 str<> fail or { fail }

  if fail then
    " invalid use of `assert`: must be terminated with `end`" throw
  end

  loop beg  @b is_whitespace while inc: beg end
  loop ceil @b is_whitespace while dec: ceil end

  ceil beg - { len }
  beg len comp_cstr
  compile' assert_cond
end

fun_comp: assert { -- beg fun err } ( E: cond -- )
  interp Interp_module @ Interp_module_reader { read }
  read Interp_reader_src @ read Interp_reader_pos @u32 +
  xt' assert_pop
  [ true comp_only ]
end
