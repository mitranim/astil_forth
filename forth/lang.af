fun: elf                     LF eputchar             { -- } end
fun: space                   SPACE putchar           { -- } end
fun: espace                  SPACE eputchar          { -- } end
fun: fprint { str len file } str 1 len file fwrite   { -- } end

\ ## Conditionals
\
\ The general idea is to reserve branching instructions,
\ push addresses to the control stack, then patch-up the
\ instructions in later words like `else` and `end`.
\
\   if pred then \ cbz <outside>
\     if_true
\   end
\   outside
\
\   if pred then \ cbz <if_false>
\     if_true
\   else      \ b <outside>
\     if_false
\   end
\   outside
\
\ Similarly to Gforth, our conditionals use the Forth data stack
\ to store control information at compile time. When terminated,
\ they use this information to "fixup" reserved instructions.
\
\ Unlike other Forth systems, we also support chains of "elif",
\ terminated with a single "end", which is generic: it pops one
\ XT from the stack and executes it. The XT can pop another one,
\ popping multiple control frames in a chain. We terminate such
\ chains by prepending a `nop` XT.

fun: reserve_instr { -- err } ASM_PLACEHOLDER comp_instr end

fun: reserve_here { -- adr err }
  here_write { out } ASM_PLACEHOLDER comp_instr out
end

\ For forward jumps.
fun: off_to_pc { adr -- off err } here_write adr - end

\ For backward jumps.
fun: off_from_pc { adr -- off err } here_write { out } adr out - end

\ b <off>
fun: patch_branch_forward { adr -- err } adr off_to_pc asm_branch adr !32 end

\ b <off>
fun: patch_branch_back { adr -- err } adr off_from_pc asm_branch adr !32 end

\ The bits "inp len" describe _extra_ inputs after consuming the predicate.
\ Each branch gets its own input length, because expressions in each `elif`
\ may have different arities. Each branch feeds extra inputs into its body.
\ We validate that the result output length is consistent between branches.
\
\ The bits "out len" describe leftover arguments at branch exits.
\ We infer them at the first branch exit. Every subsequent branch
\ exit validates arity match.
ASM_ARG_LEN_MAX bit_len            let: COND_LEN_OFF
COND_LEN_OFF low_bits              let: COND_INP_LEN_MASK
COND_INP_LEN_MASK COND_LEN_OFF lsl let: COND_OUT_LEN_MASK
1 COND_LEN_OFF 1 lsl lsl           let: COND_HAS_INP_LEN
COND_HAS_INP_LEN 1 lsl             let: COND_HAS_OUT_LEN
COND_HAS_OUT_LEN 1 lsl             let: COND_HAS_ELSE

fun: cond_meta_inp_len { meta -- len } meta COND_INP_LEN_MASK and end
fun: cond_meta_out_len { meta -- len } meta COND_OUT_LEN_MASK and COND_LEN_OFF lsr end

\ Caller must also use `comp_barrier` with appropriate arity.
fun: if_pop { prev adr meta -- err }
  adr off_to_pc { off }
  meta cond_meta_inp_len { reg }
  reg off asm_cmp_branch_zero adr !32 \ cbz <reg>, <else|end>
  prev execute
end

\ Caller must also use `comp_barrier` with appropriate arity.
fun: ifn_pop { prev adr meta -- err }
  adr off_to_pc { off }
  meta cond_meta_inp_len { reg }
  reg off asm_cmp_branch_not_zero adr !32 \ cbnz <reg>, <else|end>
  prev execute
end

fun: if_pop_void  { prev adr -- err } 0 nil comp_barrier prev adr 0 if_pop  end
fun: ifn_pop_void { prev adr -- err } 0 nil comp_barrier prev adr 0 ifn_pop end

fun_comp: if  { -- nop pop } xt' nop xt' if_pop_void  end
fun_comp: ifz { -- nop pop } xt' nop xt' ifn_pop_void end

fun_comp: then { pop -- adr pop err } ( E: pred -- )
  " when calling `then`" { ctx }
  1 ctx comp_args_valid
  0     comp_args_set
  0 ctx comp_barrier
  reserve_here pop
end

\ Now that we have nullary conditionals, we can redefine
\ them into full-blown arity-aware condition expressions.

fun: cond_branch_open { meta ctx -- meta branch_meta err }
  1 ctx comp_args_min
  comp_args_get dec { len }
  len comp_args_set
  len ctx comp_barrier
  meta len
end

fun: cond_branch_close { meta ctx -- meta err }
  meta cond_meta_out_len { len }

  ifz meta COND_HAS_OUT_LEN and then
    comp_args_get { len }
    len COND_LEN_OFF lsl meta or COND_HAS_OUT_LEN or { meta }
  end

  len ctx comp_barrier
  meta
end

\ Caller must also use `comp_barrier` with appropriate arity.
\ Takes "meta" because this shares the signature with `if_pop`
\ and `ifn_pop`; all these words may be executed by `cond_pop`.
fun: else_pop { prev adr _meta -- err }
  adr patch_branch_forward
  prev execute
end

\ Used by `else elif elifz`. `pop` is one of: `if_pop ifn_pop`.
fun: cond_separator { adr branch_meta pop meta ctx -- adr branch_meta else_pop meta err }
  meta ctx cond_branch_close { meta }
  reserve_here { next_adr }

  xt' nop STACK >s \ Prevent chaining.
  adr         STACK >s
  branch_meta STACK >s
  pop execute

  branch_meta cond_meta_inp_len comp_args_set
  next_adr branch_meta xt' else_pop meta
end

\ Popped by `end` after `if elif elifz … then`.
\ `pop` is one of: `if_pop ifn_pop else_pop`.
fun: cond_pop { adr branch_meta pop meta -- err }
  " when ending conditional branch" { ctx }
  meta ctx cond_branch_close { meta }
  meta cond_meta_out_len { len }

  ifz meta COND_HAS_ELSE and then
    branch_meta cond_meta_inp_len { inp_len }
    if len inp_len <> then
      if inp_len =0 len and then
        " conditional with outputs requires final `else`" throw
      end
      inp_len ctx comp_args_valid
    end
  end

  adr         STACK >s
  branch_meta STACK >s
  pop         execute
  len ctx comp_args_valid
end

fun_comp: if  { -- nop pop meta err } [ redefine ] xt' nop xt' if_pop  0 end
fun_comp: ifz { -- nop pop meta err } [ redefine ] xt' nop xt' ifn_pop 0 end

\ `pop` is one of: `if_pop ifn_pop`.
fun_comp: then { pop meta -- adr branch_meta pop meta cond_pop err } ( E: pred -- )
  [ redefine ]
  meta " when calling `then`" cond_branch_open { meta branch_meta }
  reserve_here branch_meta pop meta xt' cond_pop
end

\ `pop` is one of: `if_pop ifn_pop`.
fun_comp: elif
  { adr branch_meta pop meta _cond_pop -- adr branch_meta else_pop if_pop meta err }
  adr branch_meta pop meta
  " when calling `elif`" cond_separator { adr branch_meta pop meta }
  adr branch_meta pop xt' if_pop meta
end

\ `pop` is one of: `if_pop ifn_pop`.
fun_comp: elifz
  { adr branch_meta pop meta _cond_pop -- adr branch_meta else_pop ifn_pop meta err }
  adr branch_meta pop meta
  " when calling `elifz`" cond_separator { adr branch_meta pop meta }
  adr branch_meta pop xt' ifn_pop meta
end

\ `pop` is one of: `if_pop ifn_pop`.
fun_comp: else { adr branch_meta pop meta cond_pop -- adr branch_meta else_pop meta cond_pop err }
  adr branch_meta pop meta COND_HAS_ELSE or
  " when calling `else`" cond_separator cond_pop
end

fun: switch_pop { prev _val_loc_ _branch_meta meta -- err }
  meta " when ending `switch`" cond_branch_close { -- }
  prev execute
end

fun_comp: switch { -- nop val branch_meta meta switch_pop err } ( E: … val -- … )
  " when calling `switch`" { ctx }
  1 ctx comp_args_min
  comp_args_get dec { branch_meta }
  comp_local_anon { val }
  branch_meta val comp_local_set \ mov <val>, xN | str xN, [FP, <val>]
  branch_meta comp_args_set
  branch_meta ctx comp_barrier
  xt' nop val branch_meta 0 xt' switch_pop
end

fun: case_else_pop { prev adr -- err }
  adr patch_branch_forward
  prev execute
end

fun: case_pop
  {
    val_loc branch_meta meta switch_pop case_adr
    --
    adr_end case_else_pop val_loc branch_meta meta switch_pop err
  }

  meta " when ending `case`" cond_branch_close { meta }
  reserve_here { adr_end }
  case_adr off_to_pc { off }

  off ASM_NE asm_branch_cond case_adr !32 \ b.ne <case_end>
  branch_meta cond_meta_inp_len comp_args_set
  adr_end xt' case_else_pop val_loc branch_meta meta switch_pop
end

fun_comp: case
  {
    val_loc switch_branch_meta meta switch_pop
    --
    val_loc branch_meta meta switch_pop case_adr case_pop err
  }
  ( E: pred -- )

  " when calling `case`" { ctx }
  1 ctx comp_args_min
  comp_args_get { len }

  \ TODO: un-hardcode the numbers.
  if len ASM_ARG_LEN_MAX >= then
    " unable to compile `case`: too many arguments: 15 registers available, 16 arguments provided" throw
  end

  len dec          { branch_meta }
  comp_scratch_reg { val_reg }

  val_reg val_loc comp_local_get \ mov <val_reg>, <val> | ldr <val_reg>, [FP, <val>]
  branch_meta val_reg asm_cmp_reg comp_instr \ cmp <pred>, <val>
  branch_meta comp_args_set
  branch_meta ctx comp_barrier

  reserve_here { adr } \ b.ne <case_end>
  val_loc branch_meta meta switch_pop adr xt' case_pop
end

\ ## Types
\
\ We define type descriptors with size and alignment information.
\ This allows us to provide `struct:` with proper field alignment
\ compatible with C, for easier libc interop.

\ Internal tool for type definitions. Each type is represented with the
\ structure listed below. Since we do not yet have `struct:` because it
\ can only be defined later, we get / set fields via hardcoded offsets.
\
\   struct: Type
\     Cell 1 field: Type_size
\     Cell 1 field: Type_align
\     U8   0 field: Type_name  \ Variable length; null-terminated.
\   end
\
\ Types are defined with shortcuts `int: arr: struct: opaque:`.
\
\ Most of the time size and alignment should be accessed via
\ `size'` and `align'` shortcuts, which inline the values at
\ compile time, without loading type descriptors at runtime.
\
\ SYNC[type_fields].
fun: define_type { name name_len size align -- err }
  name_len inc             { name_cap }
  2 cells name_cap +       { full_size }
  nil full_size alloc_data { type }

  size type !
  align type CELL !at
  2 cells type + name name_cap strlcpy
  name name_len type init_data_word

  [ false comp_only ]
end

fun: int: { size -- err } ( C: "name" -- ) ( E: -- type )
  read_word size size define_type
end

fun: opaque: { size align -- err } ( C: "name" -- ) ( E: -- type )
  read_word size align define_type
end

fun: sizeof { type -- size } type @ end

fun: size' { -- size err } ( C: "type" -- )
  WORDLIST_EXEC next_word execute STACK s> sizeof
end

fun_comp: size' { -- err } ( C: "type" -- ) ( E: -- size )
  execute' size' comp_push
end

fun: alignof { type -- align } type +cell @ end

fun: align' { -- align err } ( C: "type" -- )
  WORDLIST_EXEC next_word execute STACK s> alignof
end

fun_comp: align' { -- err } ( C: "type" -- ) ( E: -- align )
  execute' align' comp_push
end

fun_comp: alloca' { -- err } ( C: "type" -- ) ( E: -- adr )
  execute'' size' execute'' alloca
end

fun_comp: is_aligned_to' { -- err } ( C: "type" -- ) ( E: adr -- bool )
  execute'' align' execute'' is_aligned_to
end

fun: is_aligned_to' { adr -- bool err }
  execute' align' { size }
  adr size is_aligned_to
end

\ ### Integer types
\
\ Assumes Arm64 + Apple ABI.
\
\ "S" stands for "signed integer", "U" for "unsigned integer".
\
\ When converting shorter signed integers to wider ones,
\ they must be sign-extended. See `int_to_cell` for `S32`.
\
\ When accessing memory, use the appropriately sized/typed memory operators.
\ For example, `U32` is loaded with `@u32`, but `S32` is loaded with `@s32`.
\ Both are stored with `!32`. Aliases like `Cint` get their own "operators".
\ See memory ops above.
1 int: U8
1 int: S8
2 int: U16
2 int: S16
4 int: U32
4 int: S32
8 int: U64
8 int: S64
8 int: Adr
8 int: Cell \ Classic Forth name for machine word. Interpreted as signed.
8 int: Cstr \ char*
4 int: Cint
4 int: Cuint
8 int: Clong
8 int: Culong

\ ### Array types

\ Usage:
\
\   U8 128   arr: Some_arr
\   Some_arr mem: SOME_BUF
\
\ An array's alignment is equal to the alignment of its element type.
\ An array type can be used in a struct field, although that's usually
\ unnecessary, because each struct field is declared exactly the same
\ way as an array type:
\
\   Elem_type 32 arr:   Some_arr
\   Elem_type 32 field: Some_field
\   Some_arr  1  field: Some_field
fun: arr: { type len -- err } ( C: "name" -- ) ( E: -- type )
  type sizeof len * { size }
  type alignof      { align }
  read_word size align define_type
end

\ ### Struct types
\
\ Structs allow C interop. Fields are aligned
\ and padded to match the C ABI. Basic usage:
\
\   struct: Type
\     S32 1  field: Type_field0
\     U8  32 field: Type_field1
\   end
\
\   size' Type alloca { adr }
\
\       adr Type_field0 @
\   123 adr Type_field0 !
\
\ The name of a struct type returns an actual `Type`.
\ When allocating, use `size'` to get the size instead.
\
\ The name of each field is a compile-time word which calculates its
\ offset from an address. To get an offset from zero, provide zero.
\
\ Normally, a verb consumes all arguments; a field appears to have arity 1.
\ But these fields are not exactly verbs; multiple fields can be accessed in
\ one argument list. The load operator `@` behaves the same way, so they can
\ be all used inside a longer argument list, exactly like verbs behave in
\ stack-based programming:
\
\   adr Type_field0 @ \ noun0
\   adr Type_field1 @ \ noun1
\   some_verb
\
\ Note that load / store is type-specific. Fields which are't cell-sized
\ must be loaded and stored using dedicated typed operators.

\ For internal use, invoked by `end`.
fun: struct_pop { name name_len align off -- err } ( C: name name_len align off -- )
  off align align_up { size }
  name name_len size align define_type
  name free
  [ false comp_only ]
end

\ Begins a definition; terminate with `end`.
fun: struct: { -- str len align off fun err } ( C: "name" -- ) ( E: -- size )
  read_word       { str len }
  str len strndup { str } \ Leak if comp error before `struct_pop` done.
  xt' struct_pop  { fun }
  str len 0 0 fun
end

\ Compile field access, which computes address + offset.
fun: struct_field_comp { off -- err }
  comp_args_get { len }
  ifz len then " struct field must be preceded by struct pointer" throw end
  ifz off then ret end

  \ Same reg: replace prior address with address + offset.
  len dec { adr_reg }
  adr_reg comp_clobber \ Disassociate locals from this reg.

  if off ASM_MAX_IMM12 <= then
    adr_reg adr_reg off asm_add_imm comp_instr \ add <adr>, <adr>, <off>
  else
    comp_scratch_reg { off_reg }
    off off_reg comp_load \ mov <reg>, <imm> | ldr <reg>, <some_off>
    adr_reg adr_reg off_reg asm_add_reg comp_instr \ add <adr>, <adr>, <off>
  end
end

\ For internal use.
fun: struct_field_define
  { name name_len struct_align align off type len -- align off err }
  ( E: struct_adr -- field_adr )

  \ Since structs are intended for C interop, alignment of every field
  \ must match the platform's C ABI. So far, ABI compat seems to hold.
  \ We still need more comprehensive tests.
  off align align_up { off }

  \ Execution-time semantics.
  name name_len define_fun
    1 1 false comp_signature_set ( E: struct_adr -- field_adr )
    1 comp_args_set
    if off then off comp_push compile' + end
  semicolon

  \ Compile-time semantics.
  name name_len define_fun_comp
    false try_all
    0 1 true comp_signature_set
    off comp_push compile' struct_field_comp
  semicolon

  type sizeof len * off + { off }
  struct_align align max off

  [ false comp_only ]
end

\ Every field takes two inputs: type decl, like `U8`, and element count.
\ This allows us to align fields to element size rather than total size.
\
\ A field becomes a word `( struct_adr -- field_adr )` which computes
\ a field address from a struct address. Cell-sized fields are loaded
\ and stored with `@ !`. Smaller fields require operators specific to
\ their size and type. For example, signed 32-bit integers `S32` must
\ be stored with `!32` and loaded with `@s32`, which sign-extends the
\ upper bits when loading. Unsigned `U32` must be loaded with `@u32`.
fun: field: { struct_align off fun type len -- align off fun err }
  ( C: "name" -- )
  ( E: struct_adr -- field_adr )

  type alignof { align }
  read_word struct_align align off type len
  struct_field_define fun
end

fun: field_aligned: { struct_align off fun type len align -- align off fun err }
  ( C: "name" -- )
  ( E: struct_adr -- field_adr )

  read_word struct_align align off type len
  struct_field_define fun
end

\ Can finally define the type layout officially.
struct: Type
  Cell 1 field: Type_size
  Cell 1 field: Type_align
  U8   0 field: Type_name  \ Variable width; null-terminated.
end

\ ## Interpreter internals
\
\ Internal stuff not exposed via intrinsics.

\ SYNC[set_fields].
struct: Interp_set
  U32 1 field: Interp_set_len
  U32 1 field: Interp_set_cap
  Adr 1 field: Interp_set_bits \ Cell*
  Adr 1 field: Interp_set_vals \ Sym**
end

\ SYNC[word_str].
struct: Sym_word
  U32 1   field: Sym_word_len
  U8  128 field: Sym_word_buf
end

\ SYNC[sym_fields].
struct: Sym_instrs
  U32 1 field: Sym_instrs_floor
  U32 1 field: Sym_instrs_prologue
  U32 1 field: Sym_instrs_inner
  U32 1 field: Sym_instrs_epi_ok
  U32 1 field: Sym_instrs_epi_err
  U32 1 field: Sym_instrs_ret
  U32 1 field: Sym_instrs_data
  U32 1 field: Sym_instrs_ceil
end

\ SYNC[sym_fields].
struct: Sym_norm
  Adr        1 field: Sym_norm_exec
  Sym_instrs 1 field: Sym_norm_spans
  U8         1 field: Sym_norm_inlinable
  U8         1 field: Sym_norm_has_loads
  U8         1 field: Sym_norm_has_recur
  U8         1 field: Sym_norm_has_alloca
end

\ Word metadata defined internally by the interpreter.
\ Also execution token returned by `xt'` and `xt''`.
\
\ SYNC[sym_fields].
struct: Sym
  Cint       1 field: Sym_type
  Sym_word   1 field: Sym_name
  U8         1 field: Sym_wordlist
  Sym_norm   1 field: Sym_union   \ Begins with executable instruction address.
  Interp_set 1 field: Sym_callees \ set_of(Sym*)
  Interp_set 1 field: Sym_callers \ set_of(Sym*)
  Cell       1 field: Sym_clobber \ `Bits`
  U8         1 field: Sym_inp_len
  U8         1 field: Sym_out_len
  U8         1 field: Sym_has_err
  U8         1 field: Sym_comp_only
  U8         1 field: Sym_interp_only
end

fun: sym_name { XT -- str } XT Sym_name Sym_word_buf end

\ SYNC[sym_fields].
fun: sym_instr { XT -- instr } XT Sym_union @ end

\ For internal use below.
fun: comp_word_instr { wordlist -- err } ( C: "name" -- ) ( E: -- instr )
  wordlist next_word comp_push
  compile' sym_instr
end

\ Similar to `xt'` and `xt''`, but instead of returning an execution token,
\ which is `Sym *`, returns the address of the first executable instruction
\ of the next word.
\
\ Intended for callbacks passed to foreign callers
\ such as `pthread_create` or `qsort`.
fun: instr' { -- instr err } execute' xt' sym_instr end

fun_comp: instr' { -- err } ( C: "name" -- ) ( E: -- instr )
  WORDLIST_EXEC comp_word_instr
end

fun_comp: instr'' { -- err } ( C: "name" -- ) ( E: -- instr )
  WORDLIST_COMP comp_word_instr
end

\ This definition is assumed by stack operations defined earlier,
\ and shared with the interpreter C code. See `## Stacks` above.
\
\ SYNC[stack_field_offsets].
struct: Stack
  Cell 1 field: Stack_bytelen
  Adr  1 field: Stack_cellar
  Adr  1 field: Stack_floor
  Adr  1 field: Stack_top
  Adr  1 field: Stack_ceil
end

\ SYNC[hash_table_structure].
struct: Interp_dict
  U32 1 field: Interp_dict_len
  U32 1 field: Interp_dict_cap
  Adr 1 field: Interp_dict_bits \ Cell*
  Adr 1 field: Interp_dict_keys \ char**
  Adr 1 field: Interp_dict_vals \ Sym**
end

\ SYNC[list_fields].
struct: Interp_list
  Adr 1 field: Interp_list_dat
  U32 1 field: Interp_list_len
  U32 1 field: Interp_list_cap
end

\ SYNC[interp_reader_fields].
struct: Interp_reader
  Cstr 1 field: Interp_reader_src
  U32  1 field: Interp_reader_len
  U32  1 field: Interp_reader_pos
  Cstr 1 field: Interp_reader_path
  U8   1 field: Interp_reader_tty
end

\ SYNC[interp_module_fields].
struct: Interp_module_ctx
  Interp_reader 1 field: Interp_module_reader
  U8            1 field: Interp_module_try_all
end

\ SYNC[reg_val_types].
1 let: REG_VAL_IMM
2 let: REG_VAL_LOC

\ SYNC[reg_val_fields].
struct: Interp_reg_val
  Cint 1 field: Interp_reg_val_type
  U32  1 field: Interp_reg_val_pad
  Cell 1 field: Interp_reg_val_imm
  Adr  1 field: Interp_reg_val_loc
  U32  1 field: Interp_reg_val_instr_floor
  U32  1 field: Interp_reg_val_instr_ceil
  U8   1 field: Interp_reg_val_can_backtrack
end

\ SYNC[comp_syms_fields].
struct: Interp_comp_syms
  Interp_list 1 field: Interp_comp_syms_addrs
  Stack       1 field: Interp_comp_syms_names
  Interp_dict 1 field: Interp_comp_syms_inds
end

\ SYNC[comp_code_fields].
struct: Interp_comp_code
  Adr              1 field: Interp_comp_code_write
  Adr              1 field: Interp_comp_code_heap
  Interp_list      1 field: Interp_comp_code_code_write
  Interp_list      1 field: Interp_comp_code_code_exec
  Interp_list      1 field: Interp_comp_code_data
  Interp_comp_syms 1 field: Interp_comp_code_externs
  Interp_comp_syms 1 field: Interp_comp_code_intrins
  U32              1 field: Interp_comp_code_valid_instr_len
end

\ SYNC[comp_ctx_fields].
struct: Interp_comp_ctx
  Adr            1  field: Interp_comp_ctx_sym
  Stack          1  field: Interp_comp_ctx_locals
  Interp_dict    1  field: Interp_comp_ctx_local_dict
  U32            1  field: Interp_comp_ctx_anon_locs
  U32            1  field: Interp_comp_ctx_fp_off
  Interp_reg_val 16 field: Interp_comp_ctx_reg_vals
  Cell           1  field: Interp_comp_ctx_vol_regs
  U8             1  field: Interp_comp_ctx_saved_reg
  U8             1  field: Interp_comp_ctx_arg_low
  U8             1  field: Interp_comp_ctx_arg_len
end

\ SYNC[comp_fields].
struct: Interp_comp
  Interp_comp_code 1 field: Interp_comp_code_field
  Interp_comp_ctx  1 field: Interp_comp_ctx_field
end

\ SYNC[interp_snap_fields].
struct: Interp_snap
  Interp_comp 1 field: Interp_snap_comp
  Stack       1 field: Interp_snap_ints
  Stack       1 field: Interp_snap_syms
end

\ State of the outer C-based intepreter.
\
\ SYNC[interp_fields].
struct: Interp
  Stack       1 field: Interp_ints
  Interp_dict 1 field: Interp_dict_exec
  Interp_dict 1 field: Interp_dict_comp
  Stack       1 field: Interp_sym
  Adr         1 field: Interp_module \ Interp_module_ctx*
  Interp_dict 1 field: Interp_imports
  Interp_comp 1 field: Interp_comp_field
  Interp_snap 1 field: Interp_snap_field
  U8          1 field: Interp_welcomed
end

\ True if running in JIT mode (interpreter available).
\ False if running in AOT-compiled mode.
\
\ In JIT mode, the outer interpreter (in C) always sets this register when
\ calling into Forth. in AOT mode, the reg starts as zero when the OS runs
\ the process, none of our compiled code modifies it, and locals are never
\ assigned to this register.
fun: has_interp { -- bool } [
  0                           comp_clobber
  ASM_REG_INTERP asm_cmp_zero comp_instr \ cmp x28, 0
  0 ASM_NE       asm_cset     comp_instr \ cset x0, ne
  1                           comp_args_set
] end

fun: interp { -- adr } [
  true interp_only
  0 ASM_REG_INTERP asm_mov_reg comp_instr
  0 comp_clobber
  1 comp_args_set
] end

\ ## Constant folding
\
\ When allocating values to registers, the outer compiler detects
\ comptime immediates. We can access this by directly reading the
\ compiler context, without the need for new intrinsics.
\
\ Then we can simply redefine our arithmetic words,
\ wrapping them into new versions which detect such
\ constants and fold them at comptime, falling back
\ on the regular runtime arithmetic.

fun: cf_comp_ctx { -- Interp_comp_ctx* }
  interp Interp_comp_field Interp_comp_ctx_field
end

fun: cf_reg_val { reg -- Interp_reg_val* err }
  cf_comp_ctx Interp_comp_ctx_reg_vals reg size' Interp_reg_val * +
end

fun: cf_writable_instrs { -- Interp_list* }
  interp Interp_comp_field Interp_comp_code_field Interp_comp_code_code_write
end

fun: cf_code_len { -- len } cf_writable_instrs Interp_list_len @u32 end

fun: cf_regs2 { -- reg0 reg1 err }
  2 nil comp_args_min
  comp_args_get dec { reg1 }
  reg1 dec reg1
end

fun: cf_reg_val_foldable_imm { val -- imm ok }
  if
    val Interp_reg_val_type @cint REG_VAL_IMM =
    val Interp_reg_val_can_backtrack @b and
  then val Interp_reg_val_imm @ true
  else 0 false
  end
end

fun: cf_reg_val_current { val -- ok }
  cf_code_len val Interp_reg_val_instr_ceil @u32 =
end

fun: cf_reg_vals_contiguous { val0 val1 -- ok }
  cf_code_len                      { code_len }
  val0 Interp_reg_val_instr_ceil  @u32 { cal0 }
  val1 Interp_reg_val_instr_floor @u32 { floor1 }
  val1 Interp_reg_val_instr_ceil  @u32 { ceil1 }
  code_len ceil1 = cal0 floor1 = and
end

fun: cf_rewind_to_before_reg_val { val }
  val Interp_reg_val_instr_floor @u32 { floor }
  cf_writable_instrs { instrs }
  floor instrs Interp_list_len !32
end

fun: cf_reg_val_clear { val } 0 val Interp_reg_val_type !cint end

fun: cf_foldables2 { reg0 reg1 -- val0 val1 imm0 imm1 ok err }
  reg0 cf_reg_val              { val0 }
  reg1 cf_reg_val              { val1 }
  val0 cf_reg_val_foldable_imm { imm0 ok0 }
  val1 cf_reg_val_foldable_imm { imm1 ok1 }
  ok0 ok1 and                  { both_const }

  if ok0 ok1 and then
    val0 val1 cf_reg_vals_contiguous { contiguous }
    if contiguous then
      val0 val1 imm0 imm1 true ret
    end
  end

  0 0 0 0 false
end

fun: cf_fold_cleared1 { -- reg imm ok err }
  1 nil comp_args_min
  comp_args_get dec { reg }

  reg cf_reg_val { val }
  val cf_reg_val_foldable_imm { imm foldable }

  ifz foldable then reg 0 false ret end
  ifz val cf_reg_val_current then reg 0 false ret end

  val cf_rewind_to_before_reg_val
  val cf_reg_val_clear
  reg imm true
end

fun: cf_fold_cleared2 { -- reg imm0 imm1 ok err }
  cf_regs2                { reg0 reg1 }
  reg0 reg1 cf_foldables2 { val0 val1 imm0 imm1 ok }

  ifz ok then 0 0 0 false ret end
  val0 cf_rewind_to_before_reg_val
  val1 cf_reg_val_clear
  reg0 imm0 imm1 true
end

fun: cf_fold_cleared2_keep2 { -- reg0 reg1 imm0 imm1 ok err }
  cf_regs2                { reg0 reg1 }
  reg0 reg1 cf_foldables2 { val0 val1 imm0 imm1 ok }

  ifz ok then 0 0 0 0 false ret end
  val0 cf_rewind_to_before_reg_val
  val0 cf_reg_val_clear
  val1 cf_reg_val_clear
  reg0 reg1 imm0 imm1 true
end

fun: cf_fold_done { reg imm -- err }
  imm reg comp_load
  reg inc comp_args_set
end

fun: cf_fold_done2 { reg0 reg1 imm0 imm1 -- err }
  imm0 reg0 comp_load
  imm1 reg1 comp_load
  reg1 inc comp_args_set
end

