1 try_all
fun_comp: \ { -- err } 10 read_until_char { -- } 0 end
fun_comp: ( { -- err } 41 read_until_char { -- } 0 end

\ Can use comments now!
\
\ This file boostraps the Forth language. The outer interpreter / compiler
\ provides only the most fundamental intrinsics; enough for self-assembly.
\ We define basic words in terms of machine instructions, building up from
\ there. Currently only the Arm64 CPU architecture is supported.
\
\ The compiler and language come in two variants: stack-CC and register-CC.
\ This file uses the native register-based calling convention. See adjacent
\ file `./lang_s.af` for the stack-based calling convention.

\ brk 666
fun: abort [ 0b110_101_00_001_0000001010011010_000_00 comp_instr ] end
fun: unreachable abort end
fun: nop end

\ ## Compilation-related words
\
\ These words are used for metaprogramming and mostly rely on
\ compiler intrinsics. We define them first to be able to use
\ constants via `let:`.
\
\ Unlike in standard Forth, we use separate wordlists for
\ regular and compile-time / immediate words. As a result,
\ we have to define parsing words like "compile" in pairs:
\ one tick seeks in the regular wordlist, and double tick
\ seeks in the compile-time wordlist.

\ Finds an extern symbol by name and declares it as a function.
fun: extern: { inp_len out_len -- err } ( C: "name" -- ) ( E: …inps -- …outs )
  read_word inp_len out_len extern_fun 0
end

\ Non-immediate replacement for standard `literal`.
fun: comp_push { val -- err } ( E: -- val )
  comp_next_arg_reg { reg }
  val reg comp_load
  0
end

fun: next_word { wlist -- XT err } ( "word" -- XT )
  read_word wlist find_word 0
end

\ "XT" is short for "execution token".
\ `xt'` is renamed from standard `'`.
\ Each execution token is a `Sym*`.
fun: xt_next { wlist -- err } ( "word" -- ) ( E: -- XT )
  wlist next_word comp_push 0
end

fun: xt'  { -- XT err } ( "word" -- ) 1 next_word 0 end \ WORDLIST_EXEC
fun: xt'' { -- XT err } ( "word" -- ) 2 next_word 0 end \ WORDLIST_COMP

fun_comp: xt'  { -- err } ( E: -- XT ) ( C: "word" -- ) 1 xt_next 0 end \ WORDLIST_EXEC
fun_comp: xt'' { -- err } ( E: -- XT ) ( C: "word" -- ) 2 xt_next 0 end \ WORDLIST_COMP

fun: inline_next { wlist -- err } ( "word" -- ) ( E: <word> )
  wlist next_word inline_word 0
end

fun_comp: inline'  { -- err } 1 inline_next 0 end
fun_comp: inline'' { -- err } 2 inline_next 0 end

\ "execute" is renamed from standard "postpone".
\ Also see `execute_raw` for raw instruction addresses.
fun: execute_next { wlist -- err } ( "word" -- ) ( E: <word> )
  wlist next_word comp_call 0
end

fun_comp: execute'  { -- err } 1 execute_next 0 end
fun_comp: execute'' { -- err } 2 execute_next 0 end

fun: compile_next { wlist -- err } ( "word" -- )
  wlist next_word comp_push xt' comp_call comp_call 0
end

fun_comp: compile'  { -- err } 1 compile_next 0 end
fun_comp: compile'' { -- err } 2 compile_next 0 end

fun: semicolon { -- err } execute'' ; 0 end

fun: let_init { str len val -- err } ( C: "name" -- ) ( E: -- val )
  \ Execution-time semantics.
  str len define_fun
    0 1 0 comp_signature_set ( -- val )
    val comp_push
  semicolon

  \ Compile-time semantics.
  str len define_fun_comp
    0 try_all
    0 1 1 comp_signature_set ( -- err )
    val comp_push compile' comp_push
  semicolon
  0
end

\ Similar to standard `constant`.
fun: let: { val -- err } ( C: "name" -- ) ( E: -- val )
  read_word val let_init
  [ 0 comp_only ]
  0
end

0 let: nil
0 let: false
1 let: true

1 let: WORDLIST_EXEC
2 let: WORDLIST_COMP

\ ## Assembler and bitwise ops
\
\ We interleave definitions of assembler words with definitions
\ of various arithmetic words used by the assembler.

4      let: ASM_INSTR_SIZE
8      let: ASM_PARAM_LEN_MAX
8      let: ASM_REG_SCRATCH \ Dangerous; high chance of collision.
29     let: ASM_REG_FP
30     let: ASM_REG_LR
31     let: ASM_REG_SP
31     let: ASM_REG_ZR
0b0000 let: ASM_EQ
0b0001 let: ASM_NE
0b0010 let: ASM_CS
0b0011 let: ASM_CC
0b0100 let: ASM_MI
0b0101 let: ASM_PL
0b0110 let: ASM_VS
0b0111 let: ASM_VC
0b1000 let: ASM_HI
0b1001 let: ASM_LS
0b1010 let: ASM_GE
0b1011 let: ASM_LT
0b1100 let: ASM_GT
0b1101 let: ASM_LE
0b1110 let: ASM_AL
0b1111 let: ASM_NV
666    let: ASM_PLACEHOLDER

\ SYNC[asm_reg_interp].
fun: ASM_REG_INTERP { -- reg } 28 end

fun_comp: ASM_REG_INTERP { -- err }
  true interp_only
  ASM_REG_INTERP comp_push
  nil
end

\ Bitwise arithmetic needed for the early stages of the self-assembler.

fun: or { i0 i1 -- i2 } [
  0 comp_clobber
  0b1_01_01010_00_0_00001_000000_00000_00000 comp_instr \ orr x0, x0, x1
  1 comp_args_set
] end

fun: and { i0 i1 -- i2 } [
  0 comp_clobber
  0b1_00_01010_00_0_00001_000000_00000_00000 comp_instr \ and x0, x0, x1
  1 comp_args_set
] end

fun: xor { i0 i1 -- i2 } [
  0 comp_clobber
  0b1_10_01010_00_0_00001_000000_00000_00000 comp_instr \ eor x0, x0, x1
  1 comp_args_set
] end

fun: lsl { i0 bits -- i1 } [
  0 comp_clobber
  0b1_0_0_11010110_00001_0010_00_00000_00000 comp_instr \ lsl x0, x0, x1
  1 comp_args_set
] end

fun: lsr { i0 bits -- i1 } [
  0 comp_clobber
  0b1_0_0_11010110_00001_0010_01_00000_00000 comp_instr \ lsr x0, x0, x1
  1 comp_args_set
] end

fun: invert { i0 -- i1 } [
  0 comp_clobber
  0b1_01_01010_00_1_00000_000000_11111_00000 comp_instr \ mvn x0, x0
  1 comp_args_set
] end

\ Our parsing rules prevent `1+` or `+1` from being a word name.
fun: inc { i0 -- i1 } [
  0 comp_clobber
  0b1_0_0_100010_0_000000000001_00000_00000 comp_instr \ add x0, x0, 1
  1 comp_args_set
] end

\ Our parsing rules prevent `1-` or `-1` from being a word name.
fun: dec { i0 -- i1 } [
  0 comp_clobber
  0b1_1_0_100010_0_000000000001_00000_00000 comp_instr \ sub x0, x0, 1
  1 comp_args_set
] end

fun: low_bits { len -- bits } 1 len lsl dec end
fun: bit_trunc { imm len -- imm } len low_bits imm and end

\ cmp Xn, <imm>
fun: asm_cmp_imm { Xn imm -- instr }
  imm  10 lsl { imm }
  Xn   5  lsl
  imm or
  0b1_1_1_100010_0_000000000000_00000_11111 or
end

\ cmp Xn, 0
fun: asm_cmp_zero { Xn -- instr } Xn 0 asm_cmp_imm end

\ cset Xd, <cond>
fun: asm_cset { Xd cond -- instr }
  cond 1 xor 12 lsl { cond }
  Xd cond or
  0b1_0_0_11010100_11111_0000_0_1_11111_00000 or
end

fun: <>0 { int -- bool } [
  0                     comp_clobber
  0        asm_cmp_zero comp_instr \ cmp x0, 0
  0 ASM_NE asm_cset     comp_instr \ cset x0, ne
  1                     comp_args_set
] end

fun: =0 { int -- bool } [
  0                     comp_clobber
  0        asm_cmp_zero comp_instr \ cmp x0, 0
  0 ASM_EQ asm_cset     comp_instr \ cset x0, eq
  1                     comp_args_set
] end

\ True if running in JIT mode (interpreter available).
\ False if running in AOT-compiled mode.
\
\ In JIT mode, the outer interpreter (in C) always sets this register when
\ calling into Forth. in AOT mode, the reg starts as zero when the OS runs
\ the process, none of our compiled code modifies it, and locals are never
\ assigned to this register.
fun: has_interp { -- bool } [
  0                           comp_clobber
  ASM_REG_INTERP asm_cmp_zero comp_instr \ cmp x28, 0
  0 ASM_NE       asm_cset     comp_instr \ cset x0, ne
  1                           comp_args_set
] end

\ brk <imm16>
fun: asm_brk { imm16 -- instr }
  imm16 5 lsl
  0b110_101_00_001_0000000000000000_000_00 or
end

\ Shared by a lot of load and store instructions. 64-bit only.
fun: asm_pattern_load_store_pair { Xt1 Xt2 Xn imm7 -- pattern }
  Xt2                    10 lsl { Xt2 }
  Xn                      5 lsl { Xn }
  imm7 3 lsr 7 bit_trunc 15 lsl
  Xt1  or
  Xt2  or
  Xn   or
end

\ ldp Xt1, Xt2, [Xn, <imm>]!
fun: asm_load_pair_pre { Xt1 Xt2 Xn imm7 -- instr }
  Xt1 Xt2 Xn imm7 asm_pattern_load_store_pair
  0b10_101_0_011_1_0000000_00000_00000_00000 or
end

\ ldp Xt1, Xt2, [Xn], <imm>
fun: asm_load_pair_post { Xt1 Xt2 Xn imm7 -- instr }
  Xt1 Xt2 Xn imm7 asm_pattern_load_store_pair
  0b10_101_0_001_1_0000000_00000_00000_00000 or
end

\ ldp Xt1, Xt2, [Xn, <imm>]
fun: asm_load_pair_off { Xt1 Xt2 Xn imm7 -- instr }
  Xt1 Xt2 Xn imm7 asm_pattern_load_store_pair
  0b10_101_0_010_1_0000000_00000_00000_00000 or
end

\ stp Xt1, Xt2, [Xn, <imm>]!
fun: asm_store_pair_pre { Xt1 Xt2 Xn imm7 -- instr }
  Xt1 Xt2 Xn imm7 asm_pattern_load_store_pair
  0b10_101_0_011_0_0000000_00000_00000_00000 or
end

\ stp Xt1, Xt2, [Xn], <imm>
fun: asm_store_pair_post { Xt1 Xt2 Xn imm7 -- instr }
  Xt1 Xt2 Xn imm7 asm_pattern_load_store_pair
  0b10_101_0_001_0_0000000_00000_00000_00000 or
end

\ stp Xt1, Xt2, [Xn, <imm>]
fun: asm_store_pair_off { Xt1 Xt2 Xn imm7 -- instr }
  Xt1 Xt2 Xn imm7 asm_pattern_load_store_pair
  0b10_101_0_010_0_0000000_00000_00000_00000 or
end

\ Shared by a lot of load and store instructions.
\ Patches the X bits:
\   0b00_000_0_00_00_0_XXXXXXXXX_00_XXXXX_XXXXX
fun: asm_pattern_load_store { Xt Xn imm9 -- instr_mask }
  Xn                5 lsl { Xn }
  imm9 9 bit_trunc 12 lsl
  Xt or Xn or
end

\ ldr Xt, [Xn, <imm>]!
fun: asm_load_pre { Xt Xn imm9 -- instr }
  Xt Xn imm9 asm_pattern_load_store
  0b11_111_0_00_01_0_000000000_11_00000_00000 or
end

\ ldr Xt, [Xn], <imm>
fun: asm_load_post { Xt Xn imm9 -- instr }
  Xt Xn imm9 asm_pattern_load_store
  0b11_111_0_00_01_0_000000000_01_00000_00000 or
end

\ str Xt, [Xn, <imm>]!
fun: asm_store_pre { Xt Xn imm9 -- instr }
  Xt Xn imm9 asm_pattern_load_store
  0b11_111_0_00_00_0_000000000_11_00000_00000 or
end

\ str Xt, [Xn], <imm>
fun: asm_store_post { Xt Xn imm9 -- instr }
  Xt Xn imm9 asm_pattern_load_store
  0b11_111_0_00_00_0_000000000_01_00000_00000 or
end

\ ldur Xt, [Xn, <imm>]
fun: asm_load_unscaled_off { Xt Xn imm9 -- instr }
  Xt Xn imm9 asm_pattern_load_store
  0b11_111_0_00_01_0_000000000_00_00000_00000 or
end

\ stur Xt, [Xn, <imm>]
fun: asm_store_unscaled_off { Xt Xn imm9 -- instr }
  Xt Xn imm9 asm_pattern_load_store
  0b11_111_0_00_00_0_000000000_00_00000_00000 or
end

\ Shared by register-offset load and store instructions.
\ `scale` must be 0 or 1; if 1, offset is multiplied by 8.
fun: asm_pattern_load_store_with_register_off { Xt Xn Xm scale -- instr_mask }
  Xn        5  lsl { Xn }
  Xm        16 lsl { Xm }
  scale <>0 12 lsl \ lsl 3
  Xt or Xn or Xm or
end

\ ldr Xt, [Xn, Xm, lsl <scale>]
fun: asm_load_with_register_off { Xt Xn Xm scale -- instr }
  Xt Xn Xm scale asm_pattern_load_store_with_register_off
  0b11_111_0_00_01_1_00000_011_0_10_00000_00000 or
end

\ str Xt, [Xn, Xm, lsl <scale>]
fun: asm_store_with_register_off { Xt Xn Xm scale -- instr }
  Xt Xn Xm scale asm_pattern_load_store_with_register_off
  0b11_111_0_00_00_1_00000_011_0_10_00000_00000 or
end

\ Shared by some integer arithmetic instructions.
fun: asm_pattern_arith_reg { Xd Xn Xm -- instr_mask }
  Xn 5  lsl { Xn }
  Xm 16 lsl
  Xd or Xn or
end

\ Shared by some integer arithmetic and load/store instructions.
fun: asm_pattern_arith_imm { Xd Xn imm12 -- instr_mask }
  Xn                  5 lsl { Xn }
  imm12 12 bit_trunc 10 lsl
  Xd or Xn or
end

\ size:
\
\   0b00 -- 8  bit
\   0b01 -- 16 bit
\   0b10 -- 32 bit
\   0b11 -- 64 bit
\
\ opc examples for size = 0b00:
\
\   0b01 -- ldrb  Wt
\   0b11 -- ldrsb Wt
\   0b10 -- ldrsb Xt
\   0b00 -- strb  Wt
\
\ Base instruction variant: "immediate, unsigned offset". Offset is 0.
fun: asm_load_store_imm { Rt Xn imm12 size opc -- instr }
  size 30 lsl         { size }
  opc  22 lsl size or { mask }
  Rt Xn imm12 asm_pattern_arith_imm
  mask or
  0b00_111_0_01_00_000000000000_00000_00000 or
end

\ Unsigned 8-bit.
\
\ ldrb Wt, [Xn, imm12]
fun: asm_load_off_u8 { Wt Xn imm12 -- instr }
  Wt Xn imm12 0b00 0b01 asm_load_store_imm
end

\ Signed 8-bit.
\
\ ldrsb Xt, [Xn, imm12]
fun: asm_load_off_s8 { Xt Xn imm12 -- instr }
  Xt Xn imm12 0b00 0b10 asm_load_store_imm
end

\ Either unsigned or signed 8-bit.
\
\ strb Wt, [Xn, imm12]
fun: asm_store_off_u8 { Wt Xn imm12 -- instr }
  Wt Xn imm12 0b00 0b00 asm_load_store_imm
end

\ ldrh Wt, [Xn, imm12]
fun: asm_load_off_u16 { Wt Xn imm12 -- instr }
  Wt Xn imm12 0b01 0b01 asm_load_store_imm
end

\ ldrsh Xt, [Xn, imm12]
fun: asm_load_off_s16 { Xt Xn imm12 -- instr }
  Xt Xn imm12 0b01 0b10 asm_load_store_imm
end

\ strh Wt, [Xn, imm12]
fun: asm_store_off_u16 { Wt Xn imm12 -- instr }
  Wt Xn imm12 0b01 0b00 asm_load_store_imm
end

\ ldr Wt, [Xn, imm12]
fun: asm_load_off_u32 { Wt Xn imm12 -- instr }
  Wt Xn imm12 0b10 0b01 asm_load_store_imm
end

\ ldrsw Xt, [Xn, imm12]
fun: asm_load_off_s32 { Xt Xn imm12 -- instr }
  Xt Xn imm12 0b10 0b10 asm_load_store_imm
end

\ str Wt, [Xn, imm12]
fun: asm_store_off_u32 { Wt Xn imm12 -- instr }
  Wt Xn imm12 0b10 0b00 asm_load_store_imm
end

\ ldr Xt, [Xn, imm12]
fun: asm_load_off { Xt Xn imm12 -- instr }
  Xt Xn imm12 0b11 0b01 asm_load_store_imm
end

\ str Xt, [Xn, imm12]
fun: asm_store_off { Xt Xn imm12 -- instr }
  Xt Xn imm12 0b11 0b00 asm_load_store_imm
end

\ neg Xd, Xd
fun: asm_neg { Xd -- instr }
  Xd 16 lsl \ Xt
  Xd or
  0b1_1_0_01011_00_0_00000_000000_11111_00000 or
end

\ add Xd, Xn, <imm12>
fun: asm_add_imm { Xd Xn imm12 -- instr }
  Xd Xn imm12 asm_pattern_arith_imm
  0b1_0_0_100010_0_000000000000_00000_00000 or
end

\ add Xd, Xn, Xm
fun: asm_add_reg { Xd Xn Xm -- instr }
  Xd Xn Xm asm_pattern_arith_reg
  0b1_0_0_01011_00_0_00000_000000_00000_00000 or
end

\ adds Xd, Xn, Xm
fun: asm_adds_reg { Xd Xn Xm -- instr }
  Xd Xn Xm asm_add_reg
  0b0_0_1_00000000000000000000000000000 or
end

\ sub Xd, Xn, <imm12>
fun: asm_sub_imm { Xd Xn imm12 -- instr }
  Xd Xn imm12 asm_pattern_arith_imm
  0b1_1_0_100010_0_000000000000_00000_00000 or
end

\ sub Xd, Xn, Xm
fun: asm_sub_reg { Xd Xn Xm -- instr }
  Xd Xn Xm asm_pattern_arith_reg
  0b1_1_0_01011_00_0_00000_000000_00000_00000 or
end

\ subs Xd, Xn, Xm
fun: asm_subs_reg { Xd Xn Xm -- instr }
  Xd Xn Xm asm_sub_reg
  0b0_0_1_00000000000000000000000000000 or
end

\ sub Xd, Xn, Xm, lsl 3
fun: asm_sub_reg_words { Xd Xn Xm -- instr }
  Xd Xn Xm asm_sub_reg
  0b0_0_0_00000_00_0_00000_000011_00000_00000 or
end

\ mul Xd, Xn, Xm
fun: asm_mul { Xd Xn Xm -- instr }
  Xd Xn Xm asm_pattern_arith_reg
  0b1_00_11011_000_00000_0_11111_00000_00000 or
end

\ udiv Xd, Xn, Xm
fun: asm_udiv { Xd Xn Xm -- instr }
  Xd Xn Xm asm_pattern_arith_reg
  0b1_0_0_11010110_00000_00001_0_00000_00000 or
end

\ sdiv Xd, Xn, Xm
fun: asm_sdiv { Xd Xn Xm -- instr }
  Xd Xn Xm asm_pattern_arith_reg
  0b1_0_0_11010110_00000_00001_1_00000_00000 or
end

\ msub Xd, Xn, Xm, Xa
fun: asm_msub { Xd Xn Xm Xa -- instr }
  Xn  5 lsl { Xn }
  Xm 16 lsl { Xm }
  Xa 10 lsl
  Xd or Xn or Xm or
  0b1_00_11011_000_00000_1_00000_00000_00000 or
end

fun: asm_pattern_arith_csel { Xd Xn Xm cond -- instr_mask }
  cond 12 lsl { cond }
  Xd Xm Xn asm_pattern_arith_reg
  cond or
end

\ csel Xd, Xn, Xm, <cond>
fun: asm_csel { Xd Xn Xm cond -- instr }
  Xd Xm Xn cond asm_pattern_arith_csel
  0b1_0_0_11010100_00000_0000_0_0_00000_00000 or
end

\ csneg Xd, Xn, Xm, <cond>
fun: asm_csneg { Xd Xn Xm cond -- instr }
  Xd Xm Xn cond asm_pattern_arith_csel
  0b1_1_0_11010100_00000_0000_0_1_00000_00000 or
end

\ asr Xd, Xn, imm6
fun: asm_asr_imm { Xd Xn imm6 -- instr }
  Xd Xn imm6 asm_pattern_arith_reg
  0b1_00_100110_1_000000_111111_00000_00000 or
end

\ asr Xd, Xn, Xm
fun: asm_asr_reg { Xd Xn Xm -- instr }
  Xd Xn Xm asm_pattern_arith_reg
  0b1_0_0_11010110_00000_0010_10_00000_00000 or
end

\ Arithmetic (sign-preserving) right shift.
fun: asr { i0 bits -- i1 } [
  0                 comp_clobber
  0 0 1 asm_asr_reg comp_instr \ asr x0, x0, x1
  1                 comp_args_set
] end

\ eor Xd, Xn, Xm
fun: asm_eor_reg { Xd Xn Xm -- instr }
  Xd Xn Xm asm_pattern_arith_reg
  0b1_10_01010_00_0_00000_000000_00000_00000 or
end

\ cmp Xn, Xm
fun: asm_cmp_reg { Xn Xm -- instr }
  Xn  5 lsl { Xn }
  Xm 16 lsl
  Xn or
  0b1_1_1_01011_00_0_00000_000_000_00000_11111 or
end

\ b <off>
fun: asm_branch { off26 -- instr }
  off26
  2  lsr       \ Offset is implicitly times 4.
  26 bit_trunc \ Offset may be negative.
  0b0_00_101_00000000000000000000000000 or
end

\ b.<cond> <off>
fun: asm_branch_cond { off19 cond -- instr }
  off19 2 asr 19 bit_trunc 5 lsl \ Implicitly times 4.
  cond or
  0b010_101_00_0000000000000000000_0_0000 or
end

\ `off19` offset is implicitly times 4 and can be negative.
fun: asm_pattern_cmp_branch { Xt off19 -- instr_mask }
  off19 2 lsr 19 bit_trunc 5 lsl
  Xt or
end

\ cbz x1, <off>
fun: asm_cmp_branch_zero { Xt off19 -- instr }
  Xt off19 asm_pattern_cmp_branch
  0b1_011010_0_0000000000000000000_00000 or
end

\ cbnz x1, <off>
fun: asm_cmp_branch_not_zero { Xt off19 -- instr }
  Xt off19 asm_pattern_cmp_branch
  0b1_011010_1_0000000000000000000_00000 or
end

\ `off9` offset is implicitly times 4 and can be negative.
fun: asm_pattern_cmp_branch_cond { Xt off9 cond -- instr_mask }
  off9 2 lsr 9 bit_trunc 5  lsl { off9 }
  cond                   21 lsl
  Xt or off9 or
end

\ Not supported on M3 Pro.
\ cb.<cond> Xt, <imm>, <off>
fun: asm_cmp_imm_branch { Xt imm6 off9 cond -- instr }
  Xt off9 cond asm_pattern_cmp_branch_cond { mask }
  imm6 15 lsl
  mask or
  0b1_1110101_000_000000_0_000000000_00000 or
end

\ Not supported on M3 Pro.
\ cb.<cond> Xt, Xm, <off>
fun: asm_cmp_reg_branch { Xt Xm off9 cond -- instr }
  Xt off9 cond asm_pattern_cmp_branch_cond { mask }
  Xm 16 lsl
  mask or
  0b1_1110100_000_00000_00_000000000_00000 or
end

\ eor Xd, Xd, Xd
fun: asm_zero_reg { Xd -- instr } Xd Xd Xd asm_eor_reg end

fun: asm_mov_reg { Xd Xm -- instr }
  Xm 16 lsl
  Xd or
  0b1_01_01010_00_0_00000_000000_11111_00000 or
end

\ Immediate must be unsigned and within range.
fun: asm_mov_imm { Xd imm -- instr }
  imm 5 lsl
  Xd or
  0b1_10_100101_00_0000000000000000_00000 or
end

\ mvn Xd, Xm
fun: asm_mvn { Xd Xm -- instr }
  Xm 16 lsl
  Xd or
  0b1_01_01010_00_1_00000_000000_11111_00000 or
end

\ `ret x30`; requires caution with SP / FP.
0b110_101_1_0_0_10_11111_0000_0_0_11110_00000 let: asm_ret

0b110_101_01000000110010_0000_000_11111 let: asm_nop

\ svc 666
0b110_101_00_000_0000001010011010_000_01 let: asm_svc

\ ## Arithmetic

fun: negate { i0 -- i1 } [
  0         comp_clobber
  0 asm_neg comp_instr \ neg x0, x0
  1         comp_args_set
] end

fun: + { i0 i1 -- i2 } [
  0                 comp_clobber
  0 0 1 asm_add_reg comp_instr \ add x0, x0, x1
  1                 comp_args_set
] end

fun: - { i0 i1 -- i2 } [
  0                 comp_clobber
  0 0 1 asm_sub_reg comp_instr \ sub x0, x0, x1
  1                 comp_args_set
] end

fun: * { i0 i1 -- i2 } [
  0             comp_clobber
  0 0 1 asm_mul comp_instr \ mul x0, x0, x1
  1             comp_args_set
] end

fun: / { i0 i1 -- i2 } [
  0              comp_clobber
  0 0 1 asm_sdiv comp_instr \ sdiv x0, x0, x1
  1              comp_args_set
] end

fun: u/ { i0 i1 -- i2 } [
  0              comp_clobber
  0 0 1 asm_udiv comp_instr \ udiv x0, x0, x1
  1              comp_args_set
] end

fun: mod { i0 i1 -- i2 } [
  0                comp_clobber
  2                comp_clobber
  2 0 1   asm_sdiv comp_instr \ sdiv x2, x0, x1
  0 2 1 0 asm_msub comp_instr \ msub x0, x2, x1, x0
  1                comp_args_set
] end

fun: /mod { dividend divisor -- rem quo } [
  0                   comp_clobber
  1                   comp_clobber
  2                   comp_clobber
  2 1     asm_mov_reg comp_instr \ mov x2, x1
  1 0 2   asm_sdiv    comp_instr \ sdiv x1, x0, x2
  0 1 2 0 asm_msub    comp_instr \ msub x0, x1, x2, x0
  2                   comp_args_set
] end

fun: abs { int -- +int } [
  0                         comp_clobber
  0            asm_cmp_zero comp_instr \ cmp x0, 0
  0 0 0 ASM_PL asm_csneg    comp_instr \ cneg x0, x0, pl
  1                         comp_args_set
] end

fun: min { i0 i1 -- i0|i1 } [
  0                        comp_clobber
  0 1          asm_cmp_reg comp_instr \ cmp x0, x1
  0 0 1 ASM_LT asm_csel    comp_instr \ csel x0, x0, x1, lt
  1                        comp_args_set
] end

fun: max { i0 i1 -- i0|i1 } [
  0                        comp_clobber
  0 1          asm_cmp_reg comp_instr \ cmp x0, x1
  0 0 1 ASM_GT asm_csel    comp_instr \ csel x0, x0, x1, gt
  1                        comp_args_set
] end

fun: align_down { len wid -- len } wid negate len and end
fun: align_up   { len wid -- len } wid dec len + wid align_down end

8 let: CELL

fun: cells  { len  -- size } len 3 lsl  end
fun: /cells { size -- len  } size 3 asr end
fun: +cell  { adr  -- adr  } adr CELL + end
fun: -cell  { adr  -- adr  } adr CELL - end

\ ## Assembler continued

\ lsl Xd, Xn, <imm>
fun: asm_lsl_imm { Xd Xn imm6 -- instr }
  imm6 negate 64 mod 6 bit_trunc 16 lsl { immr }
  63 imm6 -          6 bit_trunc 10 lsl { imms }
  Xn 5 lsl
  Xd or imms or immr or
  0b1_10_100110_1_000000_000000_00000_00000 or
end

\ tbz Xt, <bit>, <imm>
fun: asm_test_bit_branch_zero { Xt bit imm14 -- instr }
  imm14 2 lsr 14 bit_trunc 5 lsl { imm14 } \ Implicitly times 4.
  bit   5 lsr             31 lsl { b5 }
  bit         5 bit_trunc 19 lsl \ b40
  Xt or imm14 or b5 or
  0b0_01_101_1_0_00000_00000000000000_00000 or
end

\ adr Xd, <imm21>
fun: asm_adr { Xd imm21 -- instr }
  imm21 0b11 and                 { low }
  imm21 2 lsr 19 bit_trunc 5 lsl { high }
  high low or Xd or
  0b0_00_100_00_0000000000000000000_00000 or
end

\ br Xn
fun: asm_branch_to_reg { Xn -- instr }
  Xn 5 lsl
  0b110_101_1_0_0_00_11111_0000_0_0_00000_00000 or
end

\ bl imm26
\
\ Requires caution to avoid messing up the link register.
fun: asm_branch_link_off { imm26 -- instr }
  imm26 2 lsr 26 bit_trunc \ Implicitly times 4.
  0b100_101_00000000000000000000000000 or
end

\ blr Xn
\
\ Requires caution to avoid messing up the link register.
fun: asm_branch_link_reg { Xn -- instr }
  Xn 5 lsl
  0b110_101_1_0_0_01_11111_0000_0_0_00000_00000 or
end

\ orr Xd, Xn, #(1 << bit)
\
\ TODO add general-purpose `orr`.
fun: asm_orr_bit { Xd Xn bit -- instr }
  64 bit - 16 lsl { immr }
  Xn        5 lsl
  Xd or immr or
  0b1_01_100100_1_000000_000000_00000_00000 or
end

fun: asm_comp_cset_reg { cond -- err } ( E: i0 i1 -- bool )
  0                  comp_clobber
  0 1    asm_cmp_reg comp_instr \ cmp x0, x1
  0 cond asm_cset    comp_instr \ cset x0, <cond>
  1                  comp_args_set
  nil
end

fun: asm_comp_cset_zero { cond -- err } ( E: num -- bool )
  0                   comp_clobber
  0      asm_cmp_zero comp_instr \ cmp x0, 0
  0 cond asm_cset     comp_instr \ cset x0, <cond>
  1                   comp_args_set
  nil
end

\ sbfm Xd, Xn, immr, imms
fun: asm_bitfield_move { Xd Xn immr imms -- instr }
  imms 10 lsl { imms }
  immr 16 lsl { immr }
  Xn   5  lsl { Xn }

  0b1_00_100110_1_000000_000000_00000_00000
  Xd   or
  Xn   or
  immr or
  imms or
end

\ sxtw Xd, Xn | sbfm Xd, Xn, 0, 31
fun: asm_sign_extend_32 { Xd Xn -- instr } Xd Xn 0 31 asm_bitfield_move end

\ Since we don't have a real type system, the compiler
\ doesn't support automatically sign-extending integers
\ when converting between types. Sometimes it has to be
\ done manually, particularly when dealing with C words
\ which return `(int)-1` which ends up being 0xffffffff.
fun: int_to_cell { int32 -- cell } [
  0                      comp_clobber
  0 0 asm_sign_extend_32 comp_instr \ sxtw x0, x0
  1                      comp_args_set
] end

\ ## Numeric comparison

\ https://gforth.org/manual/Numeric-comparison.html
fun: =   { i0 i1 -- bool } [ ASM_EQ asm_comp_cset_reg  ] end
fun: <>  { i0 i1 -- bool } [ ASM_NE asm_comp_cset_reg  ] end
fun: >   { i0 i1 -- bool } [ ASM_GT asm_comp_cset_reg  ] end
fun: <   { i0 i1 -- bool } [ ASM_LT asm_comp_cset_reg  ] end
fun: <=  { i0 i1 -- bool } [ ASM_LE asm_comp_cset_reg  ] end
fun: >=  { i0 i1 -- bool } [ ASM_GE asm_comp_cset_reg  ] end
fun: <0  { num   -- bool } [ ASM_LT asm_comp_cset_zero ] end \ Or `MI`.
fun: >0  { num   -- bool } [ ASM_GT asm_comp_cset_zero ] end
fun: <=0 { num   -- bool } [ ASM_LE asm_comp_cset_zero ] end
fun: >=0 { num   -- bool } [ ASM_GE asm_comp_cset_zero ] end \ Or `PL`.

fun: within { num one two -- bool }
  one num > { one }
  num two >
  one or =0
end

fun: odd { i0 -- bool } i0 1 and end

\ ## Memory load / store

\ We allow to load inside an argument list, replacing the latest argument,
\ which is an address, with a value without consuming all prior arguments.
\ This violates the idea that every verb should consume all arguments, but
\ can be convenient at times. TODO reconsider.
\
\ TODO validate there's an input.
fun: comp_mem_load { size opc -- err }
  comp_args_get dec { reg }
  reg comp_clobber
  \ ldr<size> <reg>, [<reg>]
  reg reg 0 size opc asm_load_store_imm comp_instr
  nil
end

\ Generically defines a load word for the given size / type.
fun: load: { size opc -- err } ( C: "name" -- )  ( E: adr -- val )
  read_word { str len }

  \ Execution-time semantics.
  str len define_fun
    1 1 false comp_signature_set ( E: adr -- val )
    0 comp_clobber
    0 0 0 size opc asm_load_store_imm comp_instr \ ldr<size> r0, [x0]
    1 comp_args_set
  semicolon

  \ Compile-time semantics.
  str len define_fun_comp
    false try_all
    0 1 true comp_signature_set
    size     comp_push
    opc      comp_push
    compile' comp_mem_load
  semicolon

  [ false comp_only ]
  nil
end

\ Generically defines a store word for the given size / type.
\ Execution-time semantics only. The compiler always inlines.
fun: store: { size -- err } ( C: "name" -- ) ( E: val adr -- )
  read_word define_fun
    2 0 false comp_signature_set
    \ str<size> r0, [x1]
    0 1 0 size 0b00 asm_load_store_imm comp_instr
  semicolon

  [ false comp_only ]
  nil
end

0b00 0b01 load:  @u8 \ Renamed from standard `c@`.
0b00 0b10 load:  @s8
0b00      store: !8  \ Renamed from standard `c!`.

\ Byte load/store; aliases for `@u8` and `!8`.
0b00 0b01 load:  @b \ Renamed from standard `c@`.
0b00      store: !b \ Renamed from standard `c!`.

0b01 0b01 load:  @u16
0b01 0b10 load:  @s16
0b01      store: !16

0b10 0b01 load:  @u32
0b10 0b10 load:  @s32
0b10      store: !32

0b11 0b01 load:  @
0b11      store: !

\ Aliases for some C types, so the user
\ doesn't have to remember their width.

\ 32 bit
0b10 0b10 load:  @cint
0b10      store: !cint

\ 32 bit
0b10 0b01 load:  @cuint
0b10      store: !cuint

\ 64 bit (Apple ABI)
0b11 0b10 load:  @clong
0b11      store: !clong

\ 64 bit (Apple ABI)
0b11 0b01 load:  @culong
0b11      store: !culong

fun: @2 { adr -- val0 val1 } [
  0                         comp_clobber
  1                         comp_clobber
  0 1 0 0 asm_load_pair_off comp_instr \ ldp x0, x1, [x0]
  2                         comp_args_set
] end

fun: !2 { val0 val1 adr } [
  0 1 2 0 asm_store_pair_off comp_instr \ stp x0, x1, [x2]
] end

fun: !at { val adr off } [
  \ str x0, [x1, x2]
  0 1 2 0 asm_store_with_register_off comp_instr
  0 comp_args_set
] end

fun: off! { adr } false adr ! end
fun: on!  { adr } true  adr ! end

\ ## Stacks
\
\ This section defines operations on integer / cell stacks like the one
\ provided by the outer interpreter. We also allocate additional stacks
\ for auxiliary control information, such as `LOOP_AUX`.
\
\ Each stack is represented with an address of the struct below.
\ The definition matches `Stack` in our C code. The default data
\ stack provided by the interpreter is one of these. We hardcode
\ the offsets below, because `struct:` is not yet available.
\
\   \ SYNC[stack_field_offsets].
\   struct: Stack
\     Cell 1 field: Stack_bytelen \ Total size with guards.
\     Adr  1 field: Stack_cellar  \ Lower guard.
\     Adr  1 field: Stack_floor   \ First data cell.
\     Adr  1 field: Stack_top     \ Next data cell.
\     Adr  1 field: Stack_ceil    \ After last data cell.
\   end
\
\ See `stack_init` for guarded allocation via memory mapping.
\ A stack can also be allocated without guards if so desired.
\
\ The stack operations below have somewhat suboptimal performance.
\ They're meant primarily for control frames, used in compilation
\ and testing.
\
\ Because the interpreter's stack is accessible on the interpreter object,
\ we get away with not having to reserve any special registers for stacks.
\
\ The default stack is available ONLY in interpreted and JIT-compiled code.
\ AOT-compiled executables do not have the Forth interpreter or data stack.
\
\ All our stacks are empty-ascending.

\ SYNC[stack_field_offsets].
16 let: STACK_OFF_FLOOR
24 let: STACK_OFF_TOP
32 let: STACK_OFF_CEIL

\ Default Forth stack provided by the interpreter.
\ Not available when running in AOT-compiled mode.
\
\ SYNC[interp_stack_offset].
fun_comp: STACK { -- err } ( E: -- adr )
  \ mov <arg>, x28
  comp_next_arg_reg ASM_REG_INTERP asm_mov_reg comp_instr
  true interp_only
  nil
end

fun: STACK { -- adr } STACK end

fun: comp_load_off { off -- err } ( E: adr -- adr )
  0 comp_clobber
  0 0 off asm_load_unscaled_off comp_instr \ ldur x0, [x0, <off>]
  1 comp_args_set
  nil
end

\ Note: `stack_top` is the top EMPTY cell, not a full one.
fun: stack?      { stack -- bool  } stack @ <>0 end
fun: stack_floor { stack -- floor } [ STACK_OFF_FLOOR comp_load_off ] end
fun: stack_top   { stack -- top   } [ STACK_OFF_TOP   comp_load_off ] end
fun: stack_ceil  { stack -- ceil  } [ STACK_OFF_CEIL  comp_load_off ] end

\ ldur <out>, [<stack>, STACK_OFF_TOP]
fun: asm_stack_top_load { out stack -- instr }
  out stack STACK_OFF_TOP asm_load_unscaled_off
end

\ stur <out>, [<stack>, STACK_OFF_TOP]
fun: asm_stack_top_store { out stack -- instr }
  out stack STACK_OFF_TOP asm_store_unscaled_off
end

fun: stack@ { stack -- val } stack stack_top -cell @ end

fun: stack_top! { top stack } [
  \ stur <top>, [<stack>, STACK_OFF_TOP]
  0 1 asm_stack_top_store comp_instr
] end

fun: stack_cell_at { ind stack  -- adr }
  ind cells { off } stack stack_floor off +
end

fun: stack_len_bytes { stack -- len }
  stack stack_floor { floor }
  stack stack_top floor -
end

fun: stack_cap_bytes { stack -- len }
  stack stack_floor { floor }
  stack stack_ceil floor -
end

fun: stack_len_cells { stack -- len } stack stack_len_bytes /cells end
fun: stack_cap_cells { stack -- len } stack stack_cap_bytes /cells end

fun: stack_trunc { stack } stack stack_floor stack stack_top! end

fun: stack_len_cells_set { len stack }
  len stack stack_cell_at stack stack_top!
end

fun: stack_len_cells+ { diff stack }
  stack stack_len_cells diff + stack stack_len_cells_set
end

fun: stack_len_cells- { diff stack }
  stack stack_len_cells diff - stack stack_len_cells_set
end

fun: stack_drop_cell { stack } 1 stack stack_len_cells- end

\ Pops a cell from a stack. Usage:
\
\   stack s> { val }
\
\ Mind the backwards order:
\
\   10 20 30 stack >>s
\   stack s> . \ 30
\   stack s> . \ 20
\   stack s> . \ 10
\
\ Also see `stack{` which is more convenient and less error-prone.
fun: s> { stack -- val } [
  2 comp_clobber
  1 comp_clobber
  0 comp_clobber
  2 0    asm_mov_reg         comp_instr \ mov  x2, x0
  1 2    asm_stack_top_load  comp_instr \ ldur x1, [x2, STACK_OFF_TOP]
  0 1 -8 asm_load_pre        comp_instr \ ldr  x0, [x1, -8]!
  1 2    asm_stack_top_store comp_instr \ stur x1, [x2, STACK_OFF_TOP]
  1 comp_args_set
] end

\ Pushes a cell to a stack.
\
\ Also see `:: >>s` defined later in this file.
\ Unlike this version, it's variadic.
fun: >s { val stack } [
  2 comp_clobber
  1 comp_clobber
  0 comp_clobber
  2 1   asm_mov_reg         comp_instr \ mov  x2, x1
  1 2   asm_stack_top_load  comp_instr \ ldur x1, [x2, STACK_OFF_TOP]
  0 1 8 asm_store_post      comp_instr \ str  x0, [x1], 8
  1 2   asm_stack_top_store comp_instr \ stur x1, [x2, STACK_OFF_TOP]
] end

\ ## System stack stuff

fun_comp: systack_ptr { -- err } ( E: -- sp )
  \ add <reg>, sp, 0 | mov <reg>, sp
  comp_next_arg_reg ASM_REG_SP 0 asm_add_imm comp_instr
  nil
end

fun: systack_ptr { -- sp } systack_ptr end

fun_comp: sysstack_frame_ptr { -- err } ( E: -- fp )
  \ mov <reg>, x29
  comp_next_arg_reg ASM_REG_FP asm_mov_reg comp_instr
  nil
end

fun: sysstack_frame_ptr { -- fp } sysstack_frame_ptr end
\ ## Global variables and buffers

\ Asks for a register and compiles this idiom:
\
\   adrp <reg>, <page>
\   add <reg>, <reg>, <pageoff>
\
\ Used for taking an address of a data entry
\ in the code heap allocated via `alloc_data`.
fun: comp_next_page_addr { adr -- err } ( E: -- adr )
  comp_next_arg_reg { reg }
  adr reg comp_page_addr
  nil
end

fun: init_data_word { name name_len adr -- err }
  name name_len define_fun
    0 1 false comp_signature_set ( E: -- ptr )
    adr comp_next_page_addr
  semicolon

  name name_len define_fun_comp
    false try_all
    0 1 true comp_signature_set
    adr comp_push compile' comp_next_page_addr
  semicolon

  [ false comp_only ]
  nil
end

fun: var_init { str len val -- err }
  nil CELL alloc_data { adr }
  val adr !
  str len adr init_data_word
  nil
end

\ Similar to standard `variable`, but takes an initial value like `let:`.
fun: var: { val -- err } ( C: "name" -- ) ( E: -- ptr )
  read_word val var_init nil
end

\ Shortcut for the standard idiom `create <name> N allot`.
\ Unlike the standard idiom, this also zeroes the memory.
\ Like `buf:` but doesn't return capacity.
\ Also see `buf:` for warnings about AOT.
fun: mem: { cap -- err } ( C: "name" -- ) ( E: -- adr )
  nil cap alloc_data { adr }
  read_word adr init_data_word
  nil
end

fun: comp_buf { adr cap -- err } ( E: -- adr cap )
  comp_next_arg_reg { RA }
  comp_next_arg_reg { RL }
  adr RA comp_page_addr
  cap RL comp_load
  nil
end

fun: buf_init { adr cap -- err }
  read_word { str len }

  str len define_fun
    0 2 false comp_signature_set ( E: -- ptr cap )
    adr cap comp_buf
  semicolon

  str len define_fun_comp
    false try_all
    0 1 true comp_signature_set
    adr comp_push cap comp_push compile' comp_buf
  semicolon

  [ false comp_only ]
  nil
end

\ Similar to the standard idiom `create <name> N allot`.
\ Creates a global variable which refers to a buffer of
\ at least the given size in bytes, initialized to zero.
\
\ TODO dedup code with `init_data_word`.
\
\ The buffer is allocated in the compiler-managed data region,
\ which is preserved in AOT compilation. Changes to this data
\ made during interpretation persist into the AOT executable.
\
\ The variable does NOT hold a fixed address. Instead, it compiles
\ instructions to calculate the address using PC-relative offsets.
\ The address CHANGES from JIT to AOT. This means: it must not be
\ stored in another static variable, or used to derive an address
\ which would be stored in another static variable.
fun: buf: { cap -- err } ( C: "name" -- ) ( E: -- adr cap )
  nil cap alloc_data cap buf_init nil
end

\ ## Memory
\
\ The program is implicitly linked with `libc`,
\ so we get to use C stdlib functions.
\
\ Compiler also provides `alloca` intrinsically.

\ Maximum alignment needed for any value on Arm64.
16 let: FUND_ALIGN

2 1 extern: calloc  ( len size -- addr )
1 1 extern: malloc  ( size -- addr )
1 0 extern: free    ( addr -- )
3 0 extern: memset  ( buf char len -- )
3 0 extern: memcpy  ( dst src len -- )
3 0 extern: memmove ( dst src len -- )

1 1 extern: strdup  ( cstr -- cstr )
2 1 extern: strndup ( cstr len -- cstr )
1 1 extern: strlen  ( cstr -- len )
2 1 extern: strcmp  ( cstr0 cstr1 -- cmp )
3 1 extern: strncmp ( str0 str1 len -- cmp )
3 0 extern: strncpy ( dst src str_len -- )
3 0 extern: strlcpy ( dst src buf_len -- )
2 1 extern: strstr  ( cstr0 cstr0 -- adr )

fun: move  { src dst len  } dst src len strncpy end
fun: fill  { buf len char } buf char len memset end
fun: erase { buf len      } buf len 0 fill end

\ See `ccompare` below for null-terminated strings.
fun: compare { str0 len0 str1 len1 -- direction }
  len0 len1 min { len }
  str0 str1 len strncmp
end

\ See `cstr=` and more below for null-terminated strings.
fun: str=  { str0 len0 str1 len1 -- bool } str0 len0 str1 len1 compare =0 end
fun: str<  { str0 len0 str1 len1 -- bool } str0 len0 str1 len1 compare <0 end
fun: str<> { str0 len0 str1 len1 -- bool } str0 len0 str1 len1 compare <>0 end

\ ## Characters and strings

\ FIXME rename
fun: parse_char { -- char err } read_word { buf -- } buf @u8 nil end

fun: char' { -- char err } ( E: "str" -- char ) parse_char nil end

fun_comp: char' { -- err } ( C: "str" -- ) ( E: -- char )
  parse_char        { char }
  comp_next_arg_reg { reg }
  char reg comp_load
  nil
end

fun: parse_str { -- str len err } char' " read_until_char nil end

fun: comp_alloc_cstr { buf len -- cstr err }
  len inc            { cap } \ Reserve terminating null byte.
  buf cap alloc_data { adr }
  adr len +          { ceil }
  nil ceil !b
  adr nil
end

\ Copies a string and appends a terminating null byte.
fun: comp_str { buf len -- err } ( E: -- cstr len )
  buf len comp_alloc_cstr { adr }
  comp_next_arg_reg       { RS }
  comp_next_arg_reg       { RL }
  adr RS comp_page_addr \ `adrp RS, <page>` & `add RS, RS, <pageoff>`
  len RL comp_load      \ ldr RL, <len>
  nil
end

fun: comp_cstr { buf len -- err } ( E: -- cstr )
  comp_next_arg_reg { reg }
  buf len comp_alloc_cstr
  reg comp_page_addr \ `adrp <reg>, <page>` & `add <reg>, <reg>, <pageoff>`
  nil
end

\ Parses the input until the terminating quote, and returns the address and
\ length of the resulting string. In interpretation mode, the string points
\ into the transient reader input and is not null-terminated. In compilation
\ mode, the string is statically allocated, unique, and null-terminated.
fun: s" { -- str len err } ( E: "str" -- str len )
  read_char { -- } parse_str nil
end
fun_comp: s" { -- err } ( C: "str" -- ) ( E: -- str len )
  read_char { -- } parse_str comp_str nil
end

4096 buf: ROOT_STR_BUF

\ C-style string literal. Like `s"` but returns only the address without the
\ length. The string is always null-terminated. In interpretation mode, this
\ reuses the same buffer for each call, and the string may be truncated.
fun: " { -- cstr err } ( E: "str" -- cstr )
  read_char { -- }
  parse_str { src len }
  ROOT_STR_BUF { buf cap }
  len cap min { len }
  buf src len memcpy
  buf len + { ceil }
  nil ceil !b
  buf nil
end

\ Unlike interpretation-mode `"`, this allocates a unique string
\ in the compiler-managed data region and compiles a PC-relative
\ reference to it.
fun_comp: " { -- err } ( C: "str" -- ) ( E: -- cstr )
  read_char { -- } parse_str comp_cstr nil
end

\ Shortcut for creating string "constants". Typical use:
\
\   " one" str: STR_ONE
\   " two" str: STR_TWO
\
\ Reason: literal strings in root scope are transient.
\ They always refer to the start of the reader buffer.
fun: str: { str -- err }
  str strlen inc { cap }
  str cap alloc_data { adr }
  read_word adr init_data_word
  nil
end

\ ## Compilation-related words continued

\ Finds an extern symbol by name and returns its address.
fun_comp: extern_adr' { -- err } ( C: "name" -- ) ( E: -- adr )
  read_word comp_extern_adr nil
end

\ Indirect version of `extern_adr'`: compiles its usage into another word.
fun_comp: comp_extern_adr' { -- err } ( C: "name" -- ) ( E: -- adr )
  read_word comp_str compile' comp_extern_adr nil
end

\ Returns the address of a local (on the system stack).
\ Often avoids the need for `alloca`.
\
\ By accident, this also implicitly declares the local, but if it wasn't
\ previously assigned, the compiler knows that it hasn't been initialized,
\ and forbids any attempt to use it by name until the first assignment.
\ So in practice, it doesn't really declare.
\
\ SYNC[asm_local_addressing].
fun_comp: ref' { -- err } ( C: "name" -- ) ( E: -- adr )
  read_word comp_local_named comp_local_off { off }
  comp_next_arg_reg { reg }
  reg ASM_REG_FP off asm_add_imm comp_instr \ add <reg>, FP, <off>
  nil
end

fun: comp_clobber_params { -- err }
  0 comp_clobber \ x0
  1 comp_clobber \ x1
  2 comp_clobber \ x2
  3 comp_clobber \ x3
  4 comp_clobber \ x4
  5 comp_clobber \ x5
  6 comp_clobber \ x6
  7 comp_clobber \ x7
  nil
end

fun: comp_clobber_scratch { -- err }
  8  comp_clobber \ x8
  9  comp_clobber \ x9
  10 comp_clobber \ x10
  11 comp_clobber \ x11
  12 comp_clobber \ x12
  13 comp_clobber \ x13
  14 comp_clobber \ x14
  15 comp_clobber \ x15
  nil
end

\ External calls are assumed to clobber all caller-saved GPRs.
\ This is used when compiling words which call external funcs.
fun: comp_clobber_volatile { -- err }
  comp_clobber_params
  comp_clobber_scratch
  nil
end

\ ## Errors
\
\ The compiler provides the following error-related intrinsics:
\ - `try`
\ - `throw`
\ - `catch`
\ - `try_all`
\
\ Errors are plain outputs, always explicitly declared in signatures.
\ By convention, if the last output parameter is named exactly `err`,
\ the compiler marks that word as having an error; see `Sym_has_err`.
\
\ By default, all control flow is explicit. Errors are visible,
\ handled just like other outputs. We also support Swift-style
\ `try` and `throw` which are entirely local. They're basically
\ like `ret`, but without having to list the non-error outputs.
\
\ We also support `try_all`, which is a blanket auto-try, where
\ a "try" is implicitly inserted when calling "erroring" words.
\ It's opt-in and opt-out per-file and per-word.
\
\ `catch` serves ONLY to suppress `try_all` for a single call.
\ By default, without `try_all`, `catch` doesn't even compile.
\
\ Examples:
\
\   fun: inner { -- one two err }
\     " some_error" throw
\     10 20 nil
\   end
\
\   fun: outer
\     inner { one two err }
\     inner try { one two }
\     [ true try_all ]
\     inner { one two } \ Implicit "try".
\   end

\ Interp-mode version of `throw`, to complement compile-time intrinsic.
fun: throw { err }
  [
    1 1 true comp_signature_set
    1 comp_args_set
  ]
end

fun_comp: catch'  { -- err } WORDLIST_EXEC catch nil end
fun_comp: catch'' { -- err } WORDLIST_COMP catch nil end

\ ## IO
\
\ Having access to `libc` spares us from having to implement
\ these functions or provide them as intrinsics.
\
\ This is a partial interface. More is defined in `./io.af`.

0 let: STDIN
1 let: STDOUT
2 let: STDERR

10 let: LF
13 let: CR

3 mem: CRLF    \ \r\n\0
CR CRLF     !8 \ \r
LF CRLF inc !8 \ \n

fun: stdin  { -- adr } extern_adr' __stdinp  @ end
fun: stdout { -- adr } extern_adr' __stdoutp @ end
fun: stderr { -- adr } extern_adr' __stderrp @ end

fun_comp: stdin { -- err } ( E: -- adr )
  comp_extern_adr' __stdinp execute'' @ nil
end

fun_comp: stdout { -- err } ( E: -- adr )
  comp_extern_adr' __stdoutp execute'' @ nil
end

fun_comp: stderr { -- err } ( E: -- adr )
  comp_extern_adr' __stderrp execute'' @ nil
end

4 1 extern: fread            ( buf size len file -- len        )
4 1 extern: fwrite           ( buf size len file -- len        )
2 1 extern: fputs            ( buf file          -- junk|eof32 )
2 1 extern: fputc            ( char file         -- char|eof32 )
2 1 extern: putc             ( char file         -- char|eof32 )
2 1 extern: putc_unlocked    ( char file         -- char|eof32 )
1 1 extern: putchar          ( char              -- char|eof32 )
1 1 extern: putchar_unlocked ( char              -- char|eof32 )
2 1 extern: putw             ( char file         -- zero|eof32 )
1 1 extern: fflush           ( file              -- err        )
1 1 extern: fpurge           ( file              -- err        )

\ Variadic formatting words; see vararg support below.
1 1 extern: printf    ( fmt               … -- len|err )
2 1 extern: fprintf   ( file fmt          … -- len|err )
2 1 extern: sprintf   ( buf fmt           … -- len|err )
3 1 extern: snprintf  ( buf cap fmt       … -- len|err )
