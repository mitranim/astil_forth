  comp_args2_regs { reg0 reg1 }
  reg1 0                asm_cmp_imm comp_instr \ cmp x1, 0
  reg0 reg1 reg0 ASM_NE asm_csel    comp_instr \ csel x0, x1, x0, ne
  reg1 comp_args_set
end

\ Chooses a non-zero value, preferring the second input.
fun: fallback { one two -> out } fallback end

fun_comp: bit_mask_unset { -- err }
  comp_args2_regs { reg0 reg1 }
  reg0 reg0 reg1 asm_bic comp_instr \ bic Xd, Xn, Xm
  reg1 comp_args_set
end

fun: bit_mask_unset { src mask -> out } bit_mask_unset end

\ Gets bits according to mask and returns them in low bits.
\ The mask must be nonzero and contiguous.
fun_comp: bit_mask_get { -- err }
  comp_args2_regs { reg0 reg1 }
  reg0 reg0 reg1 asm_and_reg comp_instr \ and Xd, Xn, Xm
  reg1 reg1      asm_rbit    comp_instr \ rbit Xd, Xn
  reg1 reg1      asm_clz     comp_instr \ clz Xd, Xn
  reg0 reg0 reg1 asm_lsr_reg comp_instr \ lsr Xd, Xn, Xm
  reg1 comp_args_set
end

fun: bit_mask_get { src mask -> out } bit_mask_get end

\ Sets bits according to the mask.
\ The input value must be in low bits.
\ The mask must be nonzero and contiguous.
fun_comp: bit_mask_set { -- err }
  3 nil comp_args_min
  comp_args_get dec { mask }
  mask dec          { src  }
  src  dec          { inp  }

  inp  comp_realloc_reg
  src  comp_realloc_reg
  mask comp_realloc_reg
  comp_alloc_next_reg { shift }

  src   src   mask  asm_bic     comp_instr \ bic Xd, Xn, Xm
  shift mask        asm_rbit    comp_instr \ rbit Xd, Xn
  shift shift       asm_clz     comp_instr \ clz Xd, Xn
  inp   inp   shift asm_lsl_reg comp_instr \ lsl Xd, Xn, Xm
  inp   inp   mask  asm_and_reg comp_instr \ and Xd, Xn, Xm
  inp   inp   src   asm_orr_reg comp_instr \ orr Xd, Xn, Xm
  inp inc comp_args_set
end

fun: bit_mask_set { inp src mask -> out } bit_mask_set end

