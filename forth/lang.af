  " redundant arithmetic: modulo by 1" { err1 }
  false 0 err0 1 err1 .cf_fold2_valid { reg reg1 imm0 imm1 consumed ok }
  if ok .then reg imm0 imm1 .mod .cf_fold_done .ret end
  reg1 imm1 consumed .cf_restore_rhs call_xt'' mod
