\ ## Compiler context
\
\ We use C-mirror structs to access the state of the running compiler.
\ This requires keeping definitions in sync, but gives us an automatic
\ ABI without the need for an API.

fun: comp_ctx { -- Interp_comp_ctx* }
  interp Interp_comp_field Interp_comp_ctx_field
end

fun: comp_arg { reg -- Interp_comp_arg* err }
  comp_ctx Interp_comp_ctx_args { args }
  Interp_comp_arg sizeof reg * args +
end

fun: comp_writable_instrs { -- Interp_list* }
  interp Interp_comp_field Interp_comp_code_field Interp_comp_code_code_write
end

fun: comp_code_len { -- len } comp_writable_instrs Interp_list_len @u32 end

fun: comp_top_arg_regs2 { -- reg0 reg1 err }
  2 nil comp_args_min
  comp_args_get dec { reg1 }
  reg1 dec reg1
end

fun: comp_top_arg_regs3 { -- reg0 reg1 reg2 err }
  3 nil comp_args_min
  comp_args_get dec { reg2 }
  reg2 dec { reg1 }
  reg1 dec reg1 reg2
end

fun: comp_arg_imm_floor { val -> floor }
  Interp_comp_arg_imm_field Interp_reg_imm_floor @u32
end

fun: comp_arg_imm_ceil { val -> ceil }
  Interp_comp_arg_imm_field Interp_reg_imm_ceil @u32
end

\ ## Raw callbacks

\ Used when calling words with unknown clobbers.
fun: comp_realloc_regs { -- err }
  0  comp_realloc_reg \ x0
  1  comp_realloc_reg \ x1
  2  comp_realloc_reg \ x2
  3  comp_realloc_reg \ x3
  4  comp_realloc_reg \ x4
  5  comp_realloc_reg \ x5
  6  comp_realloc_reg \ x6
  7  comp_realloc_reg \ x7
  8  comp_realloc_reg \ x8
  9  comp_realloc_reg \ x9
  10 comp_realloc_reg \ x10
  11 comp_realloc_reg \ x11
  12 comp_realloc_reg \ x12
  13 comp_realloc_reg \ x13
  14 comp_realloc_reg \ x14
  15 comp_realloc_reg \ x15
end

\ blr x0
fun: execute_raw { _fun } [ 0 asm_branch_link_reg comp_instr ] end

\ Takes any amount of args where the last arg is assumed to be a raw
\ instruction address, known in C as "function pointer". Invokes the
\ function with the preceding args. Assumes no outputs. The caller
\ may assume outputs afterwards: `[ N comp_args_set ]`.
fun_comp: execute_raw { -- err } ( C: …args… fun -- ) ( E: …args… fun -- )
  comp_args_get { len }

  ifz len then
    " unable to compile `execute_raw`: at least 1 argument is required" throw
  end

  if len ASM_PARAM_LEN_MAX inc > then
    " unable to compile `execute_raw`: 8 param registers available, 9 arguments provided" throw
  end

  comp_realloc_regs \ Assume full clobber.
  0 comp_args_set

  \ The frame record is a workaround for "leaf" callers without their own.
  ASM_REG_FP ASM_REG_LR ASM_REG_SP -16 asm_store_pair_pre comp_instr \ stp x29, x30, [sp, #-16]!
  len dec asm_branch_link_reg comp_instr                             \ blr <fun>
  ASM_REG_FP ASM_REG_LR ASM_REG_SP 16 asm_load_pair_post comp_instr  \ ldp x29, x30, [sp], #16
end

\ ## Constant folding and locals mutation
\
\ When allocating values to registers, the outer compiler detects
\ comptime immediates. We can access this by directly reading the
\ compiler context, without the need for new intrinsics.
\
\ Then we can simply redefine our arithmetic words,
\ wrapping them into new versions which detect such
\ constants and fold them at comptime, falling back
\ on the regular runtime arithmetic.

fun: cf_arg_foldable_imm { arg -- imm ok }
  arg Interp_comp_arg_imm_field Interp_reg_imm_num @
  arg Interp_comp_arg_imm_field Interp_reg_imm_has_imm @b
end

fun: cf_arg_current { arg -- ok }
  comp_code_len { len }
  arg comp_arg_imm_ceil len =
end

fun: cf_args_contiguous { arg0 arg1 -- ok }
  comp_code_len           { code_len }
  arg0 comp_arg_imm_ceil  { ceil0 }
  arg1 comp_arg_imm_floor { floor1 }
  arg1 comp_arg_imm_ceil  { ceil1 }
  code_len ceil1 = ceil0 floor1 = and
end

fun: cf_args_contiguous3 { arg0 arg1 arg2 -- ok }
  comp_code_len           { code_len }
  arg0 comp_arg_imm_ceil  { ceil0 }
  arg1 comp_arg_imm_floor { floor1 }
  arg1 comp_arg_imm_ceil  { ceil1 }
  arg2 comp_arg_imm_floor { floor2 }
  arg2 comp_arg_imm_ceil  { ceil2 }
  code_len ceil2 = ceil1 floor2 = and ceil0 floor1 = and
end

fun: cf_rewind_to_before_arg { arg }
  comp_writable_instrs { instrs }
  arg comp_arg_imm_floor instrs Interp_list_len !32
end

fun: cf_arg_clear { arg }
  0 arg Interp_comp_arg_imm_field Interp_reg_imm_has_imm !b
end

fun: cf_arg_rewind_clear { arg }
  arg cf_rewind_to_before_arg
  arg cf_arg_clear
end

fun: cf_arg_read_fixup { arg reg -- fix ok }
  arg Interp_comp_arg_loc_field Interp_comp_arg_loc_fix @ { fix }
  ifz fix then nil false ret end
  if fix Interp_loc_fixup_type @cint LOC_FIX_READ <> then nil false ret end
  if fix Interp_loc_fixup_read Interp_loc_read_reg @b reg <> then nil false ret end
  fix true
end

fun: cf_read_fixup_move_here { fix -- err }
  here_write fix Interp_loc_fixup_read Interp_loc_read_instr !
  ASM_PLACEHOLDER comp_instr
end

fun: asm_addsub_imm { Xd Xn imm12 imm add -- instr }
  Xd Xn imm12 asm_pattern_arith_imm
  if imm >=0 add = then ASM_OP_ADD_IMM else ASM_OP_SUB_IMM end or
end

fun: cf_fold_rhs_imm_raw { reg0 arg1 imm aux emit -- err }
  arg1 cf_arg_rewind_clear
  reg0 comp_realloc_reg
  reg0 reg0 imm aux emit execute_raw
  reg0 inc comp_args_set
end

fun: cf_fold_rhs_imm_checked { reg0 arg1 imm aux emit fits -- ok err }
  ifz fits then false ret end
  ifz arg1 cf_arg_current then false ret end

  reg0 arg1 imm aux emit cf_fold_rhs_imm_raw
  true
end

fun: cf_fold_lhs_imm_raw { reg0 reg1 arg0 arg1 imm0 aux emit -- ok err }
  arg1 Interp_comp_arg_loc_field Interp_comp_arg_loc_loc @ { loc1 }
  ifz loc1 then false ret end

  comp_code_len { code_len }
  arg0 comp_arg_imm_ceil { ceil0 }
  nil { fix1 }
  if code_len ceil0 <> then
    if code_len ceil0 inc <> then false ret end
    arg1 reg1 cf_arg_read_fixup { fix1 ok }
    ifz ok then false ret end
  end

  arg0 cf_arg_rewind_clear
  if fix1 then fix1 cf_read_fixup_move_here end
  reg0 comp_realloc_reg
  reg0 reg1 imm0 aux emit execute_raw
  reg0 inc comp_args_set
  true
end

fun: cf_imm_u12 { imm -- ok }
  imm 0 >= imm ASM_MAX_IMM12 <= and
end

fun: cf_emit_cmp_imm_cset { reg0 reg_src imm cond -- err }
  reg_src imm asm_cmp_imm comp_instr \ cmp Xn, #imm12
  reg0 cond asm_cset      comp_instr \ cset Xd, cond
end

fun: cf_foldables2 { reg0 reg1 -- arg0 arg1 imm0 imm1 ok err }
  reg0 comp_arg            { arg0 }
  reg1 comp_arg            { arg1 }
  arg0 cf_arg_foldable_imm { imm0 ok0 }
  arg1 cf_arg_foldable_imm { imm1 ok1 }

  if ok0 ok1 and then
    if arg0 arg1 cf_args_contiguous then arg0 arg1 imm0 imm1 true ret end
  end

  0 0 0 0 false
end

fun: cf_foldables3 { reg0 reg1 reg2 -- arg0 arg1 arg2 imm0 imm1 imm2 ok err }
  reg0 comp_arg            { arg0 }
  reg1 comp_arg            { arg1 }
  reg2 comp_arg            { arg2 }
  arg0 cf_arg_foldable_imm { imm0 ok0 }
  arg1 cf_arg_foldable_imm { imm1 ok1 }
  arg2 cf_arg_foldable_imm { imm2 ok2 }

  if ok0 ok1 ok2 and and then
    if arg0 arg1 arg2 cf_args_contiguous3 then
      arg0 arg1 arg2 imm0 imm1 imm2 true ret
    end
  end

  0 0 0 0 0 0 false
end

fun: cf_top_arg_foldable { -- reg arg imm ok err }
  1 nil comp_args_min
  comp_args_get dec { reg }
  reg comp_arg { arg }
  arg cf_arg_foldable_imm { imm ok }
  reg arg imm ok
end

fun: cf_fold_cleared1 { -- reg imm ok err }
  cf_top_arg_foldable { reg arg imm ok }

  ifz ok then reg 0 false ret end
  ifz arg cf_arg_current then reg 0 false ret end

  arg cf_arg_rewind_clear
  reg imm true
end

fun: cf_fold_cleared2 { -- reg imm0 imm1 ok err }
  comp_top_arg_regs2      { reg0 reg1 }
  reg0 reg1 cf_foldables2 { arg0 arg1 imm0 imm1 ok }

  ifz ok then 0 0 0 false ret end
  arg0 cf_arg_rewind_clear
  arg1 cf_arg_clear
  reg0 imm0 imm1 true
end

fun: cf_fold_cleared2_keep2 { -- reg0 reg1 imm0 imm1 ok err }
  comp_top_arg_regs2      { reg0 reg1 }
  reg0 reg1 cf_foldables2 { arg0 arg1 imm0 imm1 ok }

  ifz ok then 0 0 0 0 false ret end
  arg0 cf_arg_rewind_clear
  arg1 cf_arg_clear
  reg0 reg1 imm0 imm1 true
end

fun: cf_fold_cleared3 { -- reg imm0 imm1 imm2 ok err }
  comp_top_arg_regs3           { reg0 reg1 reg2 }
  reg0 reg1 reg2 cf_foldables3 { arg0 arg1 arg2 imm0 imm1 imm2 ok }

  ifz ok then 0 0 0 0 false ret end
  arg0 cf_arg_rewind_clear
  arg1 cf_arg_clear
  arg2 cf_arg_clear
  reg0 imm0 imm1 imm2 true
end

fun: cf_fold_done { reg imm -- err }
  imm reg comp_load
  reg inc comp_args_set
end

fun: cf_fold_done2 { reg0 reg1 imm0 imm1 -- err }
  imm0 reg0 comp_load
  imm1 reg1 comp_load
  reg1 inc comp_args_set
end

\ Fits the unsigned immediate accepted by our `add/sub #imm12` helpers.
fun: comp_loc_step_imm12 { imm -- mag ok }
  if imm >=0 then imm imm ASM_MAX_IMM12 <= ret end
  if imm ASM_MAX_IMM12 negate >= then imm negate true ret end
  0 false
end

fun: cf_fold_cmp_rhs_imm { reg0 arg1 imm cond -- ok err }
  imm cf_imm_u12 { fits }
  instr' cf_emit_cmp_imm_cset { emit }
  reg0 arg1 imm cond emit fits cf_fold_rhs_imm_checked
end

fun: cf_fold_cmp_lhs_imm { reg0 reg1 arg1 cond -- ok err }
  reg0 comp_arg { arg0 }
  arg0 cf_arg_foldable_imm { imm0 foldable0 }
  ifz foldable0 then false ret end
  ifz imm0 cf_imm_u12 then false ret end

  instr' cf_emit_cmp_imm_cset { emit }
  reg0 reg1 arg0 arg1 imm0 cond emit cf_fold_lhs_imm_raw
end

fun: cf_fold_cmp_imm { cond -- ok err }
  comp_top_arg_regs2 { reg0 reg1 }
  reg1 comp_arg { arg1 }
  arg1 cf_arg_foldable_imm { imm foldable }

  if foldable then reg0 arg1 imm cond cf_fold_cmp_rhs_imm ret end
  reg0 reg1 arg1 cond cf_fold_cmp_lhs_imm
end

fun: cf_emit_addsub_imm { reg0 reg1 imm add -- err }
  imm comp_loc_step_imm12 { mag _ }
  reg0 reg1 mag imm add asm_addsub_imm comp_instr \ add|sub Xd, Xn, #imm12
end

\ Try folding a constant operand into an add/sub immediate instruction.
fun: cf_fold_addsub_imm { add -- ok err }
  comp_top_arg_regs2 { reg0 reg1 }
  reg1 comp_arg { arg1 }
  arg1 cf_arg_foldable_imm { imm foldable }

  if foldable then
    imm comp_loc_step_imm12 { _ fits }
    instr' cf_emit_addsub_imm { emit }
    reg0 arg1 imm add emit fits cf_fold_rhs_imm_checked ret
  end

  ifz add then false ret end

  reg0 comp_arg { arg0 }
  arg0 cf_arg_foldable_imm { imm foldable }
  ifz foldable then false ret end

  imm comp_loc_step_imm12 { _ fits }
  ifz fits then false ret end

  instr' cf_emit_addsub_imm { emit }
  reg0 reg1 arg0 arg1 imm true emit cf_fold_lhs_imm_raw
end

0 let: CF_SHIFT_LSL
1 let: CF_SHIFT_LSR
2 let: CF_SHIFT_ASR

fun: cf_emit_shift_imm { reg0 reg_src imm shift -- err }
  if shift CF_SHIFT_LSL = then
    64 imm - 6 bits_trunc { immr }
    63 imm - 6 bits_trunc { imms }
    reg0 reg_src immr imms ASM_OP_UBFM asm_bitfield comp_instr \ lsl Xd, Xn, #imm6
    ret
  end

  imm 6 bits_trunc { immr }
  if shift CF_SHIFT_LSR = then ASM_OP_UBFM else ASM_OP_SBFM end { bitfield_op }
  reg0 reg_src immr 63 bitfield_op asm_bitfield comp_instr \ lsr|asr Xd, Xn, #imm6
end

fun: cf_fold_shift_imm { shift -- ok err }
  comp_top_arg_regs2 { reg0 reg1 }
  reg1 comp_arg { arg1 }
  arg1 cf_arg_foldable_imm { imm foldable }

  ifz foldable then false ret end

  imm 0 >= imm 63 <= and { fits }
  instr' cf_emit_shift_imm { emit }
  reg0 arg1 imm shift emit fits cf_fold_rhs_imm_checked
end

fun: comp_loc_step_prepare { -- reg arg loc imm foldable err }
  cf_top_arg_foldable { reg arg imm foldable }
  read_word comp_local { loc }
  reg arg loc imm foldable
end

fun: comp_loc_step_store { loc reg -- err }
  reg inc comp_args_set
  loc comp_pop_into_local
end

fun: comp_loc_unary_begin { -- reg loc err } ( C: "name" -- ) ( E: -- )
  read_word comp_local { loc }
  loc comp_push_from_local
  comp_args_get dec loc
end

fun: comp_loc_addsub_step_imm { loc reg imm mag add -- err }
  reg comp_realloc_reg
  loc comp_push_from_local
  reg reg inc mag imm add asm_addsub_imm comp_instr \ add|sub Xd, Xn, #imm12
  loc reg comp_loc_step_store
end

fun: comp_loc_imm1_step { imm_op -- err } ( C: "name" -- ) ( E: -- )
  read_word comp_local { loc }
  loc comp_push_from_local
  comp_args_get dec { reg }
  reg reg 1 asm_pattern_arith_imm imm_op or comp_instr \ add|sub Xd, Xn, #1
  loc reg comp_loc_step_store
end

fun: comp_loc_reg_pattern_emit { loc reg_op -- err }
  comp_args1_reg { reg }
  loc comp_push_from_local
  reg reg inc reg asm_pattern_arith_reg reg_op or comp_instr \ <op> Xd, Xn, Xm
  loc reg comp_loc_step_store
end

fun: comp_loc_reg_pattern_step { reg_op -- err } ( C: "name" -- ) ( E: step -- )
  1 nil comp_args_min
  read_word comp_local reg_op comp_loc_reg_pattern_emit
end

fun: comp_loc_arg_begin { -- arg cur loc err }
  comp_args1_reg { arg }
  read_word comp_local { loc }
  loc comp_push_from_local
  arg inc { cur }
  arg cur loc
end

fun: comp_loc_rem_step { div_op -- err } ( C: "name" -- ) ( E: divisor -- )
  comp_loc_arg_begin { divisor dividend loc }
  comp_alloc_next_reg { quotient }
  quotient dividend divisor asm_pattern_arith_reg div_op or comp_instr \ sdiv|udiv Xd, Xn, Xm
  divisor quotient divisor dividend asm_msub comp_instr \ msub Xd, Xn, Xm, Xa
  loc divisor comp_loc_step_store
end

fun: comp_loc_csel_step { cond -- err } ( C: "name" -- ) ( E: candidate -- )
  comp_loc_arg_begin { candidate cur loc }
  cur candidate asm_cmp_reg comp_instr \ cmp Xn, Xm
  candidate cur candidate cond asm_csel comp_instr \ csel Xd, Xn, Xm, cond
  loc candidate comp_loc_step_store
end

fun: comp_loc_fallback_step { -- err } ( C: "name" -- ) ( E: candidate -- )
  comp_loc_arg_begin { candidate cur loc }
  candidate 0 asm_cmp_imm comp_instr \ cmp Xn, #0
  candidate candidate cur ASM_NE asm_csel comp_instr \ csel Xd, Xn, Xm, ne
  loc candidate comp_loc_step_store
end

fun: comp_loc_cset_zero_step { cond -- err } ( C: "name" -- ) ( E: -- )
  comp_loc_unary_begin { reg loc }
  reg      asm_cmp_zero comp_instr \ cmp Xn, #0
  reg cond asm_cset     comp_instr \ cset Xd, cond
  loc reg comp_loc_step_store
end

fun: comp_loc_cset_reg_step { cond -- err } ( C: "name" -- ) ( E: rhs -- )
  comp_loc_arg_begin { reg1 reg0 loc }
  reg0 reg1 asm_cmp_reg comp_instr \ cmp Xn, Xm
  reg1 cond asm_cset comp_instr \ cset Xd, cond
  loc reg1 comp_loc_step_store
end

fun: comp_loc_align_down_step { -- err } ( C: "name" -- ) ( E: wid -- )
  comp_loc_arg_begin { wid len loc }
  wid asm_neg comp_instr \ neg Xd, Xd
  wid len wid asm_and_reg comp_instr \ and Xd, Xn, Xm
  loc wid comp_loc_step_store
end

fun: comp_loc_align_up_step { -- err } ( C: "name" -- ) ( E: wid -- )
  comp_loc_arg_begin { wid len loc }
  len len wid asm_add_reg comp_instr \ add Xd, Xn, Xm
  len len 1   asm_sub_imm comp_instr \ sub Xd, Xn, #1
  wid         asm_neg     comp_instr \ neg Xd, Xd
  wid len wid asm_and_reg comp_instr \ and Xd, Xn, Xm
  loc wid comp_loc_step_store
end

fun: comp_loc_bit_mask_get_step { -- err } ( C: "name" -- ) ( E: mask -- )
  comp_loc_arg_begin { mask src loc }
  src src mask  asm_and_reg comp_instr \ and Xd, Xn, Xm
  mask mask     asm_rbit    comp_instr \ rbit Xd, Xn
  mask mask     asm_clz     comp_instr \ clz Xd, Xn
  mask src mask asm_lsr_reg comp_instr \ lsr Xd, Xn, Xm
  loc mask comp_loc_step_store
end

fun: comp_loc_bit_mask_set_step { -- err } ( C: "name" -- ) ( E: inp mask -- )
  comp_args2_regs { inp mask }
  read_word comp_local { loc }
  loc comp_push_from_local
  mask inc { src }
  comp_alloc_next_reg { shift }
  src   src   mask  asm_bic     comp_instr \ bic Xd, Xn, Xm
  shift mask        asm_rbit    comp_instr \ rbit Xd, Xn
  shift shift       asm_clz     comp_instr \ clz Xd, Xn
  inp   inp   shift asm_lsl_reg comp_instr \ lsl Xd, Xn, Xm
  inp   inp   mask  asm_and_reg comp_instr \ and Xd, Xn, Xm
  inp   inp   src   asm_orr_reg comp_instr \ orr Xd, Xn, Xm
  loc inp comp_loc_step_store
end

fun: comp_loc_bits_trunc_step { -- err } ( C: "name" -- ) ( E: len -- )
  comp_loc_arg_begin { len val loc }
  comp_alloc_next_reg { tmp }
  1 tmp comp_load
  tmp tmp len asm_lsl_reg comp_instr \ lsl Xt, Xt, Xlen
  tmp tmp 1   asm_sub_imm comp_instr \ sub Xt, Xt, #1
  len val tmp asm_and_reg comp_instr \ and Xval, Xval, Xt
  loc len comp_loc_step_store
end

\ Mutate a local by a runtime or foldable add/sub constant step.
fun: comp_loc_addsub_step { add -- err }
  ( C: "name" -- ) ( E: step -- )

  comp_loc_step_prepare { reg arg loc imm foldable }

  if foldable then
    imm comp_loc_step_imm12 { mag fits }
    if fits then
      if arg cf_arg_current then
        arg cf_arg_rewind_clear
      end
      loc reg imm mag add comp_loc_addsub_step_imm
      ret
    end
  end

  loc if add then ASM_OP_ADD_REG else ASM_OP_SUB_REG end comp_loc_reg_pattern_emit
end

fun_comp: or { -- err } [ redefine ]
  if cf_fold_cleared2 then or cf_fold_done else { -- } execute'' or end
end

