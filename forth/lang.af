\ ## Assembler continued

\ tbz Xt, #bit, #imm14
fun: asm_test_bit_branch_zero { Xt bit imm14 -- instr }
  imm14 instr_off_unpack 14 bits_trunc 5 lsl { imm14 } \ Implicitly times 4.
  bit 5 lsr 31 lsl { b5 }
  bit 5 bits_trunc 19 lsl \ b40
  Xt or imm14 or b5 or
  0b0_01_101_1_0_00000_00000000000000_00000 or
end

\ adr Xd, #imm21
fun: asm_adr { Xd imm21 -- instr }
  imm21 0b11 and { low }
  imm21 instr_off_unpack 19 bits_trunc 5 lsl { high }
  high low or Xd or
  0b0_00_100_00_0000000000000000000_00000 or
end

fun: asm_branch_to_reg { Xn -> instr }
  5 lsl 0b110_101_1_0_0_00_11111_0000_0_0_00000_00000 or \ br Xn
end

\ bl imm26
\
\ Requires caution to avoid messing up the link register.
fun: asm_branch_link_off { imm26 -> instr }
  instr_off_unpack 26 bits_trunc \ Implicitly times 4.
  0b100_101_00000000000000000000000000 or
end

\ Requires caution to avoid messing up the link register.
fun: asm_branch_link_reg { Xn -> instr }
  5 lsl 0b110_101_1_0_0_01_11111_0000_0_0_00000_00000 or \ blr Xn
end

\ orr Xd, Xn, #(1 << bit)
fun: asm_orr_bit { Xd Xn bit -- instr }
  64 bit - 16 lsl { immr }
  Xn 5 lsl
  Xd or immr or
  0b1_01_100100_1_000000_000000_00000_00000 or
end

fun: asm_comp_cset_reg { cond -- err } ( E: i0 i1 -- bool )
  comp_args2_regs { reg0 reg1 }
  reg0 reg1 asm_cmp_reg comp_instr \ cmp Xn, Xm
  reg0 cond asm_cset    comp_instr \ cset Xd, cond
  reg1 comp_args_set
end

fun: asm_comp_cset_zero { cond -- err } ( E: num -- bool )
  comp_args1_reg { reg }
  reg      asm_cmp_zero comp_instr \ cmp Xn, #0
  reg cond asm_cset     comp_instr \ cset Xd, cond
end

\ sbfm Xd, Xn, immr, imms
fun: asm_bitfield_move { Xd Xn immr imms -- instr }
  Xd Xn immr imms ASM_OP_SBFM asm_bitfield
end

\ sxtw Xd, Xn | sbfm Xd, Xn, 0, 31
fun: asm_sign_extend_32 { Xd Xn -> instr } 0 31 asm_bitfield_move end

\ Since we don't have a real type system, the compiler
\ doesn't support automatically sign-extending integers
\ when converting between types. Sometimes it has to be
\ done manually, particularly when dealing with C words
\ which return `(int)-1` which ends up being 0xffffffff.
fun_comp: int_to_cell { -- err }
  comp_args1_reg { reg }
  reg reg asm_sign_extend_32 comp_instr \ sxtw Xd, Wn
end

fun: int_to_cell { int32 -> cell } int_to_cell end

