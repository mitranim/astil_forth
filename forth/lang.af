\ ## More memory stuff

fun: .comp_mem_try_fold_offset { Rt Xn size opc -- fused err }
  \ Peephole: replace immediately preceding `add Xn, Xn, #off`
  \ with a load/store with an inline offset when it fits.
  .here_write ASM_INSTR_SIZE - { instr_adr }
  instr_adr .asm_add_imm_decode_at { Xd Xn0 off ok }
  ok Xd Xn = .and Xn0 Xn = .and { ok }
  ok =0 .then false .ret end

  Rt Xn off size opc .asm_load_store_byte_off { instr -- ok }
  ok =0 .then false .ret end

  \ Safe only because this is the most recently emitted instruction.
  instr instr_adr !32
  true
end

fun: .comp_mem_load { size opc -- err } [ .redefine ]
  1 nil .comp_args_min
  .comp_args_get .dec { reg }
  reg .comp_realloc_reg

  reg reg size opc .comp_mem_try_fold_offset .then .ret end

  \ ldr<size> <reg>, [<reg>]
  reg reg 0 size opc .asm_load_store_off .comp_instr
end

fun: .comp_mem_store { size -- err }
  2 nil .comp_args_min
  .comp_args_get .dec { adr }
  adr .dec { val }

  val adr size 0b00 .comp_mem_try_fold_offset .then
    val .comp_args_set
    .ret
  end

  \ str<size> <val>, [<adr>]
  val adr 0 size 0b00 .asm_load_store_off .comp_instr
  val .comp_args_set
end

