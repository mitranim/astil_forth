  comp_args1_reg      { reg }
  comp_alloc_next_reg { tmp }
  reg reg     asm_clz     comp_instr \ clz Xd, Xn
  tmp 64      asm_mov_imm comp_instr \ mov Xd, #imm
  reg tmp reg asm_sub_reg comp_instr \ sub Xd, Xn, Xm
  tmp comp_args_set
end

