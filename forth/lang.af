\
\ The program is implicitly linked with `libc`,
\ so we get to use C stdlib functions.
\
\ Compiler also provides `alloca` intrinsically.

\ Maximum alignment needed for any value on Arm64.
16 let: FUND_ALIGN

2 1 extern: calloc  ( len size -- addr )
1 1 extern: malloc  ( size -- addr )
2 1 extern: realloc ( addr size -- addr )
1 0 extern: free    ( addr -- )
3 0 extern: memset  ( buf char len -- )
3 0 extern: memcpy  ( out src len -- )
3 0 extern: memmove ( out src len -- )

1 1 extern: strdup  ( cstr -- cstr )
2 1 extern: strndup ( cstr len -- cstr )
1 1 extern: strlen  ( cstr -- len )
2 1 extern: strcmp  ( cstr0 cstr1 -- cmp )
3 1 extern: strncmp ( str0 str1 len -- cmp )
3 0 extern: strncpy ( out src str_len -- )
3 0 extern: strlcpy ( out src buf_len -- )
2 1 extern: strstr  ( cstr0 cstr0 -- adr )

fun: move    { src out len  } out src len .strncpy end
fun: memfill { buf len char } buf char len .memset end
fun: memzero { buf len ->   } 0 .memfill end

\ ## Characters and strings

fun: read_word_char { -- char err } .read_word { buf -- } buf @u8 end

fun: char' { -- char err } ( E: "str" -- char ) .read_word_char end

fun_comp: char' { -- err } ( C: "str" -- ) ( E: -- char )
  .read_word_char      { char }
  .comp_alloc_next_reg { reg }
  char reg .comp_load
end

fun: read_delimited { delim -- str len err }
  .read_char { -- }
  delim .read_until_char { str len }
  .read_char { -- }
  str len
end

fun: comp_alloc_cstr { buf len -- cstr err }
  len .inc            { cap } \ Reserve terminating null byte.
  buf cap .alloc_data { adr }
  adr len +          { ceil }
  nil ceil !b
  adr
end

\ Copies a string and appends a terminating null byte.
fun: comp_str { buf len -> err } ( E: -- cstr len )
  .comp_alloc_cstr     { adr }
  .comp_alloc_next_reg { RS }
  .comp_alloc_next_reg { RL }
  adr RS .comp_page_addr \ `adrp RS, <page>` & `add RS, RS, <pageoff>`
  len RL .comp_load      \ ldr RL, <len>
end

fun: comp_cstr { buf len -- err } ( E: -- cstr )
  .comp_alloc_next_reg { reg }
  buf len .comp_alloc_cstr
  reg .comp_page_addr \ `adrp <reg>, <page>` & `add <reg>, <reg>, <pageoff>`
end

\ Parses the input until the terminating quote, and returns the address and
\ length of the resulting string. In interpretation mode, the string points
\ into the transient reader input and is not null-terminated. In compilation
\ mode, the string is statically allocated, unique, and null-terminated.
fun: s" { -- str len err } ( E: "str" -- str len ) char' " .read_delimited end
fun: s` { -- str len err } ( E: `str` -- str len ) char' ` .read_delimited end
fun_comp: s" { -- err } ( C: "str" -- ) ( E: -- str len ) call_xt' s" .comp_str end
fun_comp: s` { -- err } ( C: `str` -- ) ( E: -- str len ) call_xt' s` .comp_str end

4096 buf: ROOT_STR_BUF

fun: read_interp_cstr { delim -> cstr err }
  .read_delimited { src len }
  ROOT_STR_BUF { buf cap }
  len cap .min { len }
  buf src len .memcpy
  nil buf len + !b
  buf
end

\ Interpretation-mode string "literals" which return null-terminated strings
\ without length. Reuses the same buffer for each call; may also truncate.
fun: " { -- cstr err } ( E: "str" -- cstr ) char' " .read_interp_cstr end
fun: ` { -- cstr err } ( E: `str` -- cstr ) char' ` .read_interp_cstr end

\ Reads a string, copies it to compiler-managed data,
\ and compiles a PC-relative reference to it.
fun: read_comp_cstr { delim -> err } .read_delimited .comp_cstr end

fun_comp: " { -- err } ( C: "str" -- ) ( E: -- cstr ) char' " .read_comp_cstr end
fun_comp: ` { -- err } ( C: `str` -- ) ( E: -- cstr ) char' ` .read_comp_cstr end

\ Shortcut for creating string "constants". Typical use:
\
\   " one" str: STR_ONE
\   " two" str: STR_TWO
\
\ Reason: literal strings in root scope are transient.
\ They always refer to the start of the reader buffer.
fun: str: { str -> err }
  .strlen .inc { cap }
  str cap .alloc_data { adr }
  .read_word adr .init_data_word
end

\ ## Compilation-related words continued

\ Finds an extern symbol by name and returns its address.
fun_comp: extern_adr' { -- err } ( C: "name" -- ) ( E: -- adr )
  .read_word .comp_extern_adr
end

\ Indirect version of `extern_adr'`: compiles its usage into another word.
fun_comp: comp_extern_adr' { -- err } ( C: "name" -- ) ( E: -- adr )
  .read_word .comp_str compile' comp_extern_adr
end

\ ## Errors
\
\ The compiler provides the following error-related intrinsics:
\ - `.try`
\ - `.throw`
\ - `.catch`
\ - `.try_all`
\
\ Errors are plain outputs, always explicitly declared in signatures.
\ By convention, if the last output parameter is named exactly `err`,
\ the compiler marks that word as having an error; see `Sym_has_err`.
\
\ By default, all control flow is explicit. Errors are visible,
\ handled just like other outputs. We also support Swift-style
\ `.try` and `.throw` which are entirely local. They're nearly
\ as `.ret`, but without having to list the non-error outputs.
\
\ Error may be partial or total. Each word decides its contract.
\ On partial failure, non-error outputs are defined.
\ On total failure, non-error outputs are undefined.
\
\ We also support `.try_all`, which is a blanket auto-try, where
\ a `.try` is implicitly inserted when calling "erroring" words.
\ It's opt-in and opt-out per-file and per-word.
\
\ Under `.try_all`, postfix `.catch` restores the error output
\ from the preceding call by backtracking the implicit `.try`.
\
\ Examples:
\
\   fun: inner { -- one two err }
\     " some_error" .throw
\     10 20 nil
\   end
\
\   fun: outer
\     inner { one two err }
\     inner .try { one two }
\     [ true .try_all ]
\     inner { one two } \ Implicit `.try`.
\     inner .catch { one two err }
\   end

