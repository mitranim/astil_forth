fun_comp: odd { -- err }
  comp_args1_reg { reg }
  reg reg 0b1_000000_000000 asm_and_imm_enc comp_instr \ and Xd, Xd, 1
end

fun: odd { val -- bool } val odd end

\ ## Memory load / store

\ We allow to load inside an argument list, replacing the latest argument,
\ which is an address, with a value without consuming all prior arguments.
\ This violates the idea that every verb should consume all arguments, but
\ can be convenient at times. TODO reconsider.
\
\ TODO validate there's an input.
fun: comp_mem_load { size opc -- err }
  comp_args_get dec { reg }
  reg comp_clobber
  \ ldr<size> <reg>, [<reg>]
  reg reg 0 size opc asm_load_store_imm comp_instr
end

\ Generically defines a load word for the given size / type.
fun: load: { size opc -- err } ( C: "name" -- )  ( E: adr -- val )
  read_word { str len }

  \ Execution-time semantics.
  str len define_fun
    1 1 false comp_signature_set ( E: adr -- val )
    0 comp_clobber
    0 0 0 size opc asm_load_store_imm comp_instr \ ldr<size> r0, [x0]
    1 comp_args_set
  semicolon

  \ Compile-time semantics.
  str len define_fun_comp
    false try_all
    0 1 true comp_signature_set
    size     comp_push
    opc      comp_push
    compile' comp_mem_load
  semicolon

  [ false comp_only ]
end

\ Generically defines a store word for the given size / type.
\ Execution-time semantics only. The compiler always inlines.
fun: store: { size -- err } ( C: "name" -- ) ( E: val adr -- )
  read_word define_fun
    2 0 false comp_signature_set
    \ str<size> r0, [x1]
    0 1 0 size 0b00 asm_load_store_imm comp_instr
  semicolon

  [ false comp_only ]
end

0b00 0b01 load:  @u8 \ Renamed from standard `c@`.
0b00 0b10 load:  @s8
0b00      store: !8  \ Renamed from standard `c!`.

\ Byte load/store; aliases for `@u8` and `!8`.
0b00 0b01 load:  @b \ Renamed from standard `c@`.
0b00      store: !b \ Renamed from standard `c!`.

0b01 0b01 load:  @u16
0b01 0b10 load:  @s16
0b01      store: !16

0b10 0b01 load:  @u32
0b10 0b10 load:  @s32
0b10      store: !32

0b11 0b01 load:  @
0b11      store: !

\ Aliases for some C types, so the user
\ doesn't have to remember their width.

\ 32 bit
0b10 0b10 load:  @cint
0b10      store: !cint

\ 32 bit
0b10 0b01 load:  @cuint
0b10      store: !cuint

\ 64 bit (Apple ABI)
0b11 0b10 load:  @clong
0b11      store: !clong

\ 64 bit (Apple ABI)
0b11 0b01 load:  @culong
0b11      store: !culong

fun_comp: @2 { -- err }
  comp_args1_reg2 { val0 val1 adr }
  val0 val1 adr 0 asm_load_pair_off comp_instr \ ldp Xt1, Xt2, [Xn]
  val1 inc comp_args_set
end

fun: @2 { adr -- val0 val1 } adr @2 end

fun_comp: @@2 { -- err }
  comp_args2_regs2 { val0 val1 adr0 adr1 }
  val0 adr0 0 asm_load_off comp_instr \ ldr Xt, [Xn]
  val1 adr1 0 asm_load_off comp_instr \ ldr Xt, [Xn]
end

fun: @@2 { adr0 adr1 -- val0 val1 } adr0 adr1 @@2 end

fun_comp: !2 { -- err }
  comp_args_get dec { adr }
  adr dec { val1 }
  val1 dec { val0 }
  val0 val1 adr 0 asm_store_pair_off comp_instr \ stp Xt1, Xt2, [Xn]
  val0 comp_args_set
end

fun: !2 { val0 val1 adr } val0 val1 adr !2 end

fun_comp: @at { -- err }
  comp_args_get dec { off }
  off dec { adr }
  adr adr off 0 asm_load_with_register_off comp_instr \ ldr Xt, [Xn, Xm]
  off comp_args_set
end

fun: @at { adr off -- val } adr off @at end

fun_comp: !at { -- err }
  comp_args_get dec { off }
  off dec { adr }
  adr dec { val }
  val adr off 0 asm_store_with_register_off comp_instr \ str Xt, [Xn, Xm]
  val comp_args_set
end

fun: !at { val adr off } val adr off !at end

fun: off! { adr } false adr ! end
fun: on!  { adr } true  adr ! end

\ ## Stacks
\
\ This section defines operations on integer / cell stacks like the one
\ provided by the outer interpreter. We also allocate additional stacks
\ for auxiliary control information, such as `LOOP_AUX`.
\
\ Each stack is represented with an address of the struct below.
\ The definition matches `Stack` in our C code. The default data
\ stack provided by the interpreter is one of these. We hardcode
\ the offsets below, because `struct:` is not yet available.
\
\   \ SYNC[stack_field_offsets].
\   struct: Stack
\     Cell 1 field: Stack_bytelen \ Total size with guards.
\     Adr  1 field: Stack_cellar  \ Lower guard.
\     Adr  1 field: Stack_floor   \ First data cell.
\     Adr  1 field: Stack_top     \ Next data cell.
\     Adr  1 field: Stack_ceil    \ After last data cell.
\   end
\
\ See `stack_init` for guarded allocation via memory mapping.
\ A stack can also be allocated without guards if so desired.
\
\ The stack operations below have somewhat suboptimal performance.
\ They're meant primarily for control frames, used in compilation
\ and testing.
\
\ Because the interpreter's stack is accessible on the interpreter object,
\ we get away with not having to reserve any special registers for stacks.
\
\ The default stack is available ONLY in interpreted and JIT-compiled code.
\ AOT-compiled executables do not have the Forth interpreter or data stack.
\
\ All our stacks are empty-ascending.

\ SYNC[stack_field_offsets].
16 let: STACK_OFF_FLOOR
24 let: STACK_OFF_TOP
32 let: STACK_OFF_CEIL

\ Default Forth stack provided by the interpreter.
\ Not available when running in AOT-compiled mode.
\
\ SYNC[interp_fields].
fun_comp: STACK { -- err } ( E: -- adr )
  \ mov <arg>, x28
  comp_next_arg_reg ASM_REG_INTERP asm_mov_reg comp_instr
  true interp_only
end

fun: STACK { -- adr } STACK end

fun: comp_load_off { off -- err } ( E: adr -- adr )
  0 comp_clobber
  0 0 off asm_load_unscaled_off comp_instr \ ldur x0, [x0, <off>]
  1 comp_args_set
end

\ Note: `stack_top` is the top EMPTY cell, not a full one.
fun: stack?      { stack -- bool  } stack @ <>0 end
fun: stack_floor { stack -- floor } [ STACK_OFF_FLOOR comp_load_off ] end
fun: stack_top   { stack -- top   } [ STACK_OFF_TOP   comp_load_off ] end
fun: stack_ceil  { stack -- ceil  } [ STACK_OFF_CEIL  comp_load_off ] end

\ ldur <out>, [<stack>, STACK_OFF_TOP]
fun: asm_stack_top_load { out stack -- instr }
  out stack STACK_OFF_TOP asm_load_unscaled_off
end

\ stur <out>, [<stack>, STACK_OFF_TOP]
fun: asm_stack_top_store { out stack -- instr }
  out stack STACK_OFF_TOP asm_store_unscaled_off
end

fun: stack@ { stack -- val } stack stack_top -cell @ end

fun: stack_top! { top stack } [
  \ stur <top>, [<stack>, STACK_OFF_TOP]
  0 1 asm_stack_top_store comp_instr
] end

fun: stack_cell_at { ind stack  -- adr }
  ind cells { off } stack stack_floor off +
end

fun: stack_len_bytes { stack -- len }
  stack stack_floor { floor }
  stack stack_top floor -
end

fun: stack_cap_bytes { stack -- len }
  stack stack_floor { floor }
  stack stack_ceil floor -
end

fun: stack_len_cells { stack -- len } stack stack_len_bytes /cells end
fun: stack_cap_cells { stack -- len } stack stack_cap_bytes /cells end

fun: stack_trunc { stack } stack stack_floor stack stack_top! end

fun: stack_len_cells_set { len stack }
  len stack stack_cell_at stack stack_top!
end

fun: stack_len_cells+ { diff stack }
  stack stack_len_cells diff + stack stack_len_cells_set
end

fun: stack_len_cells- { diff stack }
  stack stack_len_cells diff - stack stack_len_cells_set
end

fun: stack_drop_cell { stack } 1 stack stack_len_cells- end

\ Pops a cell from a stack. Usage:
\
\   stack s> { val }
\
\ Mind the backwards order:
\
\   10 20 30 stack >>s
\   stack s> . \ 30
\   stack s> . \ 20
\   stack s> . \ 10
\
\ Also see `stack{` which is more convenient and less error-prone.
fun: s> { stack -- val } [
  2 comp_clobber
  1 comp_clobber
  0 comp_clobber
  2 0    asm_mov_reg         comp_instr \ mov  x2, x0
  1 2    asm_stack_top_load  comp_instr \ ldur x1, [x2, STACK_OFF_TOP]
  0 1 -8 asm_load_pre        comp_instr \ ldr  x0, [x1, -8]!
  1 2    asm_stack_top_store comp_instr \ stur x1, [x2, STACK_OFF_TOP]
  1 comp_args_set
] end

\ Pushes a cell to a stack.
\
\ Also see `:: >>s` defined later in this file.
\ Unlike this version, it's variadic.
fun: >s { val stack } [
  2 comp_clobber
  1 comp_clobber
  0 comp_clobber
  2 1   asm_mov_reg         comp_instr \ mov  x2, x1
  1 2   asm_stack_top_load  comp_instr \ ldur x1, [x2, STACK_OFF_TOP]
  0 1 8 asm_store_post      comp_instr \ str  x0, [x1], 8
  1 2   asm_stack_top_store comp_instr \ stur x1, [x2, STACK_OFF_TOP]
] end

\ ## System stack stuff

fun_comp: systack_ptr { -- err } ( E: -- sp )
  \ add <reg>, sp, 0 | mov <reg>, sp
  comp_next_arg_reg ASM_REG_SP 0 asm_add_imm comp_instr
end

fun: systack_ptr { -- sp } systack_ptr end

fun_comp: sysstack_frame_ptr { -- err } ( E: -- fp )
  \ mov <reg>, x29
  comp_next_arg_reg ASM_REG_FP asm_mov_reg comp_instr
end

fun: sysstack_frame_ptr { -- fp } sysstack_frame_ptr end
\ ## Global variables and buffers

\ Asks for a register and compiles this idiom:
\
\   adrp <reg>, <page>
\   add <reg>, <reg>, <pageoff>
\
\ Used for taking an address of a data entry
\ in the code heap allocated via `alloc_data`.
fun: comp_next_page_addr { adr -- err } ( E: -- adr )
  comp_next_arg_reg { reg }
  adr reg comp_page_addr
end

fun: init_data_word { name name_len adr -- err }
  name name_len define_fun
    0 1 false comp_signature_set ( E: -- ptr )
    adr comp_next_page_addr
  semicolon

  name name_len define_fun_comp
    false try_all
    0 1 true comp_signature_set
    adr comp_push compile' comp_next_page_addr
  semicolon

  [ false comp_only ]
end

fun: var_init { str len val -- err }
  nil CELL alloc_data { adr }
  val adr !
  str len adr init_data_word
end

\ Similar to standard `variable`, but takes an initial value like `let:`.
fun: var: { val -- err } ( C: "name" -- ) ( E: -- ptr )
  read_word val var_init
end

\ Shortcut for the standard idiom `create <name> N allot`.
\ Unlike the standard idiom, this also zeroes the memory.
\ Like `buf:` but doesn't return capacity.
\ Also see `buf:` for warnings about AOT.
fun: mem: { cap -- err } ( C: "name" -- ) ( E: -- adr )
  nil cap alloc_data { adr }
  read_word adr init_data_word
end

fun: comp_buf { adr cap -- err } ( E: -- adr cap )
  comp_next_arg_reg { RA }
  comp_next_arg_reg { RL }
  adr RA comp_page_addr
  cap RL comp_load
end

fun: buf_init { adr cap -- err }
  read_word { str len }

  str len define_fun
    0 2 false comp_signature_set ( E: -- ptr cap )
    adr cap comp_buf
  semicolon

  str len define_fun_comp
    false try_all
    0 1 true comp_signature_set
    adr comp_push cap comp_push compile' comp_buf
  semicolon

  [ false comp_only ]
end

\ Similar to the standard idiom `create <name> N allot`.
\ Creates a global variable which refers to a buffer of
\ at least the given size in bytes, initialized to zero.
\
\ TODO dedup code with `init_data_word`.
\
\ The buffer is allocated in the compiler-managed data region,
\ which is preserved in AOT compilation. Changes to this data
\ made during interpretation persist into the AOT executable.
\
\ The variable does NOT hold a fixed address. Instead, it compiles
\ instructions to calculate the address using PC-relative offsets.
\ The address CHANGES from JIT to AOT. This means: it must not be
\ stored in another static variable, or used to derive an address
\ which would be stored in another static variable.
fun: buf: { cap -- err } ( C: "name" -- ) ( E: -- adr cap )
  nil cap alloc_data cap buf_init
end

\ ## Memory
\
\ The program is implicitly linked with `libc`,
\ so we get to use C stdlib functions.
\
\ Compiler also provides `alloca` intrinsically.

\ Maximum alignment needed for any value on Arm64.
16 let: FUND_ALIGN

2 1 extern: calloc  ( len size -- addr )
1 1 extern: malloc  ( size -- addr )
1 0 extern: free    ( addr -- )
3 0 extern: memset  ( buf char len -- )
3 0 extern: memcpy  ( out src len -- )
3 0 extern: memmove ( out src len -- )

1 1 extern: strdup  ( cstr -- cstr )
2 1 extern: strndup ( cstr len -- cstr )
1 1 extern: strlen  ( cstr -- len )
2 1 extern: strcmp  ( cstr0 cstr1 -- cmp )
3 1 extern: strncmp ( str0 str1 len -- cmp )
3 0 extern: strncpy ( out src str_len -- )
3 0 extern: strlcpy ( out src buf_len -- )
2 1 extern: strstr  ( cstr0 cstr0 -- adr )

fun: move  { src out len  } out src len strncpy end
fun: fill  { buf len char } buf char len memset end
fun: erase { buf len      } buf len 0 fill end

\ ## Characters and strings

fun: read_word_char { -- char err } read_word { buf -- } buf @u8 end

fun: char' { -- char err } ( E: "str" -- char ) read_word_char end

fun_comp: char' { -- err } ( C: "str" -- ) ( E: -- char )
  read_word_char    { char }
  comp_next_arg_reg { reg }
  char reg comp_load
end

fun: comp_alloc_cstr { buf len -- cstr err }
  len inc            { cap } \ Reserve terminating null byte.
  buf cap alloc_data { adr }
  adr len +          { ceil }
  nil ceil !b
  adr
end

\ Copies a string and appends a terminating null byte.
fun: comp_str { buf len -- err } ( E: -- cstr len )
  buf len comp_alloc_cstr { adr }
  comp_next_arg_reg       { RS }
  comp_next_arg_reg       { RL }
  adr RS comp_page_addr \ `adrp RS, <page>` & `add RS, RS, <pageoff>`
  len RL comp_load      \ ldr RL, <len>
end

fun: comp_cstr { buf len -- err } ( E: -- cstr )
  comp_next_arg_reg { reg }
  buf len comp_alloc_cstr
  reg comp_page_addr \ `adrp <reg>, <page>` & `add <reg>, <reg>, <pageoff>`
end

\ Parses the input until the terminating quote, and returns the address and
\ length of the resulting string. In interpretation mode, the string points
\ into the transient reader input and is not null-terminated. In compilation
\ mode, the string is statically allocated, unique, and null-terminated.
fun: s" { -- str len err } ( E: "str" -- str len )
  read_char { -- } char' " read_until_char
end
fun_comp: s" { -- err } ( C: "str" -- ) ( E: -- str len )
  read_char { -- } char' " read_until_char comp_str
end

fun: s` { -- str len err } ( E: `str` -- str len )
  read_char { -- } char' ` read_until_char
end
fun_comp: s` { -- err } ( C: `str` -- ) ( E: -- str len )
  read_char { -- } char' ` read_until_char comp_str
end

4096 buf: ROOT_STR_BUF

fun: read_interp_cstr { delim -- cstr err }
  read_char { -- }
  delim read_until_char { src len }
  ROOT_STR_BUF { buf cap }
  len cap min { len }
  buf src len memcpy
  nil buf len + !b
  buf
end

\ Interpretation-mode string "literals" which return null-terminated strings
\ without length. Reuses the same buffer for each call; may also truncate.
fun: " { -- cstr err } ( E: "str" -- cstr ) char' " read_interp_cstr end
fun: ` { -- cstr err } ( E: `str` -- cstr ) char' ` read_interp_cstr end

\ Reads a string, copies it to compiler-managed data,
\ and compiles a PC-relative reference to it.
fun: read_comp_cstr { delim -- err }
  read_char { -- } delim read_until_char comp_cstr
end

fun_comp: " { -- err } ( C: "str" -- ) ( E: -- cstr ) char' " read_comp_cstr end
fun_comp: ` { -- err } ( C: `str` -- ) ( E: -- cstr ) char' ` read_comp_cstr end

\ Shortcut for creating string "constants". Typical use:
\
\   " one" str: STR_ONE
\   " two" str: STR_TWO
\
\ Reason: literal strings in root scope are transient.
\ They always refer to the start of the reader buffer.
fun: str: { str -- err }
  str strlen inc { cap }
  str cap alloc_data { adr }
  read_word adr init_data_word
end

\ ## Compilation-related words continued

\ Finds an extern symbol by name and returns its address.
fun_comp: extern_adr' { -- err } ( C: "name" -- ) ( E: -- adr )
  read_word comp_extern_adr
end

\ Indirect version of `extern_adr'`: compiles its usage into another word.
fun_comp: comp_extern_adr' { -- err } ( C: "name" -- ) ( E: -- adr )
  read_word comp_str compile' comp_extern_adr
end

\ Returns the address of a local (on the system stack).
\ Often avoids the need for `alloca`.
\
\ By accident, this also implicitly declares the local, but if it wasn't
\ previously assigned, the compiler knows that it hasn't been initialized,
\ and forbids any attempt to use it by name until the first assignment.
\ So in practice, it doesn't really declare.
\
\ SYNC[asm_local_addressing].
fun_comp: ref' { -- err } ( C: "name" -- ) ( E: -- adr )
  read_word comp_local_named comp_local_off { off }
  comp_next_arg_reg { reg }
  reg ASM_REG_FP off asm_add_imm comp_instr \ add <reg>, FP, <off>
end

fun: comp_clobber_params { -- err }
  0 comp_clobber \ x0
  1 comp_clobber \ x1
  2 comp_clobber \ x2
  3 comp_clobber \ x3
  4 comp_clobber \ x4
  5 comp_clobber \ x5
  6 comp_clobber \ x6
  7 comp_clobber \ x7
end

fun: comp_clobber_scratch { -- err }
  8  comp_clobber \ x8
  9  comp_clobber \ x9
  10 comp_clobber \ x10
  11 comp_clobber \ x11
  12 comp_clobber \ x12
  13 comp_clobber \ x13
  14 comp_clobber \ x14
  15 comp_clobber \ x15
end

\ External calls are assumed to clobber all caller-saved GPRs.
\ This is used when compiling words which call external funcs.
fun: comp_clobber_volatile { -- err }
  comp_clobber_params
  comp_clobber_scratch
end

\ ## Errors
\
\ The compiler provides the following error-related intrinsics:
\ - `try`
\ - `throw`
\ - `catch`
\ - `try_all`
\
\ Errors are plain outputs, always explicitly declared in signatures.
\ By convention, if the last output parameter is named exactly `err`,
\ the compiler marks that word as having an error; see `Sym_has_err`.
\
\ By default, all control flow is explicit. Errors are visible,
\ handled just like other outputs. We also support Swift-style
\ `try` and `throw` which are entirely local. They're basically
\ like `ret`, but without having to list the non-error outputs.
\
\ We also support `try_all`, which is a blanket auto-try, where
\ a "try" is implicitly inserted when calling "erroring" words.
\ It's opt-in and opt-out per-file and per-word.
\
\ `catch` serves ONLY to suppress `try_all` for a single call.
\ By default, without `try_all`, `catch` doesn't even compile.
\
\ Examples:
\
\   fun: inner { -- one two err }
\     " some_error" throw
\     10 20 nil
\   end
\
\   fun: outer
\     inner { one two err }
\     inner try { one two }
\     [ true try_all ]
\     inner { one two } \ Implicit "try".
\   end

\ Interp-mode version of `throw`, to complement compile-time intrinsic.
fun: throw { err }
  [
    1 1 true comp_signature_set
    1 comp_args_set
  ]
end

fun_comp: catch'  { -- err } WORDLIST_EXEC catch end
fun_comp: catch'' { -- err } WORDLIST_COMP catch end

\ ## IO
\
\ Having access to `libc` spares us from having to implement
\ these functions or provide them as intrinsics.
\
\ This is a partial interface. More is defined in `./io.af`.

0 let: STDIN
1 let: STDOUT
2 let: STDERR

10 let: LF
13 let: CR
9  let: TAB
11 let: VTAB
32 let: SPACE

3 mem: CRLF    \ \r\n\0
CR CRLF     !8 \ \r
LF CRLF inc !8 \ \n

fun: stdin  { -- adr } extern_adr' __stdinp  @ end
fun: stdout { -- adr } extern_adr' __stdoutp @ end
fun: stderr { -- adr } extern_adr' __stderrp @ end

fun_comp: stdin { -- err } ( E: -- adr )
  comp_extern_adr' __stdinp execute'' @
end

fun_comp: stdout { -- err } ( E: -- adr )
  comp_extern_adr' __stdoutp execute'' @
end

fun_comp: stderr { -- err } ( E: -- adr )
  comp_extern_adr' __stderrp execute'' @
end

4 1 extern: fread            ( buf size len file -- len        )
4 1 extern: fwrite           ( buf size len file -- len        )
2 1 extern: fputs            ( buf file          -- junk|eof32 )
2 1 extern: fputc            ( char file         -- char|eof32 )
2 1 extern: putc             ( char file         -- char|eof32 )
2 1 extern: putc_unlocked    ( char file         -- char|eof32 )
