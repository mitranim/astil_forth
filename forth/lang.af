\ Chooses a non-zero value, preferring the second input.
fun: .fallback { one two -> out } .fallback end

fun_comp: .is_aligned_to { -- err }
  .comp_args2_regs { reg0 reg1 }
  reg1 reg1 1 .asm_sub_imm .comp_instr \ sub Xd, Xn, 1
  reg0 reg1   .asm_tst     .comp_instr \ tst Xn, Xm
  reg0 ASM_EQ .asm_cset    .comp_instr \ cset Xd, eq
  reg1 .comp_args_set
end

fun: .is_aligned_to { adr size -> bool } .is_aligned_to end

fun: .comp_emit_align_down { out len wid -- err }
  wid         .asm_neg     .comp_instr \ neg Xd, Xd
  out len wid .asm_and_reg .comp_instr \ and Xd, Xn, Xm
end

fun_comp: .align_down { -- err }
  .comp_args2_regs { reg0 reg1 }
  reg0 reg0 reg1 .comp_emit_align_down
  reg1 .comp_args_set
end

fun: .align_down { len wid -> len } .align_down end

\ Assumes power of two.
fun_comp: .align_up { -- err }
  .comp_args2_regs { reg0 reg1 }
  reg0 reg0 reg1 .asm_add_reg .comp_instr \ add Xd, Xn, Xm
  reg0 reg0 1    .asm_sub_imm .comp_instr \ sub Xd, Xn, #1
  reg0 reg0 reg1 .comp_emit_align_down
  reg1 .comp_args_set
end

fun: .align_up { len wid -> len } .align_up end

\ Flip all the bits.
fun_comp: .invert { -- err }
  .comp_args1_reg { reg }
  reg reg .asm_mvn .comp_instr \ mvn Xd, Xm
end

fun: .invert { i0 -> i1 } [ .redefine ] .invert end

\ 1-based index of the highest bit.
fun: .comp_emit_bit_len { reg tmp -- err }
  reg reg     .asm_clz     .comp_instr \ clz Xd, Xn
  64  tmp                  .comp_load  \ mov Xd, #imm
  reg tmp reg .asm_sub_reg .comp_instr \ sub Xd, Xn, Xm
end

fun_comp: .bit_len { -- err }
  .comp_args1_reg      { reg }
  .comp_alloc_next_reg { tmp }
  reg tmp .comp_emit_bit_len
  tmp .comp_args_set
end

fun: .bit_len { val -> len } .bit_len end

fun: .comp_emit_pow2_ceil { reg tmp -- err }
  1 tmp .comp_load
  reg reg tmp reg tmp ASM_HI .comp_emit_csel_reg \ csel Xd, Xn, Xm, hi
  reg reg 1 .asm_sub_imm     .comp_instr         \ sub Xd, Xn, #1
  reg reg .asm_clz           .comp_instr         \ clz Xd, Xn
  reg .asm_neg               .comp_instr         \ neg Xd, Xn
  reg reg 64 .asm_add_imm    .comp_instr         \ add Xd, Xn, #64
  reg tmp reg .asm_lsl_reg   .comp_instr         \ lsl Xd, Xn, Xm
end

fun_comp: .pow2_ceil { -- err }
  .comp_args1_reg      { reg }
  .comp_alloc_next_reg { tmp }
  reg tmp .comp_emit_pow2_ceil
  reg .inc .comp_args_set
end

fun: .pow2_ceil { val -- pow2 } 1 val 1 .umax .dec .bit_len .lsl end

\ "count leading zeros" (in high bits)
fun_comp: .bit_clz { -- err }
  .comp_args1_reg { reg }
  reg reg .asm_clz .comp_instr \ clz Xd, Xn
end

fun: .bit_clz { num -> bool } .bit_clz end

\ "count trailing zeros" (in low bits)
\
\ Fallback version of `ctz Xd, Xn` for chips without `ctz`.
fun: .comp_emit_bit_ctz { reg -- err }
  reg reg .asm_rbit .comp_instr \ rbit Xd, Xn
  reg reg .asm_clz  .comp_instr \ clz Xd, Xd
end

fun_comp: .bit_ctz { -- err } .comp_args1_reg .comp_emit_bit_ctz end
fun: .bit_ctz { num -> bool } .bit_ctz end

fun: .comp_emit_low_bits { reg tmp -- err }
  1 tmp .comp_load
  tmp tmp reg .asm_lsl_reg .comp_instr \ lsl Xt, Xt, Xn
  reg tmp 1 .asm_sub_imm .comp_instr   \ sub Xn, Xt, #1
end

fun_comp: .low_bits { -- err }
  .comp_args1_reg        { reg }
  .comp_alloc_next_reg   { tmp }
  reg tmp .comp_emit_low_bits
  reg .inc .comp_args_set
end

fun: .low_bits { len -> bits } [ .redefine ] .low_bits end

fun_comp: .bits_trunc { -- err }
  .comp_args2_regs     { imm len }
  .comp_alloc_next_reg { tmp }
  1 tmp .comp_load
  tmp tmp len .asm_lsl_reg .comp_instr \ lsl Xt, Xt, Xlen
  tmp tmp 1   .asm_sub_imm .comp_instr \ sub Xt, Xt, #1
  imm imm tmp .asm_and_reg .comp_instr \ and Xd, Xn, Xm
  len .comp_args_set
end

fun: .bits_trunc { imm len -> imm } [ .redefine ] .bits_trunc end

fun_comp: .bits_clear { -- err }
  .comp_args2_regs { imm mask }
  imm imm mask .asm_bic .comp_instr \ bic Ximm, Ximm, Xmask
  mask .comp_args_set
end

fun: .bits_clear { imm mask -> out } .bits_clear end

fun_comp: .bit_mask_get { -- err }
  .comp_args2_regs { reg0 reg1 }
  \ Get bits according to a nonzero contiguous mask and return them in low bits.
  reg0 reg0 reg1 .asm_and_reg .comp_instr \ and Xd, Xn, Xm
  reg1 reg1      .asm_rbit    .comp_instr \ rbit Xd, Xn
  reg1 reg1      .asm_clz     .comp_instr \ clz Xd, Xn
  reg0 reg0 reg1 .asm_lsr_reg .comp_instr \ lsr Xd, Xn, Xm
  reg1 .comp_args_set
end

fun: .bit_mask_get { src mask -> out } .bit_mask_get end

\ Sets bits according to the mask.
\ The input value must be in low bits.
\ The mask must be nonzero and contiguous.
fun: .comp_emit_bit_mask_set { inp src mask -- err }
  .comp_alloc_next_reg { shift }
  src   src   mask  .asm_bic     .comp_instr \ bic Xd, Xn, Xm
  shift mask        .asm_rbit    .comp_instr \ rbit Xd, Xn
  shift shift       .asm_clz     .comp_instr \ clz Xd, Xn
  inp   inp   shift .asm_lsl_reg .comp_instr \ lsl Xd, Xn, Xm
  inp   inp   mask  .asm_and_reg .comp_instr \ and Xd, Xn, Xm
  inp   inp   src   .asm_orr_reg .comp_instr \ orr Xd, Xn, Xm
end

fun_comp: .bit_mask_set { -- err }
  3 nil .comp_args_min
  .comp_args_get .dec { mask }
  mask .dec { src }
  src .dec { inp }
  inp .comp_realloc_reg
  src .comp_realloc_reg
  mask .comp_realloc_reg
  inp src mask .comp_emit_bit_mask_set
  inp .inc .comp_args_set
end

fun: .bit_mask_set { inp src mask -> out } .bit_mask_set end

8 let: CELL

