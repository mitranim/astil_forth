4 1 extern: vsnprintf ( buf cap fmt vlist … -- len|err )

fun: eputchar { char -- -1 } char stderr fputc              end \ Symmetry with `putchar`.
fun: logc     { char }       char putchar            { -- } end \ Renamed from `emit`.
fun: elogc    { char }       char stderr fputc       { -- } end
fun: log      { cstr }       cstr stdout fputs       { -- } end
fun: elog     { cstr }       cstr stderr fputs       { -- } end
fun: logs     { str len }    str 1 len stdout fwrite { -- } end \ Renamed from `type`.
fun: elogs    { str len }    str 1 len stderr fwrite { -- } end
