fun: cf_cmp_fold2_or_call { raw_xt fallback rhs_cond -- err }
  .cf_args_fold2 { reg0 reg1 imm0 imm1 _known consumed }

  if consumed 2 = .then
    imm0 imm1 raw_xt .sym_instr .call [ 1 .comp_args_set ] { bool }
    reg0 bool .cf_fold_done .ret
  end

  reg0 reg1 imm1 consumed rhs_cond
  instr' cf_cmp_validate instr' cf_emit_cmp_imm_cset fallback
  .cf_fold2_partial_or_fallback
end

