1 .try_all
fun_comp: \ { -- err } 10 .read_until_char { -- } .read_char { -- } end
fun_comp: ( { -- err } 41 .read_until_char { -- } .read_char { -- } end

\ Can use comments now!
\
\ This file boostraps the Forth language. The outer interpreter / compiler
\ provides only the most fundamental intrinsics; enough for self-assembly.
\ We define basic words in terms of machine instructions, building up from
\ there. Currently only the Arm64 CPU architecture is supported.
\
\ The compiler and language come in two variants: stack-CC and register-CC.
\ This file uses the native register-based calling convention. See adjacent
\ file `./lang_s.af` for the stack-based calling convention.

\ brk 666
fun: abort [ 0b110_101_00_001_0000001010011010_000_00 .comp_instr ] end
fun: unreachable .abort end
fun: nop end

\ ## Compilation-related words
\
\ These words are used for metaprogramming and mostly rely on
\ compiler intrinsics. We define them first to be able to use
\ constants via `let:`.
\
\ Unlike in standard Forth, we use separate wordlists for
\ regular and compile-time / immediate words. As a result,
\ we have to define parsing words like "compile" in pairs:
\ one tick seeks in the regular wordlist, and double tick
\ seeks in the compile-time wordlist.

\ Finds an extern symbol by name and declares it as a function.
fun: extern: { inp_len out_len -- err } ( C: "name" -- ) ( E: …inps -- …outs )
  .read_word inp_len out_len .extern_fun
end

\ Non-immediate replacement for standard `literal`.
fun: comp_push { val -- err } ( E: -- val )
  .comp_alloc_next_reg { reg }
  val reg .comp_load
end

fun: next_word { wlist -- XT err } ( "word" -- XT )
  .read_word wlist .find_word
end

\ "XT" is short for "execution token".
\ `xt'` is renamed from standard `'`.
\ Each execution token is a `Sym*`.
fun: xt_next { wlist -> err } ( "word" -- ) ( E: -- XT )
  .next_word .comp_push
end

fun: xt'  { -- XT err } ( "word" -- ) 1 .next_word end \ WORDLIST_EXEC
fun: xt'' { -- XT err } ( "word" -- ) 2 .next_word end \ WORDLIST_COMP

fun_comp: xt'  { -- err } ( E: -- XT ) ( C: "word" -- ) 1 .xt_next end \ WORDLIST_EXEC
fun_comp: xt'' { -- err } ( E: -- XT ) ( C: "word" -- ) 2 .xt_next end \ WORDLIST_COMP

fun: inline_next { wlist -> err } ( "word" -- ) ( E: <word> )
  .next_word .inline_word
end

fun_comp: inline'  { -- err } 1 .inline_next end
fun_comp: inline'' { -- err } 2 .inline_next end

\ `call_xt` is renamed from standard "postpone".
\ Also see `call` for raw instruction addresses.
fun: call_xt_next { wlist -> err } ( "word" -- ) ( E: <word> )
  .next_word .comp_call
end

fun_comp: call_xt'  { -- err } 1 .call_xt_next end
fun_comp: call_xt'' { -- err } 2 .call_xt_next end

fun: compile_next { wlist -> err } ( "word" -- )
  .next_word .comp_push xt' comp_call .comp_call
end

fun_comp: compile'  { -- err } 1 .compile_next end
fun_comp: compile'' { -- err } 2 .compile_next end

\ Similar to standard `constant`.
fun: let: { val -- err } ( C: "name" -- ) ( E: -- val )
  .read_word { str len }

  \ Execution-time semantics.
  str len .define_fun .plain_call
    0 1 0 .comp_signature_set ( -- val )
    val .comp_push
  call_xt'' end

  \ Compile-time semantics.
  str len .define_fun_comp .plain_call
    0 1 1 .comp_signature_set ( -- err )
    val .comp_push compile' comp_push
  call_xt'' end
  [ 0 .comp_only ]
end

0 let: nil
0 let: false
1 let: true

1 let: WORDLIST_EXEC
2 let: WORDLIST_COMP

\ ## Assembler and bitwise ops
\
\ We interleave definitions of assembler words with definitions
\ of various arithmetic words used by the assembler.

4      let: ASM_INSTR_SIZE
8      let: ASM_PARAM_LEN_MAX
16     let: ASM_ARG_LEN_MAX
29     let: ASM_REG_FP
30     let: ASM_REG_LR
31     let: ASM_REG_SP
31     let: ASM_REG_ZR
4095   let: ASM_MAX_IMM12 \ Shared by many instructions.
0b0000 let: ASM_EQ
0b0001 let: ASM_NE
0b0010 let: ASM_CS
0b0010 let: ASM_HS
0b0011 let: ASM_CC
0b0011 let: ASM_LO
0b0100 let: ASM_MI
0b0101 let: ASM_PL
0b0110 let: ASM_VS
0b0111 let: ASM_VC
0b1000 let: ASM_HI
0b1001 let: ASM_LS
0b1010 let: ASM_GE
0b1011 let: ASM_LT
0b1100 let: ASM_GT
0b1101 let: ASM_LE
0b1110 let: ASM_AL
0b1111 let: ASM_NV
666    let: ASM_PLACEHOLDER

16384 let: PAGE_SIZE

\ SYNC[asm_reg_interp].
fun: ASM_REG_INTERP { -- reg } [ .plain_call ] 28 end

fun_comp: ASM_REG_INTERP { -- err }
  [ .plain_call ]
  true .interp_only
  ASM_REG_INTERP .comp_push
end

\ ## Early arithmetic
\
\ Bitwise ops needed for the early stages of the self-assembler.

fun: comp_out0 { instr -- err }
  0 .comp_realloc_reg
  instr .comp_instr
  1 .comp_args_set
end

fun: comp_out0_2 { instr0 instr1 -- err }
  0 .comp_realloc_reg
  instr0 .comp_instr
  instr1 .comp_instr
  1 .comp_args_set
end

fun: or { i0 i1 -> i2 } [
  0b1_01_01010_00_0_00001_000000_00000_00000 .comp_out0 \ orr x0, x0, x1
] end

fun: and { i0 i1 -> i2 } [
  0b1_00_01010_00_0_00001_000000_00000_00000 .comp_out0 \ and x0, x0, x1
] end

fun: xor { i0 i1 -> i2 } [
  0b1_10_01010_00_0_00001_000000_00000_00000 .comp_out0 \ eor x0, x0, x1
] end

fun: lsl { i0 bits -> i1 } [
  0b1_0_0_11010110_00001_0010_00_00000_00000 .comp_out0 \ lsl x0, x0, x1
] end

fun: lsr { i0 bits -> i1 } [
  0b1_0_0_11010110_00001_0010_01_00000_00000 .comp_out0 \ lsr x0, x0, x1
] end

fun: invert { i0 -> i1 } [
  0b1_01_01010_00_1_00000_000000_11111_00000 .comp_out0 \ mvn x0, x0
] end

fun: negate { i0 -> i1 } [
  0b1_1_0_01011_00_0_00000_000000_11111_00000 .comp_out0 \ neg x0, x0
] end

\ Our parsing rules prevent `1+` or `+1` from being a word name.
fun: inc { i0 -> i1 } [
  0b1_0_0_100010_0_000000000001_00000_00000 .comp_out0 \ add x0, x0, 1
] end

\ Our parsing rules prevent `1-` or `-1` from being a word name.
fun: dec { i0 -> i1 } [
  0b1_1_0_100010_0_000000000001_00000_00000 .comp_out0 \ sub x0, x0, 1
] end

fun: + { i0 i1 -> i2 } [
  0b1_0_0_01011_00_0_00001_000000_00000_00000 .comp_out0 \ add x0, x0, x1
] end

fun: - { i0 i1 -> i2 } [
  0b1_1_0_01011_00_0_00001_000000_00000_00000 .comp_out0 \ sub x0, x0, x1
] end

fun: low_bits   { len     -- bits } 1 len .lsl .dec end
fun: bits_trunc { imm len -- imm  } len .low_bits imm .and end

\ ## Early assembler

\ cmp Xn, #imm12
fun: asm_cmp_imm { Xn imm12 -- instr }
  imm12  10 .lsl { imm12 }
  Xn     5  .lsl
  imm12 .or 0b1_1_1_100010_0_000000000000_00000_11111 .or
end

\ cmp Xn, 0
fun: asm_cmp_zero { Xn -> instr } 0 .asm_cmp_imm end

\ cset Xd, <cond>
0b1_0_0_11010100_11111_0000_0_1_11111_00000 let: ASM_OP_CSET

fun: asm_cset { Xd cond -- instr }
  cond 1 .xor 12 .lsl { cond }
  Xd cond .or ASM_OP_CSET .or
end

\ ccmp Xd, Xm, <nzcv>, <cond>
fun: asm_ccmp_reg { Xn Xm nzcv cond -- instr }
  Xm   16 .lsl { Xm }
  cond 12 .lsl { cond }
  Xn 5 .lsl Xm .or cond .or nzcv .or 0b1_1_1_11010010_00000_0000_0_0_00000_0_0000 .or
end

\ brk #imm16
fun: asm_brk { imm16 -> instr }
  5 .lsl 0b110_101_00_001_0000000000000000_000_00 .or
end

\ ## Early booleans

fun: <>0 { int -> bool } [
  0 .asm_cmp_zero 0 ASM_NE .asm_cset .comp_out0_2 \ cmp x0, 0; cset x0, ne
] end

fun: =0 { int -> bool } [
  0 .asm_cmp_zero 0 ASM_EQ .asm_cset .comp_out0_2 \ cmp x0, 0; cset x0, eq
] end

\ ## Assembler: instruction patterns

\ Arm64 instructions are 32-bit; PC-relative offsets tend
\ to be encoded in packed form: implicitly times 4.
fun: instr_off_pack   { off -> packed } 2 .lsr end
fun: instr_off_unpack { packed -> off } 2 .lsl end

\ Shared by a lot of load and store instructions. 64-bit only.
fun: asm_pattern_load_store_pair { Xt1 Xt2 Xn imm7 -- pattern }
  Xt2 10 .lsl { Xt2 }
  Xn  5  .lsl { Xn }
  imm7 3 .lsr 7 .bits_trunc 15 .lsl Xt1 .or Xt2 .or Xn .or
end

\ Shared by a lot of load and store instructions.
\ Patches the X bits:
\   0b00_000_0_00_00_0_XXXXXXXXX_00_XXXXX_XXXXX
fun: asm_pattern_load_store { Xt Xn imm9 -- instr_mask }
  Xn 5 .lsl { Xn }
  imm9 9 .bits_trunc 12 .lsl Xt .or Xn .or
end

\ Shared by register-offset load and store instructions.
\ `scale` must be 0 or 1; if 1, offset is multiplied by 8.
fun: asm_pattern_load_store_with_register_off { Xt Xn Xm scale -- instr_mask }
  Xn        5  .lsl { Xn }
  Xm        16 .lsl { Xm }
  scale <>0 12 .lsl \ lsl 3
  Xt .or Xn .or Xm .or
end

\ Shared by some integer arithmetic instructions.
fun: asm_pattern_arith_reg { Xd Xn Xm -- instr_mask }
  Xn 5  .lsl { Xn }
  Xm 16 .lsl Xd .or Xn .or
end

\ Shared by some integer arithmetic and load/store instructions.
fun: asm_pattern_arith_imm { Xd Xn imm12 -- instr_mask }
  Xn 5 .lsl { Xn }
  imm12 12 .bits_trunc 10 .lsl Xd .or Xn .or
end

fun: asm_pattern_arith_csel { Xd Xn Xm cond -- instr_mask }
  cond 12 .lsl { cond }
  Xd Xn Xm .asm_pattern_arith_reg cond .or
end

\ `off19` offset is implicitly times 4 and can be negative.
fun: asm_pattern_cmp_branch { Xt off19 -- instr_mask }
  off19 .instr_off_pack 19 .bits_trunc 5 .lsl Xt .or
end

\ `off9` offset is implicitly times 4 and can be negative.
fun: asm_pattern_cmp_branch_cond { Xt off9 cond -- instr_mask }
  off9 .instr_off_pack 9 .bits_trunc 5 .lsl { off9 }
  cond 21 .lsl Xt .or off9 .or
end

\ ## Assembler: memory ops

\ ldp Xt1, Xt2, [Xn, #imm7]!
fun: asm_load_pair_pre { Xt1 Xt2 Xn imm7 -> instr }
  .asm_pattern_load_store_pair 0b10_101_0_011_1_0000000_00000_00000_00000 .or
end

\ ldp Xt1, Xt2, [Xn], #imm7
fun: asm_load_pair_post { Xt1 Xt2 Xn imm7 -> instr }
  .asm_pattern_load_store_pair 0b10_101_0_001_1_0000000_00000_00000_00000 .or
end

\ ldp Xt1, Xt2, [Xn, #imm7]
fun: asm_load_pair_off { Xt1 Xt2 Xn imm7 -> instr }
  .asm_pattern_load_store_pair 0b10_101_0_010_1_0000000_00000_00000_00000 .or
end

\ stp Xt1, Xt2, [Xn, #imm7]!
fun: asm_store_pair_pre { Xt1 Xt2 Xn imm7 -> instr }
  .asm_pattern_load_store_pair 0b10_101_0_011_0_0000000_00000_00000_00000 .or
end

\ stp Xt1, Xt2, [Xn], #imm7
fun: asm_store_pair_post { Xt1 Xt2 Xn imm7 -> instr }
  .asm_pattern_load_store_pair 0b10_101_0_001_0_0000000_00000_00000_00000 .or
end

\ stp Xt1, Xt2, [Xn, #imm7]
fun: asm_store_pair_off { Xt1 Xt2 Xn imm7 -> instr }
  .asm_pattern_load_store_pair 0b10_101_0_010_0_0000000_00000_00000_00000 .or
end

\ ldr Xt, [Xn, #imm9]!
fun: asm_load_pre { Xt Xn imm9 -> instr }
  .asm_pattern_load_store 0b11_111_0_00_01_0_000000000_11_00000_00000 .or
end

\ ldr Xt, [Xn], #imm9
fun: asm_load_post { Xt Xn imm9 -> instr }
  .asm_pattern_load_store 0b11_111_0_00_01_0_000000000_01_00000_00000 .or
end

\ str Xt, [Xn, #imm9]!
fun: asm_store_pre { Xt Xn imm9 -> instr }
  .asm_pattern_load_store 0b11_111_0_00_00_0_000000000_11_00000_00000 .or
end

\ str Xt, [Xn], #imm9
fun: asm_store_post { Xt Xn imm9 -> instr }
  .asm_pattern_load_store 0b11_111_0_00_00_0_000000000_01_00000_00000 .or
end

\ ldur Xt, [Xn, #imm9]
fun: asm_load_unscaled_off { Xt Xn imm9 -> instr }
  .asm_pattern_load_store 0b11_111_0_00_01_0_000000000_00_00000_00000 .or
end

\ stur Xt, [Xn, #imm9]
fun: asm_store_unscaled_off { Xt Xn imm9 -> instr }
  .asm_pattern_load_store 0b11_111_0_00_00_0_000000000_00_00000_00000 .or
end

\ ldr Xt, [Xn, Xm, lsl <scale>]
fun: asm_load_with_register_off { Xt Xn Xm scale -> instr }
  .asm_pattern_load_store_with_register_off
  0b11_111_0_00_01_1_00000_011_0_10_00000_00000 .or
end

\ str Xt, [Xn, Xm, lsl <scale>]
fun: asm_store_with_register_off { Xt Xn Xm scale -> instr }
  .asm_pattern_load_store_with_register_off
  0b11_111_0_00_00_1_00000_011_0_10_00000_00000 .or
end

\ size:
\
\   0b00 -- 8  bit
\   0b01 -- 16 bit
\   0b10 -- 32 bit
\   0b11 -- 64 bit
\
\ opc examples for size = 0b00:
\
\   0b01 -- ldrb  Wt
\   0b11 -- ldrsb Wt
\   0b10 -- ldrsb Xt
\   0b00 -- strb  Wt
\
\ Base instruction variant: "immediate, unsigned offset". The Arm field is
\ scaled by access width: for 64-bit loads, imm12 = 2 means byte offset 16.
fun: asm_load_store_off { Rt Xn imm12 size opc -- instr }
  size 30 .lsl          { size }
  opc  22 .lsl size .or { mask }
  Rt Xn imm12 .asm_pattern_arith_imm
  mask .or 0b00_111_0_01_00_000000000000_00000_00000 .or
end

\ Generic unscaled load/store. Offset is a signed 9-bit byte offset.
fun: asm_load_store_unscaled_off { Rt Xn imm9 size opc -- instr }
  size 30 .lsl          { size }
  opc  22 .lsl size .or { mask }
  Rt Xn imm9 .asm_pattern_load_store
  mask .or 0b00_111_0_00_00_0_000000000_00_00000_00000 .or
end

\ Unsigned 8-bit.
\
\ ldrb Wt, [Xn, imm12]
fun: asm_load_off_u8 { Wt Xn imm12 -> instr } 0b00 0b01 .asm_load_store_off end

\ Signed 8-bit.
\
\ ldrsb Xt, [Xn, imm12]
fun: asm_load_off_s8 { Xt Xn imm12 -> instr } 0b00 0b10 .asm_load_store_off end

\ Either unsigned or signed 8-bit.
\
\ strb Wt, [Xn, imm12]
fun: asm_store_off_u8 { Wt Xn imm12 -> instr } 0b00 0b00 .asm_load_store_off end

\ ldrh Wt, [Xn, imm12]
fun: asm_load_off_u16 { Wt Xn imm12 -> instr } 0b01 0b01 .asm_load_store_off end

\ ldrsh Xt, [Xn, imm12]
fun: asm_load_off_s16 { Xt Xn imm12 -> instr } 0b01 0b10 .asm_load_store_off end

\ strh Wt, [Xn, imm12]
fun: asm_store_off_u16 { Wt Xn imm12 -> instr } 0b01 0b00 .asm_load_store_off end

\ ldr Wt, [Xn, imm12]
fun: asm_load_off_u32 { Wt Xn imm12 -> instr } 0b10 0b01 .asm_load_store_off end

\ ldrsw Xt, [Xn, imm12]
fun: asm_load_off_s32 { Xt Xn imm12 -> instr } 0b10 0b10 .asm_load_store_off end

\ str Wt, [Xn, imm12]
fun: asm_store_off_u32 { Wt Xn imm12 -> instr } 0b10 0b00 .asm_load_store_off end

\ ldr Xt, [Xn, imm12]
fun: asm_load_off { Xt Xn imm12 -> instr } 0b11 0b01 .asm_load_store_off end

\ str Xt, [Xn, imm12]
fun: asm_store_off { Xt Xn imm12 -> instr } 0b11 0b00 .asm_load_store_off end

\ neg Xd, Xd
fun: asm_neg { Xd -> instr }
  16 .lsl Xd .or 0b1_1_0_01011_00_0_00000_000000_11111_00000 .or
end

\ add Xd, Xn, #imm12
0b1_0_0_100010_0_000000000000_00000_00000 let: ASM_OP_ADD_IMM

\ add Xd, Xn, Xm
0b1_0_0_01011_00_0_00000_000000_00000_00000 let: ASM_OP_ADD_REG
fun: asm_add_reg { Xd Xn Xm -> instr }
  .asm_pattern_arith_reg ASM_OP_ADD_REG .or
end

\ adds Xd, Xn, Xm
fun: asm_adds_reg { Xd Xn Xm -> instr }
  .asm_add_reg 0b0_0_1_00000000000000000000000000000 .or
end

\ sub Xd, Xn, #imm12
0b1_1_0_100010_0_000000000000_00000_00000 let: ASM_OP_SUB_IMM
fun: asm_addsub_imm { Xd Xn imm12 imm add -- instr }
  \ Select `add` when `(imm >= 0) == add`, else `sub`.
  imm 63 .lsr add .xor .negate { sel }
  ASM_OP_ADD_IMM ASM_OP_SUB_IMM .xor sel .and ASM_OP_SUB_IMM .xor { op }
  Xd Xn imm12 .asm_pattern_arith_imm op .or
end

fun: asm_add_imm { Xd Xn imm12 -> instr } imm12 true  .asm_addsub_imm end
fun: asm_sub_imm { Xd Xn imm12 -> instr } imm12 false .asm_addsub_imm end

\ sub Xd, Xn, Xm
0b1_1_0_01011_00_0_00000_000000_00000_00000 let: ASM_OP_SUB_REG
fun: asm_sub_reg { Xd Xn Xm -> instr }
  .asm_pattern_arith_reg ASM_OP_SUB_REG .or
end

\ subs Xd, Xn, #imm12
fun: asm_subs_imm { Xd Xn imm12 -> instr }
  .asm_sub_imm 0b0_0_1_00000000000000000000000000000 .or
end

\ subs Xd, Xn, Xm
fun: asm_subs_reg { Xd Xn Xm -> instr }
  .asm_sub_reg 0b0_0_1_00000000000000000000000000000 .or
end

\ sub Xd, Xn, Xm, lsl 3
fun: asm_sub_reg_words { Xd Xn Xm -> instr }
  .asm_sub_reg 0b0_0_0_00000_00_0_00000_000011_00000_00000 .or
end

\ orr Xd, Xn, Xm
0b1_01_01010_00_0_00000_000000_00000_00000 let: ASM_OP_ORR_REG
fun: asm_orr_reg { Xd Xn Xm -> instr }
  .asm_pattern_arith_reg ASM_OP_ORR_REG .or
end

\ eor Xd, Xn, Xm
0b1_10_01010_00_0_00000_000000_00000_00000 let: ASM_OP_EOR_REG
fun: asm_eor_reg { Xd Xn Xm -> instr }
  .asm_pattern_arith_reg ASM_OP_EOR_REG .or
end

\ and Xd, Xn, Xm
0b1_00_01010_00_0_00000_000000_00000_00000 let: ASM_OP_AND_REG
fun: asm_and_reg { Xd Xn Xm -> instr }
  .asm_pattern_arith_reg ASM_OP_AND_REG .or
end

\ bic Xd, Xn, Xm
0b1_00_01010_00_1_00000_000000_00000_00000 let: ASM_OP_BIC_REG
fun: asm_bic { Xd Xn Xm -> instr }
  .asm_pattern_arith_reg ASM_OP_BIC_REG .or
end

\ mul Xd, Xn, Xm
0b1_00_11011_000_00000_0_11111_00000_00000 let: ASM_OP_MUL_REG
fun: asm_mul { Xd Xn Xm -> instr }
  .asm_pattern_arith_reg ASM_OP_MUL_REG .or
end

\ udiv Xd, Xn, Xm
0b1_0_0_11010110_00000_00001_0_00000_00000 let: ASM_OP_UDIV_REG
fun: asm_udiv { Xd Xn Xm -> instr }
  .asm_pattern_arith_reg ASM_OP_UDIV_REG .or
end

\ sdiv Xd, Xn, Xm
0b1_0_0_11010110_00000_00001_1_00000_00000 let: ASM_OP_SDIV_REG
fun: asm_sdiv { Xd Xn Xm -> instr }
  .asm_pattern_arith_reg ASM_OP_SDIV_REG .or
end

\ msub Xd, Xn, Xm, Xa
fun: asm_msub { Xd Xn Xm Xa -- instr }
  Xn  5 .lsl { Xn }
  Xm 16 .lsl { Xm }
  Xa 10 .lsl
  Xd .or Xn .or Xm .or
  0b1_00_11011_000_00000_1_00000_00000_00000 .or
end

\ csel Xd, Xn, Xm, <cond>
fun: asm_csel { Xd Xn Xm cond -> instr }
  .asm_pattern_arith_csel 0b1_0_0_11010100_00000_0000_0_0_00000_00000 .or
end

\ csneg Xd, Xn, Xm, <cond>
fun: asm_csneg { Xd Xn Xm cond -> instr }
  .asm_pattern_arith_csel 0b1_1_0_11010100_00000_0000_0_1_00000_00000 .or
end

0b1_00_100110_1_000000_000000_00000_00000 let: ASM_OP_SBFM
0b1_10_100110_1_000000_000000_00000_00000 let: ASM_OP_UBFM

fun: asm_bitfield { Xd Xn immr imms op -- instr }
  imms 10 .lsl { imms }
  immr 16 .lsl { immr }
  Xn   5  .lsl { Xn }
  Xd Xn .or immr .or imms .or op .or
end

\ asr Xd, Xn, #imm6
fun: asm_asr_imm { Xd Xn imm6 -- instr }
  imm6 6 .bits_trunc { immr }
  Xd Xn immr 63 ASM_OP_SBFM .asm_bitfield
end

\ asr Xd, Xn, Xm
0b1_0_0_11010110_00000_0010_10_00000_00000 let: ASM_OP_ASR_REG
fun: asm_asr_reg { Xd Xn Xm -> instr }
  .asm_pattern_arith_reg ASM_OP_ASR_REG .or
end

\ Arithmetic (sign-preserving) right shift.
fun: asr { i0 bits -> i1 } [ 0 0 1 .asm_asr_reg .comp_out0 ] end \ asr x0, x0, x1

\ lsl Xd, Xn, Xm
0b1_0_0_11010110_00000_0010_00_00000_00000 let: ASM_OP_LSL_REG
fun: asm_lsl_reg { Xd Xn Xm -> instr }
  .asm_pattern_arith_reg ASM_OP_LSL_REG .or
end

\ lsl Xd, Xn, #imm6
fun: asm_lsl_imm { Xd Xn imm6 -- instr }
  64 imm6 - 6 .bits_trunc { immr }
  63 imm6 - 6 .bits_trunc { imms }
  Xd Xn immr imms ASM_OP_UBFM .asm_bitfield
end

\ lsr Xd, Xn, #imm6
fun: asm_lsr_imm { Xd Xn imm6 -- instr }
  imm6 6 .bits_trunc { immr }
  Xd Xn immr 63 ASM_OP_UBFM .asm_bitfield
end

\ lsr Xd, Xn, Xm
0b1_0_0_11010110_00000_0010_01_00000_00000 let: ASM_OP_LSR_REG
fun: asm_lsr_reg { Xd Xn Xm -> instr }
  .asm_pattern_arith_reg ASM_OP_LSR_REG .or
end

\ cmp Xn, Xm
fun: asm_cmp_reg { Xn Xm -- instr }
  Xn  5 .lsl { Xn }
  Xm 16 .lsl Xn .or 0b1_1_1_01011_00_0_00000_000_000_00000_11111 .or
end

\ b <off>
fun: asm_branch { off26 -> instr }
  .instr_off_pack \ Offset is implicitly times 4.
  26 .bits_trunc  \ Offset may be negative.
  0b0_00_101_00000000000000000000000000 .or
end

\ b.<cond> <off>
fun: asm_branch_cond { off19 cond -- instr }
  off19 .instr_off_pack 19 .bits_trunc 5 .lsl
  cond .or 0b010_101_00_0000000000000000000_0_0000 .or
end

fun: asm_cmp_branch { Xt off19 not_zero -- instr }
  not_zero <>0 24 .lsl { op_mask }
  Xt off19 .asm_pattern_cmp_branch op_mask .or
  0b1_011010_0_0000000000000000000_00000 .or
end

\ cbz x1, <off>
fun: asm_cbz { Xt off19 -> instr } 0 .asm_cmp_branch end

\ cbnz x1, <off>
fun: asm_cbnz { Xt off19 -> instr } 1 .asm_cmp_branch end

\ Not supported on M3 Pro.
\ cb.<cond> Xt, #imm6, #off9
fun: asm_cmp_imm_branch { Xt imm6 off9 cond -- instr }
  Xt off9 cond .asm_pattern_cmp_branch_cond { mask }
  imm6 15 .lsl mask .or 0b1_1110101_000_000000_0_000000000_00000 .or
end

\ Not supported on M3 Pro.
\ cb.<cond> Xt, Xm, #off9
fun: asm_cmp_reg_branch { Xt Xm off9 cond -- instr }
  Xt off9 cond .asm_pattern_cmp_branch_cond { mask }
  Xm 16 .lsl mask .or 0b1_1110100_000_00000_00_000000000_00000 .or
end

\ eor Xd, Xd, Xd
fun: asm_zero_reg { Xd -- instr } Xd Xd Xd .asm_eor_reg end

fun: asm_mov_reg { Xd Xm -- instr }
  Xm 16 .lsl Xd .or 0b1_01_01010_00_0_00000_000000_11111_00000 .or
end

\ movn/movz/movk Xd, #imm16, lsl #hw*16
fun: asm_mov_wide { Xd opc hw imm16 -- instr }
  opc   29 .lsl { opc }
  hw    21 .lsl { hw }
  imm16 5  .lsl
  opc      .or
  hw       .or
  Xd       .or
  0b1_00_100101_00_0000000000000000_00000 .or
end

\ Immediate must be unsigned and within range.
fun: asm_mov_imm { Xd imm -- instr } Xd 0b10 0 imm .asm_mov_wide end

\ mvn Xd, Xm
fun: asm_mvn { Xd Xm -- instr }
  Xm 16 .lsl Xd .or 0b1_01_01010_00_1_00000_000000_11111_00000 .or
end

\ clz Xd, Xn
fun: asm_clz { Xd Xn -- instr }
  Xn 5 .lsl Xd .or 0b1_1_0_11010110_00000_00010_0_00000_00000 .or
end

\ Requires Arm64 `FEAT_CSSC`; not supported on M3 Pro.
\ ctz Xd, Xn
fun: asm_ctz { Xd Xn -- instr }
  Xn 5 .lsl Xd .or 0b1_1_0_11010110_00000_000110_00000_00000 .or
end

\ rbit Xd, Xn
fun: asm_rbit { Xd Xn -- instr }
  Xn 5 .lsl Xd .or 0b1_1_0_11010110_00000_00000_0_00000_00000 .or
end

\ TODO: support shift.
fun: asm_tst { Xn Xm -- instr }
  Xm 16 .lsl { Xm }
  Xn 5 .lsl Xm .or 0b1_11_01010_00_0_00000_000000_00000_11111 .or
end

\ `.ret x30`; requires caution with SP / FP.
0b110_101_1_0_0_10_11111_0000_0_0_11110_00000 let: asm_ret

0b110_101_01000000110010_0000_000_11111 let: asm_nop

\ svc 666
0b110_101_00_000_0000001010011010_000_01 let: asm_svc

\ ## Assembler: register selection

fun: comp_args1_reg { -- reg err }
  1 nil .comp_args_min
  .comp_args_get .dec { reg }
  reg .comp_realloc_reg
  reg
end

fun: comp_args2_regs { -- reg0 reg1 err }
  2 nil .comp_args_min
  .comp_args_get .dec { reg1 }
  reg1 .dec { reg0 }
  reg0 .comp_realloc_reg
  reg0 reg1
end

fun: comp_args2_arith_reg { op -- err }
  .comp_args2_regs { reg0 reg1 }
  reg0 reg0 reg1 .asm_pattern_arith_reg op .or .comp_instr \ <op> Xd, Xn, Xm
  reg1 .comp_args_set
end

fun: comp_args2_regs2 { -- reg0 reg1 err }
  .comp_args2_regs { reg0 reg1 }
  reg1 .comp_realloc_reg
  reg0 reg1
end

\ ## Arithmetic continued
\
\ This section adds comptime versions of arithmetic words,
\ which respect the comptime "argument / register stack".
\ In addition, we ensure they all have runtime versions.
\
\ Some runtime redefinitions here are redundant with earlier versions,
\ but tracking the redundancies is effort. Redefining all is easier.

fun_comp: or { -- err } ASM_OP_ORR_REG .comp_args2_arith_reg end

fun: or { i0 i1 -> i2 } [ .redefine ] .or end

fun_comp: and { -- err } ASM_OP_AND_REG .comp_args2_arith_reg end

fun: and { i0 i1 -> i2 } [ .redefine ] .and end

fun_comp: xor { -- err } ASM_OP_EOR_REG .comp_args2_arith_reg end

fun: xor { i0 i1 -> i2 } [ .redefine ] .xor end

fun_comp: lsl { -- err } ASM_OP_LSL_REG .comp_args2_arith_reg end

fun: lsl { i0 bits -> i1 } [ .redefine ] .lsl end

fun_comp: lsr { -- err } ASM_OP_LSR_REG .comp_args2_arith_reg end

fun: lsr { i0 bits -> i1 } [ .redefine ] .lsr end

fun_comp: negate { -- err }
  .comp_args1_reg .asm_neg .comp_instr \ neg Xd, Xn
end

fun: negate { i0 -> i1 } [ .redefine ] .negate end

fun: ?invert { val cond -> out } .negate .xor end

fun_comp: inc { -- err }
  .comp_args1_reg { reg }
  reg reg 1 .asm_add_imm .comp_instr \ add Xd, Xn, #imm12
end

fun: inc { i0 -> i1 } [ .redefine ] .inc end

fun_comp: dec { -- err }
  .comp_args1_reg { reg }
  reg reg 1 .asm_sub_imm .comp_instr \ sub Xd, Xn, #imm12
end

fun: dec { i0 -> i1 } [ .redefine ] .dec end

fun_comp: + { -- err } ASM_OP_ADD_REG .comp_args2_arith_reg end

\ fun: + { i0 i1 -> i2 } [ .redefine ] + end

fun_comp: - { -- err } ASM_OP_SUB_REG .comp_args2_arith_reg end

fun: - { i0 i1 -> i2 } [ .redefine ] - end

fun_comp: * { -- err } ASM_OP_MUL_REG .comp_args2_arith_reg end

fun: * { i0 i1 -> i2 } * end

fun_comp: / { -- err } ASM_OP_SDIV_REG .comp_args2_arith_reg end

fun: / { i0 i1 -> i2 } / end

fun_comp: u/ { -- err } ASM_OP_UDIV_REG .comp_args2_arith_reg end

fun: u/ { i0 i1 -> i2 } u/ end

fun_comp: asr { -- err } ASM_OP_ASR_REG .comp_args2_arith_reg end

fun: asr { i0 bits -> i1 } [ .redefine ] .asr end

fun: comp_emit_mod { out dividend divisor div_op -- err }
  .comp_alloc_next_reg { quotient }
  quotient dividend divisor .asm_pattern_arith_reg div_op .or .comp_instr \ sdiv|udiv Xd, Xn, Xm
  out quotient divisor dividend .asm_msub .comp_instr \ msub Xd, Xn, Xm, Xa
end

fun_comp: mod { -- err }
  .comp_args2_regs { reg0 reg1 }
  reg0 reg0 reg1 ASM_OP_SDIV_REG .comp_emit_mod
  reg1 .comp_args_set
end

fun: mod { i0 i1 -> i2 } .mod end

fun_comp: umod { -- err }
  .comp_args2_regs { reg0 reg1 }
  reg0 reg0 reg1 ASM_OP_UDIV_REG .comp_emit_mod
  reg1 .comp_args_set
end

fun: umod { i0 i1 -> i2 } .umod end

fun: comp_emit_divmod { reg0 reg1 div_op -- tmp err }
  reg0 reg1 reg0 reg1 { rem quo dividend divisor }
  .comp_alloc_next_reg { tmp }
  tmp divisor .asm_mov_reg .comp_instr \ mov Xd, Xm
  quo dividend tmp .asm_pattern_arith_reg div_op .or .comp_instr \ sdiv|udiv Xd, Xn, Xm
  rem quo tmp dividend .asm_msub .comp_instr \ msub Xd, Xn, Xm, Xa
  tmp
end

fun_comp: /mod { -- err }
  .comp_args2_regs2 { rem quo }
  rem quo ASM_OP_SDIV_REG .comp_emit_divmod .comp_args_set
end

fun: /mod { dividend divisor -> rem quo } /mod end

fun_comp: u/mod { -- err }
  .comp_args2_regs2 { rem quo }
  rem quo ASM_OP_UDIV_REG .comp_emit_divmod .comp_args_set
end

fun: u/mod { dividend divisor -> rem quo } u/mod end

fun: comp_emit_abs { reg -- err }
  reg                .asm_cmp_zero .comp_instr \ cmp Xn, #0
  reg reg reg ASM_PL .asm_csneg    .comp_instr \ cneg Xd, Xn, cond
end

fun_comp: abs { -- err } .comp_args1_reg .comp_emit_abs end
fun: abs { int -> +int } .abs end

fun: comp_emit_csel_reg { out cmp_lhs cmp_rhs lhs rhs cond -- err }
  cmp_lhs cmp_rhs  .asm_cmp_reg .comp_instr \ cmp Xn, Xm
  out lhs rhs cond .asm_csel    .comp_instr \ csel Xd, Xn, Xm, cond
end

fun: comp_emit_csel_nonzero { out nonzero zero cond -- err }
  nonzero 0             .asm_cmp_imm .comp_instr \ cmp Xn, #0
  out nonzero zero cond .asm_csel    .comp_instr \ csel Xd, Xn, Xm, cond
end

fun_comp: min { -- err }
  .comp_args2_regs { reg0 reg1 }
  reg0 reg0 reg1 reg0 reg1 ASM_LT .comp_emit_csel_reg
  reg1 .comp_args_set
end

fun: min { i0 i1 -> i0|i1 } .min end

fun_comp: umin { -- err }
  .comp_args2_regs { reg0 reg1 }
  reg0 reg0 reg1 reg0 reg1 ASM_LO .comp_emit_csel_reg
  reg1 .comp_args_set
end

fun: umin { i0 i1 -> i0|i1 } .umin end

fun_comp: max { -- err }
  .comp_args2_regs { reg0 reg1 }
  reg0 reg0 reg1 reg0 reg1 ASM_GT .comp_emit_csel_reg
  reg1 .comp_args_set
end

fun: max { i0 i1 -> i0|i1 } .max end

fun_comp: umax { -- err }
  .comp_args2_regs { reg0 reg1 }
  reg0 reg0 reg1 reg0 reg1 ASM_HI .comp_emit_csel_reg
  reg1 .comp_args_set
end

fun: umax { i0 i1 -> i0|i1 } .umax end

fun_comp: fallback { -- err }
  .comp_args2_regs { reg0 reg1 }
  reg0 reg1 reg0 ASM_NE .comp_emit_csel_nonzero
  reg1 .comp_args_set
end

\ Chooses a non-zero value, preferring the second input.
fun: fallback { one two -> out } .fallback end

fun_comp: is_aligned_to { -- err }
  .comp_args2_regs { reg0 reg1 }
  reg1 reg1 1 .asm_sub_imm .comp_instr \ sub Xd, Xn, 1
  reg0 reg1   .asm_tst     .comp_instr \ tst Xn, Xm
  reg0 ASM_EQ .asm_cset    .comp_instr \ cset Xd, eq
  reg1 .comp_args_set
end

fun: is_aligned_to { adr size -> bool } .is_aligned_to end

fun: comp_emit_align_down { out len wid -- err }
  wid         .asm_neg     .comp_instr \ neg Xd, Xd
  out len wid .asm_and_reg .comp_instr \ and Xd, Xn, Xm
end

fun_comp: align_down { -- err }
  .comp_args2_regs { reg0 reg1 }
  reg0 reg0 reg1 .comp_emit_align_down
  reg1 .comp_args_set
end

fun: align_down { len wid -> len } .align_down end

\ Assumes power of two.
fun_comp: align_up { -- err }
  .comp_args2_regs { reg0 reg1 }
  reg0 reg0 reg1 .asm_add_reg .comp_instr \ add Xd, Xn, Xm
  reg0 reg0 1    .asm_sub_imm .comp_instr \ sub Xd, Xn, #1
  reg0 reg0 reg1 .comp_emit_align_down
  reg1 .comp_args_set
end

fun: align_up { len wid -> len } .align_up end

\ Flip all the bits.
fun_comp: invert { -- err }
  .comp_args1_reg { reg }
  reg reg .asm_mvn .comp_instr \ mvn Xd, Xm
end

fun: invert { i0 -> i1 } [ .redefine ] .invert end

\ 1-based index of the highest bit.
fun: comp_emit_bit_len { reg tmp -- err }
  reg reg     .asm_clz     .comp_instr \ clz Xd, Xn
  64  tmp                  .comp_load  \ mov Xd, #imm
  reg tmp reg .asm_sub_reg .comp_instr \ sub Xd, Xn, Xm
end

fun_comp: bit_len { -- err }
  .comp_args1_reg      { reg }
  .comp_alloc_next_reg { tmp }
  reg tmp .comp_emit_bit_len
  tmp .comp_args_set
end

fun: bit_len { val -> len } .bit_len end

fun: comp_emit_pow2_ceil { reg tmp -- err }
  1 tmp .comp_load
  reg reg tmp reg tmp ASM_HI .comp_emit_csel_reg \ csel Xd, Xn, Xm, hi
  reg reg 1 .asm_sub_imm     .comp_instr         \ sub Xd, Xn, #1
  reg reg .asm_clz           .comp_instr         \ clz Xd, Xn
  reg .asm_neg               .comp_instr         \ neg Xd, Xn
  reg reg 64 .asm_add_imm    .comp_instr         \ add Xd, Xn, #64
  reg tmp reg .asm_lsl_reg   .comp_instr         \ lsl Xd, Xn, Xm
end

fun_comp: pow2_ceil { -- err }
  .comp_args1_reg      { reg }
  .comp_alloc_next_reg { tmp }
  reg tmp .comp_emit_pow2_ceil
  reg .inc .comp_args_set
end

fun: pow2_ceil { val -- pow2 } 1 val 1 .umax .dec .bit_len .lsl end

\ "count leading zeros" (in high bits)
fun_comp: bit_clz { -- err }
  .comp_args1_reg { reg }
  reg reg .asm_clz .comp_instr \ clz Xd, Xn
end

fun: bit_clz { num -> bool } .bit_clz end

\ "count trailing zeros" (in low bits)
\
\ Fallback version of `ctz Xd, Xn` for chips without `ctz`.
fun: comp_emit_bit_ctz { reg -- err }
  reg reg .asm_rbit .comp_instr \ rbit Xd, Xn
  reg reg .asm_clz  .comp_instr \ clz Xd, Xd
end

fun_comp: bit_ctz { -- err } .comp_args1_reg .comp_emit_bit_ctz end
fun: bit_ctz { num -> bool } .bit_ctz end

fun: comp_emit_low_bits { reg tmp -- err }
  1 tmp .comp_load
  tmp tmp reg .asm_lsl_reg .comp_instr \ lsl Xt, Xt, Xn
  reg tmp 1 .asm_sub_imm .comp_instr   \ sub Xn, Xt, #1
end

fun_comp: low_bits { -- err }
  .comp_args1_reg        { reg }
  .comp_alloc_next_reg   { tmp }
  reg tmp .comp_emit_low_bits
  reg .inc .comp_args_set
end

fun: low_bits { len -> bits } [ .redefine ] .low_bits end

fun_comp: bits_trunc { -- err }
  .comp_args2_regs     { imm len }
  .comp_alloc_next_reg { tmp }
  1 tmp .comp_load
  tmp tmp len .asm_lsl_reg .comp_instr \ lsl Xt, Xt, Xlen
  tmp tmp 1   .asm_sub_imm .comp_instr \ sub Xt, Xt, #1
  imm imm tmp .asm_and_reg .comp_instr \ and Xd, Xn, Xm
  len .comp_args_set
end

fun: bits_trunc { imm len -> imm } [ .redefine ] .bits_trunc end

fun_comp: bits_clear { -- err }
  .comp_args2_regs { imm mask }
  imm imm mask .asm_bic .comp_instr \ bic Ximm, Ximm, Xmask
  mask .comp_args_set
end

fun: bits_clear { imm mask -> out } .bits_clear end

fun_comp: bit_mask_get { -- err }
  .comp_args2_regs { reg0 reg1 }
  \ Get bits according to a nonzero contiguous mask and return them in low bits.
  reg0 reg0 reg1 .asm_and_reg .comp_instr \ and Xd, Xn, Xm
  reg1 reg1      .asm_rbit    .comp_instr \ rbit Xd, Xn
  reg1 reg1      .asm_clz     .comp_instr \ clz Xd, Xn
  reg0 reg0 reg1 .asm_lsr_reg .comp_instr \ lsr Xd, Xn, Xm
  reg1 .comp_args_set
end

fun: bit_mask_get { src mask -> out } .bit_mask_get end

\ Sets bits according to the mask.
\ The input value must be in low bits.
\ The mask must be nonzero and contiguous.
fun: comp_emit_bit_mask_set { inp src mask -- err }
  .comp_alloc_next_reg { shift }
  src   src   mask  .asm_bic     .comp_instr \ bic Xd, Xn, Xm
  shift mask        .asm_rbit    .comp_instr \ rbit Xd, Xn
  shift shift       .asm_clz     .comp_instr \ clz Xd, Xn
  inp   inp   shift .asm_lsl_reg .comp_instr \ lsl Xd, Xn, Xm
  inp   inp   mask  .asm_and_reg .comp_instr \ and Xd, Xn, Xm
  inp   inp   src   .asm_orr_reg .comp_instr \ orr Xd, Xn, Xm
end

fun_comp: bit_mask_set { -- err }
  3 nil .comp_args_min
  .comp_args_get .dec { mask }
  mask .dec { src }
  src .dec { inp }
  inp .comp_realloc_reg
  src .comp_realloc_reg
  mask .comp_realloc_reg
  inp src mask .comp_emit_bit_mask_set
  inp .inc .comp_args_set
end

fun: bit_mask_set { inp src mask -> out } .bit_mask_set end

8 let: CELL

fun_comp: cells { -- err }
  .comp_args1_reg { reg }
  reg reg 3 .asm_lsl_imm .comp_instr \ lsl Xd, Xd, #shift
end

fun: cells { len -> size } .cells end

fun_comp: /cells { -- err }
  .comp_args1_reg { reg }
  reg reg 3 .asm_asr_imm .comp_instr \ asr Xd, Xd, #shift
end

fun: /cells { size -> len } /cells end

fun_comp: +cell { -- err }
  .comp_args1_reg { reg }
  reg reg CELL .asm_add_imm .comp_instr \ add Xd, Xn, #imm12
end

fun: +cell { adr -> adr } +cell end

fun_comp: -cell { -- err }
  .comp_args1_reg { reg }
  reg reg CELL .asm_sub_imm .comp_instr \ sub Xd, Xn, #imm12
end

fun: -cell { adr -> adr } -cell end

\ ## Assembler continued

\ tbz Xt, #bit, #imm14
fun: asm_test_bit_branch_zero { Xt bit imm14 -- instr }
  imm14 .instr_off_pack 14 .bits_trunc 5 .lsl { imm14 }
  bit 5 .lsr 31 .lsl { b5 }
  bit 5 .bits_trunc 19 .lsl \ b40
  Xt .or imm14 .or b5 .or
  0b0_01_101_1_0_00000_00000000000000_00000 .or
end

\ adr Xd, #imm21
fun: asm_adr { Xd imm21 -- instr }
  imm21 0b11 .and { low }
  imm21 .instr_off_pack 19 .bits_trunc 5 .lsl { high }
  high low .or Xd .or
  0b0_00_100_00_0000000000000000000_00000 .or
end

fun: asm_branch_to_reg { Xn -> instr }
  5 .lsl 0b110_101_1_0_0_00_11111_0000_0_0_00000_00000 .or \ br Xn
end

\ bl imm26
\
\ Requires caution to avoid messing up the link register.
fun: asm_branch_link_off { imm26 -> instr }
  .instr_off_pack 26 .bits_trunc
  0b100_101_00000000000000000000000000 .or
end

\ Requires caution to avoid messing up the link register.
fun: asm_branch_link_reg { Xn -> instr }
  5 .lsl 0b110_101_1_0_0_01_11111_0000_0_0_00000_00000 .or \ blr Xn
end

\ orr Xd, Xn, #(1 << bit)
fun: asm_orr_bit { Xd Xn bit -- instr }
  64 bit - 16 .lsl { immr }
  Xn 5 .lsl
  Xd .or immr .or
  0b1_01_100100_1_000000_000000_00000_00000 .or
end

fun: comp_emit_cmp_cset_reg { out lhs rhs cond -- err }
  lhs rhs  .asm_cmp_reg .comp_instr \ cmp Xn, Xm
  out cond .asm_cset    .comp_instr \ cset Xd, cond
end

fun: comp_emit_cset_zero { reg cond -- err }
  reg      .asm_cmp_zero .comp_instr \ cmp Xn, #0
  reg cond .asm_cset     .comp_instr \ cset Xd, cond
end

fun: asm_comp_cset_reg { cond -- err } ( E: i0 i1 -- bool )
  .comp_args2_regs { reg0 reg1 }
  reg0 reg0 reg1 cond .comp_emit_cmp_cset_reg
  reg1 .comp_args_set
end

fun: asm_comp_cset_zero { cond -- err } ( E: num -- bool )
  .comp_args1_reg cond .comp_emit_cset_zero
end

\ sbfm Xd, Xn, immr, imms
fun: asm_bitfield_move { Xd Xn immr imms -- instr }
  Xd Xn immr imms ASM_OP_SBFM .asm_bitfield
end

\ sxtw Xd, Xn | sbfm Xd, Xn, 0, 31
fun: asm_sign_extend_32 { Xd Xn -> instr } 0 31 .asm_bitfield_move end

\ Since we don't have a real type system, the compiler
\ doesn't support automatically sign-extending integers
\ when converting between types. Sometimes it has to be
\ done manually, particularly when dealing with C words
\ which return `(int)-1` which ends up being 0xffffffff.
fun_comp: int_to_cell { -- err }
  .comp_args1_reg { reg }
  reg reg .asm_sign_extend_32 .comp_instr \ sxtw Xd, Wn
end

fun: int_to_cell { int32 -> cell } .int_to_cell end

\ ## Numeric comparison

\ https://gforth.org/manual/Numeric-comparison.html
fun_comp: =0  {       -- err  } ASM_EQ .asm_comp_cset_zero end
fun:      =0  { int   -> bool } [ .redefine ] =0           end
fun_comp: <>0 {       -- err  } ASM_NE .asm_comp_cset_zero end
fun:      <>0 { int   -> bool } [ .redefine ] <>0          end
fun_comp: =   {       -- err  } ASM_EQ .asm_comp_cset_reg  end
fun:      =   { i0 i1 -> bool } =                          end
fun_comp: <>  {       -- err  } ASM_NE .asm_comp_cset_reg  end
fun:      <>  { i0 i1 -> bool } <>                         end
fun_comp: >   {       -- err  } ASM_GT .asm_comp_cset_reg  end
fun:      >   { i0 i1 -> bool } >                          end
fun_comp: <   {       -- err  } ASM_LT .asm_comp_cset_reg  end
fun:      <   { i0 i1 -> bool } <                          end
fun_comp: <=  {       -- err  } ASM_LE .asm_comp_cset_reg  end
fun:      <=  { i0 i1 -> bool } <=                         end
fun_comp: >=  {       -- err  } ASM_GE .asm_comp_cset_reg  end
fun:      >=  { i0 i1 -> bool } >=                         end
fun_comp: u>  {       -- err  } ASM_HI .asm_comp_cset_reg  end
fun:      u>  { i0 i1 -> bool } u>                         end
fun_comp: u<  {       -- err  } ASM_LO .asm_comp_cset_reg  end
fun:      u<  { i0 i1 -> bool } u<                         end
fun_comp: u<= {       -- err  } ASM_LS .asm_comp_cset_reg  end
fun:      u<= { i0 i1 -> bool } u<=                        end
fun_comp: u>= {       -- err  } ASM_HS .asm_comp_cset_reg  end
fun:      u>= { i0 i1 -> bool } u>=                        end
fun_comp: <0  {       -- err  } ASM_LT .asm_comp_cset_zero end \ Or `MI`.
fun:      <0  { num   -> bool } <0                         end
fun_comp: >0  {       -- err  } ASM_GT .asm_comp_cset_zero end
fun:      >0  { num   -> bool } >0                         end
fun_comp: <=0 {       -- err  } ASM_LE .asm_comp_cset_zero end
fun:      <=0 { num   -> bool } <=0                        end
fun_comp: >=0 {       -- err  } ASM_GE .asm_comp_cset_zero end \ Or `PL`.
fun:      >=0 { num   -> bool } >=0                        end

\ Non-standard and sane: no wraparound semantics.
fun: within  { num floor ceil -- bool } num floor  >= num ceil  < .and end
fun: uwithin { num floor ceil -- bool } num floor u>= num ceil u< .and end

\ ## Memory load / store

\ Loads replace the latest argument, which should be an address, with a value.
\ Like arithmetic words, they respect the argument stack, preserving the other
\ prior arguments.
fun: comp_mem_load { size opc -- err }
  1 nil .comp_args_min
  .comp_args_get .dec { reg }
  reg .comp_realloc_reg
  \ ldr<size> <reg>, [<reg>]
  reg reg 0 size opc .asm_load_store_off .comp_instr
end

\ Generically defines a load word for the given size / type.
fun: load: { size opc -- err } ( C: "name" -- )  ( E: adr -- val )
  .read_word { str len }

  \ Execution-time semantics.
  str len .define_fun
    1 1 false .comp_signature_set ( E: adr -- val )
    0 .comp_realloc_reg
    0 0 0 size opc .asm_load_store_off .comp_instr \ ldr<size> r0, [x0]
    1 .comp_args_set
  call_xt'' end

  \ Compile-time semantics.
  str len .define_fun_comp
    0 1 true .comp_signature_set
    size     .comp_push
    opc      .comp_push
    compile' comp_mem_load
  call_xt'' end

  [ false .comp_only ]
end

\ Generically defines a store word for the given size / type.
\ Execution-time semantics only. The compiler always inlines.
fun: store: { size -- err } ( C: "name" -- ) ( E: val adr -- )
  .read_word .define_fun
    2 0 false .comp_signature_set
    \ str<size> r0, [x1]
    0 1 0 size 0b00 .asm_load_store_off .comp_instr
  call_xt'' end

  [ false .comp_only ]
end

0b00 0b01 load:  @u8 \ Renamed from standard `c@`.
0b00 0b10 load:  @s8
0b00      store: !8  \ Renamed from standard `c!`.

\ Byte load/store; aliases for `@u8` and `!8`.
0b00 0b01 load:  @b \ Renamed from standard `c@`.
0b00      store: !b \ Renamed from standard `c!`.

0b01 0b01 load:  @u16
0b01 0b10 load:  @s16
0b01      store: !16

0b10 0b01 load:  @u32
0b10 0b10 load:  @s32
0b10      store: !32

0b11 0b01 load:  @
0b11      store: !

\ Aliases for some C types, so the user
\ doesn't have to remember their width.

\ 32 bit
0b10 0b10 load:  @cint
0b10      store: !cint

\ 32 bit
0b10 0b01 load:  @cuint
0b10      store: !cuint

\ 64 bit (Apple ABI)
0b11 0b01 load:  @clong
0b11      store: !clong

\ 64 bit (Apple ABI)
0b11 0b01 load:  @culong
0b11      store: !culong

fun_comp: @2 { -- err }
  1 nil .comp_args_min
  .comp_args_get .dec { adr }
  adr .inc { val1 }
  adr  .comp_realloc_reg
  val1 .comp_realloc_reg
  adr val1 adr 0 .asm_load_pair_off .comp_instr \ ldp Xt1, Xt2, [Xn]
  val1 .inc .comp_args_set
end

fun: @2 { adr -> val0 val1 } @2 end

fun_comp: @@2 { -- err }
  .comp_args2_regs2 { reg0 reg1 }
  reg0 reg0 0 .asm_load_off .comp_instr \ ldr Xt, [Xn]
  reg1 reg1 0 .asm_load_off .comp_instr \ ldr Xt, [Xn]
end

fun: @@2 { adr0 adr1 -> val0 val1 } @@2 end

fun_comp: !2 { -- err }
  .comp_args_get .dec { adr }
  adr .dec { val1 }
  val1 .dec { val0 }
  val0 val1 adr 0 .asm_store_pair_off .comp_instr \ stp Xt1, Xt2, [Xn]
  val0 .comp_args_set
end

fun: !2 { val0 val1 adr -> } !2 end

fun_comp: !swap { -- err }
  .comp_args_get .dec { adr }
  adr .dec { val1 }
  val1 .dec { val0 }
  val1 val0 adr 0 .asm_store_pair_off .comp_instr \ stp Xt2, Xt1, [Xn]
  val0 .comp_args_set
end

fun: !swap { val0 val1 adr -> } !swap end

fun_comp: @at { -- err }
  .comp_args_get .dec { off }
  off .dec { adr }
  adr adr off 0 .asm_load_with_register_off .comp_instr \ ldr Xt, [Xn, Xm]
  off .comp_args_set
end

fun: @at { adr off -> val } @at end

fun_comp: !at { -- err }
  .comp_args_get .dec { off }
  off .dec { adr }
  adr .dec { val }
  val adr off 0 .asm_store_with_register_off .comp_instr \ str Xt, [Xn, Xm]
  val .comp_args_set
end

fun: !at { val adr off -> } !at end

fun: off! { adr } false adr ! end
fun: on!  { adr } true  adr ! end

\ Shortcut for allocating a cell-sized slot on the system stack via `alloca`.
fun_comp: slot { -- err } ( E: -- adr ) call_xt'' CELL call_xt'' alloca end

\ Shortcut for stack-allocating a slot and immediately setting a value.
\ Replaces the need for taking references to locals we had before.
fun_comp: >slot { -- err } ( E: val -- adr )
  call_xt'' slot
  compile'  !
  0 .comp_realloc_reg
  0 1 .asm_mov_reg .comp_instr \ mov x0, x1
  1 .comp_args_set
end

\ ## Stacks
\
\ This section defines operations on integer / cell stacks like the one
\ provided by the outer interpreter. We also allocate additional stacks
\ for auxiliary control information, such as `LOOP_AUX`.
\
\ Each stack is represented with an address of the struct below.
\ The definition matches `Stack` in our C code. The default data
\ stack provided by the interpreter is one of these. We hardcode
\ the offsets below, because `struct:` is not yet available.
\
\   \ SYNC[stack_field_offsets].
\   struct: Stack
\     Cell 1 field: Stack_bytelen \ Total size with guards.
\     Adr  1 field: Stack_cellar  \ Lower guard.
\     Adr  1 field: Stack_floor   \ First data cell.
\     Adr  1 field: Stack_top     \ Next data cell.
\     Adr  1 field: Stack_ceil    \ After last data cell.
\   end
\
\ See `stack_init` for guarded allocation via memory mapping.
\ A stack can also be allocated without guards if so desired.
\
\ The stack operations below have somewhat suboptimal performance.
\ They're meant primarily for control frames, used in compilation
\ and testing.
\
\ Because the interpreter's stack is accessible on the interpreter object,
\ we get away with not having to reserve any special registers for stacks.
\
\ The default stack is available ONLY in interpreted and JIT-compiled code.
\ AOT-compiled executables do not have the Forth interpreter or data stack.
\
\ All our stacks are empty-ascending.

\ SYNC[stack_field_offsets].
16 let: STACK_OFF_FLOOR
24 let: STACK_OFF_TOP
32 let: STACK_OFF_CEIL
40 let: STACK_SIZE

\ Default Forth stack provided by the interpreter.
\ Not available when running in AOT-compiled mode.
\
\ SYNC[interp_fields].
fun_comp: STACK { -- err } ( E: -- adr )
  [ .plain_call ]
  \ mov <arg>, x28
  .comp_alloc_next_reg ASM_REG_INTERP .asm_mov_reg .comp_instr
  true .interp_only
end

fun: STACK { -- adr } [ .plain_call ] STACK end

\ Note: `stack_top` is the top EMPTY cell, not a full one.
fun: stack? { stack -> bool  } @ <>0 end

\ ldur <out>, [<stack>, STACK_OFF_TOP]
fun: asm_stack_top_load { out stack -> instr }
  STACK_OFF_TOP .asm_load_unscaled_off
end

\ stur <out>, [<stack>, STACK_OFF_TOP]
fun: asm_stack_top_store { out stack -> instr }
  STACK_OFF_TOP .asm_store_unscaled_off
end

\ Pops a cell from a stack. Usage:
\
\   stack s> { val }
\
\ Mind the backwards order:
\
\   10 stack >s 20 stack >s 30 stack >s
\   stack s> .show \ 30
\   stack s> .show \ 20
\   stack s> .show \ 10
\
\ Also see `stack{` which is more convenient and less error-prone.
fun: s> { _stack -> val } [
  0 .comp_realloc_reg
  1 .comp_realloc_reg
  1 0      .asm_mov_reg         .comp_instr \ mov x1, x0
  0 1      .asm_stack_top_load  .comp_instr \ ldur x0, [x1, STACK_OFF_TOP]
  0 0 CELL .asm_sub_imm         .comp_instr \ sub x0, x0, CELL
  0 1      .asm_stack_top_store .comp_instr \ stur x0, [x1, STACK_OFF_TOP]
  0 0 0    .asm_load_off        .comp_instr \ ldr x0, [x0]
  1 .comp_args_set
] end

\ Pushes a cell to a stack.
fun: >s { _val _stack } [
  2 .comp_realloc_reg
  2 1      .asm_stack_top_load  .comp_instr \ ldur x2, [x1, STACK_OFF_TOP]
  0 2 0    .asm_store_off       .comp_instr \ str x0, [x2]
  2 2 CELL .asm_add_imm         .comp_instr \ add x2, x2, CELL
  2 1      .asm_stack_top_store .comp_instr \ stur x2, [x1, STACK_OFF_TOP]
  0 .comp_args_set
] end

\ ## System stack stuff

fun_comp: systack_ptr { -- err } ( E: -- sp )
  [ .plain_call ]
  \ add <reg>, sp, 0 | mov <reg>, sp
  .comp_alloc_next_reg ASM_REG_SP 0 .asm_add_imm .comp_instr
end

fun: systack_ptr { -- sp } [ .plain_call ] systack_ptr end

fun_comp: sysstack_frame_ptr { -- err } ( E: -- fp )
  [ .plain_call ]
  \ mov <reg>, x29
  .comp_alloc_next_reg ASM_REG_FP .asm_mov_reg .comp_instr
end

fun: sysstack_frame_ptr { -- fp } [ .plain_call ] sysstack_frame_ptr end

\ ## Global variables and buffers

\ Asks for a register and compiles this idiom:
\
\   adrp <reg>, <page>
\   add <reg>, <reg>, <pageoff>
\
\ Used for taking an address of a data entry
\ in the code heap allocated via `.alloc_data`.
fun: comp_next_page_addr { adr -- err } ( E: -- adr )
  .comp_alloc_next_reg { reg }
  adr reg .comp_page_addr
end

fun: init_data_word { name name_len adr -- err }
  name name_len .define_fun .plain_call
    0 1 false .comp_signature_set ( E: -- ptr )
    adr .comp_next_page_addr
  call_xt'' end

  name name_len .define_fun_comp
    .plain_call
    0 1 true .comp_signature_set
    adr .comp_push compile' comp_next_page_addr
  call_xt'' end

  [ false .comp_only ]
end

\ Similar to standard `variable`, but takes an initial value like `let:`.
fun: var: { val -- err } ( C: "name" -- ) ( E: -- ptr )
  nil CELL .alloc_data { adr }
  val adr !
  .read_word adr .init_data_word
end

\ Shortcut for the standard idiom `create <name> N allot`.
\ Unlike the standard idiom, this also zeroes the memory.
\ Like `buf:` but doesn't return capacity.
\ Also see `buf:` for warnings about AOT.
fun: mem: { cap -- err } ( C: "name" -- ) ( E: -- adr )
  nil cap .alloc_data { adr }
  .read_word adr .init_data_word
end

fun: comp_buf { adr cap -- err } ( E: -- adr cap )
  .comp_alloc_next_reg { RA }
  .comp_alloc_next_reg { RL }
  adr RA .comp_page_addr
  cap RL .comp_load
end

\ Similar to the standard idiom `create <name> N allot`.
\ Creates a global variable which refers to a buffer of
\ at least the given size in bytes, initialized to zero.
\
\ TODO dedup code with `init_data_word`.
\
\ The buffer is allocated in the compiler-managed data region,
\ which is preserved in AOT compilation. Changes to this data
\ made during interpretation persist into the AOT executable.
\
\ The variable does NOT hold a fixed address. Instead, it compiles
\ instructions to calculate the address using PC-relative offsets.
\ The address CHANGES from JIT to AOT. This means: it must not be
\ stored in another static variable, or used to derive an address
\ which would be stored in another static variable.
fun: buf: { cap -- err } ( C: "name" -- ) ( E: -- adr cap )
  nil cap .alloc_data { adr }
  .read_word { str len }

  str len .define_fun .plain_call
    0 2 false .comp_signature_set ( E: -- ptr cap )
    adr cap .comp_buf
  call_xt'' end

  str len .define_fun_comp
    .plain_call
    0 1 true .comp_signature_set
    adr .comp_push cap .comp_push compile' comp_buf
  call_xt'' end

  [ false .comp_only ]
end

