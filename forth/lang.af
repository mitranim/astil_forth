\ ## Interpreter internals (basic)

\ True if running in JIT mode (interpreter available).
\ False if running in AOT-compiled mode.
\
\ In JIT mode, the outer interpreter (in C) always stores its address in the
\ `ASM_REG_INTERP` register just before calling into Forth. in AOT mode, the
\ reg starts as zero when the OS runs the process, none of our compiled code
\ modifies it, and locals are never assigned to this register.
fun_comp: interp { -- err } ( E: -- adr )
  [ .plain_call ]
  .comp_alloc_next_reg { reg }
  reg ASM_REG_INTERP .asm_mov_reg .comp_instr \ mov <arg>, x28
  true .interp_only
end

fun: interp { -- adr } [ .plain_call ] interp end
fun: has_interp { -- bool } interp <>0 [ false .interp_only ] end

\ SYNC[interp_fields].
\ SYNC[comp_code_fields].
\ SYNC[instr_heap_fields].
\
\ Returns the address of the first writable instruction in interpreter's heap.
\ We subtract this from instruction addresses because the resulting offset is
\ easily packed into 32 bits.
\
\ This looks ridiculously unsafe and it is, but I'm a firm believer
\ that the best API is a stable ABI. Just don't break your offsets.
184 let: INTERP_COMP_CODE_WRITE_OFF

fun_comp: interp_instrs { -- err } ( E: -- adr )
  [ .plain_call ]
  call_xt'' interp
  INTERP_COMP_CODE_WRITE_OFF .comp_push
  call_xt'' +
  call_xt'' @
  PAGE_SIZE .comp_push
  call_xt'' +
end

fun: interp_instrs {     -- adr } [ .plain_call ] interp_instrs end
fun: instr_off     { adr -> off } interp_instrs - end
fun: instr_adr     { off -> adr } interp_instrs + end

\ ## Control flow metadata
\
\ All control structures pass around a "meta" cell.
\
\ SYNC[control_meta_layout]:
\
\ - 19..63: instruction offset
\ - 15..18: branch_cond + 1, or 0 for none
\ -     14: exec_prev
\ -     13: 0 / 1 = `cbz` / `cbnz`
\ -     12: has_else
\ -     11: has_out_len
\ -     10: has_inp_len
\ -   5..9: out_len
\ -   0..4: inp_len
\
\ Instruction offset describes the start of some conditional branch or loop.
\ It's used to compile PC-relative branch instructions at the branch points.
\
\ `inp_len` and `out_len` record "register stack length" or "arg length"
\ at branch entry and exit points respectively. `has_inp` and `has_out`
\ record whether we've already recorded / inferred respective lengths.
\
\ Branch points must validate matching lengths. Such as:
\ in conditionals, every `.then` takes the same `inp_len`,
\ and `out_len` must match between every `elif else end`.
\
\ Single-bit masks are used with `or and`.
\ Multi-bit masks must be used with `bit_mask_get bit_mask_set`.

ASM_ARG_LEN_MAX .bit_len .low_bits let: CONT_MASK_INP_LEN
CONT_MASK_INP_LEN CONT_MASK_INP_LEN .bit_len .lsl let: CONT_MASK_OUT_LEN

1 CONT_MASK_OUT_LEN .bit_len   .lsl      let: CONT_MASK_HAS_INP
CONT_MASK_HAS_INP            1 .lsl      let: CONT_MASK_HAS_OUT
CONT_MASK_HAS_OUT            1 .lsl      let: CONT_MASK_HAS_ELSE
CONT_MASK_HAS_ELSE           1 .lsl      let: CONT_MASK_CBNZ
CONT_MASK_CBNZ 1 .lsl                    let: CONT_MASK_EXEC_PREV
0b1111 CONT_MASK_EXEC_PREV .bit_len .lsl let: CONT_MASK_BRANCH_COND

CONT_MASK_BRANCH_COND .bit_len .low_bits .invert let: CONT_MASK_INSTR_OFF

fun: cont_meta_instr_off_set { off meta -- meta }
  off .instr_off_pack meta CONT_MASK_INSTR_OFF .bit_mask_set
end

fun: cont_meta_instr_adr { meta -> adr }
  CONT_MASK_INSTR_OFF .bit_mask_get .instr_off_unpack .instr_adr
end

fun: reserve_instr { -- off err }
  .here_write .instr_off { off }
  ASM_PLACEHOLDER .comp_instr
  off
end

\ ## Conditionals
\
\ The general idea is to reserve branching instructions,
\ then patch them later via words like `else` and `end`.
\ We pass instruction address offsets through the control
\ stack, along with extra metadata about input and output
\ length at branch points.
\
\   if pred .then \ cbz <outside>
\     if_true
\   end
\   outside
\
\   if pred .then \ cbz <if_false>
\     if_true
\   else      \ b <outside>
\     if_false
\   end
\   outside
\
\ Unlike other Forth systems, we also support chains of "elif",
\ terminated with a single "end", which is generic: it pops one
\ XT from the stack and calls it. The XT can pop another one,
\ popping multiple control frames in a chain.
\
\ Conditional chains involving `elif` have two passes.
\ In the forward pass, every `else elif elifz` calls
\ one previous frame, with special flags passed through
\ the "meta" input. `else` pushes one replacement frame,
\ `elif elifz` push two replacement frames; the second
\ frame is configured to also call the first one.
\ When `end` calls the last frame, the entire prior
\ chain calls as a backwards pass, retropatching
\ instructions reserved by each `else elif elifz`.

fun: if_patch { reg meta -- err }
  meta .cont_meta_instr_adr { adr }
  .here_write adr - { off }
  meta CONT_MASK_CBNZ .and { cbnz }
  reg off cbnz .asm_cmp_branch adr !32 \ cbz/cbnz Xn, <target>
end

fun: if_end_xt { meta -- err }
  .comp_barrier
  0 " branch outputs" .comp_args_valid
  meta CONT_MASK_INP_LEN .bit_mask_get meta .if_patch
end

\ Early definition; used in bare form: `pred .then end`.
fun_comp: then { -- meta end_xt err } ( E: pred -- )
  .comp_barrier
  1 " arguments before `.then`" .comp_args_valid
  0 .comp_args_set
  .reserve_instr 0 .cont_meta_instr_off_set xt' if_end_xt
end

fun: asm_cset_decode { instr -- reg cond ok }
  \ `cset` with `Rd` and `cond` masked out.
  0b1_1_1_11111111_11111_0000_1_1_11111_00000 { mask }

  instr 0b11111 .and { reg }
  instr 12 .lsr 0b1111 .and 1 .xor { cond }

  instr mask .and ASM_OP_CSET =
  cond ASM_AL <> .and
  cond ASM_NV <> .and { ok }

  reg cond ok
end

fun: control_try_cset_branch { pred_reg branch_on_true meta -- meta fused err }
  .here_write ASM_INSTR_SIZE - { adr }
  adr @u32 .asm_cset_decode { cset_reg cond ok }
  ok cset_reg pred_reg = .and { fused }
  fused .then
    branch_on_true =0 .then cond 1 .xor { cond } end
    cond .inc meta CONT_MASK_BRANCH_COND .bit_mask_set { meta }
    adr .instr_off meta .cont_meta_instr_off_set { meta }
  end
  meta fused
end

fun: if_patch { reg meta -- err } [ .redefine ]
  meta CONT_MASK_BRANCH_COND .bit_mask_get { cond }
  cond .then
    meta .cont_meta_instr_adr { adr }
    .here_write adr - { off }
    cond .dec { cond }
    off cond .asm_branch_cond adr !32 \ b.<cond> <target>
    .ret
  end
  reg meta .if_patch
end

\ Now that we have nullary conditionals, we can redefine
\ them into full-blown arity-aware condition expressions.

\ Called either during the forward pass by `else elif elifz`,
\ or during the backward pass by `end`.
fun: if_end_xt { meta -- err } [ .redefine ]
  .comp_barrier
  meta CONT_MASK_INP_LEN .bit_mask_get meta .if_patch

  meta CONT_MASK_HAS_ELSE .and =0 .then
    meta CONT_MASK_INP_LEN .bit_mask_get
    " arguments before ending conditional without `else`"
    .comp_args_valid
  end

  \ Only in the backward pass.
  meta CONT_MASK_EXEC_PREV .and .then call_xt'' end end
end

fun_comp: if  { -- meta end_xt } [ .plain_call true .comp_only ]
  nil xt' if_end_xt
end

fun_comp: ifz { -- meta end_xt } [ .plain_call true .comp_only ]
  CONT_MASK_CBNZ xt' if_end_xt
end

\ Caution: after this definition, `if ifz` are required,
\ and bare `.then` is invalid. Shape: `if pred .then end`.
fun_comp: then { meta end_xt -- meta end_xt err } ( E: pred -- ) [ .redefine ]
  .comp_barrier
  " arguments before `.then`" { ctx }
  meta CONT_MASK_HAS_INP .and { has }

  has .then
    meta CONT_MASK_INP_LEN .bit_mask_get { len }
    len .inc ctx .comp_args_valid
  end

  has =0 .then
    1 ctx .comp_args_min
    .comp_args_get .dec { len }
    len meta CONT_MASK_INP_LEN .bit_mask_set CONT_MASK_HAS_INP .or { meta }
  end

  len .comp_args_set
  len meta CONT_MASK_CBNZ .and meta .control_try_cset_branch { meta fused }

  \ Fused path patches old `cset`; fallback reserves a fresh `cbz/cbnz`.
  fused =0 .then
    .reserve_instr meta .cont_meta_instr_off_set { meta }
  end
  meta end_xt
end

fun: else_patch { meta -- err }
  meta .cont_meta_instr_adr { adr }
  .here_write adr - .asm_branch adr !32
end

fun: else_end_xt { meta -- err }
  .comp_barrier
  meta .else_patch
  meta CONT_MASK_OUT_LEN .bit_mask_get " branch outputs" .comp_args_valid
  if meta CONT_MASK_EXEC_PREV .and .then call_xt'' end end
end

fun_comp: else { meta end_xt -- meta end_xt err }
  [ .plain_call ]
  .comp_barrier
  .reserve_instr { off }

  meta
    CONT_MASK_HAS_ELSE .or
    CONT_MASK_EXEC_PREV .bits_clear
  STACK >s
  end_xt .call_xt

  off meta .cont_meta_instr_off_set { meta }
  meta CONT_MASK_HAS_OUT .and { has }

  if has .then
    meta CONT_MASK_OUT_LEN .bit_mask_get " branch outputs" .comp_args_valid
  end

  ifz has .then
    .comp_args_get meta CONT_MASK_OUT_LEN .bit_mask_set CONT_MASK_HAS_OUT .or { meta }
  end

  meta CONT_MASK_INP_LEN .bit_mask_get .comp_args_set
  meta xt' else_end_xt
end

fun_comp: elif { meta end_xt -> else_meta else_xt meta end_xt err }
  [ .plain_call ]
  call_xt'' else { meta else_xt }
  meta else_xt
  meta CONT_MASK_EXEC_PREV .or xt' if_end_xt
end

fun_comp: elifz { meta end_xt -> else_meta else_xt meta end_xt err }
  [ .plain_call ]
  call_xt'' else { meta else_xt }
  meta else_xt
  meta CONT_MASK_EXEC_PREV .or CONT_MASK_CBNZ .or xt' if_end_xt
end

\ ## Types
\
\ We define type descriptors with size and alignment information.
\ This allows us to provide `struct:` with proper field alignment
\ compatible with C, for easier libc interop.
\
\ First: some internal tools for type definitions. Each type is represented
\ with the structure listed below. We do not yet have `struct:`, because it
\ requires the utils below first, so we access fields via hardcoded offsets.
\
\   struct: Type
\     Cell 1 field: Type_size
\     Cell 1 field: Type_align
\     U8   0 field: Type_name  \ Variable length; null-terminated.
\   end
\
\ Types are defined with shortcuts `opaque: int: arr: struct:` and so on.
\
\ Most of the time size and alignment should be accessed via
\ `size'` and `align'` shortcuts, which inline the values at
\ compile time, without loading type descriptors at runtime.

\ SYNC[type_fields].
fun: type_beg { name len -- type err }
  len .inc             { cap }
  2 .cells cap +       { size }
  nil size .alloc_data { type }
  2 .cells type + name cap .strlcpy
  type
end

\ SYNC[type_fields].
fun: type_end { type size align -- err }
  size type !
  align type +cell !
  2 .cells type + { name }
  name .strlen    { len }
  name len type .init_data_word
end

fun: define_type { name name_len size align -- err }
  name name_len .type_beg size align .type_end
end

fun: opaque: { size align -- err } ( C: "name" -- ) ( E: -- type )
  .read_word size align .define_type
end

fun: int: { size -- err } ( C: "name" -- ) ( E: -- type )
  .read_word size size .define_type
end

\ SYNC[type_fields].
fun: sizeof { type -> size } @ end

fun: size' { -- size err } ( C: "type" -- )
  WORDLIST_EXEC .next_word .call_xt STACK s> .sizeof
end

fun_comp: size' { -- err } ( C: "type" -- ) ( E: -- size )
  call_xt' size' .comp_push
end

\ SYNC[type_fields].
fun: alignof { type -> align } +cell @ end

fun: align' { -- align err } ( C: "type" -- )
  WORDLIST_EXEC .next_word .call_xt STACK s> .alignof
end

fun_comp: align' { -- err } ( C: "type" -- ) ( E: -- align )
  call_xt' align' .comp_push
end

fun_comp: is_aligned_to' { -- err } ( C: "type" -- ) ( E: adr -- bool )
  call_xt'' align' call_xt'' is_aligned_to
end

fun: is_aligned_to' { adr -- bool err }
  call_xt' align' { size }
  adr size .is_aligned_to
end

\ ### Integer types
\
\ Assumes Arm64 + Apple ABI.
\
\ "S" stands for "signed integer", "U" for "unsigned integer".
\
\ When converting shorter signed integers to wider ones,
\ they must be sign-extended. See `int_to_cell` for `S32`.
\
\ When accessing memory, use the appropriately sized/typed memory operators.
\ For example, `U32` is loaded with `@u32`, but `S32` is loaded with `@s32`.
\ Both are stored with `!32`. Aliases like `Cint` get their own "operators".
\ See memory ops above.
1 int: U8
1 int: S8
2 int: U16
2 int: S16
4 int: U32
4 int: S32
8 int: U64
8 int: S64
8 int: Adr
8 int: Cell \ Forth name for machine word. Neither signed nor unsigned.
8 int: Cstr \ char*
4 int: Cint
4 int: Cuint
8 int: Clong
8 int: Culong

\ ### Array types

\ Usage:
\
\   U8 128   arr: Some_arr
\   Some_arr mem: SOME_BUF
\
\ An array's alignment is equal to the alignment of its element type.
\ An array type can be used in a struct field, although that's usually
\ unnecessary, because each struct field is declared exactly the same
\ way as an array type:
\
\   Elem_type 32 arr:   Some_arr
\   Elem_type 32 field: Some_field
\   Some_arr  1  field: Some_field
fun: arr: { type len -- err } ( C: "name" -- ) ( E: -- type )
  type .sizeof len * { size }
  type .alignof      { align }
  .read_word size align .define_type
end

\ ### Struct types
\
\ Structs allow C interop. Fields are aligned
\ and padded to match the C ABI. Basic usage:
\
\   struct: Type
\     S32 1  field: Type_field0
\     U8  32 field: Type_field1
\   end
\
\   size' Type .alloca { adr }
\
\       adr Type_field0 @
\   123 adr Type_field0 !
\
\ The name of a struct type returns an actual `Type`.
\ When allocating, use `size'` to get the size instead.
\
\ The name of each field is a compile-time word which calculates its
\ offset from an address. To get an offset from zero, provide zero.
\
\ Note that load / store is type-specific. Fields which aren't cell-sized
\ must be loaded and stored using dedicated typed operators. For example,
\ a C `int` must be loaded with `@cint`; a byte must be loaded with `@b`.

0 let: AGG_STRUCT
1 let: AGG_UNION

\ For internal use, invoked by `end`.
fun: agg_end_xt { type _mode align off -- err } ( C: type mode align off -- )
  off align .align_up { size }
  type size align .type_end
end

\ Begins a struct definition; terminate with `end`.
fun: struct: { -- type mode align off end_xt err } ( C: "name" -- ) ( E: -- size )
  .read_word .type_beg AGG_STRUCT 0 0 xt' agg_end_xt
end

\ Begins a union definition; terminate with `end`.
fun: union: { -- type mode align off end_xt err } ( C: "name" -- ) ( E: -- size )
  .read_word .type_beg AGG_UNION 0 0 xt' agg_end_xt
end

\ Compile field access, which computes address + offset.
fun: comp_struct_field { off -- err }
  .comp_args_get { len }
  ifz len .then " struct field must be preceded by struct pointer" .throw end
  ifz off .then .ret end

  \ Same reg: replace prior address with address + offset.
  len .dec { adr_reg }
  adr_reg .comp_realloc_reg \ Disassociate locals from this reg.

  if off ASM_MAX_IMM12 <= .then
    adr_reg adr_reg off .asm_add_imm .comp_instr \ add <adr>, <adr>, <off>
  else
    .comp_alloc_next_reg { off_reg }
    off off_reg .comp_load \ mov <reg>, <imm> | ldr <reg>, <some_off>
    adr_reg adr_reg off_reg .asm_add_reg .comp_instr \ add <adr>, <adr>, <off>
    len .comp_args_set
  end
end

\ For internal use.
fun: define_field_word { name name_len off -- err }
  ( E: struct_adr -- field_adr )

  \ Execution-time semantics.
  name name_len .define_fun
    1 1 false .comp_signature_set ( E: struct_adr -- field_adr )
    1 .comp_args_set
    if off .then off .comp_push compile' + end
  call_xt'' end

  \ Compile-time semantics.
  name name_len .define_fun_comp
    0 1 true .comp_signature_set
    off .comp_push compile' comp_struct_field
  call_xt'' end

  [ false .comp_only ]
end

\ For internal use.
fun: define_agg_field
  { name name_len mode agg_align align off type len -- mode align off err }
  ( E: struct_adr -- field_adr )

  \ Since aggregate types are intended for C interop, alignment of every field
  \ must match the platform's C ABI. So far, ABI compat seems to hold.
  \ We still need more comprehensive tests.
  type .sizeof len * { size }

  if mode AGG_UNION = .then
    name name_len 0 .define_field_word
    mode agg_align align .max off size .max .ret
  end

  off align .align_up { off }
  name name_len off .define_field_word
  mode agg_align align .max size off +

  [ false .comp_only ]
end

\ Every field takes two inputs: type decl, like `U8`, and element count.
\ This allows us to align fields to element size rather than total size.
\
\ A field becomes a word `( struct_adr -- field_adr )` which computes
\ a field address from a struct address. Cell-sized fields are loaded
\ and stored with `@ !`. Smaller fields require operators specific to
\ their size and type. For example, signed 32-bit integers `S32` must
\ be stored with `!32` and loaded with `@s32`, which sign-extends the
\ upper bits when loading. Unsigned `U32` must be loaded with `@u32`.
fun: field: { mode agg_align off fun type len -- mode align off fun err }
  ( C: "name" -- )
  ( E: struct_adr -- field_adr )
  type .alignof { align }
  .read_word mode agg_align align off type len .define_agg_field fun
end

fun: field_aligned: { mode agg_align off fun type len align -- mode align off fun err }
  ( C: "name" -- )
  ( E: struct_adr -- field_adr )
  .read_word mode agg_align align off type len .define_agg_field fun
end

\ Can finally define the type layout officially.
struct: Type
  Cell 1 field: Type_size
  Cell 1 field: Type_align
  U8   0 field: Type_name  \ Variable width; null-terminated.
end

\ ## Interpreter internals continued
\
\ Internal stuff not exposed via intrinsics.

\ SYNC[set_fields].
struct: Interp_set
  U32 1 field: Interp_set_len
  U32 1 field: Interp_set_cap
  Adr 1 field: Interp_set_bits \ Cell*
  Adr 1 field: Interp_set_vals \ Sym**
end

\ SYNC[word_str].
struct: Sym_word
  U32 1   field: Sym_word_len
  U8  128 field: Sym_word_buf
end

\ SYNC[sym_fields].
struct: Sym_instrs
  U32 1 field: Sym_instrs_floor
  U32 1 field: Sym_instrs_prologue
  U32 1 field: Sym_instrs_inner
  U32 1 field: Sym_instrs_epi_ok
  U32 1 field: Sym_instrs_epi_err
  U32 1 field: Sym_instrs_ret
  U32 1 field: Sym_instrs_data
  U32 1 field: Sym_instrs_ceil
end

\ SYNC[sym_fields].
struct: Sym_norm
  Adr        1 field: Sym_norm_exec
  Sym_instrs 1 field: Sym_norm_spans
  U8         1 field: Sym_norm_inlinable
  U8         1 field: Sym_norm_has_loads
  U8         1 field: Sym_norm_has_recur
  U8         1 field: Sym_norm_has_alloca
end

\ Word metadata defined internally by the interpreter.
\ Also execution token returned by `xt'` and `xt''`.
\
\ SYNC[sym_fields].
struct: Sym
  Cint       1 field: Sym_type
  Sym_word   1 field: Sym_name
  U8         1 field: Sym_wordlist
  Sym_norm   1 field: Sym_union   \ Begins with executable instruction address.
  Interp_set 1 field: Sym_callees \ set_of(Sym*)
  Interp_set 1 field: Sym_callers \ set_of(Sym*)
  Cell       1 field: Sym_clobber \ `Bits`
  U8         1 field: Sym_inp_len
  U8         1 field: Sym_out_len
  U8         1 field: Sym_has_err
  U8         1 field: Sym_comp_only
  U8         1 field: Sym_interp_only
  U8         1 field: Sym_plain_call
end

\ SYNC[sym_fields].
fun_comp: sym_instr { -- err } ( E: XT -- instr )
  call_xt'' Sym_union call_xt'' @
end

fun: sym_instr { XT -> instr } .sym_instr end

\ For internal use below.
fun: comp_word_instr { wordlist -> err } ( C: "name" -- ) ( E: -- instr )
  .next_word .comp_push
  call_xt'' sym_instr
end

\ Similar to `xt'` and `xt''`, but instead of returning an execution token,
\ which is `Sym *`, returns the address of the first executable instruction
\ of the next word.
\
\ Intended use cases:
\
\ - Where XT introspection     needed -> `xt'    + `.call_xt`.
\ - Where XT introspection not needed -> `instr' + call`.
\
\ This is the same as a "function pointer" in C. When passing callbacks to
\ foreign callers such as `pthread_create` or `qsort`, this "just works",
\ since we use the standard calling convention.
fun: instr' { -- instr err } call_xt' xt' .sym_instr end

fun_comp: instr' { -- err } ( C: "name" -- ) ( E: -- instr )
  WORDLIST_EXEC .comp_word_instr
end

fun_comp: instr'' { -- err } ( C: "name" -- ) ( E: -- instr )
  WORDLIST_COMP .comp_word_instr
end

\ This definition is assumed by stack operations defined earlier,
\ and shared with the interpreter C code. See `## Stacks` above.
\
\ SYNC[stack_field_offsets].
struct: Stack
  Cell 1 field: Stack_bytelen
  Adr  1 field: Stack_cellar
  Adr  1 field: Stack_floor
  Adr  1 field: Stack_top
  Adr  1 field: Stack_ceil
end

\ SYNC[hash_table_structure].
struct: Interp_dict
  U32 1 field: Interp_dict_len
  U32 1 field: Interp_dict_cap
  Adr 1 field: Interp_dict_bits \ Cell*
  Adr 1 field: Interp_dict_keys \ char**
  Adr 1 field: Interp_dict_vals \ Sym**
end

\ SYNC[interp_reader_fields].
struct: Interp_reader
  Cstr 1 field: Interp_reader_src
  U32  1 field: Interp_reader_len
  U32  1 field: Interp_reader_pos
  \ ... other fields ...
end

\ SYNC[interp_module_fields].
struct: Interp_module_ctx
  Interp_reader 1 field: Interp_module_reader
  \ ... other fields ...
end

\ Used as prefix padding before `Comp.ctx`.
\ SYNC[comp_code_fields].
\ Partial mirror of C `Comp_code`. Forth only needs its size to reach
\ `Comp.ctx`; fields are intentionally inaccessible.
248 8 opaque: Interp_comp_code

\ Partial mirror of C `Comp_ctx`. Defines only what we use.
\ SYNC[comp_ctx_fields].
struct: Interp_comp_ctx
  Adr 1 field: Interp_comp_ctx_sym
  \ ... other fields ...
end

\ SYNC[comp_fields].
struct: Interp_comp
  Interp_comp_code 1 field: Interp_comp_code_field
  Interp_comp_ctx  1 field: Interp_comp_ctx_field
end

\ Partial mirror of the outer C-based interpreter. Only fields actually read by
\ Forth are defined; omitted tail fields are intentionally inaccessible.
\
\ SYNC[interp_fields].
struct: Interp
  Stack       1 field: Interp_ints
  Interp_dict 1 field: Interp_dict_exec
  Interp_dict 1 field: Interp_dict_comp
  Stack       1 field: Interp_sym
  Adr         1 field: Interp_module \ Interp_module_ctx*
  Interp_dict 1 field: Interp_imports
  Interp_comp 1 field: Interp_comp_field
end

\ ## Compiler context
\ We use C-mirror structs to access the state of the running compiler.
\ This requires keeping definitions in sync, but gives us an automatic
\ ABI without the need for an API.

\ ## Raw callbacks

\ Used when calling words with unknown clobbers.
fun: comp_realloc_regs { -- err }
  0  .comp_realloc_reg \ x0
  1  .comp_realloc_reg \ x1
  2  .comp_realloc_reg \ x2
  3  .comp_realloc_reg \ x3
  4  .comp_realloc_reg \ x4
  5  .comp_realloc_reg \ x5
  6  .comp_realloc_reg \ x6
  7  .comp_realloc_reg \ x7
  8  .comp_realloc_reg \ x8
  9  .comp_realloc_reg \ x9
  10 .comp_realloc_reg \ x10
  11 .comp_realloc_reg \ x11
  12 .comp_realloc_reg \ x12
  13 .comp_realloc_reg \ x13
  14 .comp_realloc_reg \ x14
  15 .comp_realloc_reg \ x15
end

\ blr x0
fun: call { _fun } [ 0 .asm_branch_link_reg .comp_instr ] end

\ Takes any amount of args where the last arg is assumed to be a raw
\ instruction address, known in C as "function pointer". Invokes the
\ function with the preceding args. Assumes no outputs. The caller
\ may assume outputs afterwards: `[ N .comp_args_set ]`.
\
\ Important comptime semantics: words defined with `fun_comp` are compiled
\ exactly like regular words. Only execution time differs: they execute at
\ comptime as soon as the reader parses them .while compiling another word.
\
\ This behavior stacks. Earlier comptime words run immediately when
\ used inside other words, even when compiling other comptime words.
\ For example, using this `call` word inside another `fun_comp` word
\ invokes `call` at comptime, and compiles a runtime call of some
\ dynamically-provided instruction pointer, usually from `instr'`.
\ For the newly-defined comptime word, that call runs at comptime
\ of _other_ words where it's later used.
\
\ Many comptime words manipulate compiler state, sometimes appending
\ or backtracking instructions or affecting argument count. Comptime
\ words used in other comptime words tend to affect just the current
\ target word, with some exceptions like `compile'` / `compile''`.
fun_comp: call { -- err } ( C: …args… fun -- ) ( E: …args… fun -- )
  .comp_args_get { len }

  ifz len .then
    " unable to compile `call`: at least 1 argument is required" .throw
  end

  if len ASM_PARAM_LEN_MAX .inc > .then
    " unable to compile `call`: 8 param registers available, 9 arguments provided" .throw
  end

  .comp_realloc_regs \ Assume full clobber.
  0 .comp_args_set

  \ Emit frame record as workaround for leaf callers without their own.
  \ Current word may become non-leaf later, but we don't know it yet.
  interp .Interp_comp_field .Interp_comp_ctx_field .Interp_comp_ctx_sym @ { sym }
  sym .Sym_callees .Interp_set_len @u32 0 = { leaf }

  if leaf .then
    ASM_REG_FP ASM_REG_LR ASM_REG_SP -16 .asm_store_pair_pre .comp_instr \ stp x29, x30, [sp, #-16]!
  end
  len .dec .asm_branch_link_reg .comp_instr \ blr <fun>
  if leaf .then
    ASM_REG_FP ASM_REG_LR ASM_REG_SP 16 .asm_load_pair_post .comp_instr  \ ldp x29, x30, [sp], #16
  end
end

\ ## Assembler continued -- logical immediates and other stuff

fun: asm_ror64 { val rot -- out }
  rot 63 .and { rot }
  ifz rot .then val .ret end

  val rot .lsr
  val 64 rot - .lsl
  .or
end

fun: asm_logical_imm_enc { imm -- N immr imms err }
  if imm 0 = .then
    " unable to encode logical immediate: 0 is reserved" .throw
  end
  if imm .invert 0 = .then
    " unable to encode logical immediate: all ones is reserved" .throw
  end

  imm imm .inc .and .bit_ctz { rot }
  imm rot .asm_ror64 { norm }
  norm .bit_clz { zeros }
  norm .invert .bit_ctz { ones }
  zeros ones + { size }

  if imm size .asm_ror64 imm <> .then
    " unable to encode logical immediate: value is not a repeated bitmask" .throw
  end

  size 6 .lsr
  rot .negate size .dec .and
  size 1 .lsl .negate ones .dec .or 0x3f .and
end

fun: asm_logical_imm_mask { imm op -- mask err }
  imm .asm_logical_imm_enc { N immr imms }
  op
  N    22 .lsl .or
  immr 16 .lsl .or
  imms 10 .lsl .or
end

fun: asm_logical_imm_instr { Xd Xn imm op -- instr err }
  imm op .asm_logical_imm_mask
  Xn 5 .lsl .or
  Xd .or
end

0b1_00_100100_0_000000_000000_00000_00000 let: ASM_OP_AND_IMM
0b1_01_100100_0_000000_000000_00000_00000 let: ASM_OP_ORR_IMM
0b1_10_100100_0_000000_000000_00000_00000 let: ASM_OP_EOR_IMM
0b1_11_100100_0_000000_000000_00000_00000 let: ASM_OP_ANDS_IMM

fun: asm_and_imm { Xd Xn imm -- instr err } Xd Xn imm ASM_OP_AND_IMM .asm_logical_imm_instr end
fun: asm_orr_imm { Xd Xn imm -- instr err } Xd Xn imm ASM_OP_ORR_IMM .asm_logical_imm_instr end
fun: asm_eor_imm { Xd Xn imm -- instr err } Xd Xn imm ASM_OP_EOR_IMM .asm_logical_imm_instr end
fun: asm_bic_imm { Xd Xn imm -- instr err } Xd Xn imm .invert ASM_OP_AND_IMM .asm_logical_imm_instr end
fun: asm_tst_imm { Xn imm -- instr err } 31 Xn imm ASM_OP_ANDS_IMM .asm_logical_imm_instr end

fun: asm_add_imm_decode { instr -- Xd Xn imm ok }
  \ `add Xd, Xn, #imm12` with `Xd`, `Xn`, and `imm12` masked out.
  \ Not bothering to decode `sub`, shifted immediates, or flags ops.
  0b1_1_1_111111_1_000000000000_00000_00000 { mask }

  instr 0b11111 .and { Xd }
  instr 5 .lsr 0b11111 .and { Xn }
  instr 10 .lsr 0xfff .and { imm }

  instr mask .and ASM_OP_ADD_IMM = { ok }
  Xd Xn imm ok
end

fun: asm_add_imm_decode_at { instr_adr -- Xd Xn imm ok }
  instr_adr @u32 .asm_add_imm_decode
end

fun: asm_load_store_byte_off { Rt Xn off size opc -- instr ok }
  \ Prefer unsigned scaled addressing: it has much larger range.
  if off >=0 .then
    1 size .lsl { width }
    ifz off width .mod .then
      off width / { imm }
      if imm ASM_MAX_IMM12 <= .then
        Rt Xn imm size opc .asm_load_store_off true .ret
      end
    end
  end

  \ Fall back to unscaled addressing for small byte-precision offsets.
  if off -256 >= off 255 <= .and .then
    Rt Xn off size opc .asm_load_store_unscaled_off true .ret
  end

  0 false
end

\ ## Constant folding and locals mutation
\
\ The outer compiler associates comptime constants with argument registers.
\ Some associations support backtracking previously-emitted instructions.
\ We use this to fold constants in full and partial modes.
\
\ After defining the CF support code, we simply redefine our arithmetic words,
\ wrapping them into new versions which grab comptime constants, backtracking
\ the instructions whenever possible, and fold them at comptime, avoiding new
\ runtime arithmetic. When not possible, they fallback at runtime operations.

fun: cf_imm_u12 { imm -- ok }
  imm 0 >= imm ASM_MAX_IMM12 <= .and
end

fun: cf_emit_cmp_imm_cset { reg0 reg1 imm cond -- err }
  reg1 imm  .asm_cmp_imm .comp_instr \ cmp Xn, #imm12
  reg0 cond .asm_cset    .comp_instr \ cset Xd, cond
end

fun: cf_cmp_validate { imm cond -- aux ok err }
  imm .cf_imm_u12 { ok }
  cond ok
end

fun: cf_args_fold1 { -- reg imm consumed err }
  1 nil .comp_args_min
  .comp_args_get .dec { reg }
  1 .comp_args_fold { imm _imm1 _known consumed }
  reg imm consumed
end

fun: cf_fold_cleared1 { -- reg imm ok err }
  .cf_args_fold1 { reg imm consumed }
  ifz consumed .then reg 0 false .ret end
  reg imm true
end

fun: cf_args_fold2 { -- reg0 reg1 imm0 imm1 known consumed err }
  2 nil .comp_args_min
  .comp_args_get .dec { reg1 }
  reg1 .dec { reg0 }
  2 .comp_args_fold { imm0 imm1 known consumed }
  reg0 reg1 imm0 imm1 known consumed
end

fun: cf_fold_cleared2 { -- reg imm0 imm1 ok err }
  .cf_args_fold2 { reg0 reg1 imm0 imm1 _known consumed }
  if consumed 2 <> .then
    if consumed 1 = .then imm1 reg1 .comp_load end
    0 0 0 false .ret
  end
  reg0 imm0 imm1 true
end

fun: cf_fold_done { reg imm -- err }
  imm reg .comp_load
  reg .inc .comp_args_set
end

fun: cf_fold_done2 { reg0 reg1 imm0 imm1 -- err }
  imm0 reg0 .comp_load
  imm1 reg1 .comp_load
  reg1 .inc .comp_args_set
end

fun: cf_restore_rhs { reg1 imm1 consumed -- err }
  if consumed 1 = .then imm1 reg1 .comp_load end
end

fun: cf_fold2_valid { lhs bad0 msg0 bad1 msg1 -- reg0 reg1 imm0 imm1 consumed ok err }
  .cf_args_fold2 { reg0 reg1 imm0 imm1 known consumed }

  if known .then
    if imm1 bad0 = .then msg0 .throw end
    if msg1 .then if imm1 bad1 = .then msg1 .throw end end
  end

  if consumed 2 <> .then reg0 reg1 imm0 imm1 consumed false .ret end

  if imm1 bad0 = lhs imm0 bad0 = .and .or .then msg0 .throw end

  if msg1 .then
    if imm1 bad1 = lhs imm0 bad1 = .and .or .then msg1 .throw end
  end
  reg0 reg1 imm0 imm1 consumed
  true
end

\ Fits the unsigned immediate accepted by our `add/sub #imm12` utils.
fun: cf_addsub_imm12_mag { imm -- mag ok }
  if imm >=0 .then imm imm ASM_MAX_IMM12 <= .ret end
  if imm ASM_MAX_IMM12 .negate >= .then imm .negate true .ret end
  0 false
end

fun: cf_validate { imm validate_inp validate -> aux ok err }
  .call [ 3 .comp_args_set ]
end

fun: cf_fold2_partial_or_fallback { reg0 reg1 imm1 consumed validate_inp validate emit fallback -- err }
  if consumed 1 >= .then
    \ RHS constant: `num 10 +`.
    imm1 validate_inp validate .cf_validate { aux ok }
    reg1 .inc .comp_args_set
    if ok .then
      reg0 .comp_realloc_reg
      reg0 reg0 imm1 aux emit .call [ 1 .comp_args_set ] .try
      reg0 .inc .comp_args_set
      .ret
    end
  end

  reg1 imm1 consumed .cf_restore_rhs
  fallback .call_xt
end

fun: cf_shift_validate { imm reg_op -- aux ok err }
  ifz imm .then " redundant arithmetic" .throw end
  reg_op imm 0 >= imm 63 <= .and
end

fun: cf_shift_emit { reg0 reg1 imm reg_op -- err }
  if reg_op ASM_OP_LSL_REG = .then
    64 imm - 6 .bits_trunc { immr }
    63 imm - 6 .bits_trunc { imms }
    reg0 reg1 immr imms ASM_OP_UBFM .asm_bitfield .comp_instr \ lsl Xd, Xn, #imm6
    .ret
  end

  imm 6 .bits_trunc { immr }
  ASM_OP_SBFM ASM_OP_UBFM ASM_OP_SBFM .xor reg_op ASM_OP_LSR_REG = .negate .and .xor { bitfield_op }
  reg0 reg1 immr 63 bitfield_op .asm_bitfield .comp_instr \ lsr|asr Xd, Xn, #imm6
end

fun: cf_logical_validate { imm aux -- aux ok err }
  aux 1 .and { inv }
  aux inv - { op }
  imm 0 = imm -1 = op ASM_OP_EOR_IMM <> .and .or { edge }
  imm inv ?invert { imm }
  if edge .then " redundant arithmetic" .throw end
  imm op .asm_logical_imm_mask .catch =0
end

fun: cf_logical_emit { reg0 reg1 _imm mask -- err }
  mask reg1 5 .lsl .or reg0 .or .comp_instr \ and|orr|eor Xd, Xn, #imm
end

fun: cf_align_validate { size _ -- aux ok err }
  if size 1 = .then " redundant arithmetic" .throw end
  size .dec ASM_OP_ANDS_IMM .asm_logical_imm_mask .catch =0
end

fun: cf_align_emit { out adr _size mask -- err }
  mask adr 5 .lsl .or 31 .or .comp_instr \ tst Xn, #imm
  out ASM_EQ .asm_cset .comp_instr      \ cset Xd, eq
end

fun: cf_align_down_validate { size _ -- aux ok err }
  if size 1 = .then " redundant arithmetic" .throw end
  size .negate ASM_OP_AND_IMM .asm_logical_imm_mask .catch =0
end

fun: cf_align_down_emit { out len _size mask -- err }
  mask len 5 .lsl .or out .or .comp_instr \ and Xd, Xn, #imm
end

fun: cf_align_up_validate { size _ -- aux ok err }
  if size 1 = .then " redundant arithmetic" .throw end
  size .dec .cf_imm_u12 { add_ok }
  size .negate ASM_OP_AND_IMM .asm_logical_imm_mask .catch { mask mask_err }
  mask add_ok mask_err =0 .and
end

fun: cf_align_up_emit { out len size mask -- err }
  out len size .dec .asm_add_imm .comp_instr \ add Xd, Xn, #imm12
  mask out 5 .lsl .or out .or .comp_instr  \ and Xd, Xn, #imm
end

fun: cf_bits_trunc_validate { len _ -- aux ok err }
  if len 0 <= len 64 >= .or .then " redundant arithmetic" .throw end
  len .low_bits ASM_OP_AND_IMM .asm_logical_imm_mask .catch =0
end

fun: cf_bit_mask_validate { mask -- err }
  if mask .then
    mask mask .bit_ctz .lsr { packed }
    if packed packed .inc .and =0 .then .ret end
  end
  " invalid bit mask: expected nonzero contiguous mask" .throw
end

fun: cf_bit_mask_get_validate { mask _ -- aux ok err }
  if mask -1 = .then " redundant arithmetic" .throw end
  mask .cf_bit_mask_validate
  mask ASM_OP_AND_IMM .asm_logical_imm_mask .catch { instr_mask err }
  if err .then nil false .ret end
  mask .bit_ctz 32 .lsl instr_mask .or true
end

fun: cf_bit_mask_get_emit { out src _mask aux -- err }
  aux 32 .bits_trunc { instr_mask }
  aux 32 .lsr        { shift      }
  instr_mask src 5 .lsl .or out .or .comp_instr \ and Xd, Xn, #imm
  out out shift .asm_lsr_imm .comp_instr      \ lsr Xd, Xn, #imm6
end

fun: cf_addsub_validate { imm add -- aux ok err }
  ifz imm .then " redundant arithmetic" .throw end
  imm .cf_addsub_imm12_mag { -- ok }
  add ok
end

fun: cf_addsub_emit { reg0 reg1 imm add -- err }
  imm .cf_addsub_imm12_mag { mag -- }
  reg0 reg1 mag imm add .asm_addsub_imm .comp_instr \ add|sub Xd, Xn, #imm12
end

fun: cf_pow2_validate { imm flags -- aux ok err }
  " redundant arithmetic" { err }
  ifz imm .then
    if flags 1 .and .then err .throw end
    nil false .ret
  end
  if imm 1 = .then err .throw end
  imm <0 { neg }
  if neg .then
    ifz flags 1 .and .then nil false .ret end
    imm .negate { imm }
  end
  if imm imm .dec .and .then nil false .ret end
  imm .bit_ctz neg 6 .lsl .or { aux }
  aux true
end

fun: cf_pow2_validate_reject_1 { imm msg -- aux ok err }
  if imm 1 = .then msg .throw end
  imm nil .cf_pow2_validate
end

fun: cf_udiv_pow2_emit { reg0 reg1 _imm aux -- err }
  aux 0x3f .and { shift }
  reg0 reg1 shift .asm_lsr_imm .comp_instr \ lsr Xd, Xn, #imm6
end

fun: cf_umod_pow2_emit { reg0 reg1 _imm aux -- err }
  aux 0x3f .and .low_bits { mask }
  reg0 reg1 mask .asm_and_imm .comp_instr \ and Xd, Xn, #imm
end

fun: cf_mul_pow2_emit { reg0 reg1 _imm aux -- err }
  aux 0x3f .and { shift }
  reg0 reg1 shift .asm_lsl_imm .comp_instr \ lsl Xd, Xn, #imm6
  if aux 0x40 .and .then
    reg0 .asm_neg .comp_instr \ neg Xd, Xn
  end
end

fun: comp_loc_mut_arg_prepare { -- reg loc imm consumed err }
  \ For words like `imm +: loc`: capture RHS arg and target local.
  .cf_args_fold1 { reg imm consumed }
  .read_word .comp_local { loc }
  reg loc imm consumed
end

fun: comp_loc_mut_store_prepared { loc reg -- err }
  \ `reg` metadata already invalidated by allocator/fold backtracking.
  reg .inc .comp_args_set
  loc .comp_pop_into_local
end

fun: comp_loc_mut_store_realloc { loc reg -- err }
  \ Hand-emitted op changed `reg`; discard stale arg metadata before storing.
  reg .comp_realloc_reg
  loc reg .comp_loc_mut_store_prepared
end

fun: comp_loc_mut_fold_imm { reg loc imm aux emit -- err }
  \ Emit immediate-form mutation of `loc`; RHS was already backtracked.
  reg .comp_args_set
  loc .comp_push_from_local
  .comp_args_get .dec { loc_reg }
  loc_reg .comp_realloc_reg
  loc_reg loc_reg imm aux emit .call [ 1 .comp_args_set ] .try
  loc loc_reg .comp_loc_mut_store_prepared
end

fun: comp_loc_mut_imm { reg_op validate_inp validate emit -- err }
  ( C: "name" -- ) ( E: imm -- )
  \ Try immediate-form local mutation; otherwise emit regular reg-reg op.

  .comp_loc_mut_arg_prepare { reg loc imm consumed }

  if consumed .then
    imm validate_inp validate .cf_validate { aux ok }
    if ok .then reg loc imm aux emit .comp_loc_mut_fold_imm .ret end
    imm reg .comp_load
  end

  .comp_args1_reg { rhs_reg }
  loc .comp_push_from_local
  rhs_reg rhs_reg .inc rhs_reg .asm_pattern_arith_reg reg_op .or .comp_instr \ <op> Xd, Xn, Xm
  loc rhs_reg .comp_loc_mut_store_prepared
end

fun: comp_loc_unary_init { -- reg loc err } ( C: "name" -- ) ( E: -- )
  .read_word .comp_local { loc }
  loc .comp_push_from_local
  .comp_args_get .dec loc
end

fun: comp_loc_mut_fixed { imm aux emit -- err } ( C: "name" -- ) ( E: -- )
  \ Mutate local with fixed immediate, e.g. `inc:` / `+cell:`.
  .comp_loc_unary_init { reg loc }
  reg reg imm aux emit .call [ 1 .comp_args_set ] .try
  loc reg .comp_loc_mut_store_realloc
end

fun: comp_loc_mut_csel { zero cond -- err } ( C: "name" -- ) ( E: candidate -- )
  .comp_args1_reg { candidate }
  .read_word .comp_local { loc }
  loc .comp_push_from_local
  candidate .inc { cur }

  if zero .then
    candidate candidate cur cond .comp_emit_csel_nonzero
  else
    candidate cur candidate cur candidate cond .comp_emit_csel_reg
  end

  loc candidate .comp_loc_mut_store_prepared
end

fun: comp_loc_mut_cset_zero { cond -- err } ( C: "name" -- ) ( E: -- )
  .comp_loc_unary_init { reg loc }
  reg cond .comp_emit_cset_zero
  loc reg .comp_loc_mut_store_realloc
end

fun: comp_loc_mut_cmp_imm { cond validate emit -- err } ( C: "name" -- ) ( E: rhs -- )
  .comp_loc_mut_arg_prepare { reg loc imm consumed }

  if consumed .then
    imm cond validate .cf_validate { aux ok }
    if ok .then reg loc imm aux emit .comp_loc_mut_fold_imm .ret end
    imm reg .comp_load
  end

  loc .comp_push_from_local
  reg reg .inc reg cond .comp_emit_cmp_cset_reg
  loc reg .comp_loc_mut_store_realloc
end

fun_comp: or { -- err } [ .redefine ]
  " redundant arithmetic" { err }
  true 0 err -1 err .cf_fold2_valid { reg reg1 imm0 imm1 consumed ok }
  if ok .then reg imm0 imm1 .or .cf_fold_done .ret end
  reg reg1 imm1 consumed ASM_OP_ORR_IMM
  instr' cf_logical_validate instr' cf_logical_emit xt'' or
  .cf_fold2_partial_or_fallback
end

\ Bitwise `or` into a local: `mask or: some_val`.
fun_comp: or: { -- err } ( C: "name" -- ) ( E: mask -- )
  ASM_OP_ORR_REG ASM_OP_ORR_IMM
  instr' cf_logical_validate instr' cf_logical_emit
  .comp_loc_mut_imm
end

fun_comp: and { -- err } [ .redefine ]
  " redundant arithmetic" { err }
  true 0 err -1 err .cf_fold2_valid { reg reg1 imm0 imm1 consumed ok }
  if ok .then reg imm0 imm1 .and .cf_fold_done .ret end
  reg reg1 imm1 consumed ASM_OP_AND_IMM
  instr' cf_logical_validate instr' cf_logical_emit xt'' and
  .cf_fold2_partial_or_fallback
end

\ Bitwise `and` into a local: `mask and: some_val`.
fun_comp: and: { -- err } ( C: "name" -- ) ( E: mask -- )
  ASM_OP_AND_REG ASM_OP_AND_IMM
  instr' cf_logical_validate instr' cf_logical_emit
  .comp_loc_mut_imm
end

fun_comp: xor { -- err } [ .redefine ]
  true 0 " redundant arithmetic" 0 nil .cf_fold2_valid { reg reg1 imm0 imm1 consumed ok }
  if ok .then reg imm0 imm1 .xor .cf_fold_done .ret end
  reg reg1 imm1 consumed ASM_OP_EOR_IMM
  instr' cf_logical_validate instr' cf_logical_emit xt'' xor
  .cf_fold2_partial_or_fallback
end

\ Bitwise `xor` into a local: `mask xor: some_val`.
fun_comp: xor: { -- err } ( C: "name" -- ) ( E: mask -- )
  ASM_OP_EOR_REG ASM_OP_EOR_IMM
  instr' cf_logical_validate instr' cf_logical_emit
  .comp_loc_mut_imm
end

fun_comp: lsl { -- err } [ .redefine ]
  false 0 " redundant arithmetic" 0 nil .cf_fold2_valid { reg reg1 imm0 imm1 consumed ok }
  if ok .then reg imm0 imm1 .lsl .cf_fold_done .ret end
  reg reg1 imm1 consumed ASM_OP_LSL_REG
  instr' cf_shift_validate instr' cf_shift_emit xt'' lsl
  .cf_fold2_partial_or_fallback
end

fun_comp: lsr { -- err } [ .redefine ]
  false 0 " redundant arithmetic" 0 nil .cf_fold2_valid { reg reg1 imm0 imm1 consumed ok }
  if ok .then reg imm0 imm1 .lsr .cf_fold_done .ret end
  reg reg1 imm1 consumed ASM_OP_LSR_REG
  instr' cf_shift_validate instr' cf_shift_emit xt'' lsr
  .cf_fold2_partial_or_fallback
end

fun_comp: asr { -- err } [ .redefine ]
  false 0 " redundant arithmetic" 0 nil .cf_fold2_valid { reg reg1 imm0 imm1 consumed ok }
  if ok .then reg imm0 imm1 .asr .cf_fold_done .ret end
  reg reg1 imm1 consumed ASM_OP_ASR_REG
  instr' cf_shift_validate instr' cf_shift_emit xt'' asr
  .cf_fold2_partial_or_fallback
end

fun_comp: + { -- err } [ .redefine ]
  true 0 " redundant arithmetic" 0 nil .cf_fold2_valid { reg reg1 imm0 imm1 consumed ok }
  if ok .then reg imm0 imm1 + .cf_fold_done .ret end
  reg reg1 imm1 consumed true
  instr' cf_addsub_validate instr' cf_addsub_emit xt'' +
  .cf_fold2_partial_or_fallback
end

\ Add a value to a local: `val +: some_val`.
fun_comp: +: { -- err } ( C: "name" -- ) ( E: imm -- )
  ASM_OP_ADD_REG true
  instr' cf_addsub_validate instr' cf_addsub_emit
  .comp_loc_mut_imm
end

fun_comp: - { -- err } [ .redefine ]
  false 0 " redundant arithmetic" 0 nil .cf_fold2_valid { reg reg1 imm0 imm1 consumed ok }
  if ok .then reg imm0 imm1 - .cf_fold_done .ret end
  reg reg1 imm1 consumed false
  instr' cf_addsub_validate instr' cf_addsub_emit xt'' -
  .cf_fold2_partial_or_fallback
end

fun_comp: * { -- err } [ .redefine ]
  " redundant arithmetic" { err }
  true 0 err 1 err .cf_fold2_valid { reg reg1 imm0 imm1 consumed ok }
  if ok .then reg imm0 imm1 * .cf_fold_done .ret end
  reg reg1 imm1 consumed true
  instr' cf_pow2_validate instr' cf_mul_pow2_emit xt'' *
  .cf_fold2_partial_or_fallback
end

\ Multiply a local: `factor *: some_val`.
fun_comp: *: { -- err } ( C: "name" -- ) ( E: factor -- )
  ASM_OP_MUL_REG true
  instr' cf_pow2_validate instr' cf_mul_pow2_emit
  .comp_loc_mut_imm
end

\ No partial CF: signed pow2 division needs several biasing instructions,
\ because `asr` rounds negative values down, .while signed division rounds
\ toward zero. Not worth the code size for now.
fun_comp: / { -- err } [ .redefine ]
  " redundant arithmetic: division by 0 -> 0" { err0 }
  " redundant arithmetic: division by 1" { err1 }
  false 0 err0 1 err1 .cf_fold2_valid { reg reg1 imm0 imm1 consumed ok }
  if ok .then reg imm0 imm1 / .cf_fold_done .ret end
  reg1 imm1 consumed .cf_restore_rhs call_xt'' /
end

fun_comp: u/ { -- err } [ .redefine ]
  " redundant arithmetic: division by 0 -> 0" { err0 }
  " redundant arithmetic: division by 1" { err1 }
  false 0 err0 1 err1 .cf_fold2_valid { reg reg1 imm0 imm1 consumed ok }
  if ok .then reg imm0 imm1 u/ .cf_fold_done .ret end
  reg reg1 imm1 consumed err1
  instr' cf_pow2_validate_reject_1 instr' cf_udiv_pow2_emit xt'' u/
  .cf_fold2_partial_or_fallback
end

