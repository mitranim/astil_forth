1 try_all
fun_comp: \ { -- err } 10 read_until_char { -- } read_char { -- } end
fun_comp: ( { -- err } 41 read_until_char { -- } read_char { -- } end

\ Can use comments now!
\
\ This file boostraps the Forth language. The outer interpreter / compiler
\ provides only the most fundamental intrinsics; enough for self-assembly.
\ We define basic words in terms of machine instructions, building up from
\ there. Currently only the Arm64 CPU architecture is supported.
\
\ The compiler and language come in two variants: stack-CC and register-CC.
\ This file uses the native register-based calling convention. See adjacent
\ file `./lang_s.af` for the stack-based calling convention.

\ brk 666
fun: abort [ 0b110_101_00_001_0000001010011010_000_00 comp_instr ] end
fun: unreachable abort end
fun: nop end

\ ## Compilation-related words
\
\ These words are used for metaprogramming and mostly rely on
\ compiler intrinsics. We define them first to be able to use
\ constants via `let:`.
\
\ Unlike in standard Forth, we use separate wordlists for
\ regular and compile-time / immediate words. As a result,
\ we have to define parsing words like "compile" in pairs:
\ one tick seeks in the regular wordlist, and double tick
\ seeks in the compile-time wordlist.

\ Finds an extern symbol by name and declares it as a function.
fun: extern: { inp_len out_len -- err } ( C: "name" -- ) ( E: …inps -- …outs )
  read_word inp_len out_len extern_fun
end

\ Non-immediate replacement for standard `literal`.
fun: comp_push { val -- err } ( E: -- val )
  comp_alloc_next_reg { reg }
  val reg comp_load
end

fun: next_word { wlist -- XT err } ( "word" -- XT )
  read_word wlist find_word
end

\ "XT" is short for "execution token".
\ `xt'` is renamed from standard `'`.
\ Each execution token is a `Sym*`.
fun: xt_next { wlist -> err } ( "word" -- ) ( E: -- XT )
  next_word comp_push
end

fun: xt'  { -- XT err } ( "word" -- ) 1 next_word end \ WORDLIST_EXEC
fun: xt'' { -- XT err } ( "word" -- ) 2 next_word end \ WORDLIST_COMP

fun_comp: xt'  { -- err } ( E: -- XT ) ( C: "word" -- ) 1 xt_next end \ WORDLIST_EXEC
fun_comp: xt'' { -- err } ( E: -- XT ) ( C: "word" -- ) 2 xt_next end \ WORDLIST_COMP

fun: inline_next { wlist -> err } ( "word" -- ) ( E: <word> )
  next_word inline_word
end

fun_comp: inline'  { -- err } 1 inline_next end
fun_comp: inline'' { -- err } 2 inline_next end

\ "execute" is renamed from standard "postpone".
\ Also see `execute_raw` for raw instruction addresses.
fun: execute_next { wlist -> err } ( "word" -- ) ( E: <word> )
  next_word comp_call
end

fun_comp: execute'  { -- err } 1 execute_next end
fun_comp: execute'' { -- err } 2 execute_next end

fun: compile_next { wlist -> err } ( "word" -- )
  next_word comp_push xt' comp_call comp_call
end

fun_comp: compile'  { -- err } 1 compile_next end
fun_comp: compile'' { -- err } 2 compile_next end

fun: semicolon { -- err } execute'' ; end

fun: let_init { str len val -- err } ( C: "name" -- ) ( E: -- val )
  \ Execution-time semantics.
  str len define_fun
    0 1 0 comp_signature_set ( -- val )
    val comp_push
  semicolon

  \ Compile-time semantics.
  str len define_fun_comp
    0 try_all
    0 1 1 comp_signature_set ( -- err )
    val comp_push compile' comp_push
  semicolon
end

\ Similar to standard `constant`.
fun: let: { val -- err } ( C: "name" -- ) ( E: -- val )
  read_word val let_init
  [ 0 comp_only ]
end

0 let: nil
0 let: false
1 let: true

1 let: WORDLIST_EXEC
2 let: WORDLIST_COMP

\ ## Assembler and bitwise ops
\
\ We interleave definitions of assembler words with definitions
\ of various arithmetic words used by the assembler.

4      let: ASM_INSTR_SIZE
8      let: ASM_PARAM_LEN_MAX
16     let: ASM_ARG_LEN_MAX
29     let: ASM_REG_FP
30     let: ASM_REG_LR
31     let: ASM_REG_SP
31     let: ASM_REG_ZR
4095   let: ASM_MAX_IMM12 \ Shared by many instructions.
0b0000 let: ASM_EQ
0b0001 let: ASM_NE
0b0010 let: ASM_CS
0b0010 let: ASM_HS
0b0011 let: ASM_CC
0b0011 let: ASM_LO
0b0100 let: ASM_MI
0b0101 let: ASM_PL
0b0110 let: ASM_VS
0b0111 let: ASM_VC
0b1000 let: ASM_HI
0b1001 let: ASM_LS
0b1010 let: ASM_GE
0b1011 let: ASM_LT
0b1100 let: ASM_GT
0b1101 let: ASM_LE
0b1110 let: ASM_AL
0b1111 let: ASM_NV
666    let: ASM_PLACEHOLDER

16384 let: PAGE_SIZE

\ SYNC[asm_reg_interp].
fun: ASM_REG_INTERP { -- reg } 28 end

fun_comp: ASM_REG_INTERP { -- err }
  true interp_only
  ASM_REG_INTERP comp_push
end

\ ## Early arithmetic
\
\ Bitwise ops needed for the early stages of the self-assembler.

fun: comp_out0 { instr -- err }
  0 comp_realloc_reg
  instr comp_instr
  1 comp_args_set
end

fun: comp_out0_2 { instr0 instr1 -- err }
  0 comp_realloc_reg
  instr0 comp_instr
  instr1 comp_instr
  1 comp_args_set
end

fun: or { i0 i1 -> i2 } [
  0b1_01_01010_00_0_00001_000000_00000_00000 comp_out0 \ orr x0, x0, x1
] end

fun: and { i0 i1 -> i2 } [
  0b1_00_01010_00_0_00001_000000_00000_00000 comp_out0 \ and x0, x0, x1
] end

fun: xor { i0 i1 -> i2 } [
  0b1_10_01010_00_0_00001_000000_00000_00000 comp_out0 \ eor x0, x0, x1
] end

fun: lsl { i0 bits -> i1 } [
  0b1_0_0_11010110_00001_0010_00_00000_00000 comp_out0 \ lsl x0, x0, x1
] end

fun: lsr { i0 bits -> i1 } [
  0b1_0_0_11010110_00001_0010_01_00000_00000 comp_out0 \ lsr x0, x0, x1
] end

fun: invert { i0 -> i1 } [
  0b1_01_01010_00_1_00000_000000_11111_00000 comp_out0 \ mvn x0, x0
] end

fun: negate { i0 -> i1 } [
  0b1_1_0_01011_00_0_00000_000000_11111_00000 comp_out0 \ neg x0, x0
] end

\ Our parsing rules prevent `1+` or `+1` from being a word name.
fun: inc { i0 -> i1 } [
  0b1_0_0_100010_0_000000000001_00000_00000 comp_out0 \ add x0, x0, 1
] end

\ Our parsing rules prevent `1-` or `-1` from being a word name.
fun: dec { i0 -> i1 } [
  0b1_1_0_100010_0_000000000001_00000_00000 comp_out0 \ sub x0, x0, 1
] end

fun: + { i0 i1 -> i2 } [
  0b1_0_0_01011_00_0_00001_000000_00000_00000 comp_out0 \ add x0, x0, x1
] end

fun: - { i0 i1 -> i2 } [
  0b1_1_0_01011_00_0_00001_000000_00000_00000 comp_out0 \ sub x0, x0, x1
] end

fun: mod { i0 i1 -> i2 } [
  0 comp_realloc_reg
  2 comp_realloc_reg
  0b1_0_0_11010110_00001_00001_1_00000_00010 comp_instr \ sdiv x2, x0, x1
  0b1_00_11011_000_00001_1_00000_00010_00000 comp_instr \ msub x0, x2, x1, x0
  1 comp_args_set
] end

fun: low_bits   { len      -- bits } 1 len lsl dec end
fun: bits_trunc { imm len  -- imm  } len low_bits imm and end
fun: bits_clear { imm mask -- out  } mask invert imm and end

\ ## Early assembler

\ cmp Xn, #imm12
fun: asm_cmp_imm { Xn imm12 -- instr }
  imm12  10 lsl { imm12 }
  Xn     5  lsl
  imm12 or 0b1_1_1_100010_0_000000000000_00000_11111 or
end

\ cmp Xn, 0
fun: asm_cmp_zero { Xn -> instr } 0 asm_cmp_imm end

\ cset Xd, <cond>
fun: asm_cset { Xd cond -- instr }
  cond 1 xor 12 lsl { cond }
  Xd cond or 0b1_0_0_11010100_11111_0000_0_1_11111_00000 or
end

\ ccmp Xd, Xm, <nzcv>, <cond>
fun: asm_ccmp_reg { Xn Xm nzcv cond -- instr }
  Xm   16 lsl { Xm }
  cond 12 lsl { cond }
  Xn 5 lsl Xm or cond or nzcv or 0b1_1_1_11010010_00000_0000_0_0_00000_0_0000 or
end

\ brk #imm16
fun: asm_brk { imm16 -> instr }
  5 lsl 0b110_101_00_001_0000000000000000_000_00 or
end

\ ## Early booleans

fun: <>0 { int -> bool } [
  0 asm_cmp_zero 0 ASM_NE asm_cset comp_out0_2 \ cmp x0, 0; cset x0, ne
] end

fun: =0 { int -> bool } [
  0 asm_cmp_zero 0 ASM_EQ asm_cset comp_out0_2 \ cmp x0, 0; cset x0, eq
] end

\ ## Assembler: instruction patterns

\ Shared by a lot of load and store instructions. 64-bit only.
fun: asm_pattern_load_store_pair { Xt1 Xt2 Xn imm7 -- pattern }
  Xt2 10 lsl { Xt2 }
  Xn  5  lsl { Xn }
  imm7 3 lsr 7 bits_trunc 15 lsl Xt1 or Xt2 or Xn or
end

\ Shared by a lot of load and store instructions.
\ Patches the X bits:
\   0b00_000_0_00_00_0_XXXXXXXXX_00_XXXXX_XXXXX
fun: asm_pattern_load_store { Xt Xn imm9 -- instr_mask }
  Xn 5 lsl { Xn }
  imm9 9 bits_trunc 12 lsl Xt or Xn or
end

\ Shared by register-offset load and store instructions.
\ `scale` must be 0 or 1; if 1, offset is multiplied by 8.
fun: asm_pattern_load_store_with_register_off { Xt Xn Xm scale -- instr_mask }
  Xn        5  lsl { Xn }
  Xm        16 lsl { Xm }
  scale <>0 12 lsl \ lsl 3
  Xt or Xn or Xm or
end

\ Shared by some integer arithmetic instructions.
fun: asm_pattern_arith_reg { Xd Xn Xm -- instr_mask }
  Xn 5  lsl { Xn }
  Xm 16 lsl Xd or Xn or
end

\ Shared by some integer arithmetic and load/store instructions.
fun: asm_pattern_arith_imm { Xd Xn imm12 -- instr_mask }
  Xn 5 lsl { Xn }
  imm12 12 bits_trunc 10 lsl Xd or Xn or
end

fun: asm_pattern_arith_csel { Xd Xn Xm cond -- instr_mask }
  cond 12 lsl { cond }
  Xd Xn Xm asm_pattern_arith_reg cond or
end

fun: instr_off_pack { off -- packed } off 2 lsl end
fun: instr_off_unpack { packed -- off } packed 2 lsr end

\ `off19` offset is implicitly times 4 and can be negative.
fun: asm_pattern_cmp_branch { Xt off19 -- instr_mask }
  off19 instr_off_unpack 19 bits_trunc 5 lsl Xt or
end

\ `off9` offset is implicitly times 4 and can be negative.
fun: asm_pattern_cmp_branch_cond { Xt off9 cond -- instr_mask }
  off9 instr_off_unpack 9 bits_trunc 5 lsl { off9 }
  cond 21 lsl Xt or off9 or
end

\ ## Assembler: memory ops

\ ldp Xt1, Xt2, [Xn, #imm7]!
fun: asm_load_pair_pre { Xt1 Xt2 Xn imm7 -> instr }
  asm_pattern_load_store_pair 0b10_101_0_011_1_0000000_00000_00000_00000 or
end

\ ldp Xt1, Xt2, [Xn], #imm7
fun: asm_load_pair_post { Xt1 Xt2 Xn imm7 -> instr }
  asm_pattern_load_store_pair 0b10_101_0_001_1_0000000_00000_00000_00000 or
end

\ ldp Xt1, Xt2, [Xn, #imm7]
fun: asm_load_pair_off { Xt1 Xt2 Xn imm7 -> instr }
  asm_pattern_load_store_pair 0b10_101_0_010_1_0000000_00000_00000_00000 or
end

\ stp Xt1, Xt2, [Xn, #imm7]!
fun: asm_store_pair_pre { Xt1 Xt2 Xn imm7 -> instr }
  asm_pattern_load_store_pair 0b10_101_0_011_0_0000000_00000_00000_00000 or
end

\ stp Xt1, Xt2, [Xn], #imm7
fun: asm_store_pair_post { Xt1 Xt2 Xn imm7 -> instr }
  asm_pattern_load_store_pair 0b10_101_0_001_0_0000000_00000_00000_00000 or
end

\ stp Xt1, Xt2, [Xn, #imm7]
fun: asm_store_pair_off { Xt1 Xt2 Xn imm7 -> instr }
  asm_pattern_load_store_pair 0b10_101_0_010_0_0000000_00000_00000_00000 or
end

\ ldr Xt, [Xn, #imm9]!
fun: asm_load_pre { Xt Xn imm9 -> instr }
  asm_pattern_load_store 0b11_111_0_00_01_0_000000000_11_00000_00000 or
end

\ ldr Xt, [Xn], #imm9
fun: asm_load_post { Xt Xn imm9 -> instr }
  asm_pattern_load_store 0b11_111_0_00_01_0_000000000_01_00000_00000 or
end

\ str Xt, [Xn, #imm9]!
fun: asm_store_pre { Xt Xn imm9 -> instr }
  asm_pattern_load_store 0b11_111_0_00_00_0_000000000_11_00000_00000 or
end

\ str Xt, [Xn], #imm9
fun: asm_store_post { Xt Xn imm9 -> instr }
  asm_pattern_load_store 0b11_111_0_00_00_0_000000000_01_00000_00000 or
end

\ ldur Xt, [Xn, #imm9]
fun: asm_load_unscaled_off { Xt Xn imm9 -> instr }
  asm_pattern_load_store 0b11_111_0_00_01_0_000000000_00_00000_00000 or
end

\ stur Xt, [Xn, #imm9]
fun: asm_store_unscaled_off { Xt Xn imm9 -> instr }
  asm_pattern_load_store 0b11_111_0_00_00_0_000000000_00_00000_00000 or
end

\ ldr Xt, [Xn, Xm, lsl <scale>]
fun: asm_load_with_register_off { Xt Xn Xm scale -> instr }
  asm_pattern_load_store_with_register_off
  0b11_111_0_00_01_1_00000_011_0_10_00000_00000 or
end

\ str Xt, [Xn, Xm, lsl <scale>]
fun: asm_store_with_register_off { Xt Xn Xm scale -> instr }
  asm_pattern_load_store_with_register_off
  0b11_111_0_00_00_1_00000_011_0_10_00000_00000 or
end

\ size:
\
\   0b00 -- 8  bit
\   0b01 -- 16 bit
\   0b10 -- 32 bit
\   0b11 -- 64 bit
\
\ opc examples for size = 0b00:
\
\   0b01 -- ldrb  Wt
\   0b11 -- ldrsb Wt
\   0b10 -- ldrsb Xt
\   0b00 -- strb  Wt
\
\ Base instruction variant: "immediate, unsigned offset". Offset is 0.
fun: asm_load_store_imm { Rt Xn imm12 size opc -- instr }
  size 30 lsl         { size }
  opc  22 lsl size or { mask }
  Rt Xn imm12 asm_pattern_arith_imm
  mask or 0b00_111_0_01_00_000000000000_00000_00000 or
end

\ Unsigned 8-bit.
\
\ ldrb Wt, [Xn, imm12]
fun: asm_load_off_u8 { Wt Xn imm12 -> instr } 0b00 0b01 asm_load_store_imm end

\ Signed 8-bit.
\
\ ldrsb Xt, [Xn, imm12]
fun: asm_load_off_s8 { Xt Xn imm12 -> instr } 0b00 0b10 asm_load_store_imm end

\ Either unsigned or signed 8-bit.
\
\ strb Wt, [Xn, imm12]
fun: asm_store_off_u8 { Wt Xn imm12 -> instr } 0b00 0b00 asm_load_store_imm end

\ ldrh Wt, [Xn, imm12]
fun: asm_load_off_u16 { Wt Xn imm12 -> instr } 0b01 0b01 asm_load_store_imm end

\ ldrsh Xt, [Xn, imm12]
fun: asm_load_off_s16 { Xt Xn imm12 -> instr } 0b01 0b10 asm_load_store_imm end

\ strh Wt, [Xn, imm12]
fun: asm_store_off_u16 { Wt Xn imm12 -> instr } 0b01 0b00 asm_load_store_imm end

\ ldr Wt, [Xn, imm12]
fun: asm_load_off_u32 { Wt Xn imm12 -> instr } 0b10 0b01 asm_load_store_imm end

\ ldrsw Xt, [Xn, imm12]
fun: asm_load_off_s32 { Xt Xn imm12 -> instr } 0b10 0b10 asm_load_store_imm end

\ str Wt, [Xn, imm12]
fun: asm_store_off_u32 { Wt Xn imm12 -> instr } 0b10 0b00 asm_load_store_imm end

\ ldr Xt, [Xn, imm12]
fun: asm_load_off { Xt Xn imm12 -> instr } 0b11 0b01 asm_load_store_imm end

\ str Xt, [Xn, imm12]
fun: asm_store_off { Xt Xn imm12 -> instr } 0b11 0b00 asm_load_store_imm end

\ neg Xd, Xd
fun: asm_neg { Xd -> instr }
  16 lsl Xd or 0b1_1_0_01011_00_0_00000_000000_11111_00000 or
end

\ add Xd, Xn, #imm12
0b1_0_0_100010_0_000000000000_00000_00000 let: ASM_OP_ADD_IMM
fun: asm_add_imm { Xd Xn imm12 -> instr }
  asm_pattern_arith_imm ASM_OP_ADD_IMM or
end

\ add Xd, Xn, Xm
0b1_0_0_01011_00_0_00000_000000_00000_00000 let: ASM_OP_ADD_REG
fun: asm_add_reg { Xd Xn Xm -> instr }
  asm_pattern_arith_reg ASM_OP_ADD_REG or
end

\ adds Xd, Xn, Xm
fun: asm_adds_reg { Xd Xn Xm -> instr }
  asm_add_reg 0b0_0_1_00000000000000000000000000000 or
end

\ sub Xd, Xn, #imm12
0b1_1_0_100010_0_000000000000_00000_00000 let: ASM_OP_SUB_IMM
fun: asm_sub_imm { Xd Xn imm12 -> instr }
  asm_pattern_arith_imm ASM_OP_SUB_IMM or
end

\ sub Xd, Xn, Xm
0b1_1_0_01011_00_0_00000_000000_00000_00000 let: ASM_OP_SUB_REG
fun: asm_sub_reg { Xd Xn Xm -> instr }
  asm_pattern_arith_reg ASM_OP_SUB_REG or
end

\ subs Xd, Xn, Xm
fun: asm_subs_reg { Xd Xn Xm -> instr }
  asm_sub_reg 0b0_0_1_00000000000000000000000000000 or
end

\ sub Xd, Xn, Xm, lsl 3
fun: asm_sub_reg_words { Xd Xn Xm -> instr }
  asm_sub_reg 0b0_0_0_00000_00_0_00000_000011_00000_00000 or
end

\ orr Xd, Xn, Xm
0b1_01_01010_00_0_00000_000000_00000_00000 let: ASM_OP_ORR_REG
fun: asm_orr_reg { Xd Xn Xm -> instr }
  asm_pattern_arith_reg ASM_OP_ORR_REG or
end

\ eor Xd, Xn, Xm
0b1_10_01010_00_0_00000_000000_00000_00000 let: ASM_OP_EOR_REG
fun: asm_eor_reg { Xd Xn Xm -> instr }
  asm_pattern_arith_reg ASM_OP_EOR_REG or
end

\ and Xd, Xn, Xm
0b1_00_01010_00_0_00000_000000_00000_00000 let: ASM_OP_AND_REG
fun: asm_and_reg { Xd Xn Xm -> instr }
  asm_pattern_arith_reg ASM_OP_AND_REG or
end

\ bic Xd, Xn, Xm
0b1_00_01010_00_1_00000_000000_00000_00000 let: ASM_OP_BIC_REG
fun: asm_bic { Xd Xn Xm -> instr }
  asm_pattern_arith_reg ASM_OP_BIC_REG or
end

\ and Xd, Xn, #encoded_imm
\
\ Caller must pre-encode the immediate into the mask.
\ Auto-encoding requires conditionals and maybe loops.
\ TODO implement later.
fun: asm_and_imm_enc { Xd Xn mask -- instr }
  mask 10 lsl { mask }
  Xn 5 lsl Xd or mask or 0b1_00_100100_0_000000_000000_00000_00000 or
end

\ mul Xd, Xn, Xm
0b1_00_11011_000_00000_0_11111_00000_00000 let: ASM_OP_MUL_REG
fun: asm_mul { Xd Xn Xm -> instr }
  asm_pattern_arith_reg ASM_OP_MUL_REG or
end

\ udiv Xd, Xn, Xm
0b1_0_0_11010110_00000_00001_0_00000_00000 let: ASM_OP_UDIV_REG
fun: asm_udiv { Xd Xn Xm -> instr }
  asm_pattern_arith_reg ASM_OP_UDIV_REG or
end

\ sdiv Xd, Xn, Xm
0b1_0_0_11010110_00000_00001_1_00000_00000 let: ASM_OP_SDIV_REG
fun: asm_sdiv { Xd Xn Xm -> instr }
  asm_pattern_arith_reg ASM_OP_SDIV_REG or
end

\ msub Xd, Xn, Xm, Xa
fun: asm_msub { Xd Xn Xm Xa -- instr }
  Xn  5 lsl { Xn }
  Xm 16 lsl { Xm }
  Xa 10 lsl
  Xd or Xn or Xm or
  0b1_00_11011_000_00000_1_00000_00000_00000 or
end

\ csel Xd, Xn, Xm, <cond>
fun: asm_csel { Xd Xn Xm cond -> instr }
  asm_pattern_arith_csel 0b1_0_0_11010100_00000_0000_0_0_00000_00000 or
end

\ csneg Xd, Xn, Xm, <cond>
fun: asm_csneg { Xd Xn Xm cond -> instr }
  asm_pattern_arith_csel 0b1_1_0_11010100_00000_0000_0_1_00000_00000 or
end

0b1_00_100110_1_000000_000000_00000_00000 let: ASM_OP_SBFM
0b1_10_100110_1_000000_000000_00000_00000 let: ASM_OP_UBFM

fun: asm_bitfield { Xd Xn immr imms op -- instr }
  imms 10 lsl { imms }
  immr 16 lsl { immr }
  Xn   5  lsl { Xn }
  Xd Xn or immr or imms or op or
end

\ asr Xd, Xn, #imm6
fun: asm_asr_imm { Xd Xn imm6 -- instr }
  imm6 6 bits_trunc { immr }
  Xd Xn immr 63 ASM_OP_SBFM asm_bitfield
end

\ asr Xd, Xn, Xm
0b1_0_0_11010110_00000_0010_10_00000_00000 let: ASM_OP_ASR_REG
fun: asm_asr_reg { Xd Xn Xm -> instr }
  asm_pattern_arith_reg ASM_OP_ASR_REG or
end

\ Arithmetic (sign-preserving) right shift.
fun: asr { i0 bits -> i1 } [ 0 0 1 asm_asr_reg comp_out0 ] end \ asr x0, x0, x1

\ lsl Xd, Xn, Xm
0b1_0_0_11010110_00000_0010_00_00000_00000 let: ASM_OP_LSL_REG
fun: asm_lsl_reg { Xd Xn Xm -> instr }
  asm_pattern_arith_reg ASM_OP_LSL_REG or
end

\ lsl Xd, Xn, #imm6
fun: asm_lsl_imm { Xd Xn imm6 -- instr }
  64 imm6 - 6 bits_trunc { immr }
  63 imm6 - 6 bits_trunc { imms }
  Xd Xn immr imms ASM_OP_UBFM asm_bitfield
end

\ lsr Xd, Xn, #imm6
fun: asm_lsr_imm { Xd Xn imm6 -- instr }
  imm6 6 bits_trunc { immr }
  Xd Xn immr 63 ASM_OP_UBFM asm_bitfield
end

\ lsr Xd, Xn, Xm
0b1_0_0_11010110_00000_0010_01_00000_00000 let: ASM_OP_LSR_REG
fun: asm_lsr_reg { Xd Xn Xm -> instr }
  asm_pattern_arith_reg ASM_OP_LSR_REG or
end

\ cmp Xn, Xm
fun: asm_cmp_reg { Xn Xm -- instr }
  Xn  5 lsl { Xn }
  Xm 16 lsl Xn or 0b1_1_1_01011_00_0_00000_000_000_00000_11111 or
end

\ b <off>
fun: asm_branch { off26 -> instr }
  instr_off_unpack \ Offset is implicitly times 4.
  26 bits_trunc    \ Offset may be negative.
  0b0_00_101_00000000000000000000000000 or
end

\ b.<cond> <off>
fun: asm_branch_cond { off19 cond -- instr }
  off19 instr_off_unpack 19 bits_trunc 5 lsl \ Implicitly times 4.
  cond or 0b010_101_00_0000000000000000000_0_0000 or
end

fun: asm_cmp_branch { Xt off19 not_zero -- instr }
  not_zero <>0 24 lsl { op_mask }
  Xt off19 asm_pattern_cmp_branch op_mask or
  0b1_011010_0_0000000000000000000_00000 or
end

\ cbz x1, <off>
fun: asm_cbz { Xt off19 -> instr } 0 asm_cmp_branch end

\ cbnz x1, <off>
fun: asm_cbnz { Xt off19 -> instr } 1 asm_cmp_branch end

\ Not supported on M3 Pro.
\ cb.<cond> Xt, #imm6, #off9
fun: asm_cmp_imm_branch { Xt imm6 off9 cond -- instr }
  Xt off9 cond asm_pattern_cmp_branch_cond { mask }
  imm6 15 lsl mask or 0b1_1110101_000_000000_0_000000000_00000 or
end

\ Not supported on M3 Pro.
\ cb.<cond> Xt, Xm, #off9
fun: asm_cmp_reg_branch { Xt Xm off9 cond -- instr }
  Xt off9 cond asm_pattern_cmp_branch_cond { mask }
  Xm 16 lsl mask or 0b1_1110100_000_00000_00_000000000_00000 or
end

\ eor Xd, Xd, Xd
fun: asm_zero_reg { Xd -> instr } Xd Xd asm_eor_reg end

fun: asm_mov_reg { Xd Xm -- instr }
  Xm 16 lsl Xd or 0b1_01_01010_00_0_00000_000000_11111_00000 or
end

\ movn/movz/movk Xd, #imm16, lsl #hw*16
fun: asm_mov_wide { Xd opc hw imm16 -- instr }
  opc   29 lsl { opc }
  hw    21 lsl { hw }
  imm16 5  lsl
  opc      or
  hw       or
  Xd       or
  0b1_00_100101_00_0000000000000000_00000 or
end

\ Immediate must be unsigned and within range.
fun: asm_mov_imm { Xd imm -- instr } Xd 0b10 0 imm asm_mov_wide end

\ mvn Xd, Xm
fun: asm_mvn { Xd Xm -- instr }
  Xm 16 lsl Xd or 0b1_01_01010_00_1_00000_000000_11111_00000 or
end

\ clz Xd, Xn
fun: asm_clz { Xd Xn -- instr }
  Xn 5 lsl Xd or 0b1_1_0_11010110_00000_00010_0_00000_00000 or
end

\ Requires Arm64 `FEAT_CSSC`; not supported on M3 Pro.
\ ctz Xd, Xn
fun: asm_ctz { Xd Xn -- instr }
  Xn 5 lsl Xd or 0b1_1_0_11010110_00000_000110_00000_00000 or
end

\ rbit Xd, Xn
fun: asm_rbit { Xd Xn -- instr }
  Xn 5 lsl Xd or 0b1_1_0_11010110_00000_00000_0_00000_00000 or
end

\ TODO: support shift.
fun: asm_tst { Xn Xm -- instr }
  Xm 16 lsl { Xm }
  Xn 5 lsl Xm or 0b1_11_01010_00_0_00000_000000_00000_00000 or
end

\ `ret x30`; requires caution with SP / FP.
0b110_101_1_0_0_10_11111_0000_0_0_11110_00000 let: asm_ret

0b110_101_01000000110010_0000_000_11111 let: asm_nop

\ svc 666
0b110_101_00_000_0000001010011010_000_01 let: asm_svc

\ ## Assembler: register selection

fun: comp_args1_reg { -- reg err }
  1 nil comp_args_min
  comp_args_get dec { reg }
  reg comp_realloc_reg
  reg
end

fun: comp_args2_regs { -- reg0 reg1 err }
  2 nil comp_args_min
  comp_args_get dec { reg1 }
  reg1 dec { reg0 }
  reg0 comp_realloc_reg
  reg0 reg1
end

fun: comp_args1_reg2 { -- out0 out1 src err }
  1 nil comp_args_min
  comp_args_get dec { src }
  src inc { out1 }
  src  comp_realloc_reg
  out1 comp_realloc_reg
  src out1 src
end

fun: comp_args2_regs2 { -- reg0 reg1 err }
  comp_args2_regs { reg0 reg1 }
  reg1 comp_realloc_reg
  reg0 reg1
end

