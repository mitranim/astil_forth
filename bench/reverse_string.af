import' std:lang.af

fun: reverse { str len }
  str           { low }
  str len + dec { high }

  loop
    low high < while
    low @b { tmp }
    high @b low !b
    tmp high !b
    inc: low
    dec: high
  end
end

fun: main { -- exit }
  s" 0123456789abcdef" { str len }

  1 22 lsl inc for
    str len reverse
  end

  \ str log lf
  \ fedcba9876543210

  0
end
main
