use' lang.af

fun: reverse { str len }
  str            { low }
  str len + .dec { high }

  loop
    low high < .while
    low @b high @b low !b high !b
    inc: low
    dec: high
  end
end

fun: run
  s" 0123456789abcdef" { str len }

  1 22 .lsl .inc { ind }
  loop
    ind .while
    dec: ind
    str len .reverse
  end

  \ str .log .lf \ fedcba9876543210
end
.run

fun: main { -- exit } .run 0 end
