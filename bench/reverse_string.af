use' lang.af

fun: reverse { str len }
  str           { low }
  str len + dec { high }

  loop
    low high < while
    low @b { tmp }
    high @b low !b
    tmp high !b
    inc: low
    dec: high
  end
end

fun: run
  s" 0123456789abcdef" { str len }

  1 22 lsl inc { ind }
  loop
    dec: ind
    ind >=0 while
    str len reverse
  end

  \ str log lf
  \ fedcba9876543210
end

fun: main { -- exit }
  run
  0
end
run
