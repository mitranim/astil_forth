use' lang.af

fun: .fib { ind -- out }
  0 1 { prev next }
  loop
    ind .while
    dec: ind
    prev next + next { next prev }
  end
  next
end

fun: .run { -- err }
  1 22 .lsl { runs }
  0 { out }
  loop
    runs .while
    dec: runs
    91 .fib { out }
  end
  assert= out 7540113804746346429 end
end
.run

fun: .main { -- exit }
  .with_main_ctx .run end { err }
  err .then " error: %s\n" err .elogf 1 else 0 end
end
