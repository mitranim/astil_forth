use' lang.af

fun: fib { ind -- out }
  0 1 { prev next }
  loop
    ind .while
    dec: ind
    prev next + next { next prev }
  end
  next
end

fun: run
  1 20 .lsl { runs }
  loop
    runs .while
    dec: runs
    91 .fib { -- }
  end
  \ 91 .fib .log_int .lf
end
.run

fun: main { -- exit } .run 0 end
