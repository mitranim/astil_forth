use' lang_s.af

fun: .reverse { str len -- }
  str           { low }
  str len + .dec { high }

  loop
    low high < .while
    low c@ high c@ low c! high c!
    inc: low
    dec: high
  end
end

fun: .run
  s" 0123456789abcdef" { str len }

  1 25 .lsl .for
    str len .reverse
  end
  str len .reverse
  str " fedcba9876543210" cstr<> .then
    " reverse-string output mismatch" .throw
  end
end
.run
