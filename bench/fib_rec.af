use' lang.af

fun: .fib { ind -- out }
  ind 1 <= .then 1 .ret end
  ind 1 - .recur { prev }
  ind 2 - .recur
  prev +
end

fun: .run { -- err }
  39 .fib
  assert= 102334155 end
end
.run

fun: .main { -- exit }
  .with_main_ctx .run end { err }
  err .then " error: %s\n" err .elogf 1 else 0 end
end
